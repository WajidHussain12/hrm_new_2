@model LCS_HR_MVC.Models.ExtraHoursApprovalViewModel
@{
    ViewData["PageTitle"] = "Employee Extra Hours And Day Approval";
}

@section Styles {
    <style>
        @@keyframes slideUp { from { opacity:0; transform:translateY(15px); } to { opacity:1; transform:translateY(0); } }
        .animate-main { animation: slideUp 0.4s ease-out; }
        .field-select { background-image:url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%2394a3b8%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E'); background-repeat:no-repeat; background-position:right 0.75rem top 50%; background-size:0.65rem auto; }
        .custom-scrollbar::-webkit-scrollbar { width:8px; } .custom-scrollbar::-webkit-scrollbar-track { background:#f1f5f9; border-radius:4px; } .custom-scrollbar::-webkit-scrollbar-thumb { background:#cbd5e1; border-radius:4px; }
        #dg1_wrapper .dataTables_filter input { background:#f8fafc; border:1px solid #e2e8f0; border-radius:0.75rem; padding:0.5rem 0.75rem 0.5rem 2.25rem; font-size:0.8rem; font-weight:600; color:#334155; outline:none; width:220px; }
        #dg1_wrapper .dataTables_filter label { position:relative; display:inline-flex; align-items:center; }
        #dg1_wrapper .dataTables_filter label::before { content:'\f002'; font-family:'Font Awesome 5 Free'; font-weight:900; position:absolute; left:0.65rem; color:#94a3b8; font-size:0.7rem; pointer-events:none; z-index:1; }
        #dg1_wrapper .dataTables_paginate .paginate_button { display:inline-flex; align-items:center; justify-content:center; min-width:2rem; height:2rem; padding:0 0.5rem; border-radius:0.5rem; font-size:0.75rem; font-weight:700; color:#475569; margin:0 1px; transition:all 0.15s; }
        #dg1_wrapper .dataTables_paginate .paginate_button:hover { background:#f1f5f9; color:#0f172a; }
        #dg1_wrapper .dataTables_paginate .paginate_button.current { background:linear-gradient(135deg,#fbbf24,#f59e0b); color:#1e293b; box-shadow:0 2px 8px rgba(245,158,11,0.3); }
        #dg1_wrapper .dataTables_paginate .paginate_button.disabled { opacity:0.35; cursor:default; }
        #dg1_wrapper .dataTables_info { font-size:0.7rem; color:#94a3b8; font-weight:600; padding-top:0.5rem; }
        #dg1_wrapper .dataTables_length { display:none; }
        #dg1 thead th { background:linear-gradient(135deg,#475569,#334155) !important; color:#f1f5f9 !important; font-size:0.65rem !important; font-weight:800 !important; text-transform:uppercase !important; letter-spacing:0.08em !important; padding:0.625rem 0.75rem !important; border:none !important; white-space:nowrap; }
        #dg1 tbody tr:hover td { background:#fffbeb !important; }
        #dg1 tbody td { padding:0.5rem 0.75rem !important; font-size:0.8rem; color:#334155; border-bottom:1px solid #f1f5f9 !important; border-top:none !important; border-left:none !important; border-right:none !important; }
    </style>
}

<div class="tw-p-4 sm:tw-p-6 tw-bg-transparent tw-min-h-screen animate-main">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-red-50 tw-border tw-border-red-100 tw-rounded-xl tw-text-red-600 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(239,68,68,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-red-100 tw-text-red-500 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0"><i class="fas fa-exclamation-triangle tw-text-[10px]"></i></div>
            <span class="tw-pt-0.5">@TempData["ErrorMessage"]</span>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-emerald-50 tw-border tw-border-emerald-100 tw-rounded-xl tw-text-emerald-700 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(16,185,129,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-emerald-100 tw-text-emerald-600 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0"><i class="fas fa-check tw-text-[10px]"></i></div>
            <span class="tw-pt-0.5">@TempData["SuccessMessage"]</span>
        </div>
    }

    <!-- Page Header -->
    <div class="tw-flex tw-flex-col sm:tw-flex-row sm:tw-items-end tw-justify-between tw-gap-4 tw-mb-8">
        <div>
            <nav class="tw-flex tw-items-center tw-gap-2.5 tw-text-[11px] tw-font-bold tw-text-slate-400 tw-mb-2 tw-uppercase tw-tracking-widest">
                <div class="tw-flex tw-items-center tw-gap-1.5 hover:tw-text-[#eab308] tw-transition-colors tw-cursor-pointer">
                    <i class="fas fa-clock tw-text-[10px] tw-text-slate-300"></i><span>Extras</span>
                </div>
                <i class="fas fa-chevron-right tw-text-[8px] tw-text-slate-300"></i>
                <span class="tw-text-slate-600 tw-bg-white tw-px-2 tw-py-0.5 tw-rounded-md tw-border tw-border-slate-200 tw-shadow-sm">Hours Approval</span>
            </nav>
            <div class="tw-flex tw-flex-col">
                <h1 class="tw-text-3xl tw-font-black tw-text-slate-900 tw-leading-tight tw-tracking-tight">Extra Hours &amp; Day Approval</h1>
                <div class="tw-h-1.5 tw-w-10 tw-bg-gradient-to-r tw-from-[#f5c518] tw-to-transparent tw-rounded-full tw-mt-1"></div>
            </div>
            <p class="tw-text-slate-500 tw-text-sm tw-font-medium tw-mt-3 tw-leading-relaxed">Review and approve or reject employee extra hours and day requests.</p>
        </div>
    </div>

    <form asp-controller="Extras" asp-action="ExtraHoursApproval" method="post" id="approvalForm">

        <!-- Filter Card -->
        <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-mb-5">
            <div class="tw-p-4 tw-bg-gradient-to-r tw-from-slate-900 tw-to-slate-800">
                <h3 class="tw-text-amber-400 tw-font-black tw-text-xs tw-uppercase tw-tracking-[0.2em] tw-flex tw-items-center tw-gap-2">
                    <div class="tw-w-6 tw-h-6 tw-bg-white/10 tw-rounded-md tw-flex tw-items-center tw-justify-center"><i class="fas fa-filter"></i></div>
                    Filter Records
                </h3>
            </div>
            <div class="tw-p-5">
                <div class="tw-flex tw-flex-wrap tw-items-end tw-gap-4">
                    <div>
                        <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Department</label>
                        <div class="tw-relative">
                            <i class="fas fa-layer-group tw-absolute tw-left-3 tw-top-1/2 tw--translate-y-1/2 tw-text-amber-500 tw-text-xs tw-pointer-events-none" style="z-index:1"></i>
                            <select asp-for="CityCode" asp-items="ViewBag.Cities" id="ddlCity"
                                    class="field-select tw-pl-9 tw-pr-8 tw-py-2.5 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-appearance-none tw-min-w-[180px]">
                                <option value="00">All</option>
                            </select>
                        </div>
                    </div>
                    <div>
                        <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Sub Department</label>
                        <div class="tw-relative">
                            <i class="fas fa-users-cog tw-absolute tw-left-3 tw-top-1/2 tw--translate-y-1/2 tw-text-amber-500 tw-text-xs tw-pointer-events-none" style="z-index:1"></i>
                            <select asp-for="DeptCode" id="ddlDepartments"
                                    class="field-select tw-pl-9 tw-pr-8 tw-py-2.5 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-appearance-none tw-min-w-[200px]">
                                <option value="00">All</option>
                            </select>
                        </div>
                    </div>
                    <button type="submit" name="action" value="Search"
                            class="tw-flex tw-items-center tw-gap-2 tw-px-5 tw-py-2.5 tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-text-slate-900 tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase tw-shadow-[0_4px_12px_rgba(245,197,24,0.3)] hover:tw-shadow-[0_6px_16px_rgba(245,197,24,0.4)] hover:tw--translate-y-0.5 tw-transition-all">
                        <i class="fas fa-search tw-text-xs"></i> Search
                    </button>
                </div>
            </div>
        </div>

        <!-- Approval Actions + Table Card -->
        <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden">
            <div class="tw-p-4 tw-bg-gradient-to-r tw-from-slate-700 tw-to-slate-900">
                <h3 class="tw-text-amber-400 tw-font-black tw-text-xs tw-uppercase tw-tracking-[0.2em] tw-flex tw-items-center tw-gap-2">
                    <div class="tw-w-6 tw-h-6 tw-bg-white/10 tw-rounded-md tw-flex tw-items-center tw-justify-center"><i class="fas fa-clipboard-check"></i></div>
                    Pending Requests
                </h3>
            </div>

            <!-- Action Bar -->
            <div class="tw-px-5 tw-py-4 tw-border-b tw-border-slate-100 tw-flex tw-flex-wrap tw-items-center tw-gap-3">
                <span class="tw-text-[11px] tw-font-black tw-text-slate-500 tw-uppercase tw-tracking-widest">Apply Status:</span>
                <div class="tw-relative">
                    <i class="fas fa-check-circle tw-absolute tw-left-3 tw-top-1/2 tw--translate-y-1/2 tw-text-amber-500 tw-text-xs tw-pointer-events-none" style="z-index:1"></i>
                    <select asp-for="ApprovalStatus" id="ddlApprove"
                            class="field-select tw-pl-9 tw-pr-8 tw-py-2.5 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-appearance-none tw-min-w-[140px]">
                        <option value="2">Approve</option>
                        <option value="1" selected="selected">Pending</option>
                        <option value="3">Reject</option>
                    </select>
                </div>
                <button type="submit" name="action" value="Process" id="btnProcess"
                        class="tw-flex tw-items-center tw-gap-2 tw-px-5 tw-py-2.5 tw-bg-slate-900 tw-text-white tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase hover:tw-bg-slate-800 hover:tw--translate-y-0.5 tw-transition-all tw-shadow-md">
                    <i class="fas fa-bolt tw-text-xs"></i> Apply Selected Status
                </button>
                <span class="tw-text-[10px] tw-text-slate-400 tw-font-semibold tw-ml-1">Select rows below then apply.</span>
            </div>

            <!-- DataTable -->
            <div class="tw-p-4 custom-scrollbar">
                <table id="dg1" class="tw-w-full">
                    <thead>
                        <tr>
                            <th>
                                <input type="checkbox" id="chkheader" title="Select All"
                                       class="tw-w-4 tw-h-4 tw-accent-amber-500 tw-cursor-pointer tw-align-middle" />
                                <span class="tw-ml-1">Code</span>
                            </th>
                            <th>Employee</th>
                            <th>Extra Type</th>
                            <th>Month</th>
                            <th>Year</th>
                            <th>Value</th>
                            <th>Comments</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Extras != null)
                        {
                            @foreach (var item in Model.Extras)
                            {
                                <tr>
                                    <td>
                                        <div class="tw-flex tw-items-center tw-gap-2">
                                            <input type="checkbox" name="SelectedCodes" value="@item.Code" class="chkvid tw-w-4 tw-h-4 tw-accent-amber-500 tw-cursor-pointer" />
                                            <span class="tw-text-amber-600 tw-font-black">@item.Code</span>
                                        </div>
                                    </td>
                                    <td>@item.EmployeeName</td>
                                    <td>@item.ExtraTypeName</td>
                                    <td>@item.Month</td>
                                    <td>@item.Year</td>
                                    <td>@item.Value</td>
                                    <td>@item.Comments</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </form>
</div>

@section Scripts {
    <script type="text/javascript">
        $(document).ready(function () {
            if ($.fn.DataTable) {
                $('#dg1').DataTable({
                    "pageLength": 15,
                    "lengthChange": false,
                    "searching": true,
                    "info": true,
                    "dom": '<"tw-flex tw-items-center tw-justify-between tw-mb-3"f i>t<"tw-flex tw-items-center tw-justify-end tw-mt-3"p>',
                    "language": {
                        "emptyTable": '<div class="tw-text-center tw-py-8 tw-text-slate-400 tw-font-semibold"><i class="fas fa-inbox tw-text-2xl tw-block tw-mb-2 tw-text-slate-300"></i>No pending extra hours requests found.</div>'
                    }
                });
            }

            function checkHeaderStatus() {
                var total = $('.chkvid').length;
                var checked = $('.chkvid:checked').length;
                $('#chkheader').prop('checked', total === checked && total > 0);
            }

            $('#chkheader').click(function () {
                $('.chkvid').prop('checked', $(this).is(':checked'));
            });

            $(document).on('change', '.chkvid', function () {
                checkHeaderStatus();
            });

            $('#btnProcess').click(function (e) {
                var selectedStatusText = $("#ddlApprove option:selected").text();
                var msg = "Do you want to change the status of selected request(s) to " + selectedStatusText.toUpperCase() + "?";
                if (!confirm(msg)) {
                    e.preventDefault();
                    return false;
                }
            });

            $("#ddlCity").change(function () {
                var cityId = $(this).val();
                var ddlDept = $("#ddlDepartments");
                ddlDept.empty().append('<option value="00">All</option>');
                if (cityId && cityId !== "00") {
                    $.ajax({
                        url: '@Url.Action("GetDepartmentsByCity", "Extras")',
                        type: "GET",
                        data: { cityCode: cityId },
                        success: function (res) {
                            if (res && res.length > 0) {
                                $.each(res, function (i, item) {
                                    ddlDept.append('<option value="' + item.value + '">' + item.text + '</option>');
                                });
                            }
                        }
                    });
                }
            });
        });
    </script>
}
