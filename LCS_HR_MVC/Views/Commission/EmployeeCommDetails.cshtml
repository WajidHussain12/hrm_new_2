@model LCS_HR_MVC.Models.EmployeeCommissionModel
@{
    ViewData["PageTitle"] = "Employee Commission Details";
    var dataList = ViewBag.EmployeeCommissionList as IEnumerable<LCS_HR_MVC.Models.EmployeeCommissionModel> ?? new List<LCS_HR_MVC.Models.EmployeeCommissionModel>();
    bool isNew = Model.Code == "Auto Generated";
}

@section Styles {
    <link href="~/lib/jquery-ui/jquery-ui.min.css" rel="stylesheet" />
    <style>
        @@keyframes slideUp { from { opacity:0; transform:translateY(15px); } to { opacity:1; transform:translateY(0); } }
        .animate-main { animation: slideUp 0.4s ease-out; }
        .custom-scrollbar::-webkit-scrollbar { width:8px; height:8px; }
        .custom-scrollbar::-webkit-scrollbar-track { background:#f1f5f9; border-radius:4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background:#cbd5e1; border-radius:4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background:#94a3b8; }
        .ui-autocomplete { @@apply tw-max-h-60 tw-overflow-y-auto tw-rounded-xl tw-border-slate-200 tw-shadow-xl tw-text-sm tw-font-medium tw-bg-white !important; z-index:1000 !important; }
        .ui-menu-item-wrapper { @@apply tw-py-2 tw-px-3 tw-transition-colors tw-text-slate-700 !important; }
        .ui-menu-item-wrapper.ui-state-active { @@apply tw-bg-amber-400 tw-text-slate-900 tw-border-transparent tw-rounded-md tw-font-bold !important; margin:0 !important; }
        .dataTables_wrapper .dataTables_filter { @@apply tw-relative tw-mb-5; }
        .dataTables_wrapper .dataTables_filter label { @@apply tw-w-full sm:tw-w-auto; }
        .dataTables_wrapper .dataTables_filter input { @@apply tw-w-full sm:tw-w-[300px] tw-border-2 tw-border-slate-100 tw-rounded-2xl tw-px-5 tw-py-2.5 tw-text-sm tw-outline-none tw-transition-all tw-bg-slate-50 focus:tw-bg-white tw-text-slate-700 tw-shadow-inner tw-font-medium; }
        .dataTables_wrapper .dataTables_filter input:focus { @@apply tw-border-amber-400 tw-ring-4 tw-ring-amber-400/20 tw-shadow-lg; }
        table.dataTable { @@apply tw-border-collapse; }
        table.dataTable thead th { @@apply tw-bg-slate-50 tw-text-slate-400 tw-font-black tw-uppercase tw-text-[10px] tw-tracking-[0.15em] tw-py-4 tw-px-5 tw-border-b-2 tw-border-slate-100 !important; }
        table.dataTable tbody tr { @@apply tw-border-b tw-border-slate-50 tw-transition-colors hover:tw-bg-amber-50/30; }
        table.dataTable tbody td { @@apply tw-py-4 tw-px-5 tw-align-middle; }
        .dataTables_info { @@apply tw-text-xs tw-font-semibold tw-text-slate-500 tw-mt-5; }
        .dataTables_wrapper .dataTables_paginate { @@apply tw-flex tw-items-center tw-gap-1 tw-mt-5; }
        .dataTables_wrapper .dataTables_paginate .paginate_button { @@apply tw-min-w-[32px] tw-h-8 tw-flex tw-items-center tw-justify-center tw-rounded-lg tw-text-xs tw-font-bold tw-text-slate-500 tw-border tw-border-slate-200 tw-bg-white tw-cursor-pointer tw-transition-all !important; padding:0 0.5rem !important; margin:0 !important; }
        .dataTables_wrapper .dataTables_paginate .paginate_button:hover { @@apply tw-bg-slate-100 tw-text-slate-800 tw-border-slate-300 !important; background:none !important; }
        .dataTables_wrapper .dataTables_paginate .paginate_button.current, .dataTables_wrapper .dataTables_paginate .paginate_button.current:hover { @@apply tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-text-slate-900 tw-border-transparent tw-shadow-md tw-cursor-default !important; background:none !important; }
        .dataTables_wrapper .dataTables_paginate .paginate_button.disabled { @@apply tw-opacity-50 tw-cursor-not-allowed hover:tw-bg-white hover:tw-text-slate-500 hover:tw-border-slate-200 !important; }
        .field-select { background-image:url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%2394a3b8%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E'); background-repeat:no-repeat; background-position:right 0.75rem top 50%; background-size:0.65rem auto; }
    </style>
}

<div class="tw-p-4 sm:tw-p-6 tw-bg-transparent tw-min-h-screen animate-main">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-red-50 tw-border tw-border-red-100 tw-rounded-xl tw-text-red-600 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(239,68,68,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-red-100 tw-text-red-500 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0"><i class="fas fa-exclamation-triangle tw-text-[10px]"></i></div>
            <span class="tw-pt-0.5">@TempData["ErrorMessage"]</span>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-emerald-50 tw-border tw-border-emerald-100 tw-rounded-xl tw-text-emerald-700 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(16,185,129,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-emerald-100 tw-text-emerald-600 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0"><i class="fas fa-check tw-text-[10px]"></i></div>
            <span class="tw-pt-0.5">@TempData["SuccessMessage"]</span>
        </div>
    }

    <div class="tw-flex tw-flex-col sm:tw-flex-row sm:tw-items-end tw-justify-between tw-gap-4 tw-mb-8">
        <div>
            <nav class="tw-flex tw-items-center tw-gap-2.5 tw-text-[11px] tw-font-bold tw-text-slate-400 tw-mb-2 tw-uppercase tw-tracking-widest">
                <div class="tw-flex tw-items-center tw-gap-1.5 hover:tw-text-[#eab308] tw-transition-colors tw-cursor-pointer">
                    <i class="fas fa-chart-line tw-text-[10px] tw-text-slate-300"></i><span>Commission</span>
                </div>
                <i class="fas fa-chevron-right tw-text-[8px] tw-text-slate-300"></i>
                <span class="tw-text-slate-600 tw-bg-white tw-px-2 tw-py-0.5 tw-rounded-md tw-border tw-border-slate-200 tw-shadow-sm">Employee Details</span>
            </nav>
            <div class="tw-flex tw-flex-col">
                <h1 class="tw-text-3xl tw-font-black tw-text-slate-900 tw-leading-tight tw-tracking-tight">Commission Details</h1>
                <div class="tw-h-1.5 tw-w-10 tw-bg-gradient-to-r tw-from-[#f5c518] tw-to-transparent tw-rounded-full tw-mt-1"></div>
            </div>
            <p class="tw-text-slate-500 tw-text-sm tw-font-medium tw-mt-3 tw-leading-relaxed">Manage employee commission entries by route, period and commission type.</p>
        </div>
    </div>

    <div class="tw-grid lg:tw-grid-cols-12 tw-gap-6 xl:tw-gap-8 align-top">
        <!-- Left: DataTable -->
        <div class="lg:tw-col-span-7 xl:tw-col-span-8">
            <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-relative tw-h-full">
                <div class="tw-absolute tw-top-0 tw-right-0 tw-w-64 tw-h-64 tw-bg-gradient-to-bl tw-from-amber-50/50 tw-to-transparent tw-rounded-bl-full tw-pointer-events-none" style="z-index:0"></div>
                <div class="tw-relative tw-z-10 tw-px-6 tw-py-5 tw-border-b tw-border-slate-100 tw-flex tw-items-center tw-gap-4 tw-bg-white/50">
                    <div class="tw-w-10 tw-h-10 tw-rounded-xl tw-bg-gradient-to-br tw-from-slate-700 tw-to-slate-900 tw-flex tw-items-center tw-justify-center tw-shadow-[0_4px_10px_rgba(15,23,42,0.25)]">
                        <i class="fas fa-file-invoice-dollar tw-text-amber-400 tw-text-lg"></i>
                    </div>
                    <div>
                        <h2 class="tw-font-black tw-text-base tw-text-slate-800 tw-tracking-tight">Commission Registry</h2>
                        <p class="tw-text-[10px] tw-font-bold tw-text-slate-400 tw-uppercase tw-tracking-widest">All Commission Entries</p>
                    </div>
                </div>
                <div class="tw-relative tw-z-10 tw-p-6">
                    <div class="tw-overflow-x-auto custom-scrollbar">
                        <table id="dg1" class="tw-w-full dataTable tw-text-xs">
                            <thead>
                                <tr>
                                    <th class="tw-text-center tw-w-20">Code</th>
                                    <th>Route</th>
                                    <th>Employee</th>
                                    <th class="tw-text-center">Date</th>
                                    <th class="tw-text-center">Type</th>
                                    <th class="tw-text-right">Qty</th>
                                    <th class="tw-text-right">Rate</th>
                                    <th class="tw-text-right">Amount</th>
                                </tr>
                            </thead>
                            <tbody class="tw-divide-y tw-divide-slate-100">
                                @foreach (var item in dataList)
                                {
                                    <tr class="hover:tw-bg-slate-50 tw-transition-colors group tw-text-sm">
                                        <td class="tw-py-3 tw-text-center tw-align-middle">
                                            <a href="@Url.Action("EmployeeCommDetails", "Commission", new { code = item.Code })"
                                               class="tw-px-2.5 tw-py-1 tw-bg-slate-100 group-hover:tw-bg-white tw-border tw-border-slate-200 tw-rounded-lg tw-font-mono tw-font-black tw-text-slate-600 tw-shadow-sm tw-transition-colors hover:tw-border-amber-400 hover:tw-text-amber-600">@item.Code</a>
                                        </td>
                                        <td class="tw-py-3 tw-align-middle tw-font-semibold tw-text-slate-700">@item.RouteCode</td>
                                        <td class="tw-py-3 tw-align-middle tw-font-bold tw-text-slate-800 group-hover:tw-text-amber-600 tw-transition-colors">@item.EmployeeName</td>
                                        <td class="tw-py-3 tw-align-middle tw-text-center"><span class="tw-text-xs tw-font-black tw-text-slate-500 tw-bg-slate-50 tw-border tw-border-slate-200 tw-px-2 tw-py-1 tw-rounded-md">@item.Month-@item.Year</span></td>
                                        <td class="tw-py-3 tw-align-middle tw-text-center"><span class="tw-text-xs tw-font-bold tw-text-slate-600">@item.CommType</span></td>
                                        <td class="tw-py-3 tw-align-middle tw-text-right tw-font-mono tw-font-bold tw-text-slate-700">@item.Quantity</td>
                                        <td class="tw-py-3 tw-align-middle tw-text-right tw-font-mono tw-font-bold tw-text-slate-700">@item.Rate</td>
                                        <td class="tw-py-3 tw-align-middle tw-text-right tw-font-mono tw-font-black tw-text-slate-800">@item.Amount</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Form -->
        <div class="lg:tw-col-span-5 xl:tw-col-span-4">
            <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-sticky tw-top-24 tw-relative">
                <div class="tw-absolute tw-top-[-50px] tw-right-[-50px] tw-w-40 tw-h-40 tw-bg-amber-100/40 tw-blur-2xl tw-rounded-full tw-pointer-events-none"></div>
                <div class="tw-p-6 tw-bg-gradient-to-r tw-from-slate-900 tw-to-slate-800 tw-relative tw-z-10">
                    <h3 class="tw-text-amber-400 tw-font-black tw-text-xs tw-uppercase tw-tracking-[0.2em] tw-flex tw-items-center tw-gap-2">
                        <div class="tw-w-6 tw-h-6 tw-bg-white/10 tw-rounded-md tw-flex tw-items-center tw-justify-center"><i class="fas fa-pen-nib"></i></div>
                        Commission Entry
                    </h3>
                </div>
                <form asp-controller="Commission" asp-action="EmployeeCommDetails" method="post" id="commForm" class="tw-p-7 tw-space-y-5 tw-relative tw-z-10">
                    <!-- Code -->
                    <div>
                        <label class="tw-block tw-text-[10px] tw-font-black tw-text-slate-400 tw-uppercase tw-tracking-widest tw-mb-1.5">Trace Code #</label>
                        <div class="tw-flex tw-items-center tw-bg-slate-50 tw-rounded-xl tw-px-3 tw-py-2.5 tw-border tw-border-slate-200 tw-shadow-inner opacity-80">
                            <i class="fas fa-fingerprint tw-text-slate-400 tw-mr-1.5 tw-text-[10px]"></i>
                            <input type="text" value="@Model.Code" disabled class="tw-bg-transparent tw-w-full tw-text-sm tw-font-mono tw-font-bold tw-text-slate-600 tw-outline-none" />
                            <input type="hidden" asp-for="Code" id="Code" />
                        </div>
                    </div>
                    <!-- City -->
                    <div>
                        <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">City <span class="tw-text-red-500">*</span></label>
                        <div class="tw-relative">
                            <i class="fas fa-city tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-amber-500 tw-text-sm tw-pointer-events-none" style="z-index:1"></i>
                            <select asp-for="CityCode" asp-items="ViewBag.Cities" id="ddlCity"
                                    class="field-select tw-w-full tw-pl-10 tw-pr-8 tw-py-3 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm tw-appearance-none">
                                <option value="00">Please select a city</option>
                            </select>
                        </div>
                        <span asp-validation-for="CityCode" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                    </div>
                    <!-- Route -->
                    <div>
                        <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Route <span class="tw-text-red-500">*</span></label>
                        <div class="tw-grid tw-grid-cols-[1fr_auto] tw-gap-2">
                            <div class="tw-relative">
                                <i class="fas fa-route tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-amber-500 tw-text-sm tw-pointer-events-none" style="z-index:1"></i>
                                <input type="text" asp-for="RouteDescription" id="txtRouteDescription" placeholder="Use wildcard '%'"
                                       class="tw-w-full tw-pl-10 tw-pr-3 tw-py-3 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm" />
                            </div>
                            <input type="text" asp-for="RouteCode" id="txtRouteCode" readonly
                                   class="tw-w-24 tw-px-3 tw-py-3 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-text-center tw-font-mono tw-font-bold tw-text-slate-500 tw-outline-none tw-cursor-not-allowed" />
                        </div>
                        <span asp-validation-for="RouteDescription" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                        <span asp-validation-for="RouteCode" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-block"></span>
                    </div>
                    <!-- Year / Month -->
                    <div class="tw-grid tw-grid-cols-2 tw-gap-4">
                        <div>
                            <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Year</label>
                            <div class="tw-relative">
                                <i class="fas fa-calendar-alt tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs tw-pointer-events-none" style="z-index:1"></i>
                                <select asp-for="Year" class="field-select tw-w-full tw-pl-9 tw-pr-6 tw-py-3 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-700 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-appearance-none">
                                    @for (int i = DateTime.Now.Year - 5; i <= DateTime.Now.Year + 1; i++) { <option value="@i">@i</option> }
                                </select>
                            </div>
                        </div>
                        <div>
                            <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Month</label>
                            <div class="tw-relative">
                                <i class="fas fa-clock tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs tw-pointer-events-none" style="z-index:1"></i>
                                <select asp-for="Month" class="field-select tw-w-full tw-pl-9 tw-pr-6 tw-py-3 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-700 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-appearance-none">
                                    @for (int i = 1; i <= 12; i++) { <option value="@i">@i</option> }
                                </select>
                            </div>
                        </div>
                    </div>
                    <!-- Commission Type -->
                    <div>
                        <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Commission Type <span class="tw-text-red-500">*</span></label>
                        <div class="tw-relative">
                            <i class="fas fa-tags tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-amber-500 tw-text-sm tw-pointer-events-none" style="z-index:1"></i>
                            <select asp-for="CommType" class="field-select tw-w-full tw-pl-10 tw-pr-8 tw-py-3 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm tw-appearance-none">
                                <option value="">Please Select</option>
                                <option value="L">Local</option>
                                <option value="D">Domestic</option>
                            </select>
                        </div>
                        <span asp-validation-for="CommType" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                    </div>
                    <!-- Quantity / Rate -->
                    <div class="tw-grid tw-grid-cols-2 tw-gap-4">
                        <div>
                            <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Quantity <span class="tw-text-red-500">*</span></label>
                            <div class="tw-relative">
                                <div class="tw-absolute tw-left-3 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs tw-font-bold">#</div>
                                <input type="number" step="0.01" asp-for="Quantity" class="tw-w-full tw-pl-6 tw-pr-3 tw-py-3 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-mono tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-shadow-sm" />
                            </div>
                            <span asp-validation-for="Quantity" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                        </div>
                        <div>
                            <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Rate <span class="tw-text-red-500">*</span></label>
                            <div class="tw-relative">
                                <div class="tw-absolute tw-left-3 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs tw-font-bold">$</div>
                                <input type="number" step="0.01" asp-for="Rate" class="tw-w-full tw-pl-6 tw-pr-3 tw-py-3 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-mono tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-shadow-sm" />
                            </div>
                            <span asp-validation-for="Rate" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                        </div>
                    </div>
                    <!-- Reason -->
                    <div>
                        <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Reason</label>
                        <div class="tw-relative">
                            <i class="fas fa-comment-alt tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-sm tw-pointer-events-none" style="z-index:1"></i>
                            <input asp-for="Reason" maxlength="45" class="tw-w-full tw-pl-10 tw-pr-3 tw-py-3 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm" />
                        </div>
                    </div>

                    <div class="tw-pt-2 tw-border-t tw-border-slate-100"></div>
                    <div class="tw-space-y-3">
                        <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                            <button type="submit" name="action" value="Save" id="btnSave" @(!isNew ? "disabled" : null)
                                    class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-text-slate-900 tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase tw-shadow-[0_8px_20px_rgba(245,197,24,0.25)] hover:tw-shadow-[0_8px_25px_rgba(245,197,24,0.35)] hover:tw--translate-y-0.5 tw-transition-all disabled:tw-opacity-50 disabled:tw-cursor-not-allowed">
                                <i class="fas fa-check-circle tw-text-sm"></i> Save
                            </button>
                            <button type="submit" name="action" value="Update" id="btnUpdate" @(isNew ? "disabled" : null)
                                    class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-slate-900 tw-text-white tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase hover:tw-bg-slate-800 hover:tw-shadow-[0_8px_20px_rgba(15,23,42,0.2)] hover:tw--translate-y-0.5 tw-transition-all disabled:tw-opacity-40 disabled:hover:tw-transform-none">
                                <i class="fas fa-sync-alt tw-text-sm"></i> Update
                            </button>
                        </div>
                        <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                            <button type="submit" name="action" value="Delete" id="btnDelete" @(isNew ? "disabled" : null) onclick="return confirm('Do you want to delete?');"
                                    class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-bg-white tw-text-red-500 tw-border tw-border-red-100 tw-shadow-sm tw-rounded-xl tw-font-extrabold tw-text-[11px] tw-tracking-wider tw-uppercase hover:tw-bg-red-50 hover:tw-border-red-200 tw-transition-all disabled:tw-opacity-40 disabled:tw-cursor-not-allowed">
                                <i class="fas fa-trash-alt"></i> Delete
                            </button>
                            <button type="submit" name="action" value="Reset" id="btnReset" formnovalidate
                                    class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-bg-white tw-text-slate-600 tw-border tw-border-slate-200 tw-shadow-sm tw-rounded-xl tw-font-extrabold tw-text-[11px] tw-tracking-wider tw-uppercase hover:tw-bg-slate-50 hover:tw-text-slate-900 tw-transition-all">
                                <i class="fas fa-undo-alt tw-opacity-60"></i> Reset
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/lib/jquery-ui/jquery-ui.min.js"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            if ($.fn.DataTable) {
                $('#dg1').DataTable({
                    "pageLength": 12, "lengthChange": false,
                    "dom": '<"tw-flex tw-flex-col sm:tw-flex-row tw-justify-between tw-items-center tw-mb-2"f>rt<"tw-flex tw-flex-col sm:tw-flex-row tw-justify-between tw-items-center"ip>',
                    "language": { "search": "", "searchPlaceholder": "Search commissions...", "paginate": { "previous": "<i class='fas fa-chevron-left tw-text-[10px]'></i>", "next": "<i class='fas fa-chevron-right tw-text-[10px]'></i>" } }
                });
                $('.dataTables_filter label').addClass('tw-relative tw-block tw-w-full');
                $('.dataTables_filter input').addClass('tw-pl-10');
                $('.dataTables_filter label').append('<i class="fas fa-search tw-absolute tw-left-4 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400"></i>');
            }

            $("#ddlCity").change(function() {
                $("#txtRouteCode").val('');
                $("#txtRouteDescription").val('');
            });

            $("#txtRouteDescription").autocomplete({
                source: function (request, response) {
                    var cityId = $("#ddlCity").val();
                    if (!cityId || cityId === "00") return;
                    $.ajax({
                        url: '@Url.Action("SearchRoutes", "Commission")', type: "GET", dataType: "json",
                        data: { term: request.term, cityCode: cityId },
                        success: function (data) { response($.map(data, function (item) { return { label: item.label, value: item.label, id: item.value }; })) }
                    })
                },
                select: function (event, ui) { $("#txtRouteDescription").val(ui.item.value); $("#txtRouteCode").val(ui.item.id); return false; },
                minLength: 1
            });

            $("#txtRouteDescription").keyup(function() { if (!$(this).val()) { $("#txtRouteCode").val(''); } });
        });
    </script>
}
