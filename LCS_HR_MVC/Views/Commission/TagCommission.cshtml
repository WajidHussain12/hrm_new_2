@model LCS_HR_MVC.Models.TagCommissionViewModel
@{
    ViewData["PageTitle"] = "Tag Commission";
}

@section Styles {
    <style>
        @@keyframes slideUp { from { opacity:0; transform:translateY(15px); } to { opacity:1; transform:translateY(0); } }
        .animate-main { animation: slideUp 0.4s ease-out; }
        .field-select { background-image:url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%2394a3b8%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E'); background-repeat:no-repeat; background-position:right 0.75rem top 50%; background-size:0.65rem auto; }
        .custom-scrollbar::-webkit-scrollbar { width:8px; } .custom-scrollbar::-webkit-scrollbar-track { background:#f1f5f9; border-radius:4px; } .custom-scrollbar::-webkit-scrollbar-thumb { background:#cbd5e1; border-radius:4px; }
    </style>
}

<div class="tw-p-4 sm:tw-p-6 tw-bg-transparent tw-min-h-screen animate-main">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-red-50 tw-border tw-border-red-100 tw-rounded-xl tw-text-red-600 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(239,68,68,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-red-100 tw-text-red-500 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0"><i class="fas fa-exclamation-triangle tw-text-[10px]"></i></div>
            <span class="tw-pt-0.5">@TempData["ErrorMessage"]</span>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-emerald-50 tw-border tw-border-emerald-100 tw-rounded-xl tw-text-emerald-700 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(16,185,129,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-emerald-100 tw-text-emerald-600 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0"><i class="fas fa-check tw-text-[10px]"></i></div>
            <span class="tw-pt-0.5">@TempData["SuccessMessage"]</span>
        </div>
    }

    <div class="tw-flex tw-flex-col sm:tw-flex-row sm:tw-items-end tw-justify-between tw-gap-4 tw-mb-8">
        <div>
            <nav class="tw-flex tw-items-center tw-gap-2.5 tw-text-[11px] tw-font-bold tw-text-slate-400 tw-mb-2 tw-uppercase tw-tracking-widest">
                <div class="tw-flex tw-items-center tw-gap-1.5 hover:tw-text-[#eab308] tw-transition-colors tw-cursor-pointer">
                    <i class="fas fa-chart-line tw-text-[10px] tw-text-slate-300"></i><span>Commission</span>
                </div>
                <i class="fas fa-chevron-right tw-text-[8px] tw-text-slate-300"></i>
                <span class="tw-text-slate-600 tw-bg-white tw-px-2 tw-py-0.5 tw-rounded-md tw-border tw-border-slate-200 tw-shadow-sm">Tag Commission</span>
            </nav>
            <div class="tw-flex tw-flex-col">
                <h1 class="tw-text-3xl tw-font-black tw-text-slate-900 tw-leading-tight tw-tracking-tight">Tag Commission</h1>
                <div class="tw-h-1.5 tw-w-10 tw-bg-gradient-to-r tw-from-[#f5c518] tw-to-transparent tw-rounded-full tw-mt-1"></div>
            </div>
            <p class="tw-text-slate-500 tw-text-sm tw-font-medium tw-mt-3 tw-leading-relaxed">Assign commission processing to routes between cities for a selected period.</p>
        </div>
    </div>

    <div class="tw-max-w-2xl">
        <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-relative">
            <div class="tw-absolute tw-top-0 tw-right-0 tw-w-64 tw-h-64 tw-bg-gradient-to-bl tw-from-amber-50/50 tw-to-transparent tw-rounded-bl-full tw-pointer-events-none" style="z-index:0"></div>
            <div class="tw-absolute tw-top-[-50px] tw-right-[-50px] tw-w-40 tw-h-40 tw-bg-amber-100/40 tw-blur-2xl tw-rounded-full tw-pointer-events-none"></div>
            <div class="tw-p-6 tw-bg-gradient-to-r tw-from-slate-900 tw-to-slate-800 tw-relative tw-z-10">
                <h3 class="tw-text-amber-400 tw-font-black tw-text-xs tw-uppercase tw-tracking-[0.2em] tw-flex tw-items-center tw-gap-2">
                    <div class="tw-w-6 tw-h-6 tw-bg-white/10 tw-rounded-md tw-flex tw-items-center tw-justify-center"><i class="fas fa-tag"></i></div>
                    Commission Tagging Engine
                </h3>
                <p class="tw-text-slate-400 tw-text-xs tw-font-medium tw-mt-2 tw-leading-relaxed">Define route range and period to process commission tagging.</p>
            </div>

            <form asp-controller="Commission" asp-action="TagCommission" method="post" id="tagForm" class="tw-p-7 tw-space-y-5 tw-relative tw-z-10">
                <!-- City From / City To -->
                <div class="tw-grid tw-grid-cols-2 tw-gap-4">
                    <div>
                        <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">From City <span class="tw-text-red-500">*</span></label>
                        <div class="tw-relative">
                            <i class="fas fa-map-marker-alt tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-amber-500 tw-text-sm tw-pointer-events-none" style="z-index:1"></i>
                            <select asp-for="CityFrom" asp-items="ViewBag.Cities" id="ddlCityFrom"
                                    class="field-select tw-w-full tw-pl-10 tw-pr-6 tw-py-3 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm tw-appearance-none">
                                <option value="00">Please Select</option>
                            </select>
                        </div>
                        <span asp-validation-for="CityFrom" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                    </div>
                    <div>
                        <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">To City <span class="tw-text-red-500">*</span></label>
                        <div class="tw-relative">
                            <i class="fas fa-map-marker tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-amber-500 tw-text-sm tw-pointer-events-none" style="z-index:1"></i>
                            <select asp-for="CityTo" asp-items="ViewBag.Cities" id="ddlToCity"
                                    class="field-select tw-w-full tw-pl-10 tw-pr-6 tw-py-3 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm tw-appearance-none">
                                <option value="00">Please Select</option>
                            </select>
                        </div>
                        <span asp-validation-for="CityTo" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                    </div>
                </div>
                <!-- Year / Month -->
                <div class="tw-grid tw-grid-cols-2 tw-gap-4">
                    <div>
                        <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Fiscal Year</label>
                        <div class="tw-relative">
                            <i class="fas fa-calendar-alt tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs tw-pointer-events-none" style="z-index:1"></i>
                            <select asp-for="Year" class="field-select tw-w-full tw-pl-9 tw-pr-6 tw-py-3 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-700 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-appearance-none">
                                @for (int i = DateTime.Now.Year - 5; i <= DateTime.Now.Year + 1; i++) { <option value="@i">@i</option> }
                            </select>
                        </div>
                    </div>
                    <div>
                        <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Period Month</label>
                        <div class="tw-relative">
                            <i class="fas fa-clock tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs tw-pointer-events-none" style="z-index:1"></i>
                            <select asp-for="Month" class="field-select tw-w-full tw-pl-9 tw-pr-6 tw-py-3 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-700 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-appearance-none">
                                @for (int i = 1; i <= 12; i++) { <option value="@i">@i</option> }
                            </select>
                        </div>
                    </div>
                </div>
                <!-- Route Codes -->
                <div>
                    <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Route Codes <span class="tw-text-red-500">*</span></label>
                    <div class="tw-relative">
                        <i class="fas fa-list-ol tw-absolute tw-left-3.5 tw-top-3.5 tw-text-amber-500 tw-text-sm tw-pointer-events-none" style="z-index:1"></i>
                        <textarea asp-for="RouteCodes" rows="5" id="txtRouteCodes" placeholder="Comma separated route codes (e.g. 100, 101)"
                                  class="tw-w-full tw-pl-10 tw-pr-3 tw-py-3 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 placeholder-slate-400 focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm tw-min-h-[110px] custom-scrollbar"></textarea>
                    </div>
                    <span asp-validation-for="RouteCodes" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                </div>

                <div class="tw-pt-2 tw-border-t tw-border-slate-100"></div>
                <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                    <button type="submit" name="action" value="Process" id="btnProcess" onclick="return ValidateForm();"
                            class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-text-slate-900 tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase tw-shadow-[0_8px_20px_rgba(245,197,24,0.25)] hover:tw-shadow-[0_8px_25px_rgba(245,197,24,0.35)] hover:tw--translate-y-0.5 tw-transition-all">
                        <i class="fas fa-bolt tw-text-sm"></i> Process
                    </button>
                    <button type="submit" name="action" value="Reset" id="btnReset" formnovalidate
                            class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-white tw-text-slate-600 tw-border tw-border-slate-200 tw-shadow-sm tw-rounded-xl tw-font-extrabold tw-text-[11px] tw-tracking-wider tw-uppercase hover:tw-bg-slate-50 hover:tw-text-slate-900 tw-transition-all">
                        <i class="fas fa-undo-alt tw-opacity-60"></i> Reset
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script type="text/javascript">
        function ValidateForm() {
            var flag = true;
            var cityFrom = $("#ddlCityFrom").val();
            var cityTo = $("#ddlToCity").val();
            var routeIDs = $("#txtRouteCodes").val();

            if (!cityFrom || cityFrom === '00') { $("#ddlCityFrom").css('border', '1px solid red'); flag = false; } else { $("#ddlCityFrom").css('border', ''); }
            if (!cityTo || cityTo === '00') { $("#ddlToCity").css('border', '1px solid red'); flag = false; } else { $("#ddlToCity").css('border', ''); }
            if (!routeIDs || routeIDs.trim() === '') { $("#txtRouteCodes").css('border', '1px solid red'); flag = false; } else { $("#txtRouteCodes").css('border', ''); }
            return flag;
        }
    </script>
}
