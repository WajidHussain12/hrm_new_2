<!-- SECTION 7: REAL EXAMPLES                          -->
<!-- ═══════════════════════════════════════════════════ -->
<div id="sec7" class="cfe-section">
    <div class="cfe-section-header">
        <span class="badge-num">7</span> Real Examples with Data — Asal Misaalein
    </div>

    <!-- Example 1: City Lookup -->
    <div class="cfe-card amber tw-mb-4">
        <div class="cfe-card-title"><i class="fas fa-search tw-mr-1"></i> Misaal 1 — Karachi ka City Code dhundna</div>
        <div class="cfe-code">
<span class="cmt">-- Sawaal: Karachi ka HR city Code kya hai?</span>
<span class="kw">SELECT</span> Code, FullName, station_id
<span class="kw">FROM</span> <span class="tbl">hr_city</span>
<span class="kw">WHERE</span> FullName <span class="kw">LIKE</span> <span class="str">'%Karachi%'</span>;

<span class="cmt">-- Jawab:</span>
<span class="cmt">-- Code='001' | FullName='Karachi' | station_id='00592'</span>

<span class="cmt">-- Billing mein Station_id='00592' hai</span>
<span class="cmt">-- HR mein Code='001' hai</span>
<span class="cmt">-- Yeh 2 alag values hain — LPAD se kabhi match nahi hongi!</span>
        </div>
    </div>

    <!-- Example 2: Employee Route -->
    <div class="cfe-card blue tw-mb-4">
        <div class="cfe-card-title"><i class="fas fa-route tw-mr-1"></i> Misaal 2 — Employee ka Route Code dhundna</div>
        <div class="cfe-code">
<span class="cmt">-- Sawaal: Employee 'LHE0001234567890' ka route code kya hai?</span>
<span class="kw">SELECT</span> erc.RouteCode, erc.citycode, hc.FullName
<span class="kw">FROM</span> <span class="tbl">hr_employeeroutecode</span> erc
<span class="kw">JOIN</span> <span class="tbl">hr_city</span> hc <span class="kw">ON</span> hc.Code = erc.citycode
<span class="kw">WHERE</span> erc.Emp_No = <span class="str">'LHE0001234567890'</span>
  <span class="kw">AND</span> (erc.ToDate <span class="kw">IS NULL OR</span> erc.ToDate >= <span class="kw">NOW</span>());

<span class="cmt">-- Jawab:</span>
<span class="cmt">-- RouteCode='3028' | citycode='001' | FullName='Karachi'</span>

<span class="cmt">-- Ab billing mein is courier ki deliveries dhundni hain:</span>
<span class="kw">SELECT</span> cn_no, delivery_date, shipment_type_id
<span class="kw">FROM</span> <span class="tbl">lcs_billing.billing_details</span>
<span class="kw">WHERE</span> Cour_id = <span class="str">'3028'</span>  <span class="cmt">-- RouteCode directly — NOT LPAD!</span>
  <span class="kw">AND</span> billing_date <span class="kw">BETWEEN</span> <span class="str">'2026-01-21'</span> <span class="kw">AND</span> <span class="str">'2026-02-20'</span>;
        </div>
    </div>

    <!-- Example 3: Grand Total -->
    <div class="cfe-card green tw-mb-4">
        <div class="cfe-card-title"><i class="fas fa-rupee-sign tw-mr-1"></i> Misaal 3 — Employee ki Final Commission check karna</div>
        <div class="cfe-code">
<span class="cmt">-- hr_commissionprocess mein ek employee ki total commission</span>
<span class="kw">SELECT</span>
    cp.Emp_No,
    epd.NAME,
    hc.FullName <span class="kw">AS</span> CityName,
    cp.OVERNIGHT,
    cp.COD,
    cp.YB1KG,
    cp.YB2KG,
    cp.YB5KG,
    cp.OLE,
    cp.RBI,
    cp.VAS,
    cp.CASH_Economy_Booking,
    <span class="cmt">-- Grand Total (sabhi columns ka sum)</span>
    (cp.OVERNIGHT + cp.COD + cp.YB1KG + cp.YB2KG + cp.YB5KG +
     cp.YB10KG + cp.YB25KG + cp.OLE + cp.RBI + cp.VAS +
     cp.CASH_Economy_Booking <span class="cmt">/* + baaki 80+ columns ... */</span>) <span class="kw">AS</span> GrandTotal
<span class="kw">FROM</span> <span class="tbl">hr_commissionprocess</span> cp
<span class="kw">JOIN</span> <span class="tbl">hr_city</span> hc <span class="kw">ON</span> hc.Code = cp.CityCode
<span class="kw">JOIN</span> <span class="tbl">hr_employeepersonaldetail</span> epd <span class="kw">ON</span> epd.EMP_NO = cp.Emp_No
<span class="kw">WHERE</span> cp.Emp_No = <span class="str">'LHE0001234567890'</span>
  <span class="kw">AND</span> cp.Year = <span class="str">2026</span>
  <span class="kw">AND</span> cp.Month = <span class="str">2</span>;
        </div>
    </div>

    <!-- Example 4: Missing CN -->
    <div class="cfe-card red">
        <div class="cfe-card-title"><i class="fas fa-exclamation-triangle tw-mr-1"></i> Misaal 4 — Missing CNs dhundna (Commission = 0 wale)</div>
        <div class="cfe-code">
<span class="cmt">-- Cash CNs jis par commission zero rahi</span>
<span class="kw">SELECT</span> <span class="str">'Cash'</span> <span class="kw">AS</span> Type, bd.cn_no, bd.billing_date, bd.shipment_type_id
<span class="kw">FROM</span> <span class="tbl">lcs_billing.billing_details</span> bd
<span class="kw">JOIN</span> <span class="tbl">hr_city</span> hc <span class="kw">ON</span> hc.station_id = bd.Station_id
<span class="kw">JOIN</span> <span class="tbl">hr_employeeroutecode</span> erc
    <span class="kw">ON</span> erc.RouteCode = bd.Cour_id
   <span class="kw">AND</span> erc.Emp_No = <span class="str">@@empNo</span>
   <span class="kw">AND</span> erc.citycode = hc.Code
<span class="kw">WHERE</span> bd.billing_date <span class="kw">BETWEEN</span> <span class="str">@@fromDate</span> <span class="kw">AND</span> <span class="str">@@toDate</span>
  <span class="kw">AND</span> bd.cn_no <span class="kw">NOT IN</span> (
    <span class="kw">SELECT</span> CnNumber <span class="kw">FROM</span> <span class="tbl">hr_cash_consignments</span>
    <span class="kw">WHERE</span> Emp_No = <span class="str">@@empNo</span> <span class="kw">AND</span> Year = <span class="str">@@year</span> <span class="kw">AND</span> Month = <span class="str">@@month</span>
  )

<span class="kw">UNION ALL</span>

<span class="cmt">-- COD CNs jis par commission zero rahi</span>
<span class="kw">SELECT</span> <span class="str">'COD'</span> <span class="kw">AS</span> Type, ar.CN_NO, ar.COUR_DATE, NULL
<span class="kw">FROM</span> <span class="tbl">lcs_db.arival</span> ar
<span class="kw">JOIN</span> <span class="tbl">hr_employeeroutecode</span> erc
    <span class="kw">ON</span> erc.RouteCode = ar.Cour_id
   <span class="kw">AND</span> erc.Emp_No = <span class="str">@@empNo</span>
<span class="kw">WHERE</span> ar.COUR_DATE <span class="kw">BETWEEN</span> <span class="str">@@fromDate</span> <span class="kw">AND</span> <span class="str">@@toDate</span>
  <span class="kw">AND</span> ar.CN_NO <span class="kw">NOT IN</span> (
    <span class="kw">SELECT</span> CnNumber <span class="kw">FROM</span> <span class="tbl">hr_codcommission</span>
    <span class="kw">WHERE</span> Emp_No = <span class="str">@@empNo</span> <span class="kw">AND</span> Year = <span class="str">@@year</span> <span class="kw">AND</span> Month = <span class="str">@@month</span>
  );
        </div>
        <p class="tw-text-xs tw-text-slate-600 tw-mt-2">Yeh query batati hai ke kaunse CNs billing mein to hain lekin commission mein nahi gaye — isiliye "missing commission" hua.</p>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════ -->
<!-- SECTION 8: CRITICAL JOIN RULES                    -->
<!-- ═══════════════════════════════════════════════════ -->
<div id="sec8" class="cfe-section">
    <div class="cfe-section-header">
        <span class="badge-num">8</span> Critical JOIN Rules — Woh Qawaid Jo Kabhi Toote Na
    </div>

    <div class="tw-grid tw-grid-cols-1 md:tw-grid-cols-2 tw-gap-4">
        <div class="cfe-card red">
            <div class="cfe-card-title tw-text-red-700"><i class="fas fa-times-circle tw-mr-1"></i> GALAT — Yeh Kabhi Mat Karo</div>
            <ul class="tw-text-sm tw-text-red-800 tw-space-y-2 tw-pl-4 tw-m-0">
                <li><code>LPAD(CAST(Station_id AS UNSIGNED), 3, '0')</code><br>
                <span class="tw-text-xs">'00592' → '592' — '001' se match nahi karega</span></li>
                <li><code>LPAD(Cour_id, 14, '0') = EMP_NO</code><br>
                <span class="tw-text-xs">RouteCode '3028' → '00000000003028' — EmpNo format bilkul alag hai</span></li>
                <li><code>hc.city_name</code> column use karna<br>
                <span class="tw-text-xs">Yeh column exist nahi karta — sahi column <code>hc.FullName</code> hai</span></li>
            </ul>
        </div>
        <div class="cfe-card green">
            <div class="cfe-card-title tw-text-green-700"><i class="fas fa-check-circle tw-mr-1"></i> SAHI — Yeh Tarika Use Karo</div>
            <ul class="tw-text-sm tw-text-green-800 tw-space-y-2 tw-pl-4 tw-m-0">
                <li>City JOIN:<br>
                <code>JOIN hr_city hc ON hc.station_id = cc.Station_id</code><br>
                <span class="tw-text-xs">Phir: <code>erc.citycode = hc.Code</code></span></li>
                <li>COD employee JOIN:<br>
                <code>JOIN hr_employeeroutecode erc ON erc.RouteCode = ar.Cour_id AND erc.Emp_No = @@empNo</code></li>
                <li>City name:<br>
                <code>hc.FullName</code> — hamesha yahi use karo</li>
            </ul>
        </div>
    </div>

    <div class="highlight-box tw-mt-4">
        <div class="tw-flex tw-items-start tw-gap-3">
            <i class="fas fa-lightbulb tw-text-yellow-600 tw-text-xl tw-mt-0.5"></i>
            <div>
                <strong class="tw-text-slate-800">Yaad Rakhne Ka Rule:</strong>
                <p class="tw-text-sm tw-text-slate-700 tw-m-0 tw-mt-1">
                    "Billing ka Station_id aur HR ka City Code numerically unrelated hain. Inhe sirf <code>hr_city</code> table ke zariye join kiya ja sakta hai —
                    <code>station_id</code> column se. Numerically compare karne ki koshish hamesha wrong results degi."
                </p>
            </div>
        </div>
    </div>
</div>

