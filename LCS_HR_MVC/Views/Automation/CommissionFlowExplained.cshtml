    </div>

    <div class="tw-grid tw-grid-cols-1 lg:tw-grid-cols-2 tw-gap-6">
        <div>
            <div class="flow-line">
                <div class="flow-box active">
                    <div class="dot tw-bg-orange-400"></div>
                    <div>
                        <div class="tw-text-xs tw-font-black">STEP 1 — Cash Commission</div>
