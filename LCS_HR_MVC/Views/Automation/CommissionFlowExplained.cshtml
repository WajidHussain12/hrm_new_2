<!-- SECTION 3: TEEN SERVERS                           -->
<!-- ═══════════════════════════════════════════════════ -->
<div id="sec3" class="cfe-section">
    <div class="cfe-section-header">
        <span class="badge-num">3</span> Teen Servers Ki Roles — Har Server Ka Kaam
    </div>

    <div class="tw-grid tw-grid-cols-1 lg:tw-grid-cols-3 tw-gap-5 tw-mb-5">
