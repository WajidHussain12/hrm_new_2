<span class="cmt">-- Billing server par: Station_id = '00592' (Karachi)</span>
<span class="cmt">-- HR server par: hr_city.Code = '001' (Karachi)</span>
<span class="cmt">-- Dono match nahi karte DIRECTLY</span>

<span class="kw">SELECT</span> hc.<span class="tbl">Code</span>, hc.<span class="tbl">FullName</span>, hc.<span class="tbl">station_id</span>
<span class="kw">FROM</span> <span class="tbl">hr_city</span> hc
<span class="kw">WHERE</span> hc.station_id = <span class="str">'00592'</span>;
<span class="cmt">-- Result: Code='001', FullName='Karachi', station_id='00592'</span>

<span class="cmt">-- Correct JOIN pattern:</span>
<span class="kw">JOIN</span> <span class="tbl">hr_city</span> hc <span class="kw">ON</span> hc.station_id = cc.Station_id
