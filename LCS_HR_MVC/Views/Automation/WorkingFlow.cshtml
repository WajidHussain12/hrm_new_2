@{
    ViewData["PageTitle"] = "Commission Working Flow";
    ViewData["Title"]     = "Commission Working Flow";
}

@section Styles {
<style>
/* ── Layout ── */
.wf-wrap { max-width: 1200px; margin: 0 auto; padding: 1.5rem 1rem; }

/* ── Pipeline Banner ── */
.pipeline-flow { display:flex; align-items:center; flex-wrap:wrap; gap:.25rem; }
.pipe-step { display:flex; align-items:center; gap:.25rem; }
.pipe-badge {
    display:inline-flex; align-items:center; gap:.35rem;
    padding:.35rem .75rem; border-radius:9999px;
    font-size:.72rem; font-weight:800; letter-spacing:.04em; white-space:nowrap;
}
.pipe-arrow { color:#94a3b8; font-size:1rem; }

/* ── Commission Card ── */
.comm-card { background:#fff; border-radius:1rem; box-shadow:0 1px 6px rgba(0,0,0,.07); border:1px solid #e2e8f0; margin-bottom:1.25rem; overflow:hidden; }
.comm-header { display:flex; align-items:center; gap:.75rem; padding:1rem 1.25rem; cursor:pointer; user-select:none; }
.comm-header:hover { background:#f8fafc; }
.comm-icon { width:2.25rem; height:2.25rem; border-radius:.6rem; display:flex; align-items:center; justify-content:center; font-size:.95rem; flex-shrink:0; }
.comm-title { font-size:1rem; font-weight:800; color:#1e293b; }
.comm-subtitle { font-size:.75rem; color:#64748b; font-weight:500; margin-top:.1rem; }
.comm-badges { display:flex; gap:.4rem; flex-wrap:wrap; }
.badge-auto { background:#dcfce7; color:#166534; border:1px solid #bbf7d0; }
.badge-manual { background:#fef3c7; color:#92400e; border:1px solid #fde68a; }
.badge-step { background:#eff6ff; color:#1e40af; border:1px solid #bfdbfe; }
.badge-sm { padding:.15rem .5rem; border-radius:9999px; font-size:.65rem; font-weight:800; }
.comm-toggle { margin-left:auto; color:#94a3b8; transition:transform .2s; }
.comm-toggle.open { transform:rotate(180deg); }

/* ── Commission Body ── */
.comm-body { display:none; padding:0 1.25rem 1.25rem; border-top:1px solid #f1f5f9; }
.comm-body.open { display:block; }

/* ── Sub-sections ── */
.section-grid { display:grid; grid-template-columns:1fr; gap:1rem; margin-top:1rem; }
@@media(min-width:768px){ .section-grid { grid-template-columns:1fr 1fr; } }
@@media(min-width:1024px){ .section-grid-3 { grid-template-columns:1fr 1fr 1fr; } }

.sub-card { background:#f8fafc; border:1px solid #e2e8f0; border-radius:.6rem; padding:.9rem 1rem; }
.sub-title { font-size:.7rem; font-weight:800; text-transform:uppercase; letter-spacing:.1em; color:#475569; margin-bottom:.5rem; display:flex; align-items:center; gap:.4rem; }
.sub-title i { opacity:.7; }

/* ── Info Tables ── */
.info-table { width:100%; border-collapse:collapse; font-size:.78rem; }
.info-table th { background:#f1f5f9; color:#475569; font-weight:700; padding:.4rem .65rem; text-align:left; font-size:.7rem; text-transform:uppercase; letter-spacing:.06em; }
.info-table td { padding:.4rem .65rem; color:#334155; border-top:1px solid #f1f5f9; vertical-align:top; }
.info-table tr:first-child td { border-top:none; }
.info-table td.label { font-weight:700; color:#475569; white-space:nowrap; }
.info-table td code { background:#e2e8f0; color:#1e293b; font-size:.72rem; padding:.05rem .3rem; border-radius:.25rem; font-family:monospace; }

/* ── Step list ── */
.step-list { counter-reset:step; list-style:none; padding:0; margin:0; }
.step-list li { counter-increment:step; display:flex; gap:.6rem; font-size:.78rem; color:#334155; padding:.35rem 0; border-bottom:1px solid #f1f5f9; }
.step-list li:last-child { border-bottom:none; }
.step-list li::before {
    content:counter(step); min-width:1.35rem; height:1.35rem; border-radius:50%;
    background:#e2e8f0; color:#475569; font-size:.65rem; font-weight:800;
    display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-top:.05rem;
}

/* ── Pill tags ── */
.tag { display:inline-block; padding:.1rem .45rem; border-radius:.3rem; font-size:.68rem; font-weight:700; margin:.1rem .1rem 0 0; }
.tag-blue { background:#dbeafe; color:#1e40af; }
.tag-green { background:#dcfce7; color:#166534; }
.tag-orange { background:#ffedd5; color:#9a3412; }
.tag-red { background:#fee2e2; color:#991b1b; }
.tag-purple { background:#ede9fe; color:#5b21b6; }
.tag-gray { background:#f1f5f9; color:#475569; }
.tag-yellow { background:#fef9c3; color:#854d0e; }

/* ── Hardcoded value block ── */
.hc-row { display:flex; align-items:flex-start; gap:.6rem; padding:.35rem 0; border-bottom:1px dashed #e2e8f0; font-size:.76rem; }
.hc-row:last-child { border-bottom:none; }
.hc-val { font-weight:800; font-family:monospace; background:#fef3c7; color:#92400e; padding:.1rem .4rem; border-radius:.25rem; white-space:nowrap; flex-shrink:0; }
.hc-desc { color:#475569; }

/* ── Dependency chain ── */
.dep-chain { display:flex; align-items:center; gap:.4rem; flex-wrap:wrap; font-size:.75rem; font-weight:700; }
.dep-node { padding:.3rem .7rem; border-radius:.5rem; border:1px solid #e2e8f0; background:#f8fafc; color:#334155; }
.dep-node.active { border-color:#6366f1; background:#eef2ff; color:#3730a3; }
.dep-arrow { color:#94a3b8; }

/* ── Color themes per commission ── */
.theme-blue   .comm-icon { background:#dbeafe; color:#1d4ed8; }
.theme-purple .comm-icon { background:#ede9fe; color:#6d28d9; }
.theme-orange .comm-icon { background:#ffedd5; color:#c2410c; }
.theme-rose   .comm-icon { background:#ffe4e6; color:#be123c; }
.theme-green  .comm-icon { background:#dcfce7; color:#15803d; }
.theme-amber  .comm-icon { background:#fef3c7; color:#b45309; }
.theme-indigo .comm-icon { background:#e0e7ff; color:#4338ca; }

.theme-blue   .comm-header { border-left:4px solid #3b82f6; }
.theme-purple .comm-header { border-left:4px solid #8b5cf6; }
.theme-orange .comm-header { border-left:4px solid #f97316; }
.theme-rose   .comm-header { border-left:4px solid #f43f5e; }
.theme-green  .comm-header { border-left:4px solid #22c55e; }
.theme-amber  .comm-header { border-left:4px solid #f59e0b; }
.theme-indigo .comm-header { border-left:4px solid #6366f1; }

/* ── Server info box ── */
.server-box { display:flex; align-items:flex-start; gap:.5rem; padding:.55rem .75rem; background:#f0fdf4; border:1px solid #bbf7d0; border-radius:.5rem; font-size:.75rem; margin-bottom:.4rem; }
.server-box.mis { background:#f0f9ff; border-color:#bae6fd; }
.server-box.billing { background:#fff7ed; border-color:#fed7aa; }
.server-box.ops { background:#fdf4ff; border-color:#e9d5ff; }
.server-box.main { background:#f0fdf4; border-color:#bbf7d0; }
.server-ip { font-family:monospace; font-weight:800; color:#1e293b; }

/* ── Section header chip ── */
.chip { display:inline-flex; align-items:center; gap:.3rem; padding:.2rem .65rem; border-radius:9999px; font-size:.68rem; font-weight:800; text-transform:uppercase; letter-spacing:.07em; }
</style>
}

<div class="wf-wrap">

<!-- ═══════════════════════════════════════ PAGE HEADER ═══════════════════════════════════════ -->
<div style="background:linear-gradient(135deg,#1e293b,#334155); border-radius:1rem; padding:1.5rem 1.75rem; margin-bottom:1.5rem; color:#fff;">
    <div style="display:flex; align-items:center; gap:1rem; flex-wrap:wrap;">
        <div style="width:3rem;height:3rem;background:rgba(245,197,24,.15);border:1px solid rgba(245,197,24,.3);border-radius:.75rem;display:flex;align-items:center;justify-content:center;">
            <i class="fas fa-project-diagram" style="color:#f5c518;font-size:1.2rem;"></i>
        </div>
        <div>
            <h1 style="font-size:1.35rem;font-weight:900;letter-spacing:-.02em;margin:0;">Commission Working Flow</h1>
            <p style="font-size:.8rem;color:#94a3b8;margin:.3rem 0 0;">Complete reference for all 7 commission processes — data sources, logic, formulas, dependencies, and automation coverage.</p>
        </div>
        <div style="margin-left:auto; display:flex; gap:.5rem; flex-wrap:wrap;">
            <span class="chip" style="background:rgba(34,197,94,.15);color:#4ade80;border:1px solid rgba(34,197,94,.25);">
                <i class="fas fa-robot"></i> 6 Automated
            </span>
            <span class="chip" style="background:rgba(251,191,36,.15);color:#fbbf24;border:1px solid rgba(251,191,36,.25);">
                <i class="fas fa-hand-pointer"></i> 1 Manual Tool
            </span>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════ PIPELINE OVERVIEW ═══════════════════════════════════════ -->
<div class="comm-card" style="margin-bottom:1.25rem;">
    <div style="padding:1rem 1.25rem; border-bottom:1px solid #f1f5f9;">
        <div style="font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:.1em;color:#64748b;margin-bottom:.75rem;">
            <i class="fas fa-stream" style="margin-right:.4rem;"></i>Execution Order &amp; Pipeline Overview
        </div>
        <div class="pipeline-flow">
            <div class="pipe-step">
                <span class="pipe-badge" style="background:#dbeafe;color:#1d4ed8;border:1px solid #bfdbfe;">
                    <i class="fas fa-money-bill-wave"></i> 1. Cash Commission
                </span>
            </div>
            <span class="pipe-arrow">→</span>
            <div class="pipe-step">
                <span class="pipe-badge" style="background:#ede9fe;color:#6d28d9;border:1px solid #ddd6fe;">
                    <i class="fas fa-hand-holding-usd"></i> 2. COD Commission
                </span>
            </div>
            <span class="pipe-arrow">→</span>
            <div class="pipe-step">
                <span class="pipe-badge" style="background:#ffedd5;color:#c2410c;border:1px solid #fed7aa;">
                    <i class="fas fa-truck"></i> 3. OverLand Commission
                </span>
            </div>
            <span class="pipe-arrow">→</span>
            <div class="pipe-step">
                <span class="pipe-badge" style="background:#ffe4e6;color:#be123c;border:1px solid #fecdd3;">
                    <i class="fas fa-undo-alt"></i> 4. Return COD Commission
                </span>
            </div>
            <span class="pipe-arrow">→</span>
            <div class="pipe-step">
                <span class="pipe-badge" style="background:#dcfce7;color:#15803d;border:1px solid #bbf7d0;">
                    <i class="fas fa-layer-group"></i> 5. Commission Process (Master)
                </span>
            </div>
            <span class="pipe-arrow">→</span>
            <div class="pipe-step">
                <span class="pipe-badge" style="background:#e0e7ff;color:#4338ca;border:1px solid #c7d2fe;">
                    <i class="fas fa-flag-checkered"></i> 6. Final Commission
                </span>
            </div>
            <span class="pipe-arrow" style="color:#f59e0b;">→</span>
            <div class="pipe-step">
                <span class="pipe-badge" style="background:#fef3c7;color:#b45309;border:1px solid #fde68a;">
                    <i class="fas fa-user-cog"></i> 7. Employee Reprocess <span style="font-size:.6rem;opacity:.8;">(Manual Tool)</span>
                </span>
            </div>
        </div>
    </div>
    <div style="padding:.75rem 1.25rem; display:flex; flex-wrap:wrap; gap:1.5rem; font-size:.75rem; color:#475569;">
        <span><i class="fas fa-server" style="color:#6366f1;margin-right:.3rem;"></i><strong>Main HR DB:</strong> lcs_hr &nbsp;&#64;&nbsp; <code style="background:#f1f5f9;padding:.1rem .3rem;border-radius:.25rem;font-family:monospace;">172.16.0.10</code></span>
        <span><i class="fas fa-server" style="color:#f97316;margin-right:.3rem;"></i><strong>MIS:</strong> lcs_incentive &nbsp;&#64;&nbsp; <code style="background:#f1f5f9;padding:.1rem .3rem;border-radius:.25rem;font-family:monospace;">172.16.0.7</code></span>
        <span><i class="fas fa-server" style="color:#8b5cf6;margin-right:.3rem;"></i><strong>LHR_Billing:</strong> lcs_billing &nbsp;&#64;&nbsp; <code style="background:#f1f5f9;padding:.1rem .3rem;border-radius:.25rem;font-family:monospace;">172.16.0.6</code></span>
        <span><i class="fas fa-server" style="color:#ec4899;margin-right:.3rem;"></i><strong>Central_OPS:</strong> lcs_db / lcs &nbsp;&#64;&nbsp; <code style="background:#f1f5f9;padding:.1rem .3rem;border-radius:.25rem;font-family:monospace;">172.16.0.18</code></span>
        <span><i class="fas fa-calendar-alt" style="color:#64748b;margin-right:.3rem;"></i><strong>Commission Period:</strong> 21st prev month → 20th current month</span>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════ -->
<!-- COMMISSION 1 — CASH COMMISSION                                 -->
<!-- ══════════════════════════════════════════════════════════════ -->
<div class="comm-card theme-blue">
    <div class="comm-header" onclick="toggleComm('c1')">
        <div class="comm-icon"><i class="fas fa-money-bill-wave"></i></div>
        <div>
            <div class="comm-title">Cash Commission</div>
            <div class="comm-subtitle">Step 1 of 6 in automation pipeline &mdash; Prerequisite for Master Commission</div>
        </div>
        <div class="comm-badges">
            <span class="badge-sm badge-step">Step 1</span>
            <span class="badge-sm badge-auto">Automated</span>
        </div>
        <i class="fas fa-chevron-down comm-toggle" id="toggle-c1"></i>
    </div>
    <div class="comm-body" id="body-c1">

        <!-- Overview -->
        <div class="section-grid" style="margin-top:1rem;">
            <div class="sub-card">
                <div class="sub-title"><i class="fas fa-info-circle"></i> Overview</div>
                <p style="font-size:.78rem;color:#334155;margin:0;">
                    Processes cash delivery commissions for all shipment types handled by a city's couriers during the commission period.
                    Reads raw billing data from the LHR_Billing server, applies shipment-type filters, calculates base commission and insurance commission per consignment,
                    then writes the results to <code>hr_cash_consignments</code> on the main HR DB.
                    Also processes VAS (Value-Added Service) commissions from Central_OPS.
                </p>
                <div style="margin-top:.65rem; display:flex; gap:.4rem; flex-wrap:wrap;">
                    <span class="tag tag-blue">Prerequisite for Step 5</span>
                    <span class="tag tag-green">Billing Source</span>
                    <span class="tag tag-purple">VAS Included</span>
                </div>
            </div>
            <div class="sub-card">
                <div class="sub-title"><i class="fas fa-server"></i> Server &amp; Connections</div>
                <div class="server-box billing">
                    <i class="fas fa-server" style="color:#c2410c;margin-top:.1rem;"></i>
                    <div>
                        <div class="server-ip">172.16.0.6 — LHR_Billing</div>
                        <div style="font-size:.7rem;color:#6b7280;margin-top:.15rem;">Database: <strong>lcs_billing</strong> &amp; <strong>lcs</strong> &nbsp;|&nbsp; Connection key: <code>LHR_Billing</code></div>
                        <div style="font-size:.7rem;color:#6b7280;">Source tables: <code>lcs_billing.billing_details</code>, <code>lcs.city</code>, <code>lcs.zone_color</code></div>
                    </div>
                </div>
                <div class="server-box ops">
                    <i class="fas fa-server" style="color:#9333ea;margin-top:.1rem;"></i>
                    <div>
                        <div class="server-ip">172.16.0.18 — Central_OPS</div>
                        <div style="font-size:.7rem;color:#6b7280;margin-top:.15rem;">Database: <strong>lcs</strong> &nbsp;|&nbsp; Connection key: <code>Central_OPS</code></div>
                        <div style="font-size:.7rem;color:#6b7280;">VAS source: <code>lcs.rms_cod_booking</code></div>
                    </div>
                </div>
                <div class="server-box main">
                    <i class="fas fa-server" style="color:#15803d;margin-top:.1rem;"></i>
                    <div>
                        <div class="server-ip">172.16.0.10 — Main HR DB</div>
                        <div style="font-size:.7rem;color:#6b7280;margin-top:.15rem;">Database: <strong>lcs_hr</strong> &nbsp;|&nbsp; Output tables written here</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Processing Logic -->
        <div class="sub-card" style="margin-top:1rem;">
            <div class="sub-title"><i class="fas fa-cogs"></i> Processing Logic — Step by Step</div>
            <ol class="step-list">
                <li><strong>Validate:</strong> EnsureProcessesOpenAsync — rejects if month is closed in <code>hr_closeprocesses</code>. Validates user city access via <code>hr_cityaccess</code>.</li>
                <li><strong>Context:</strong> PrepareCashCommissionExecutionContextAsync — resolves city's station IDs via <code>hr_locationmapping</code> and <code>lcs_setup.locations</code>. Builds FromDate (21st prev month) and ToDate (20th current month).</li>
                <li><strong>Existing check:</strong> If <code>hr_cash_consignments</code> already has rows for this city/month/year, throws "Already Processed on [date]".</li>
                <li><strong>Load cash rows:</strong> LoadCashCommissionSourceRowsAsync — reads <code>lcs_billing.billing_details</code> filtered by Station_id IN stationIds AND booking_date BETWEEN FromDate and ToDate AND Shipment_ID in the covered list (20+ shipment types).</li>
                <li><strong>Load VAS rows:</strong> LoadCashVasCommissionSourceRowsAsync — reads <code>lcs.rms_cod_booking</code> (Central_OPS) for the same period and stations.</li>
                <li><strong>Transaction:</strong> Opens single MySqlTransaction on main HR DB.</li>
                <li><strong>Save cash rows:</strong> SaveCashCommissionRowsAsync — inserts processed rows into <code>hr_cash_consignments</code>. Applies billing type classification, commission rate lookup, and insurance flag logic.</li>
                <li><strong>Acknowledgment:</strong> InsertCashCommissionAcknowledgmentAsync — inserts into <code>hr_acknowledgment</code> (called twice: once for cash, once for VAS).</li>
                <li><strong>Save VAS rows:</strong> SaveCashVasRowsAsync — inserts VAS incentive rows into <code>hr_vas_incentive_detail</code>.</li>
                <li><strong>Commit:</strong> Single commit covers both cash and VAS rows.</li>
            </ol>
        </div>

        <!-- Data Sources & Shipment IDs -->
        <div class="section-grid" style="margin-top:1rem;">
            <div class="sub-card">
                <div class="sub-title"><i class="fas fa-table"></i> Covered Shipment IDs</div>
                <table class="info-table">
                    <tr><td class="label">Overnight</td><td><code>17, 9, 40, 41</code></td></tr>
                    <tr><td class="label">YellowBox 1KG</td><td><code>21, 65, 68, 71</code></td></tr>
                    <tr><td class="label">YellowBox 2KG</td><td><code>22, 66, 69, 72</code></td></tr>
                    <tr><td class="label">YellowBox 5KG</td><td><code>23, 52, 67, 70, 73</code></td></tr>
                    <tr><td class="label">YellowBox 10KG</td><td><code>24</code></td></tr>
                    <tr><td class="label">YellowBox 15KG</td><td><code>32</code></td></tr>
                    <tr><td class="label">YellowBox 25KG</td><td><code>25, 53</code></td></tr>
                    <tr><td class="label">Flyer</td><td><code>10, 20, 61</code></td></tr>
                    <tr><td class="label">Economy+Detain25</td><td><code>2, 33, 42, 55, 56, 57, 58, 59, 60</code></td></tr>
                    <tr><td class="label">Overland</td><td><code>3, 8, 38</code></td></tr>
                    <tr><td class="label">Prepaid</td><td><code>26</code></td></tr>
                    <tr><td class="label">LoveLine</td><td><code>4</code></td></tr>
                    <tr><td class="label">International/Student</td><td><code>6, 7, 34, 47</code></td></tr>
                    <tr><td class="label">Mofa O2O</td><td><code>27</code></td></tr>
                    <tr><td class="label">Mofa O2D</td><td><code>28</code></td></tr>
                    <tr><td class="label">RMS COD</td><td><code>99</code></td></tr>
                    <tr><td class="label">RBI Express</td><td><code>17, 18, 19, 20, 9, 40, 41</code></td></tr>
                    <tr><td class="label">All-in-One</td><td><code>48</code></td></tr>
                    <tr><td class="label">Document Care</td><td><code>49</code></td></tr>
                </table>
            </div>
            <div>
                <div class="sub-card" style="margin-bottom:1rem;">
                    <div class="sub-title"><i class="fas fa-calculator"></i> Formulas &amp; Calculations</div>
                    <table class="info-table">
                        <tr><td class="label">Base Commission</td><td>Rate from <code>hr_commissionpolicy</code> by ShipmentType &amp; BillingType. IsPercent=1 → amount × rate / 100. IsPercent=0 → flat rate per consignment.</td></tr>
                        <tr><td class="label">Insurance Commission</td><td>Applied when insurance flag is set on consignment. Separate rate from policy table.</td></tr>
                        <tr><td class="label">VAS Commission</td><td>Rate from <code>hr_vas_incentive_detail</code> policy. Tied to RMS COD booking records.</td></tr>
                        <tr><td class="label">Period Formula</td><td>FromDate = 21st of (month − 1). ToDate = 20th of current month. Source: <code>CommissionStartDay=21, CommissionEndDay=20, CommissionStartDiff=−1</code></td></tr>
                    </table>
                </div>
                <div class="sub-card">
                    <div class="sub-title"><i class="fas fa-lock"></i> Hardcoded Values</div>
                    <div class="hc-row"><span class="hc-val">21</span><span class="hc-desc"><strong>CommissionStartDay</strong> — Period starts on 21st of previous month. Defined in <code>PayrollService.Commission.cs</code></span></div>
                    <div class="hc-row"><span class="hc-val">20</span><span class="hc-desc"><strong>CommissionEndDay</strong> — Period ends on 20th of current month.</span></div>
                    <div class="hc-row"><span class="hc-val">−1</span><span class="hc-desc"><strong>CommissionStartDiff</strong> — AddMonths(−1) to get previous month start date.</span></div>
                    <div class="hc-row"><span class="hc-val">LHR_Billing</span><span class="hc-desc">Connection string key for billing server.</span></div>
                    <div class="hc-row"><span class="hc-val">Central_OPS</span><span class="hc-desc">Connection string key for VAS/OPS server.</span></div>
                </div>
            </div>
        </div>

        <!-- Output & Dependencies -->
        <div class="section-grid" style="margin-top:1rem;">
            <div class="sub-card">
                <div class="sub-title"><i class="fas fa-database"></i> Output Tables</div>
                <table class="info-table">
                    <tr><th>Table</th><th>DB</th><th>Content</th></tr>
                    <tr><td><code>hr_cash_consignments</code></td><td>lcs_hr</td><td>Cash commission rows per consignment</td></tr>
                    <tr><td><code>hr_vas_incentive_detail</code></td><td>lcs_hr</td><td>VAS incentive rows</td></tr>
                    <tr><td><code>hr_acknowledgment</code></td><td>lcs_hr</td><td>Audit record (type=1)</td></tr>
                </table>
            </div>
            <div class="sub-card">
                <div class="sub-title"><i class="fas fa-sitemap"></i> Dependencies</div>
                <div style="font-size:.75rem;color:#475569;margin-bottom:.5rem;"><strong>Prerequisite:</strong> None — runs first</div>
