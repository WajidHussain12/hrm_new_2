            <div class="sub-card">
                <div class="sub-title"><i class="fas fa-exclamation-triangle" style="color:#f59e0b;"></i> NoData Status Behavior</div>
                <table class="info-table">
                    <tr><td class="label">Trigger</td><td>SP returns 0 rows — MIS source tables have no incentive data for the period</td></tr>
                    <tr><td class="label">Status set</td><td><code>NoData</code> (not Completed, not Failed)</td></tr>
