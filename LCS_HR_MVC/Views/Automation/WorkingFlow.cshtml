                        <div style="font-size:.7rem;color:#6b7280;">Writes: <code>is_final_commission_process</code> (lock record on success)</div>
                    </div>
                </div>
                <div class="server-box mis">
                    <i class="fas fa-server" style="color:#0284c7;margin-top:.1rem;"></i>
                    <div>
                        <div class="server-ip">172.16.0.7 — MIS</div>
