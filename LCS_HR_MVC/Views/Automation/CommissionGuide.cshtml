                <!-- ══ COD TIERS ═════════════════════════════════════════ -->
                <section id="cod-tiers" class="tw-bg-white tw-rounded-2xl tw-border tw-border-blue-200 tw-shadow-sm tw-p-6">
                    <div class="tw-flex tw-items-center tw-gap-3 tw-mb-4">
                        <div class="tw-w-9 tw-h-9 tw-rounded-xl tw-bg-blue-100 tw-flex tw-items-center tw-justify-center">
                            <i class="fas fa-sort-amount-up tw-text-blue-600"></i>
                        </div>
                        <h2 class="tw-text-lg tw-font-black tw-text-slate-800 tw-mb-0">COD Commission — Tier Rates (More CNs = Higher Rate)</h2>
                    </div>
                    <p class="tw-text-sm tw-text-slate-600 tw-mb-4">
                        COD commission is calculated per courier based on how many CNs were deposited <strong>on time</strong> (within 1 working day of delivery).
                        The more timely CNs, the <strong>higher the rate per CN</strong>:
                    </p>
                    <div class="tw-grid tw-grid-cols-1 sm:tw-grid-cols-3 tw-gap-4 tw-mb-4">
                        <div class="tw-border-2 tw-border-blue-200 tw-rounded-2xl tw-p-5 tw-text-center">
                            <div class="tw-text-3xl tw-font-black tw-text-blue-300 tw-mb-1">≤ 500</div>
                            <div class="tw-text-sm tw-text-slate-500 tw-mb-3">Timely CNs</div>
                            <div class="tw-text-3xl tw-font-black tw-text-blue-700">PKR 10</div>
                            <div class="tw-text-xs tw-text-slate-400 tw-mt-1">per CN</div>
                        </div>
                        <div class="tw-border-2 tw-border-blue-400 tw-rounded-2xl tw-p-5 tw-text-center tw-bg-blue-50">
                            <div class="tw-text-3xl tw-font-black tw-text-blue-500 tw-mb-1">501–750</div>
                            <div class="tw-text-sm tw-text-slate-500 tw-mb-3">Timely CNs</div>
                            <div class="tw-text-3xl tw-font-black tw-text-blue-700">PKR 15</div>
                            <div class="tw-text-xs tw-text-slate-400 tw-mt-1">per CN</div>
                        </div>
                        <div class="tw-border-2 tw-border-blue-600 tw-rounded-2xl tw-p-5 tw-text-center tw-bg-blue-100">
                            <div class="tw-text-3xl tw-font-black tw-text-blue-700 tw-mb-1">&gt; 750</div>
                            <div class="tw-text-sm tw-text-slate-500 tw-mb-3">Timely CNs</div>
                            <div class="tw-text-3xl tw-font-black tw-text-blue-900">PKR 20</div>
                            <div class="tw-text-xs tw-text-slate-400 tw-mt-1">per CN</div>
                        </div>
                    </div>
                    <div class="tw-p-3 tw-bg-blue-50 tw-border tw-border-blue-200 tw-rounded-xl tw-text-sm tw-text-blue-800">
                        <i class="fas fa-info-circle tw-mr-2 tw-text-blue-400"></i>
                        <strong>"Timely" definition:</strong> Cash deposited within <strong>1 working day</strong> of delivery date
                        (<code class="tw-font-mono tw-text-xs tw-bg-blue-100 tw-px-1 tw-rounded">DateDif ≤ 1</code> after subtracting public holidays via <code class="tw-font-mono tw-text-xs tw-bg-blue-100 tw-px-1 tw-rounded">lcs_hr.count_Holiday()</code>).
                    </div>
                </section>

                <!-- ══ CITY-SPECIFIC RULES ═══════════════════════════════ -->
                <section id="city-rules" class="tw-bg-white tw-rounded-2xl tw-border tw-border-teal-200 tw-shadow-sm tw-p-6">
                    <div class="tw-flex tw-items-center tw-gap-3 tw-mb-4">
                        <div class="tw-w-9 tw-h-9 tw-rounded-xl tw-bg-teal-100 tw-flex tw-items-center tw-justify-center">
                            <i class="fas fa-city tw-text-teal-600"></i>
                        </div>
                        <h2 class="tw-text-lg tw-font-black tw-text-slate-800 tw-mb-0">City-Specific Rules</h2>
                    </div>
                    <p class="tw-text-sm tw-text-slate-600 tw-mb-4">Commission rates themselves are the same across cities, but the <strong>KPI delivery threshold</strong> differs:</p>
                    <div class="tw-grid tw-grid-cols-1 sm:tw-grid-cols-2 tw-gap-4 tw-mb-4">
                        <div class="tw-bg-teal-50 tw-border tw-border-teal-300 tw-rounded-xl tw-p-4">
                            <div class="tw-text-xs tw-font-bold tw-text-teal-500 tw-uppercase tw-tracking-wider tw-mb-2">High-Volume Cities</div>
                            <div class="tw-flex tw-flex-wrap tw-gap-2 tw-mb-3">
                                <span class="tw-bg-teal-200 tw-text-teal-900 tw-font-bold tw-text-xs tw-px-2 tw-py-1 tw-rounded">001 — Karachi</span>
                                <span class="tw-bg-teal-200 tw-text-teal-900 tw-font-bold tw-text-xs tw-px-2 tw-py-1 tw-rounded">002 — Lahore</span>
                                <span class="tw-bg-teal-200 tw-text-teal-900 tw-font-bold tw-text-xs tw-px-2 tw-py-1 tw-rounded">003 — Hyderabad</span>
                                <span class="tw-bg-teal-200 tw-text-teal-900 tw-font-bold tw-text-xs tw-px-2 tw-py-1 tw-rounded">080</span>
                            </div>
                            <div class="tw-text-2xl tw-font-black tw-text-teal-700">85%</div>
                            <div class="tw-text-sm tw-text-teal-600">KPI Delivery Rate Required</div>
                        </div>
                        <div class="tw-bg-slate-50 tw-border tw-border-slate-300 tw-rounded-xl tw-p-4">
                            <div class="tw-text-xs tw-font-bold tw-text-slate-500 tw-uppercase tw-tracking-wider tw-mb-2">All Other Cities</div>
                            <div class="tw-text-sm tw-text-slate-400 tw-mb-3">(Multan, Sukkur, Faisalabad, Peshawar, etc.)</div>
                            <div class="tw-text-2xl tw-font-black tw-text-slate-700">80%</div>
                            <div class="tw-text-sm tw-text-slate-600">KPI Delivery Rate Required</div>
                        </div>
                    </div>
                    <div class="tw-p-3 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-xs">
                        <code class="guide-code tw-block"><span class="cm">-- City KPI threshold in SQL</span>
<span class="kw">IF</span>(<span class="nm">@@HrCity</span> <span class="kw">IN</span> (<span class="st">'001'</span>, <span class="st">'002'</span>, <span class="st">'003'</span>, <span class="st">'080'</span>), <span class="nm">85</span>, <span class="nm">80</span>)</code>
                    </div>
                </section>

                <!-- ══ ADJUSTMENTS ═══════════════════════════════════════ -->
                <section id="adjustments" class="tw-bg-white tw-rounded-2xl tw-border tw-border-violet-200 tw-shadow-sm tw-p-6">
                    <div class="tw-flex tw-items-center tw-gap-3 tw-mb-4">
                        <div class="tw-w-9 tw-h-9 tw-rounded-xl tw-bg-violet-100 tw-flex tw-items-center tw-justify-center">
                            <i class="fas fa-sliders-h tw-text-violet-600"></i>
                        </div>
                        <h2 class="tw-text-lg tw-font-black tw-text-slate-800 tw-mb-0">Commission Adjustments</h2>
                    </div>
                    <div class="tw-grid tw-grid-cols-1 sm:tw-grid-cols-2 tw-gap-4">
                        <div class="tw-bg-green-50 tw-border tw-border-green-200 tw-rounded-xl tw-p-4">
                            <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
                                <i class="fas fa-arrow-up tw-text-green-500"></i>
                                <span class="tw-text-sm tw-font-bold tw-text-green-800">Minimum Guarantee Top-Up</span>
                            </div>
                            <p class="tw-text-sm tw-text-green-700 tw-leading-relaxed">
                                If an eligible employee's total commission is between <strong>PKR 1 and PKR 1,500</strong> and they have working days &gt; 0:
                            </p>
                            <div class="tw-bg-green-100 tw-rounded-lg tw-p-2 tw-mt-2 tw-font-mono tw-text-xs tw-text-green-800">
                                Top-up = (1,500 ÷ 25) × WorkingDays — capped at 1,500
                            </div>
                            <p class="tw-text-xs tw-text-green-600 tw-mt-2">Stored in <code class="tw-font-mono tw-bg-green-100 tw-px-1 tw-rounded">hr_empcommadjdtl</code> as positive adjustment</p>
                        </div>
                        <div class="tw-bg-red-50 tw-border tw-border-red-200 tw-rounded-xl tw-p-4">
                            <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
                                <i class="fas fa-arrow-down tw-text-red-500"></i>
                                <span class="tw-text-sm tw-font-bold tw-text-red-800">RBI Commission Cap</span>
                            </div>
                            <p class="tw-text-sm tw-text-red-700 tw-leading-relaxed">
                                If an employee's total RBI-category commission exceeds <strong>PKR 100,000</strong>:
                            </p>
                            <div class="tw-bg-red-100 tw-rounded-lg tw-p-2 tw-mt-2 tw-font-mono tw-text-xs tw-text-red-800">
                                Deduction = (RBI Total − 100,000) × −1
                            </div>
                            <p class="tw-text-xs tw-text-red-600 tw-mt-2">Stored in <code class="tw-font-mono tw-bg-red-100 tw-px-1 tw-rounded">hr_empcommadjdtl</code> as negative adjustment</p>
                        </div>
                    </div>
                </section>

                <!-- ══ VERIFICATION QUERIES ══════════════════════════════ -->
                <section id="verify" class="tw-bg-white tw-rounded-2xl tw-border tw-border-rose-200 tw-shadow-sm tw-p-6">
                    <div class="tw-flex tw-items-center tw-gap-3 tw-mb-4">
                        <div class="tw-w-9 tw-h-9 tw-rounded-xl tw-bg-rose-100 tw-flex tw-items-center tw-justify-center">
                            <i class="fas fa-search tw-text-rose-600"></i>
                        </div>
                        <h2 class="tw-text-lg tw-font-black tw-text-slate-800 tw-mb-0">Verification Queries</h2>
                        <span class="tw-text-xs tw-bg-amber-100 tw-text-amber-700 tw-px-2 tw-py-1 tw-rounded-full tw-font-bold">Run on: HR Database (lcs_hr)</span>
                    </div>
                    <p class="tw-text-sm tw-text-slate-500 tw-mb-5">
                        Use these queries to verify data at each step. Replace <code class="tw-bg-slate-100 tw-px-1.5 tw-py-0.5 tw-rounded tw-text-xs tw-font-mono">2026</code>,
                        <code class="tw-bg-slate-100 tw-px-1.5 tw-py-0.5 tw-rounded tw-text-xs tw-font-mono">1</code> (month), and
                        <code class="tw-bg-slate-100 tw-px-1.5 tw-py-0.5 tw-rounded tw-text-xs tw-font-mono">'001'</code> (city) with your values.
                    </p>

                    <!-- Q1 -->
                    <div class="tw-mb-5">
                        <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
                            <span class="step-pill tw-bg-emerald-100 tw-text-emerald-700">Step 1 — Cash</span>
                            <span class="tw-text-sm tw-font-bold tw-text-slate-700">Cash commission summary per city</span>
                        </div>
                        <code class="guide-code tw-block"><span class="kw">SELECT</span>
    hc.<span class="tb">Code</span> <span class="kw">AS</span> city_code, hc.<span class="tb">FullName</span> <span class="kw">AS</span> city_name,
    <span class="fn">COUNT</span>(*) <span class="kw">AS</span> cn_count,
    <span class="fn">SUM</span>(cc.<span class="tb">TotalCommission</span>) <span class="kw">AS</span> total_commission,
    <span class="fn">MAX</span>(cc.<span class="tb">CreatedDate</span>) <span class="kw">AS</span> processed_at
<span class="kw">FROM</span> <span class="tb">hr_cash_consignments</span> cc
<span class="kw">JOIN</span> <span class="tb">hr_city</span> hc <span class="kw">ON</span> hc.<span class="tb">station_id</span> = cc.<span class="tb">Station_id</span>  <span class="cm">-- CORRECT: station_id join, then use hc.Code</span>
<span class="kw">WHERE</span> cc.<span class="tb">billing_date</span> <span class="kw">BETWEEN</span> <span class="st">'2025-12-21'</span> <span class="kw">AND</span> <span class="st">'2026-01-20'</span>  <span class="cm">-- Jan 2026 period</span>
<span class="kw">GROUP BY</span> hc.<span class="tb">Code</span>, hc.<span class="tb">FullName</span> <span class="kw">ORDER BY</span> cn_count <span class="kw">DESC</span>;</code>
                    </div>

                    <!-- Q2 -->
                    <div class="tw-mb-5">
                        <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
                            <span class="step-pill tw-bg-emerald-100 tw-text-emerald-700">Step 1 — Cash</span>
                            <span class="tw-text-sm tw-font-bold tw-text-slate-700">Cash commission for a specific employee</span>
                        </div>
                        <div class="tw-mb-2 tw-p-2.5 tw-bg-amber-50 tw-border tw-border-amber-200 tw-rounded-lg tw-text-xs tw-text-amber-800">
                            <i class="fas fa-exclamation-triangle tw-mr-1"></i>
                            <strong>Schema fact (verified):</strong> <code class="tw-font-mono">hr_city.Code='001'</code> ≠ <code class="tw-font-mono">station_id='00592'</code>.
                            Join via <code class="tw-font-mono">hc.station_id = cc.Station_id</code> first, then match <code class="tw-font-mono">erc.citycode = hc.Code</code>.
                            LPAD of station_id produces '592' ≠ '001' — always wrong.
                        </div>
                        <code class="guide-code tw-block"><span class="kw">SELECT</span>
    cc.<span class="tb">cn_number</span>, cc.<span class="tb">billing_date</span>, cc.<span class="tb">Shipment_id</span>,
    cc.<span class="tb">cour_id</span> <span class="kw">AS</span> route_code, cc.<span class="tb">Criteria</span>, cc.<span class="tb">TotalCommission</span>
<span class="kw">FROM</span> <span class="tb">hr_cash_consignments</span> cc
<span class="kw">JOIN</span> <span class="tb">hr_city</span> hc <span class="kw">ON</span> hc.<span class="tb">station_id</span> = cc.<span class="tb">Station_id</span>   <span class="cm">-- step 1: get city Code</span>
<span class="kw">INNER JOIN</span> <span class="tb">hr_employeeroutecode</span> erc
    <span class="kw">ON</span>  erc.<span class="tb">RouteCode</span> = cc.<span class="tb">cour_id</span>
    <span class="kw">AND</span> erc.<span class="tb">citycode</span>  = hc.<span class="tb">Code</span>              <span class="cm">-- step 2: match 3-char city Code</span>
    <span class="kw">AND</span> erc.<span class="tb">ToDate</span>   <span class="kw">IS NULL</span>
<span class="kw">WHERE</span> erc.<span class="tb">Emp_No</span> = <span class="st">'00000000003028'</span>            <span class="cm">-- replace with emp_no</span>
  <span class="kw">AND</span> cc.<span class="tb">billing_date</span> <span class="kw">BETWEEN</span> <span class="st">'2025-12-21'</span> <span class="kw">AND</span> <span class="st">'2026-01-20'</span>
<span class="kw">ORDER BY</span> cc.<span class="tb">billing_date</span> <span class="kw">DESC</span>;</code>
                    </div>

                    <!-- Q3 -->
                    <div class="tw-mb-5">
                        <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
                            <span class="step-pill tw-bg-blue-100 tw-text-blue-700">Step 2 — COD</span>
                            <span class="tw-text-sm tw-font-bold tw-text-slate-700">COD commission summary per city</span>
                        </div>
                        <code class="guide-code tw-block"><span class="kw">SELECT</span>
    <span class="tb">City</span>, <span class="fn">SUM</span>(<span class="tb">CnCount</span>) <span class="kw">AS</span> total_cns,
    <span class="fn">SUM</span>(<span class="tb">Commission</span>) <span class="kw">AS</span> total_commission,
    <span class="fn">SUM</span>(<span class="tb">CODBonus</span>) <span class="kw">AS</span> total_bonus,
    <span class="fn">SUM</span>(<span class="tb">CODDeduction</span>) <span class="kw">AS</span> total_deduction
<span class="kw">FROM</span> <span class="tb">hr_codcommission</span>
<span class="kw">WHERE</span> <span class="tb">year</span> = <span class="nm">2026</span> <span class="kw">AND</span> <span class="tb">month</span> = <span class="nm">1</span>
<span class="kw">GROUP BY</span> <span class="tb">City</span> <span class="kw">ORDER BY</span> total_commission <span class="kw">DESC</span>;</code>
                    </div>

                    <!-- Q4 -->
                    <div class="tw-mb-5">
                        <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
                            <span class="step-pill tw-bg-blue-100 tw-text-blue-700">Step 2 — COD</span>
                            <span class="tw-text-sm tw-font-bold tw-text-slate-700">COD CNs for a specific employee (on-time vs delayed)</span>
                        </div>
                        <div class="tw-mb-2 tw-p-2.5 tw-bg-amber-50 tw-border tw-border-amber-200 tw-rounded-lg tw-text-xs tw-text-amber-800">
                            <i class="fas fa-exclamation-triangle tw-mr-1"></i>
                            <strong>Schema fact (verified):</strong> <code class="tw-font-mono">hr_cod_consignments.Cour_id</code> is <strong>varchar(5) RouteCode</strong> (e.g. '00669') — NOT an employee number.
                            <code class="tw-font-mono">LPAD(Cour_id, 14, '0')</code> produces '0000000000669' which never matches any EMP_NO. Always join via <code class="tw-font-mono">hr_employeeroutecode</code>.
                        </div>
                        <code class="guide-code tw-block"><span class="kw">SELECT</span>
    hcc.<span class="tb">CN_Number</span>, hcc.<span class="tb">Cour_date</span>, hcc.<span class="tb">Delivery_date</span>,
    hcc.<span class="tb">DateDif</span>,
    <span class="kw">CASE WHEN</span> <span class="fn">IFNULL</span>(hcc.<span class="tb">DateDif</span>,<span class="nm">0</span>) <= <span class="nm">0</span> <span class="kw">THEN</span> <span class="st">'On-Time'</span> <span class="kw">ELSE</span> <span class="st">'Delayed'</span> <span class="kw">END</span> <span class="kw">AS</span> delivery_status,
    hcc.<span class="tb">ComAmnt</span>, hcc.<span class="tb">Reason</span>, hcc.<span class="tb">Cour_id</span> <span class="kw">AS</span> route_code
<span class="kw">FROM</span> <span class="tb">hr_cod_consignments</span> hcc
<span class="kw">INNER JOIN</span> <span class="tb">hr_employeeroutecode</span> erc     <span class="cm">-- Cour_id = RouteCode (5-char), NOT emp_no</span>
    <span class="kw">ON</span>  erc.<span class="tb">RouteCode</span> = hcc.<span class="tb">Cour_id</span>
    <span class="kw">AND</span> erc.<span class="tb">Emp_No</span>    = <span class="st">'00000000003028'</span>  <span class="cm">-- replace with emp_no</span>
    <span class="kw">AND</span> erc.<span class="tb">ToDate</span>   <span class="kw">IS NULL</span>
<span class="kw">WHERE</span> hcc.<span class="tb">Cyear</span> = <span class="nm">2026</span> <span class="kw">AND</span> hcc.<span class="tb">CMonth</span> = <span class="nm">1</span>
<span class="kw">ORDER BY</span> hcc.<span class="tb">Cour_date</span> <span class="kw">DESC</span>;</code>
                    </div>

                    <!-- Q5 -->
                    <div class="tw-mb-5">
                        <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
                            <span class="step-pill tw-bg-orange-100 tw-text-orange-700">Step 3 — OLE</span>
                            <span class="tw-text-sm tw-font-bold tw-text-slate-700">OverLand commission summary per city</span>
                        </div>
                        <code class="guide-code tw-block"><span class="kw">SELECT</span>
    hc.<span class="tb">Code</span> <span class="kw">AS</span> city_code, hc.<span class="tb">FullName</span> <span class="kw">AS</span> city_name,  <span class="cm">-- FullName, NOT city_name</span>
    p.<span class="tb">RateID</span>,
    <span class="fn">COUNT</span>(*) <span class="kw">AS</span> record_count,
    <span class="fn">SUM</span>(p.<span class="tb">Commission</span>) <span class="kw">AS</span> total_commission,
    <span class="fn">MAX</span>(p.<span class="tb">CreatedDate</span>) <span class="kw">AS</span> processed_at
<span class="kw">FROM</span> <span class="tb">hr_olecommissionprocess</span> p
<span class="kw">INNER JOIN</span> <span class="tb">hr_locationmapping</span> lm <span class="kw">ON</span> lm.<span class="tb">GlLocationId</span> = p.<span class="tb">GlLocationId</span>
<span class="kw">INNER JOIN</span> <span class="tb">hr_city</span> hc <span class="kw">ON</span> hc.<span class="tb">station_id</span> = lm.<span class="tb">BStationId</span>
<span class="kw">WHERE</span> p.<span class="tb">Year</span> = <span class="nm">2026</span> <span class="kw">AND</span> p.<span class="tb">Month</span> = <span class="nm">1</span>
<span class="kw">GROUP BY</span> hc.<span class="tb">Code</span>, hc.<span class="tb">FullName</span>, p.<span class="tb">RateID</span>
<span class="kw">ORDER BY</span> hc.<span class="tb">Code</span>, p.<span class="tb">RateID</span>;</code>
                    </div>

                    <!-- Q6 -->
                    <div class="tw-mb-5">
                        <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
                            <span class="step-pill tw-bg-indigo-100 tw-text-indigo-700">Step 5 — Master</span>
                            <span class="tw-text-sm tw-font-bold tw-text-slate-700">Final commission per employee (all types combined)</span>
                        </div>
                        <div class="tw-mb-2 tw-p-2.5 tw-bg-amber-50 tw-border tw-border-amber-200 tw-rounded-lg tw-text-xs tw-text-amber-800">
                            <i class="fas fa-exclamation-triangle tw-mr-1"></i>
                            <strong>Grand total warning:</strong> hr_commissionprocess has 90+ columns. The formula below includes ALL of them (verified on live DB).
                            Missing even one column (e.g. <code class="tw-font-mono">CASH_Economy_Booking</code>) gives completely wrong totals.
                            Also: city name column is <code class="tw-font-mono">FullName</code>, NOT <code class="tw-font-mono">city_name</code>.
                        </div>
                        <code class="guide-code tw-block"><span class="kw">SELECT</span>
    cp.<span class="tb">emp_no</span>, epd.<span class="tb">NAME</span>,
    cp.<span class="tb">citycode</span>, hc.<span class="tb">FullName</span> <span class="kw">AS</span> city_name,  <span class="cm">-- FullName, NOT city_name</span>
    <span class="cm">-- Key commission columns (there are 90+ total — see grand_total below for full list)</span>
    <span class="fn">IFNULL</span>(cp.<span class="tb">OVERNIGHT</span>,<span class="nm">0</span>)           <span class="kw">AS</span> overnight,
    <span class="fn">IFNULL</span>(cp.<span class="tb">CASH_Economy_Booking</span>,<span class="nm">0</span>) <span class="kw">AS</span> cash_economy,  <span class="cm">-- often largest column!</span>
    <span class="fn">IFNULL</span>(cp.<span class="tb">COD</span>,<span class="nm">0</span>)                  <span class="kw">AS</span> cod,
    <span class="fn">IFNULL</span>(cp.<span class="tb">COD_Bonus</span>,<span class="nm">0</span>)            <span class="kw">AS</span> cod_bonus,
    <span class="fn">IFNULL</span>(cp.<span class="tb">COD_Deduction</span>,<span class="nm">0</span>)        <span class="kw">AS</span> cod_deduction,
    <span class="fn">IFNULL</span>(cp.<span class="tb">OLE_Delivery</span>,<span class="nm">0</span>)         <span class="kw">AS</span> ole_delivery,
    <span class="fn">IFNULL</span>(cp.<span class="tb">OVERLAND</span>,<span class="nm">0</span>)             <span class="kw">AS</span> overland,
    <span class="fn">IFNULL</span>(cp.<span class="tb">VAS</span>,<span class="nm">0</span>)                  <span class="kw">AS</span> vas,
    <span class="cm">-- COMPLETE grand total (all 90+ columns — verified 2026-04-02)</span>
    (<span class="fn">IFNULL</span>(cp.<span class="tb">DOM_CREDIT</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">LOCAL_CREDIT</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">LOCAL_DLD</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">PMCL</span>,<span class="nm">0</span>)+
     <span class="fn">IFNULL</span>(cp.<span class="tb">DomesticDelivery</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">INTL_CREDIT</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">Porter</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">COD</span>,<span class="nm">0</span>)+
     <span class="fn">IFNULL</span>(cp.<span class="tb">OVERNIGHT</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">YB1KG</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">YB2KG</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">YB5KG</span>,<span class="nm">0</span>)+
     <span class="fn">IFNULL</span>(cp.<span class="tb">YB10KG</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">YB15KG</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">YB25KG</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">FLAYER</span>,<span class="nm">0</span>)+
     <span class="fn">IFNULL</span>(cp.<span class="tb">DETAIN</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">OVERLAND</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">PREPAID</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">LOVELINE</span>,<span class="nm">0</span>)+
     <span class="fn">IFNULL</span>(cp.<span class="tb">INTL_CASH</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">OLE_Credit_Booking</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">OLE_Dispatch_Proper</span>,<span class="nm">0</span>)+
     <span class="fn">IFNULL</span>(cp.<span class="tb">OLE_Transit_Dispatch</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">OLE_Delivery_OPS</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">OLE_Delivery</span>,<span class="nm">0</span>)+
     <span class="fn">IFNULL</span>(cp.<span class="tb">MOFA_OTO</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">MOFA_OTD</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">Rms_Cod_Booking</span>,<span class="nm">0</span>)+
     <span class="fn">IFNULL</span>(cp.<span class="tb">AllInOne</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">DocumnetCare</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">MTD</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">VAS</span>,<span class="nm">0</span>)+
     <span class="fn">IFNULL</span>(cp.<span class="tb">IntlDox</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">IntlEconomy</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">IntlParcel</span>,<span class="nm">0</span>)+
     <span class="fn">IFNULL</span>(cp.<span class="tb">ONUpto1kg</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">ONAbove1kg</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">EconomyRetail</span>,<span class="nm">0</span>)+
     <span class="fn">IFNULL</span>(cp.<span class="tb">MyCollect</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">Attestation</span>,<span class="nm">0</span>)+
     <span class="fn">IFNULL</span>(cp.<span class="tb">CEB_UpTo_2Kg</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">CEB_Above_2Kg</span>,<span class="nm">0</span>)+
     <span class="fn">IFNULL</span>(cp.<span class="tb">CASH_Economy_Booking</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">CASH_OLE_Booking</span>,<span class="nm">0</span>)+
     <span class="fn">IFNULL</span>(cp.<span class="tb">COD_Bonus</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">Pickup_Leopard</span>,<span class="nm">0</span>)+
     <span class="fn">IFNULL</span>(cp.<span class="tb">Ecom_overall_SR_Bonus</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">General_Light_Delivery</span>,<span class="nm">0</span>)+
     <span class="fn">IFNULL</span>(cp.<span class="tb">General_Heavy_Delivery</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">MTD_Delivery</span>,<span class="nm">0</span>)
     -<span class="fn">IFNULL</span>(cp.<span class="tb">Retail_Deduction</span>,<span class="nm">0</span>)-<span class="fn">IFNULL</span>(cp.<span class="tb">COD_Deduction</span>,<span class="nm">0</span>)) <span class="kw">AS</span> grand_total
<span class="kw">FROM</span> <span class="tb">hr_commissionprocess</span> cp
<span class="kw">INNER JOIN</span> <span class="tb">hr_employeepersonaldetail</span> epd <span class="kw">ON</span> epd.<span class="tb">EMP_NO</span> = cp.<span class="tb">emp_no</span>
<span class="kw">INNER JOIN</span> <span class="tb">hr_city</span> hc <span class="kw">ON</span> hc.<span class="tb">Code</span> = cp.<span class="tb">citycode</span>
<span class="kw">WHERE</span> cp.<span class="tb">Year</span> = <span class="nm">2026</span> <span class="kw">AND</span> cp.<span class="tb">Month</span> = <span class="nm">1</span>
  <span class="kw">AND</span> cp.<span class="tb">citycode</span> = <span class="st">'001'</span>     <span class="cm">-- optional: filter by city</span>
<span class="kw">ORDER BY</span> grand_total <span class="kw">DESC</span>
<span class="kw">LIMIT</span> <span class="nm">50</span>;</code>
                    </div>

                    <!-- Q7 -->
                    <div class="tw-mb-5">
                        <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
                            <span class="step-pill tw-bg-indigo-100 tw-text-indigo-700">Step 5 — Master</span>
                            <span class="tw-text-sm tw-font-bold tw-text-slate-700">Check if commission was processed for a city/month</span>
                        </div>
                        <code class="guide-code tw-block"><span class="cm">-- Quick existence check</span>
<span class="kw">SELECT</span>
    <span class="tb">citycode</span>, <span class="fn">COUNT</span>(*) <span class="kw">AS</span> employee_count,
    <span class="fn">MAX</span>(<span class="tb">CreatedDate</span>) <span class="kw">AS</span> processed_at
<span class="kw">FROM</span> <span class="tb">hr_commissionprocess</span>
<span class="kw">WHERE</span> <span class="tb">Year</span> = <span class="nm">2026</span> <span class="kw">AND</span> <span class="tb">Month</span> = <span class="nm">1</span>
<span class="kw">GROUP BY</span> <span class="tb">citycode</span>
<span class="kw">ORDER BY</span> <span class="tb">citycode</span>;</code>
                    </div>

                    <!-- Q8 -->
                    <div class="tw-mb-5">
                        <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
                            <span class="step-pill tw-bg-violet-100 tw-text-violet-700">Adjustments</span>
                            <span class="tw-text-sm tw-font-bold tw-text-slate-700">View minimum guarantee and RBI cap adjustments</span>
                        </div>
                        <code class="guide-code tw-block"><span class="kw">SELECT</span>
    adj.<span class="tb">Emp_No</span>, epd.<span class="tb">NAME</span>,
    adj.<span class="tb">Adjusment_Type_id</span>,
    <span class="kw">CASE</span> adj.<span class="tb">Adjusment_Type_id</span>
        <span class="kw">WHEN</span> <span class="nm">3</span> <span class="kw">THEN</span> <span class="st">'Min Guarantee Top-Up'</span>
        <span class="kw">WHEN</span> <span class="nm">4</span> <span class="kw">THEN</span> <span class="st">'RBI Cap Deduction'</span>
        <span class="kw">ELSE</span> <span class="st">'Other'</span>
    <span class="kw">END</span> <span class="kw">AS</span> adj_type,
    adj.<span class="tb">Adjustment_Amount</span>
<span class="kw">FROM</span> <span class="tb">hr_empcommadjdtl</span> adj
<span class="kw">INNER JOIN</span> <span class="tb">hr_employeepersonaldetail</span> epd <span class="kw">ON</span> epd.<span class="tb">EMP_NO</span> = adj.<span class="tb">Emp_No</span>
<span class="kw">WHERE</span> adj.<span class="tb">year</span> = <span class="nm">2026</span> <span class="kw">AND</span> adj.<span class="tb">month</span> = <span class="nm">1</span>
  <span class="kw">AND</span> adj.<span class="tb">Adjusment_Type_id</span> <span class="kw">NOT IN</span> (<span class="nm">1</span>, <span class="nm">2</span>)  <span class="cm">-- exclude legacy types</span>
<span class="kw">ORDER BY</span> adj.<span class="tb">Adjustment_Amount</span> <span class="kw">DESC</span>;</code>
                    </div>

                    <!-- Q9 -->
                    <div class="tw-mb-5">
                        <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
                            <span class="step-pill tw-bg-slate-200 tw-text-slate-700">Route Lookup</span>
                            <span class="tw-text-sm tw-font-bold tw-text-slate-700">Find employee by route code or employee number</span>
                        </div>
                        <code class="guide-code tw-block"><span class="cm">-- Find employee → route → city (all in one)</span>
<span class="kw">SELECT</span>
    erc.<span class="tb">Emp_No</span>, epd.<span class="tb">NAME</span>,
    erc.<span class="tb">RouteCode</span>, erc.<span class="tb">citycode</span>,
    hc.<span class="tb">FullName</span> <span class="kw">AS</span> city_name, hc.<span class="tb">Code</span>, hc.<span class="tb">station_id</span>,  <span class="cm">-- FullName + both IDs</span>
    erc.<span class="tb">FromDate</span>, erc.<span class="tb">ToDate</span>,
    <span class="kw">IF</span>(erc.<span class="tb">ToDate</span> <span class="kw">IS NULL</span>, <span class="st">'Active'</span>, <span class="st">'Inactive'</span>) <span class="kw">AS</span> route_status
<span class="kw">FROM</span> <span class="tb">hr_employeeroutecode</span> erc
<span class="kw">INNER JOIN</span> <span class="tb">hr_employeepersonaldetail</span> epd <span class="kw">ON</span> epd.<span class="tb">EMP_NO</span> = erc.<span class="tb">Emp_No</span>
<span class="kw">INNER JOIN</span> <span class="tb">hr_city</span> hc <span class="kw">ON</span> hc.<span class="tb">Code</span> = erc.<span class="tb">citycode</span>  <span class="cm">-- CORRECT: direct 3-char Code match</span>
<span class="kw">WHERE</span> erc.<span class="tb">Emp_No</span> = <span class="st">'00000000003028'</span>    <span class="cm">-- replace with emp_no</span>
   <span class="kw">OR</span> erc.<span class="tb">RouteCode</span> = <span class="st">'00202'</span>           <span class="cm">-- or search by route code</span>
<span class="kw">ORDER BY</span> erc.<span class="tb">FromDate</span> <span class="kw">DESC</span>;</code>
                    </div>

                    <!-- ── NEW: Cross-Verification Queries (added 2026-04-02) ── -->
                    <div class="tw-mb-3 tw-mt-6 tw-border-t tw-border-rose-100 tw-pt-5">
                        <div class="tw-flex tw-items-center tw-gap-2 tw-mb-4">
                            <div class="tw-w-7 tw-h-7 tw-rounded-lg tw-bg-rose-100 tw-flex tw-items-center tw-justify-center">
                                <i class="fas fa-microscope tw-text-rose-600 tw-text-xs"></i>
                            </div>
                            <span class="tw-text-sm tw-font-bold tw-text-slate-700">Employee Cross-Verification Queries</span>
                            <span class="tw-text-xs tw-bg-rose-100 tw-text-rose-700 tw-px-2 tw-py-0.5 tw-rounded-full tw-font-bold">Verified on live DB 2026-04-02</span>
                        </div>
                        <p class="tw-text-xs tw-text-slate-500 tw-mb-4">
                            Use these to diagnose why a specific employee's commission data is missing or wrong.
                            All queries use the <strong>correct schema patterns</strong> discovered during the Commission Verification screen fix.
                        </p>
                    </div>

                    <!-- QA: hr_city schema fact -->
                    <div class="tw-mb-5">
                        <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
                            <span class="step-pill tw-bg-rose-100 tw-text-rose-700">Schema Fact</span>
                            <span class="tw-text-sm tw-font-bold tw-text-slate-700">Verify hr_city Code vs station_id for a city</span>
                        </div>
                        <div class="tw-mb-2 tw-p-2.5 tw-bg-slate-800 tw-rounded-lg tw-text-xs tw-text-slate-300 tw-font-mono">
                            CRITICAL: Code='001' ≠ LPAD(station_id) — e.g. KHI has Code='001' but station_id='00592'.
                            These are completely unrelated fields. Always join tables via station_id, then use Code for display/filtering.
                        </div>
                        <code class="guide-code tw-block"><span class="cm">-- Check Code vs station_id for a city (e.g. Karachi)</span>
<span class="kw">SELECT</span> <span class="tb">Code</span>, <span class="tb">FullName</span>, <span class="tb">station_id</span>
<span class="kw">FROM</span> <span class="tb">hr_city</span>
<span class="kw">WHERE</span> <span class="tb">Code</span> = <span class="st">'001'</span>       <span class="cm">-- or filter by FullName LIKE '%Karachi%'</span>
<span class="kw">ORDER BY</span> <span class="tb">Code</span>;

<span class="cm">-- List all cities with both IDs (for reference)</span>
<span class="kw">SELECT</span> <span class="tb">Code</span>, <span class="tb">FullName</span>, <span class="tb">station_id</span>
<span class="kw">FROM</span> <span class="tb">hr_city</span>
<span class="kw">WHERE</span> <span class="tb">Code</span> <span class="kw">IS NOT NULL</span> <span class="kw">AND</span> <span class="tb">Code</span> <> <span class="st">''</span>
<span class="kw">ORDER BY</span> <span class="tb">Code</span>;</code>
                    </div>

                    <!-- QB: Cash CNs count with correct join -->
                    <div class="tw-mb-5">
                        <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
                            <span class="step-pill tw-bg-emerald-100 tw-text-emerald-700">Step 1 — Cash</span>
                            <span class="tw-text-sm tw-font-bold tw-text-slate-700">Count + total cash commission for one employee (correct join)</span>
                        </div>
                        <code class="guide-code tw-block"><span class="cm">-- Count how many cash CNs an employee has + their total commission</span>
<span class="cm">-- Uses the correct 2-step city join (station_id → Code)</span>
<span class="kw">SELECT</span>
    <span class="fn">COUNT</span>(*) <span class="kw">AS</span> cn_count,
    <span class="fn">SUM</span>(cc.<span class="tb">TotalCommission</span>) <span class="kw">AS</span> total_commission,
    <span class="fn">SUM</span>(<span class="kw">CASE WHEN</span> cc.<span class="tb">TotalCommission</span> = <span class="nm">0</span> <span class="kw">THEN</span> <span class="nm">1</span> <span class="kw">ELSE</span> <span class="nm">0</span> <span class="kw">END</span>) <span class="kw">AS</span> zero_commission_cns
<span class="kw">FROM</span> <span class="tb">hr_cash_consignments</span> cc
<span class="kw">JOIN</span> <span class="tb">hr_city</span> hc <span class="kw">ON</span> hc.<span class="tb">station_id</span> = cc.<span class="tb">Station_id</span>
<span class="kw">INNER JOIN</span> <span class="tb">hr_employeeroutecode</span> erc
    <span class="kw">ON</span>  erc.<span class="tb">RouteCode</span> = cc.<span class="tb">cour_id</span>
    <span class="kw">AND</span> erc.<span class="tb">citycode</span>  = hc.<span class="tb">Code</span>
    <span class="kw">AND</span> erc.<span class="tb">ToDate</span>   <span class="kw">IS NULL</span>
<span class="kw">WHERE</span> erc.<span class="tb">Emp_No</span> = <span class="st">'00000000010188'</span>           <span class="cm">-- replace with emp_no</span>
  <span class="kw">AND</span> cc.<span class="tb">billing_date</span> <span class="kw">BETWEEN</span> <span class="st">'2026-02-21'</span> <span class="kw">AND</span> <span class="st">'2026-03-20'</span>;  <span class="cm">-- Mar 2026 period</span>

<span class="cm">-- Show CNs with commission = 0 (missing commissions)</span>
<span class="kw">SELECT</span>
    cc.<span class="tb">cn_number</span>, cc.<span class="tb">billing_date</span>, cc.<span class="tb">Shipment_id</span>,
    cc.<span class="tb">cour_id</span> <span class="kw">AS</span> route_code, cc.<span class="tb">Criteria</span>, cc.<span class="tb">TotalCommission</span>
<span class="kw">FROM</span> <span class="tb">hr_cash_consignments</span> cc
<span class="kw">JOIN</span> <span class="tb">hr_city</span> hc <span class="kw">ON</span> hc.<span class="tb">station_id</span> = cc.<span class="tb">Station_id</span>
<span class="kw">INNER JOIN</span> <span class="tb">hr_employeeroutecode</span> erc
    <span class="kw">ON</span>  erc.<span class="tb">RouteCode</span> = cc.<span class="tb">cour_id</span>
    <span class="kw">AND</span> erc.<span class="tb">citycode</span>  = hc.<span class="tb">Code</span>
    <span class="kw">AND</span> erc.<span class="tb">ToDate</span>   <span class="kw">IS NULL</span>
<span class="kw">WHERE</span> erc.<span class="tb">Emp_No</span> = <span class="st">'00000000010188'</span>
  <span class="kw">AND</span> cc.<span class="tb">billing_date</span> <span class="kw">BETWEEN</span> <span class="st">'2026-02-21'</span> <span class="kw">AND</span> <span class="st">'2026-03-20'</span>
  <span class="kw">AND</span> cc.<span class="tb">TotalCommission</span> = <span class="nm">0</span>              <span class="cm">-- only missing commissions</span>
<span class="kw">ORDER BY</span> cc.<span class="tb">billing_date</span>;</code>
                    </div>

                    <!-- QC: COD CNs count with correct join -->
                    <div class="tw-mb-5">
                        <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
                            <span class="step-pill tw-bg-blue-100 tw-text-blue-700">Step 2 — COD</span>
                            <span class="tw-text-sm tw-font-bold tw-text-slate-700">Count + total COD commission for one employee (correct join)</span>
                        </div>
                        <code class="guide-code tw-block"><span class="cm">-- Count COD CNs for one employee via RouteCode join (NOT LPAD)</span>
<span class="kw">SELECT</span>
    <span class="fn">COUNT</span>(*) <span class="kw">AS</span> cod_cn_count,
    <span class="fn">SUM</span>(hcc.<span class="tb">ComAmnt</span>) <span class="kw">AS</span> total_cod_commission,
    <span class="fn">SUM</span>(<span class="kw">CASE WHEN</span> <span class="fn">IFNULL</span>(hcc.<span class="tb">DateDif</span>,<span class="nm">0</span>) <= <span class="nm">0</span> <span class="kw">THEN</span> <span class="nm">1</span> <span class="kw">ELSE</span> <span class="nm">0</span> <span class="kw">END</span>) <span class="kw">AS</span> on_time,
    <span class="fn">SUM</span>(<span class="kw">CASE WHEN</span> <span class="fn">IFNULL</span>(hcc.<span class="tb">DateDif</span>,<span class="nm">0</span>) >  <span class="nm">0</span> <span class="kw">THEN</span> <span class="nm">1</span> <span class="kw">ELSE</span> <span class="nm">0</span> <span class="kw">END</span>) <span class="kw">AS</span> delayed,
    <span class="fn">SUM</span>(<span class="kw">CASE WHEN</span> hcc.<span class="tb">ComAmnt</span> = <span class="nm">0</span> <span class="kw">THEN</span> <span class="nm">1</span> <span class="kw">ELSE</span> <span class="nm">0</span> <span class="kw">END</span>) <span class="kw">AS</span> zero_commission_cns
<span class="kw">FROM</span> <span class="tb">hr_cod_consignments</span> hcc
<span class="kw">INNER JOIN</span> <span class="tb">hr_employeeroutecode</span> erc
    <span class="kw">ON</span>  erc.<span class="tb">RouteCode</span> = hcc.<span class="tb">Cour_id</span>  <span class="cm">-- Cour_id is varchar(5) RouteCode, NOT emp_no</span>
    <span class="kw">AND</span> erc.<span class="tb">Emp_No</span>    = <span class="st">'00000000010188'</span>  <span class="cm">-- replace with emp_no</span>
    <span class="kw">AND</span> erc.<span class="tb">ToDate</span>   <span class="kw">IS NULL</span>
<span class="kw">WHERE</span> hcc.<span class="tb">Cyear</span> = <span class="nm">2026</span> <span class="kw">AND</span> hcc.<span class="tb">CMonth</span> = <span class="nm">3</span>;  <span class="cm">-- replace year/month</span>

<span class="cm">-- Show COD CNs with commission = 0 for this employee</span>
<span class="kw">SELECT</span>
    hcc.<span class="tb">CN_Number</span>, hcc.<span class="tb">Cour_date</span>, hcc.<span class="tb">Delivery_date</span>, hcc.<span class="tb">DateDif</span>,
    hcc.<span class="tb">ComAmnt</span>, hcc.<span class="tb">Reason</span>, hcc.<span class="tb">Remarks</span>
<span class="kw">FROM</span> <span class="tb">hr_cod_consignments</span> hcc
<span class="kw">INNER JOIN</span> <span class="tb">hr_employeeroutecode</span> erc
    <span class="kw">ON</span>  erc.<span class="tb">RouteCode</span> = hcc.<span class="tb">Cour_id</span>
    <span class="kw">AND</span> erc.<span class="tb">Emp_No</span>    = <span class="st">'00000000010188'</span>
    <span class="kw">AND</span> erc.<span class="tb">ToDate</span>   <span class="kw">IS NULL</span>
<span class="kw">WHERE</span> hcc.<span class="tb">Cyear</span> = <span class="nm">2026</span> <span class="kw">AND</span> hcc.<span class="tb">CMonth</span> = <span class="nm">3</span>
  <span class="kw">AND</span> hcc.<span class="tb">ComAmnt</span> = <span class="nm">0</span>
<span class="kw">ORDER BY</span> hcc.<span class="tb">Cour_date</span>;</code>
                    </div>

                    <!-- QD: Grand total spot check -->
                    <div class="tw-mb-5">
                        <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
                            <span class="step-pill tw-bg-indigo-100 tw-text-indigo-700">Step 5 — Master</span>
                            <span class="tw-text-sm tw-font-bold tw-text-slate-700">Spot-check grand total for one employee</span>
                        </div>
                        <code class="guide-code tw-block"><span class="cm">-- Quick check: what did this employee get processed as?</span>
<span class="kw">SELECT</span>
    cp.<span class="tb">emp_no</span>, epd.<span class="tb">NAME</span>, cp.<span class="tb">citycode</span>,
    cp.<span class="tb">OVERNIGHT</span>, cp.<span class="tb">CASH_Economy_Booking</span>,  <span class="cm">-- often the biggest cash column</span>
    cp.<span class="tb">COD</span>, cp.<span class="tb">COD_Bonus</span>, cp.<span class="tb">COD_Deduction</span>,
    cp.<span class="tb">OLE_Delivery</span>, cp.<span class="tb">OVERLAND</span>, cp.<span class="tb">VAS</span>,
    <span class="cm">-- Grand total: all 90+ columns (see Q6 for full formula)</span>
    (<span class="fn">IFNULL</span>(cp.<span class="tb">DOM_CREDIT</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">LOCAL_CREDIT</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">COD</span>,<span class="nm">0</span>)+
     <span class="fn">IFNULL</span>(cp.<span class="tb">OVERNIGHT</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">YB1KG</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">YB2KG</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">YB5KG</span>,<span class="nm">0</span>)+
     <span class="fn">IFNULL</span>(cp.<span class="tb">YB10KG</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">YB15KG</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">YB25KG</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">FLAYER</span>,<span class="nm">0</span>)+
     <span class="fn">IFNULL</span>(cp.<span class="tb">DETAIN</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">OVERLAND</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">PREPAID</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">LOVELINE</span>,<span class="nm">0</span>)+
     <span class="fn">IFNULL</span>(cp.<span class="tb">OLE_Delivery</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">VAS</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">CASH_Economy_Booking</span>,<span class="nm">0</span>)+
     <span class="fn">IFNULL</span>(cp.<span class="tb">CASH_OLE_Booking</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">COD_Bonus</span>,<span class="nm">0</span>)+<span class="fn">IFNULL</span>(cp.<span class="tb">Ecom_overall_SR_Bonus</span>,<span class="nm">0</span>)
     -<span class="fn">IFNULL</span>(cp.<span class="tb">Retail_Deduction</span>,<span class="nm">0</span>)-<span class="fn">IFNULL</span>(cp.<span class="tb">COD_Deduction</span>,<span class="nm">0</span>)) <span class="kw">AS</span> grand_total
<span class="kw">FROM</span> <span class="tb">hr_commissionprocess</span> cp
<span class="kw">INNER JOIN</span> <span class="tb">hr_employeepersonaldetail</span> epd <span class="kw">ON</span> epd.<span class="tb">EMP_NO</span> = cp.<span class="tb">emp_no</span>
<span class="kw">WHERE</span> cp.<span class="tb">emp_no</span> = <span class="st">'00000000010188'</span>   <span class="cm">-- replace with emp_no</span>
  <span class="kw">AND</span> cp.<span class="tb">Year</span> = <span class="nm">2026</span> <span class="kw">AND</span> cp.<span class="tb">Month</span> = <span class="nm">3</span>;</code>
                    </div>

                    <!-- QE: Missing CNs diagnostic -->
                    <div class="tw-mb-0">
                        <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
                            <span class="step-pill tw-bg-amber-100 tw-text-amber-700">Diagnostics</span>
                            <span class="tw-text-sm tw-font-bold tw-text-slate-700">Find all missing commissions for an employee (Cash + COD combined)</span>
                        </div>
                        <code class="guide-code tw-block"><span class="cm">-- Cash CNs with TotalCommission = 0 (assigned to employee but no commission calculated)</span>
<span class="kw">SELECT</span>
    <span class="st">'Cash'</span> <span class="kw">AS</span> commission_type,
    cc.<span class="tb">cn_number</span>, cc.<span class="tb">billing_date</span> <span class="kw">AS</span> cn_date,
    <span class="kw">NULL</span> <span class="kw">AS</span> delivery_date,
    cc.<span class="tb">Shipment_id</span>, cc.<span class="tb">Gross_Amount</span> <span class="kw">AS</span> billed_amount,
    cc.<span class="tb">Criteria</span>, <span class="kw">NULL</span> <span class="kw">AS</span> reason
<span class="kw">FROM</span> <span class="tb">hr_cash_consignments</span> cc
<span class="kw">JOIN</span> <span class="tb">hr_city</span> hc <span class="kw">ON</span> hc.<span class="tb">station_id</span> = cc.<span class="tb">Station_id</span>
<span class="kw">INNER JOIN</span> <span class="tb">hr_employeeroutecode</span> erc
    <span class="kw">ON</span>  erc.<span class="tb">RouteCode</span> = cc.<span class="tb">cour_id</span>
    <span class="kw">AND</span> erc.<span class="tb">citycode</span>  = hc.<span class="tb">Code</span>
    <span class="kw">AND</span> erc.<span class="tb">ToDate</span>   <span class="kw">IS NULL</span>
<span class="kw">WHERE</span> erc.<span class="tb">Emp_No</span> = <span class="st">'00000000010188'</span>
  <span class="kw">AND</span> cc.<span class="tb">billing_date</span> <span class="kw">BETWEEN</span> <span class="st">'2026-02-21'</span> <span class="kw">AND</span> <span class="st">'2026-03-20'</span>
  <span class="kw">AND</span> cc.<span class="tb">TotalCommission</span> = <span class="nm">0</span>

<span class="kw">UNION ALL</span>

<span class="cm">-- COD CNs with ComAmnt = 0 (assigned to employee but no commission calculated)</span>
<span class="kw">SELECT</span>
    <span class="st">'COD'</span> <span class="kw">AS</span> commission_type,
    hcc.<span class="tb">CN_Number</span>, hcc.<span class="tb">Cour_date</span> <span class="kw">AS</span> cn_date,
    hcc.<span class="tb">Delivery_date</span>,
    hcc.<span class="tb">Remarks</span> <span class="kw">AS</span> shipment_id, hcc.<span class="tb">ComAmnt</span> <span class="kw">AS</span> billed_amount,
    <span class="kw">NULL</span> <span class="kw">AS</span> criteria, hcc.<span class="tb">Reason</span>
<span class="kw">FROM</span> <span class="tb">hr_cod_consignments</span> hcc
<span class="kw">INNER JOIN</span> <span class="tb">hr_employeeroutecode</span> erc
    <span class="kw">ON</span>  erc.<span class="tb">RouteCode</span> = hcc.<span class="tb">Cour_id</span>
    <span class="kw">AND</span> erc.<span class="tb">Emp_No</span>    = <span class="st">'00000000010188'</span>
    <span class="kw">AND</span> erc.<span class="tb">ToDate</span>   <span class="kw">IS NULL</span>
<span class="kw">WHERE</span> hcc.<span class="tb">Cyear</span> = <span class="nm">2026</span> <span class="kw">AND</span> hcc.<span class="tb">CMonth</span> = <span class="nm">3</span>
  <span class="kw">AND</span> hcc.<span class="tb">ComAmnt</span> = <span class="nm">0</span>

<span class="kw">ORDER BY</span> commission_type, cn_date;</code>
                    </div>
                </section>

                <!-- Bottom back link -->
                <div class="tw-flex tw-items-center tw-justify-between tw-pb-4">
                    <a href="@Url.Action("History", "Automation")"
                       class="tw-text-sm tw-text-slate-500 hover:tw-text-slate-700 tw-flex tw-items-center tw-gap-1">
                        <i class="fas fa-arrow-left tw-text-xs"></i> Commission History
                    </a>
                    <a href="@Url.Action("Index", "CommissionVerification")"
                       class="tw-text-sm tw-text-indigo-600 hover:tw-text-indigo-800 tw-flex tw-items-center tw-gap-1">
                        Commission Verification <i class="fas fa-arrow-right tw-text-xs"></i>
                    </a>
                </div>

            </div><!-- /main content -->
        </div><!-- /flex -->
    </div><!-- /max-w -->
</div>

@section Scripts {
<script>
    // Highlight active TOC link based on scroll position
    document.addEventListener('DOMContentLoaded', function () {
        var sections = document.querySelectorAll('section[id]');
        var tocLinks = document.querySelectorAll('.toc-link');

        function onScroll() {
            var scrollY = window.scrollY + 120;
            sections.forEach(function (sec) {
                if (sec.offsetTop <= scrollY && (sec.offsetTop + sec.offsetHeight) > scrollY) {
                    tocLinks.forEach(function (l) { l.classList.remove('active'); });
                    var active = document.querySelector('.toc-link[href="#' + sec.id + '"]');
                    if (active) active.classList.add('active');
                }
            });
        }
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();

        // Smooth scroll for TOC links
        tocLinks.forEach(function (link) {
            link.addEventListener('click', function (e) {
                var target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    e.preventDefault();
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        });
    });
</script>
}
