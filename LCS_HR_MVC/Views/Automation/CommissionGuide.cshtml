@{
    ViewData["Title"] = "Commission Creation Guide";
}

<style>
    .guide-code {
        background: #0f172a;
        color: #e2e8f0;
        font-family: 'Courier New', monospace;
        font-size: 0.72rem;
        line-height: 1.6;
        border-radius: 0.75rem;
        padding: 1rem 1.25rem;
        overflow-x: auto;
        white-space: pre;
    }
    .guide-code .kw  { color: #7dd3fc; }  /* keyword */
    .guide-code .fn  { color: #86efac; }  /* function */
    .guide-code .st  { color: #fde68a; }  /* string */
    .guide-code .cm  { color: #94a3b8; font-style: italic; } /* comment */
    .guide-code .tb  { color: #f9a8d4; }  /* table */
    .guide-code .nm  { color: #fdba74; }  /* number */

    .step-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 0.2rem 0.6rem;
        border-radius: 99px;
    }
    .toc-link {
        display: flex; align-items: center; gap: 0.5rem;
        padding: 0.4rem 0.75rem;
        border-radius: 0.5rem;
        font-size: 0.78rem; font-weight: 600;
        color: #475569; text-decoration: none;
        transition: all 0.15s;
    }
    .toc-link:hover { background: #f1f5f9; color: #1e293b; }
    .toc-link.active { background: #eff6ff; color: #2563eb; }

    .db-badge {
        display: inline-flex; align-items: center; gap: 0.3rem;
        font-size: 0.68rem; font-weight: 700;
        padding: 0.18rem 0.55rem; border-radius: 0.4rem;
    }
    .rate-table th { background: #f8fafc; font-size: 0.72rem; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; }
    .rate-table td { font-size: 0.78rem; }
    .rate-table tr:hover td { background: #f8fafc; }
    .rate-table td, .rate-table th { padding: 0.5rem 0.75rem; border-bottom: 1px solid #f1f5f9; }
</style>

<div class="tw-min-h-screen tw-bg-slate-50">

    <!-- ── Page Header ──────────────────────────────────────────────────── -->
    <div class="tw-bg-gradient-to-r tw-from-slate-800 tw-to-slate-900 tw-text-white tw-px-6 tw-py-8">
        <div class="tw-max-w-6xl tw-mx-auto">
            <div class="tw-flex tw-items-center tw-gap-4 tw-mb-3">
                <div class="tw-w-12 tw-h-12 tw-rounded-2xl tw-bg-amber-400 tw-flex tw-items-center tw-justify-center tw-shadow-lg">
                    <i class="fas fa-book-open tw-text-slate-900 tw-text-lg"></i>
                </div>
                <div>
                    <h1 class="tw-text-2xl tw-font-black tw-mb-0">Employee Commission Creation Guide</h1>
                    <p class="tw-text-slate-400 tw-text-sm tw-mb-0">Complete reference — Servers · Databases · Tables · Calculations · Verification Queries</p>
                </div>
            </div>
            <div class="tw-flex tw-flex-wrap tw-gap-2 tw-mt-4">
                <span class="tw-bg-slate-700 tw-text-slate-300 tw-text-xs tw-font-semibold tw-px-3 tw-py-1 tw-rounded-full">For Non-Technical Users</span>
                <span class="tw-bg-slate-700 tw-text-slate-300 tw-text-xs tw-font-semibold tw-px-3 tw-py-1 tw-rounded-full">For Developers</span>
                <span class="tw-bg-amber-500/20 tw-text-amber-300 tw-text-xs tw-font-semibold tw-px-3 tw-py-1 tw-rounded-full">
                    <i class="fas fa-calendar-alt tw-mr-1"></i>Period: 21st prev month → 20th current month
                </span>
            </div>
        </div>
    </div>

    <div class="tw-max-w-6xl tw-mx-auto tw-px-4 lg:tw-px-6 tw-py-6">
        <div class="tw-flex tw-gap-6 tw-items-start">

            <!-- ── Left Sidebar: Table of Contents ─────────────────────── -->
            <div class="tw-hidden xl:tw-block tw-w-56 tw-flex-shrink-0">
                <div class="tw-sticky tw-top-20 tw-bg-white tw-rounded-2xl tw-border tw-border-slate-200 tw-shadow-sm tw-p-3">
                    <p class="tw-text-[10px] tw-font-black tw-text-slate-400 tw-uppercase tw-tracking-widest tw-px-2 tw-mb-2">Contents</p>
                    <nav class="tw-flex tw-flex-col tw-gap-0.5">
                        <a class="toc-link" href="#overview"><i class="fas fa-layer-group tw-w-4 tw-text-slate-400"></i> Overview</a>
                        <a class="toc-link" href="#servers"><i class="fas fa-server tw-w-4 tw-text-blue-400"></i> Servers & DBs</a>
                        <a class="toc-link" href="#period"><i class="fas fa-calendar tw-w-4 tw-text-purple-400"></i> Commission Period</a>
                        <a class="toc-link" href="#step1"><i class="fas fa-circle tw-w-4 tw-text-emerald-400"></i> Step 1 — Cash</a>
                        <a class="toc-link" href="#step2"><i class="fas fa-circle tw-w-4 tw-text-blue-400"></i> Step 2 — COD</a>
                        <a class="toc-link" href="#step3"><i class="fas fa-circle tw-w-4 tw-text-orange-400"></i> Step 3 — OverLand</a>
                        <a class="toc-link" href="#step4"><i class="fas fa-circle tw-w-4 tw-text-pink-400"></i> Step 4 — Return COD</a>
                        <a class="toc-link" href="#step5"><i class="fas fa-circle tw-w-4 tw-text-indigo-400"></i> Step 5 — Master</a>
                        <a class="toc-link" href="#rates"><i class="fas fa-table tw-w-4 tw-text-amber-400"></i> All Rates Table</a>
                        <a class="toc-link" href="#cod-tiers"><i class="fas fa-sort-amount-up tw-w-4 tw-text-blue-400"></i> COD Tiers</a>
                        <a class="toc-link" href="#city-rules"><i class="fas fa-city tw-w-4 tw-text-teal-400"></i> City-Specific Rules</a>
                        <a class="toc-link" href="#adjustments"><i class="fas fa-sliders-h tw-w-4 tw-text-violet-400"></i> Adjustments</a>
                        <a class="toc-link" href="#verify"><i class="fas fa-search tw-w-4 tw-text-rose-400"></i> Verification Queries</a>
                        <a class="toc-link" href="#verify"><i class="fas fa-microscope tw-w-4 tw-text-amber-400"></i> Cross-Verification</a>
                    </nav>
                </div>
            </div>

            <!-- ── Main Content ─────────────────────────────────────────── -->
            <div class="tw-flex-1 tw-min-w-0 tw-space-y-6">

                <!-- ══ OVERVIEW ══════════════════════════════════════════ -->
                <section id="overview" class="tw-bg-white tw-rounded-2xl tw-border tw-border-slate-200 tw-shadow-sm tw-p-6">
                    <div class="tw-flex tw-items-center tw-gap-3 tw-mb-4">
                        <div class="tw-w-9 tw-h-9 tw-rounded-xl tw-bg-slate-100 tw-flex tw-items-center tw-justify-center">
                            <i class="fas fa-layer-group tw-text-slate-600"></i>
                        </div>
                        <h2 class="tw-text-lg tw-font-black tw-text-slate-800 tw-mb-0">Overview — How Commission is Created</h2>
                    </div>
                    <p class="tw-text-sm tw-text-slate-600 tw-leading-relaxed tw-mb-4">
                        Employee commission is calculated <strong>automatically every month</strong> in <strong>5 sequential steps</strong>.
                        Data is first pulled from multiple external servers (billing, OPS) into staging tables, then consolidated into a final
                        <strong>per-employee summary</strong> in <code class="tw-bg-slate-100 tw-px-1.5 tw-py-0.5 tw-rounded tw-text-xs tw-font-mono">hr_commissionprocess</code>.
                    </p>
                    <div class="tw-grid tw-grid-cols-1 sm:tw-grid-cols-5 tw-gap-2">
                        @{
                            var steps = new[] {
                                ("1","Cash","bg-emerald-500","Cash Commission","billing_details → hr_cash_consignments"),
                                ("2","COD","bg-blue-500","COD Commission","lcs_db.arival → hr_cod_consignments"),
                                ("3","OLE","bg-orange-500","OverLand Commission","billing_download → hr_olecommissionprocess"),
                                ("4","RCod","bg-pink-500","Return COD","lcs_db.arival → hr_codreturncommissionprocess"),
                                ("5","Master","bg-indigo-600","Master Rollup","All above → hr_commissionprocess"),
                            };
                        }
                        @foreach (var s in steps)
                        {
                            <div class="tw-rounded-xl tw-border tw-border-slate-200 tw-p-3 tw-text-center">
                                <div class="tw-w-8 tw-h-8 tw-rounded-full @s.Item3 tw-text-white tw-font-black tw-text-sm tw-flex tw-items-center tw-justify-center tw-mx-auto tw-mb-2">@s.Item1</div>
                                <div class="tw-text-xs tw-font-bold tw-text-slate-700">@s.Item4</div>
                                <div class="tw-text-[10px] tw-text-slate-400 tw-mt-1 tw-leading-tight">@s.Item5</div>
                            </div>
                        }
                    </div>
                    <div class="tw-mt-4 tw-p-3 tw-bg-amber-50 tw-border tw-border-amber-200 tw-rounded-xl tw-text-sm tw-text-amber-800">
                        <i class="fas fa-exclamation-triangle tw-mr-2 tw-text-amber-500"></i>
                        <strong>Important:</strong> Steps 1–4 MUST complete successfully before Step 5 can run.
                        Step 5 reads the output of all previous steps.
                    </div>
                </section>

                <!-- ══ SERVERS & DATABASES ════════════════════════════════ -->
                <section id="servers" class="tw-bg-white tw-rounded-2xl tw-border tw-border-slate-200 tw-shadow-sm tw-p-6">
                    <div class="tw-flex tw-items-center tw-gap-3 tw-mb-4">
                        <div class="tw-w-9 tw-h-9 tw-rounded-xl tw-bg-blue-100 tw-flex tw-items-center tw-justify-center">
                            <i class="fas fa-server tw-text-blue-600"></i>
                        </div>
                        <h2 class="tw-text-lg tw-font-black tw-text-slate-800 tw-mb-0">Servers &amp; Databases Used</h2>
                    </div>
                    <div class="tw-overflow-x-auto">
                        <table class="rate-table tw-w-full">
                            <thead>
                                <tr>
                                    <th>Connection Key</th>
                                    <th>Server / Role</th>
                                    <th>Databases</th>
                                    <th>Used In</th>
                                    <th>Direction</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><code class="tw-bg-slate-100 tw-px-1.5 tw-py-0.5 tw-rounded tw-text-xs tw-font-mono">DefaultConnection</code></td>
                                    <td><span class="tw-font-semibold tw-text-slate-700">HR Server</span><br><span class="tw-text-[11px] tw-text-slate-400">Main HR database</span></td>
                                    <td><span class="db-badge tw-bg-violet-100 tw-text-violet-700">lcs_hr</span></td>
                                    <td>All Steps (output/staging)</td>
                                    <td><span class="step-pill tw-bg-green-100 tw-text-green-700"><i class="fas fa-arrow-down"></i> Write (Destination)</span></td>
                                </tr>
                                <tr>
                                    <td><code class="tw-bg-slate-100 tw-px-1.5 tw-py-0.5 tw-rounded tw-text-xs tw-font-mono">LHR_Billing</code></td>
                                    <td><span class="tw-font-semibold tw-text-slate-700">Billing Server</span><br><span class="tw-text-[11px] tw-text-slate-400">Parcel billing records</span></td>
                                    <td><span class="db-badge tw-bg-blue-100 tw-text-blue-700">lcs_billing</span> <span class="db-badge tw-bg-blue-100 tw-text-blue-700">lcs</span> <span class="db-badge tw-bg-blue-100 tw-text-blue-700">lcs_setup</span></td>
                                    <td>Step 1 (Cash), Step 3 (OLE)</td>
                                    <td><span class="step-pill tw-bg-blue-100 tw-text-blue-700"><i class="fas fa-arrow-up"></i> Read (Source)</span></td>
                                </tr>
                                <tr>
                                    <td><code class="tw-bg-slate-100 tw-px-1.5 tw-py-0.5 tw-rounded tw-text-xs tw-font-mono">MIS</code></td>
                                    <td><span class="tw-font-semibold tw-text-slate-700">MIS / Download Server</span><br><span class="tw-text-[11px] tw-text-slate-400">OverLand billing data</span></td>
                                    <td><span class="db-badge tw-bg-orange-100 tw-text-orange-700">lcs_billing_download</span></td>
                                    <td>Step 3 (OverLand)</td>
                                    <td><span class="step-pill tw-bg-blue-100 tw-text-blue-700"><i class="fas fa-arrow-up"></i> Read (Source)</span></td>
                                </tr>
                                <tr>
                                    <td><code class="tw-bg-slate-100 tw-px-1.5 tw-py-0.5 tw-rounded tw-text-xs tw-font-mono">Central_OPS</code></td>
                                    <td><span class="tw-font-semibold tw-text-slate-700">Operations Server</span><br><span class="tw-text-[11px] tw-text-slate-400">Delivery arrival records, COD</span></td>
                                    <td><span class="db-badge tw-bg-pink-100 tw-text-pink-700">lcs_db</span> <span class="db-badge tw-bg-pink-100 tw-text-pink-700">cod_payment_receive</span></td>
                                    <td>Step 2 (COD), Step 4 (Return COD), Step 1 (VAS)</td>
                                    <td><span class="step-pill tw-bg-blue-100 tw-text-blue-700"><i class="fas fa-arrow-up"></i> Read (Source)</span></td>
                                </tr>
                                <tr>
                                    <td><code class="tw-bg-slate-100 tw-px-1.5 tw-py-0.5 tw-rounded tw-text-xs tw-font-mono">Central_OPSNew</code></td>
                                    <td><span class="tw-font-semibold tw-text-slate-700">Bank Transaction Server</span><br><span class="tw-text-[11px] tw-text-slate-400">E-com bank deposit dates</span></td>
                                    <td><span class="db-badge tw-bg-pink-100 tw-text-pink-700">ecom_*</span></td>
                                    <td>Step 2 (COD deposit date backfill)</td>
                                    <td><span class="step-pill tw-bg-blue-100 tw-text-blue-700"><i class="fas fa-arrow-up"></i> Read (Source)</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </section>

                <!-- ══ COMMISSION PERIOD ══════════════════════════════════ -->
                <section id="period" class="tw-bg-white tw-rounded-2xl tw-border tw-border-purple-200 tw-shadow-sm tw-p-6">
                    <div class="tw-flex tw-items-center tw-gap-3 tw-mb-4">
                        <div class="tw-w-9 tw-h-9 tw-rounded-xl tw-bg-purple-100 tw-flex tw-items-center tw-justify-center">
                            <i class="fas fa-calendar-alt tw-text-purple-600"></i>
                        </div>
                        <h2 class="tw-text-lg tw-font-black tw-text-slate-800 tw-mb-0">Commission Period — How Dates Work</h2>
                    </div>
                    <p class="tw-text-sm tw-text-slate-600 tw-mb-4 tw-leading-relaxed">
                        Commission is processed for a <strong>calendar month</strong>, but the actual data window is:
                    </p>
                    <div class="tw-grid tw-grid-cols-1 sm:tw-grid-cols-3 tw-gap-4 tw-mb-4">
                        <div class="tw-bg-purple-50 tw-border tw-border-purple-200 tw-rounded-xl tw-p-4 tw-text-center">
                            <div class="tw-text-xs tw-font-bold tw-text-purple-500 tw-uppercase tw-tracking-wider tw-mb-1">Start Date</div>
                            <div class="tw-text-xl tw-font-black tw-text-purple-700">21st</div>
                            <div class="tw-text-sm tw-text-purple-600">of the PREVIOUS month</div>
                        </div>
                        <div class="tw-flex tw-items-center tw-justify-center">
                            <i class="fas fa-arrow-right tw-text-2xl tw-text-slate-300"></i>
                        </div>
                        <div class="tw-bg-purple-50 tw-border tw-border-purple-200 tw-rounded-xl tw-p-4 tw-text-center">
                            <div class="tw-text-xs tw-font-bold tw-text-purple-500 tw-uppercase tw-tracking-wider tw-mb-1">End Date</div>
                            <div class="tw-text-xl tw-font-black tw-text-purple-700">20th</div>
                            <div class="tw-text-sm tw-text-purple-600">of the SELECTED month</div>
                        </div>
                    </div>
                    <div class="tw-overflow-x-auto">
                        <table class="rate-table tw-w-full">
                            <thead><tr><th>Commission Month Selected</th><th>Data Start (From)</th><th>Data End (To)</th></tr></thead>
                            <tbody>
                                <tr><td class="tw-font-semibold">January 2026</td><td class="tw-text-emerald-700 tw-font-semibold">21 December 2025</td><td class="tw-text-rose-600 tw-font-semibold">20 January 2026</td></tr>
                                <tr><td class="tw-font-semibold">February 2026</td><td class="tw-text-emerald-700 tw-font-semibold">21 January 2026</td><td class="tw-text-rose-600 tw-font-semibold">20 February 2026</td></tr>
                                <tr><td class="tw-font-semibold">March 2026</td><td class="tw-text-emerald-700 tw-font-semibold">21 February 2026</td><td class="tw-text-rose-600 tw-font-semibold">20 March 2026</td></tr>
                                <tr><td class="tw-font-semibold">April 2026</td><td class="tw-text-emerald-700 tw-font-semibold">21 March 2026</td><td class="tw-text-rose-600 tw-font-semibold">20 April 2026</td></tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="tw-mt-3 tw-p-3 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl">
                        <p class="tw-text-xs tw-text-slate-600 tw-mb-1 tw-font-semibold">Code formula (C#):</p>
                        <code class="guide-code tw-block">fromDate = new DateTime(year, month, <span class="nm">21</span>).AddMonths(<span class="nm">-1</span>);
toDate   = new DateTime(year, month, <span class="nm">20</span>);</code>
                    </div>
                </section>

                <!-- ══ STEP 1: CASH COMMISSION ════════════════════════════ -->
                <section id="step1" class="tw-bg-white tw-rounded-2xl tw-border tw-border-emerald-200 tw-shadow-sm tw-p-6">
                    <div class="tw-flex tw-items-center tw-gap-3 tw-mb-4">
                        <div class="tw-w-9 tw-h-9 tw-rounded-xl tw-bg-emerald-500 tw-flex tw-items-center tw-justify-center">
                            <span class="tw-text-white tw-font-black">1</span>
                        </div>
                        <div>
                            <h2 class="tw-text-lg tw-font-black tw-text-slate-800 tw-mb-0">Step 1 — Cash Commission</h2>
                            <p class="tw-text-xs tw-text-slate-500 tw-mb-0">Commission for couriers who physically delivered cash/retail parcels</p>
                        </div>
                    </div>

                    <!-- Flow boxes -->
                    <div class="tw-flex tw-items-center tw-gap-2 tw-flex-wrap tw-mb-5">
                        <div class="tw-bg-blue-50 tw-border tw-border-blue-200 tw-rounded-xl tw-p-3 tw-text-center tw-flex-1 tw-min-w-32">
                            <div class="tw-text-[10px] tw-font-bold tw-text-blue-400 tw-uppercase tw-tracking-wider">Source Server</div>
                            <div class="tw-font-bold tw-text-blue-700 tw-text-sm">LHR_Billing</div>
                            <div class="tw-text-[11px] tw-text-blue-500 tw-font-mono">lcs_billing</div>
                        </div>
                        <i class="fas fa-arrow-right tw-text-slate-300"></i>
                        <div class="tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-p-3 tw-text-center tw-flex-1 tw-min-w-40">
                            <div class="tw-text-[10px] tw-font-bold tw-text-slate-400 tw-uppercase tw-tracking-wider">Source Table</div>
                            <div class="tw-font-bold tw-text-slate-700 tw-text-sm tw-font-mono">billing_details</div>
                            <div class="tw-text-[11px] tw-text-slate-500">+ billing_details_hist</div>
                        </div>
                        <i class="fas fa-arrow-right tw-text-slate-300"></i>
                        <div class="tw-bg-emerald-50 tw-border tw-border-emerald-200 tw-rounded-xl tw-p-3 tw-text-center tw-flex-1 tw-min-w-40">
                            <div class="tw-text-[10px] tw-font-bold tw-text-emerald-500 tw-uppercase tw-tracking-wider">Destination (lcs_hr)</div>
                            <div class="tw-font-bold tw-text-emerald-700 tw-text-sm tw-font-mono">hr_cash_consignments</div>
                            <div class="tw-text-[11px] tw-text-emerald-500">hr_vas_incentive_detail</div>
                        </div>
                    </div>

                    <!-- What it does -->
                    <div class="tw-bg-slate-50 tw-rounded-xl tw-p-4 tw-mb-4">
                        <h3 class="tw-text-sm tw-font-bold tw-text-slate-700 tw-mb-2"><i class="fas fa-cogs tw-text-slate-400 tw-mr-2"></i>What this step does (Plain English)</h3>
                        <ol class="tw-text-sm tw-text-slate-600 tw-space-y-1.5 tw-list-decimal tw-list-inside tw-leading-relaxed">
                            <li>Reads <strong>all delivered parcels</strong> from the billing system for the commission period (21st prev → 20th current).</li>
                            <li>Matches each parcel's <strong>courier ID</strong> (<code class="tw-font-mono tw-text-xs tw-bg-slate-200 tw-px-1 tw-rounded">cour_id</code>) to an employee via <code class="tw-font-mono tw-text-xs tw-bg-slate-200 tw-px-1 tw-rounded">hr_employeeroutecode</code>.</li>
                            <li>Calculates commission based on the parcel's <strong>Shipment_ID</strong> (each type has a fixed rate).</li>
                            <li>Also calculates <strong>VAS, MTD, and Insurance</strong> incentives separately.</li>
                            <li>Inserts one row per CN into <code class="tw-font-mono tw-text-xs tw-bg-slate-200 tw-px-1 tw-rounded">hr_cash_consignments</code>.</li>
                        </ol>
                    </div>

                    <!-- Key joining logic -->
                    <div class="tw-bg-emerald-50 tw-border tw-border-emerald-200 tw-rounded-xl tw-p-4 tw-mb-4">
                        <h3 class="tw-text-sm tw-font-bold tw-text-emerald-800 tw-mb-2"><i class="fas fa-link tw-mr-2"></i>Parcel → Employee Join Logic</h3>
                        <div class="tw-text-sm tw-text-emerald-700 tw-space-y-1">
                            <p><strong>billing_details.cour_id</strong> = <strong>hr_employeeroutecode.RouteCode</strong></p>
                            <p>Also must match city: <code class="tw-font-mono tw-text-xs tw-bg-emerald-100 tw-px-1.5 tw-rounded">LPAD(CAST(Station_id AS UNSIGNED), 3, '0') = erc.citycode</code></p>
                            <p>Only <strong>active routes</strong>: <code class="tw-font-mono tw-text-xs tw-bg-emerald-100 tw-px-1.5 tw-rounded">erc.ToDate IS NULL</code></p>
                        </div>
                    </div>

                    <!-- Important tables -->
                    <div class="tw-overflow-x-auto tw-mb-4">
                        <table class="rate-table tw-w-full">
                            <thead><tr><th>Table</th><th>Database</th><th>Role</th><th>Key Columns</th></tr></thead>
                            <tbody>
                                <tr><td class="tw-font-mono tw-text-xs">billing_details</td><td><span class="db-badge tw-bg-blue-100 tw-text-blue-700">lcs_billing</span></td><td>Source — all delivered parcels</td><td>cn_number, Station_id, billing_date, Shipment_id, weight, cour_id, Gross_Amount</td></tr>
                                <tr><td class="tw-font-mono tw-text-xs">billing_details_hist</td><td><span class="db-badge tw-bg-blue-100 tw-text-blue-700">lcs_billing</span></td><td>Historical source (same schema)</td><td>Same as above</td></tr>
