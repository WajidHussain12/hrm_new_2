@model LCS_HR_MVC.Models.UserLocationViewModel
@{
    ViewData["Title"] = "User Location Allocation";
    ViewData["PageTitle"] = "User Location Allocation";
}

@section Styles {
    <link href="~/lib/jquery-ui/jquery-ui.min.css" rel="stylesheet" />
    <style>
        /* Modern Fade Animation */
        @@keyframes slideUp { 
            from { opacity: 0; transform: translateY(15px); } 
            to { opacity: 1; transform: translateY(0); } 
        }
        .animate-main { animation: slideUp 0.4s ease-out; }

        /* Custom Toggle Switch */
        .toggle-switch {
            @@apply tw-relative tw-inline-block tw-w-10 tw-h-5.5;
        }
        .toggle-switch input {
            @@apply tw-opacity-0 tw-w-0 tw-h-0;
        }
        .toggle-slider {
            @@apply tw-absolute tw-cursor-pointer tw-top-0 tw-left-0 tw-right-0 tw-bottom-0 tw-bg-slate-200 tw-transition-all tw-duration-300 tw-rounded-full;
        }
        .toggle-slider:before {
            content: "";
            @@apply tw-absolute tw-h-4 tw-w-4 tw-left-1 tw-bottom-[3px] tw-bg-white tw-transition-all tw-duration-300 tw-rounded-full tw-shadow-sm;
        }
        input:checked + .toggle-slider {
            @@apply tw-bg-amber-400;
        }
        input:focus + .toggle-slider {
            @@apply tw-ring-2 tw-ring-amber-400/50;
        }
        input:checked + .toggle-slider:before {
            @@apply tw-translate-x-[18px];
        }

        /* Detail Scrollbar */
        .custom-scrollbar::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: #f1f5f9;
            border-radius: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }

        /* Modern UI Autocomplete Override */
        .ui-autocomplete {
            @@apply tw-max-h-60 tw-overflow-y-auto tw-rounded-xl tw-border-slate-200 tw-shadow-xl tw-text-sm tw-font-medium tw-font-sans tw-bg-white !important;
            z-index: 1000 !important;
        }
        .ui-menu-item-wrapper {
            @@apply tw-py-2 tw-px-3 tw-transition-colors tw-text-slate-700 !important;
        }
        .ui-menu-item-wrapper.ui-state-active {
            @@apply tw-bg-amber-400 tw-text-slate-900 tw-border-transparent tw-rounded-md tw-font-bold !important;
            margin: 0 !important;
        }
    </style>
}

<div class="tw-p-4 sm:tw-p-6 tw-bg-transparent tw-min-h-screen animate-main">

    <!-- Messages -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-red-50 tw-border tw-border-red-100 tw-rounded-xl tw-text-red-600 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(239,68,68,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-red-100 tw-text-red-500 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0">
                <i class="fas fa-exclamation-triangle tw-text-[10px]"></i>
            </div>
            <span class="tw-pt-0.5">@TempData["ErrorMessage"]</span>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-emerald-50 tw-border tw-border-emerald-100 tw-rounded-xl tw-text-emerald-700 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(16,185,129,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-emerald-100 tw-text-emerald-600 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0">
                <i class="fas fa-check tw-text-[10px]"></i>
            </div>
            <span class="tw-pt-0.5">@TempData["SuccessMessage"]</span>
        </div>
    }

    <div class="tw-flex tw-flex-col sm:tw-flex-row sm:tw-items-end tw-justify-between tw-gap-4 tw-mb-8">
        <div>
            <nav class="tw-flex tw-items-center tw-gap-2.5 tw-text-[11px] tw-font-bold tw-text-slate-400 tw-mb-2 tw-uppercase tw-tracking-widest">
                <div class="tw-flex tw-items-center tw-gap-1.5 hover:tw-text-[#eab308] tw-transition-colors tw-cursor-pointer">
                    <i class="fas fa-shield-alt tw-text-[10px] tw-text-slate-300"></i>
                    <span>Admin Utilities</span>
                </div>
                <i class="fas fa-chevron-right tw-text-[8px] tw-text-slate-300"></i> 
                <span class="tw-text-slate-600 tw-bg-white tw-px-2 tw-py-0.5 tw-rounded-md tw-border tw-border-slate-200 tw-shadow-sm">Security Matrix</span>
            </nav>
            <div class="tw-flex tw-flex-col">
                <h1 class="tw-text-3xl tw-font-black tw-text-slate-900 tw-leading-tight tw-tracking-tight">User Location Allocation</h1>
                <div class="tw-h-1.5 tw-w-10 tw-bg-gradient-to-r tw-from-[#f5c518] tw-to-transparent tw-rounded-full tw-mt-1"></div>
            </div>
            <p class="tw-text-slate-500 tw-text-sm tw-font-medium tw-mt-3 tw-leading-relaxed">Control and bind geographical data scopes mapped per user login account.</p>
        </div>
    </div>

    <!-- Main Wrapper Form -->
    <form asp-controller="Admin" asp-action="UserLocation" method="post" id="userLocForm">
        <div class="tw-grid lg:tw-grid-cols-12 tw-gap-6 xl:tw-gap-8 align-top">
            
            <!-- Left Panel: User Info & Actions -->
            <div class="lg:tw-col-span-5 xl:tw-col-span-4">
                <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-sticky tw-top-24">
                    <div class="tw-absolute tw-top-[-50px] tw-right-[-50px] tw-w-40 tw-h-40 tw-bg-amber-100/40 tw-blur-2xl tw-rounded-full tw-pointer-events-none z-0"></div>

                    <div class="tw-relative tw-z-10 tw-p-6 tw-bg-gradient-to-r tw-from-slate-900 tw-to-slate-800">
                        <h3 class="tw-text-amber-400 tw-font-black tw-text-xs tw-uppercase tw-tracking-[0.2em] tw-flex tw-items-center tw-gap-2">
                            <div class="tw-w-6 tw-h-6 tw-bg-white/10 tw-rounded-md tw-flex tw-items-center tw-justify-center">
                                <i class="fas fa-user-lock"></i>
                            </div>
                            Target Credentials
                        </h3>
                    </div>

                    <div class="tw-relative tw-z-10 tw-p-7 tw-space-y-5">
                        
                        <!-- Search User -->
                        <div>
                            <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Locate Account <span class="tw-text-red-500">*</span></label>
                            <div class="tw-relative">
                                <i class="fas fa-search tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-amber-500 tw-text-sm"></i>
                                <input type="text" id="UserSearch" placeholder="Look up account..." 
                                       class="tw-w-full tw-pl-10 tw-pr-3 tw-py-3 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-indigo-700 placeholder-slate-400 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm" />
                            </div>
                            <input type="hidden" asp-for="UserID" id="UserID" />
                            <span asp-validation-for="UserID" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                        </div>

                         <!-- Selected User -->
                        <div>
                            <label class="tw-block tw-text-[10px] tw-font-black tw-text-slate-500 tw-uppercase tw-tracking-wide tw-mb-1.5">Resolved Profile Details</label>
                            <div class="tw-flex tw-items-center tw-bg-slate-50 tw-rounded-xl tw-px-3 tw-py-3 tw-border tw-border-slate-200 tw-shadow-inner opacity-90">
                                <i class="fas fa-id-badge tw-text-slate-400 tw-mr-2 tw-text-sm"></i>
                                <input type="text" asp-for="UserDescription" id="UserDescription" disabled 
                                       class="tw-bg-transparent tw-w-full tw-text-sm tw-font-semibold tw-text-slate-700 tw-outline-none tw-cursor-not-allowed" placeholder="Awaiting selection..." />
                            </div>
                        </div>

                        <div class="tw-pt-3 tw-pb-2 tw-border-t tw-border-slate-100"></div>

                        <!-- Buttons block -->
                        <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                            <button type="submit" name="action" value="Save" id="btnSave" 
                                    class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-text-slate-900 tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase tw-shadow-[0_8px_20px_rgba(245,197,24,0.25)] hover:tw-shadow-[0_8px_25px_rgba(245,197,24,0.35)] hover:tw--translate-y-0.5 tw-transition-all disabled:tw-opacity-50 disabled:tw-cursor-not-allowed">
                                <i class="fas fa-save tw-text-sm"></i> Commit
                            </button>
                            <button type="submit" name="action" value="Reset" id="btnReset" formnovalidate
                                    class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-slate-900 tw-text-white tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase hover:tw-bg-slate-800 hover:tw-shadow-[0_8px_20px_rgba(15,23,42,0.2)] hover:tw--translate-y-0.5 tw-transition-all">
                                <i class="fas fa-undo-alt tw-text-sm"></i> Refresh
                            </button>
                        </div>
                        <div class="tw-p-4 tw-rounded-xl tw-bg-indigo-50/50 tw-border tw-border-indigo-100 tw-text-[11px] tw-font-medium tw-text-indigo-800 tw-leading-relaxed">
                            <i class="fas fa-info-circle tw-text-indigo-500 tw-mr-1"></i> Saving the profile overwrites all pre-existing location arrays bound to this user ID globally.
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Panel: Data Matrix -->
            <div class="lg:tw-col-span-7 xl:tw-col-span-8">
                <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-relative tw-flex tw-flex-col tw-h-full">
                    
                    <!-- Table Header Ribbon -->
                    <div class="tw-relative tw-z-10 tw-px-6 tw-py-5 tw-border-b tw-border-slate-100 tw-flex tw-flex-col sm:tw-flex-row sm:tw-items-center tw-justify-between tw-gap-4 tw-bg-slate-50/80">
                        <div class="tw-flex tw-items-center tw-gap-4">
                            <div class="tw-w-10 tw-h-10 tw-rounded-xl tw-bg-gradient-to-br tw-from-emerald-500 tw-to-emerald-600 tw-text-white tw-flex tw-items-center tw-justify-center tw-shadow-[0_4px_10px_rgba(16,185,129,0.3)]">
                                <i class="fas fa-map-marked-alt tw-text-lg"></i>
                            </div>
                            <div>
                                <h2 class="tw-font-black tw-text-base tw-text-slate-800 tw-tracking-tight">Mapped Zones</h2>
                                <p class="tw-text-[10px] tw-font-bold tw-text-slate-400 tw-uppercase tw-tracking-widest">Active Security Policy</p>
                            </div>
                        </div>

                        <!-- Load All Toggle -->
                        <div class="tw-flex tw-items-center tw-gap-3 tw-bg-white tw-border tw-border-slate-200 tw-px-4 tw-py-2 tw-rounded-xl tw-shadow-sm">
                            <label for="chkLoadAll" class="tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-cursor-pointer">Auto-Load All</label>
                            <label class="toggle-switch">
                                <input type="checkbox" id="chkLoadAll" title="Load All Locations" />
                                <span class="toggle-slider"></span>
                            </label>
                        </div>
                    </div>

                    <!-- Quick Attach Builder Row -->
                     <div class="tw-p-4 tw-bg-white tw-border-b tw-border-slate-100 tw-flex tw-flex-col sm:tw-flex-row tw-gap-3 tw-items-center">
                        <div class="tw-flex-1 tw-relative tw-w-full">
                           <i class="fas fa-map-marker-alt tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400"></i>
                           <input type="text" id="NewLocationSearch" class="tw-w-full tw-pl-9 tw-pr-3 tw-py-2.5 tw-input tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-medium tw-text-slate-800 placeholder-slate-400 focus:tw-bg-white focus:tw-border-emerald-500 focus:tw-ring-2 focus:tw-ring-emerald-500/20 tw-outline-none tw-transition-all" placeholder="Search branch to attach..." />
                        </div>
                        <input type="text" id="NewLocationCode" disabled class="tw-w-full sm:tw-w-28 tw-px-3 tw-py-2.5 tw-bg-slate-100 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-mono tw-font-bold tw-text-slate-500 tw-text-center tw-outline-none" placeholder="ID Code" />
                        <button type="button" id="btnAddLocation" class="tw-w-full sm:tw-w-auto tw-flex tw-items-center tw-justify-center tw-gap-2 tw-px-6 tw-py-2.5 tw-bg-slate-900 tw-text-emerald-400 tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase hover:tw-bg-slate-800 tw-transition-colors">
                            <i class="fas fa-plus"></i> Bind
                        </button>
                    </div>

                    <!-- Table Region -->
                    <div class="tw-flex-1 tw-overflow-x-auto custom-scrollbar tw-relative tw-bg-white">
                        <table class="tw-w-full tw-text-left tw-whitespace-nowrap">
                            <thead class="tw-bg-slate-50 tw-border-b tw-border-slate-100 sticky top-0 z-10">
                                <tr>
                                    <th class="tw-py-3 tw-px-5 tw-text-[10px] tw-font-black tw-text-slate-500 tw-uppercase tw-tracking-widest tw-w-16 tw-text-center">Action</th>
                                    <th class="tw-py-3 tw-px-5 tw-text-[10px] tw-font-black tw-text-slate-500 tw-uppercase tw-tracking-widest">Regional Node</th>
                                    <th class="tw-py-3 tw-px-5 tw-text-[10px] tw-font-black tw-text-slate-500 tw-uppercase tw-tracking-widest">Sys ID</th>
                                </tr>
                            </thead>
                            <tbody id="locationGridBody" class="tw-divide-y tw-divide-slate-50">
                                @for (int i = 0; i < Model.Locations.Count; i++)
                                {
                                    <tr class="hover:tw-bg-amber-50/20 tw-transition-colors group" data-index="@i">
                                        <td class="tw-py-3 tw-px-5 tw-text-center">
                                            <button type="button" class="tw-w-7 tw-h-7 tw-rounded-lg tw-bg-red-50 tw-text-red-500 hover:tw-bg-red-500 hover:tw-text-white tw-transition-colors tw-inline-flex tw-items-center tw-justify-center" onclick="removeRow(this)" title="Revoke Access">
                                                <i class="fas fa-minus tw-text-xs"></i>
                                            </button>
                                        </td>
                                        <td class="tw-py-3 tw-px-5 tw-font-semibold tw-text-slate-800 tw-text-sm">
                                            @Model.Locations[i].FullName
                                            <input type="hidden" name="Locations[@i].FullName" value="@Model.Locations[i].FullName" class="loc-fullname" />
                                        </td>
                                        <td class="tw-py-3 tw-px-5">
                                            <span class="tw-font-mono tw-font-bold tw-text-slate-600 tw-bg-slate-100 tw-border tw-border-slate-200 tw-px-2 tw-py-1 tw-rounded-md tw-text-xs">@Model.Locations[i].Code</span>
                                            <input type="hidden" name="Locations[@i].Code" value="@Model.Locations[i].Code" class="loc-code" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        <!-- Empty State Indicator via CSS if tbody maps no items-->
                        <div id="NoDataState" class="@(Model.Locations.Count > 0 ? "tw-hidden" : "") tw-p-10 tw-text-center tw-text-slate-400 tw-flex tw-flex-col tw-items-center">
                            <i class="far fa-folder-open tw-text-4xl tw-mb-3 tw-opacity-50"></i>
                            <p class="tw-text-sm tw-font-medium">No locations assigned.</p>
                            <p class="tw-text-[11px] tw-mt-1">Add nodes via Quick Attach or Load All.</p>
                        </div>

                    </div>
                </div>
            </div>

        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/lib/jquery-ui/jquery-ui.min.js"></script>
    <script type="text/javascript">
        $(document).ready(function () {
             
            // Check Empty state toggle
            function toggleEmptyState() {
                if ($('#locationGridBody tr').length === 0) {
                    $('#NoDataState').removeClass('tw-hidden');
                } else {
                    $('#NoDataState').addClass('tw-hidden');
                }
            }

            var currentUserId = $('#UserID').val();
            var currentUserDesc = $('#UserDescription').val();
            if (currentUserId && currentUserDesc) {
                $('#UserSearch').val(currentUserId + ' - ' + currentUserDesc);
            }

            $("#UserSearch").autocomplete({
                source: function (request, response) {
                    $.ajax({
                        url: '@Url.Action("GetUsers", "Admin")',
                        type: "GET",
                        dataType: "json",
                        data: { term: request.term },
                        success: function (data) {
                            response($.map(data, function (item) {
                                return { label: item.label, value: item.label, id: item.value, desc: item.desc };
                            }));
                        }
                    });
                },
                select: function (event, ui) {
                    $("#UserSearch").val(ui.item.label);
                    $("#UserID").val(ui.item.id);
                    $("#UserDescription").val(ui.item.desc);
                    window.location.href = '@Url.Action("UserLocation", "Admin")?userId=' + ui.item.id;
                    return false;
                },
                minLength: 1
            });

            $("#NewLocationSearch").autocomplete({
                source: function (request, response) {
                    $.ajax({
                        url: '@Url.Action("GetLocations", "Admin")',
                        type: "GET",
                        dataType: "json",
                        data: { term: request.term },
                        success: function (data) {
                            response($.map(data, function (item) {
                                return { label: item.label, value: item.label, id: item.value };
                            }));
                        }
                    });
                },
                select: function (event, ui) {
                    $("#NewLocationSearch").val(ui.item.label);
                    $("#NewLocationCode").val(ui.item.id);
                    return false;
                },
                minLength: 1
            });

            $('#btnAddLocation').click(function () {
                var locName = $('#NewLocationSearch').val();
                var locCode = $('#NewLocationCode').val();
                if (locName && locCode) {
                    var exists = false;
                    $('.loc-code').each(function () {
                        if ($(this).val() === locCode) {
                            exists = true;
                        }
                    });

                    if (exists) {
                        alert("Location already exists in list.");
                        return;
                    }

                    var index = $('#locationGridBody tr').length;
                    var row = `
                        <tr class="hover:tw-bg-amber-50/20 tw-transition-colors group animate-main" data-index="${index}">
                            <td class="tw-py-3 tw-px-5 tw-text-center">
                                <button type="button" class="tw-w-7 tw-h-7 tw-rounded-lg tw-bg-red-50 tw-text-red-500 hover:tw-bg-red-500 hover:tw-text-white tw-transition-colors tw-inline-flex tw-items-center tw-justify-center" onclick="removeRow(this)" title="Revoke Access">
                                    <i class="fas fa-minus tw-text-xs"></i>
                                </button>
                            </td>
                            <td class="tw-py-3 tw-px-5 tw-font-semibold tw-text-slate-800 tw-text-sm">
                                ${locName}
                                <input type="hidden" name="Locations[${index}].FullName" value="${locName}" class="loc-fullname" />
                            </td>
                            <td class="tw-py-3 tw-px-5">
                                <span class="tw-font-mono tw-font-bold tw-text-slate-600 tw-bg-slate-100 tw-border tw-border-slate-200 tw-px-2 tw-py-1 tw-rounded-md tw-text-xs">${locCode}</span>
                                <input type="hidden" name="Locations[${index}].Code" value="${locCode}" class="loc-code" />
                            </td>
                        </tr>
                    `;
                    $('#locationGridBody').append(row);

                    $('#NewLocationSearch').val('');
                    $('#NewLocationCode').val('');
                    toggleEmptyState();
                }
            });

            $('#chkLoadAll').change(function () {
                if ($(this).is(':checked')) {
                    $.ajax({
                        url: '@Url.Action("GetAllLocations", "Admin")',
                        type: "GET",
                        success: function (data) {
                            $('#locationGridBody').empty();
                            $.each(data, function (index, item) {
                                var row = `
                                    <tr class="hover:tw-bg-amber-50/20 tw-transition-colors group animate-main" data-index="${index}">
                                        <td class="tw-py-3 tw-px-5 tw-text-center">
                                            <button type="button" class="tw-w-7 tw-h-7 tw-rounded-lg tw-bg-red-50 tw-text-red-500 hover:tw-bg-red-500 hover:tw-text-white tw-transition-colors tw-inline-flex tw-items-center tw-justify-center" onclick="removeRow(this)" title="Revoke Access">
                                                <i class="fas fa-minus tw-text-xs"></i>
                                            </button>
                                        </td>
                                        <td class="tw-py-3 tw-px-5 tw-font-semibold tw-text-slate-800 tw-text-sm">
                                            ${item.fullName}
                                            <input type="hidden" name="Locations[${index}].FullName" value="${item.fullName}" class="loc-fullname" />
                                        </td>
                                        <td class="tw-py-3 tw-px-5">
                                            <span class="tw-font-mono tw-font-bold tw-text-slate-600 tw-bg-slate-100 tw-border tw-border-slate-200 tw-px-2 tw-py-1 tw-rounded-md tw-text-xs">${item.code}</span>
                                            <input type="hidden" name="Locations[${index}].Code" value="${item.code}" class="loc-code" />
                                        </td>
                                    </tr>
                                `;
                                $('#locationGridBody').append(row);
                            });
                            toggleEmptyState();
                        }
                    });
                } else {
                    $('#locationGridBody').empty();
                    toggleEmptyState();
                }
            });

            // Initialize correct state on load
            toggleEmptyState();
        });

        function removeRow(btn) {
            $(btn).closest('tr').remove();
            $('#locationGridBody tr').each(function (index) {
                $(this).find('.loc-fullname').attr('name', 'Locations[' + index + '].FullName');
                $(this).find('.loc-code').attr('name', 'Locations[' + index + '].Code');
            });
            
            if ($('#locationGridBody tr').length === 0) {
                $('#NoDataState').removeClass('tw-hidden');
            }
        }
    </script>
}
