@model LCS_HR_MVC.Models.Support.AttendanceLogViewerViewModel
@{
    ViewData["Title"] = "Attendance Log Viewer (Karachi)";
    ViewData["PageTitle"] = "Attendance Log Viewer";
}

@section Styles {
    <link href="~/lib/jquery-ui/jquery-ui.min.css" rel="stylesheet" />
    <style>
        /* Modern Fade Animation */
        @@keyframes slideUp { 
            from { opacity: 0; transform: translateY(15px); } 
            to { opacity: 1; transform: translateY(0); } 
        }
        .animate-main { animation: slideUp 0.4s ease-out; }

        /* Modern UI Autocomplete Override */
        .ui-autocomplete {
            @@apply tw-max-h-60 tw-overflow-y-auto tw-rounded-xl tw-border-slate-200 tw-shadow-xl tw-text-sm tw-font-medium tw-font-sans tw-bg-white !important;
            z-index: 1000 !important;
        }
        .ui-menu-item-wrapper {
            @@apply tw-py-2 tw-px-3 tw-transition-colors tw-text-slate-700 !important;
        }
        .ui-menu-item-wrapper.ui-state-active {
            @@apply tw-bg-amber-400 tw-text-slate-900 tw-border-transparent tw-rounded-md tw-font-bold !important;
            margin: 0 !important;
        }
    </style>
}

<div class="tw-p-4 sm:tw-p-6 tw-bg-transparent tw-min-h-screen animate-main">

    <!-- Messages / Source File Warning -->
    @if (!Model.SourceFileExists)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-amber-50 tw-border tw-border-amber-100 tw-rounded-xl tw-text-amber-800 tw-text-sm tw-font-bold tw-shadow-sm">
            <div class="tw-w-6 tw-h-6 tw-bg-amber-100 tw-text-amber-600 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0">
                <i class="fas fa-exclamation-circle tw-text-[10px]"></i>
            </div>
            <div class="tw-pt-0.5">
                Legacy source file <code>att2000.mdb</code> is missing. 
                <p class="tw-mt-1 tw-text-xs tw-font-medium tw-opacity-80">Target path: <code>@Model.SourceFilePath</code></p>
            </div>
        </div>
    }

    <!-- Header Map -->
    <div class="tw-flex tw-flex-col sm:tw-flex-row sm:tw-items-end tw-justify-between tw-gap-4 tw-mb-8">
        <div>
            <nav class="tw-flex tw-items-center tw-gap-2.5 tw-text-[11px] tw-font-bold tw-text-slate-400 tw-mb-2 tw-uppercase tw-tracking-widest">
                <div class="tw-flex tw-items-center tw-gap-1.5 hover:tw-text-[#eab308] tw-transition-colors tw-cursor-pointer">
                    <i class="fas fa-tools tw-text-[10px] tw-text-slate-300"></i>
                    <span>Support Utilities</span>
                </div>
                <i class="fas fa-chevron-right tw-text-[8px] tw-text-slate-300"></i> 
                <span class="tw-text-slate-600 tw-bg-white tw-px-2 tw-py-0.5 tw-rounded-md tw-border tw-border-slate-200 tw-shadow-sm">Log Viewer</span>
            </nav>
            <div class="tw-flex tw-flex-col">
                <h1 class="tw-text-3xl tw-font-black tw-text-slate-900 tw-leading-tight tw-tracking-tight">Attendance Log Export</h1>
                <div class="tw-h-1.5 tw-w-10 tw-bg-gradient-to-r tw-from-[#f5c518] tw-to-transparent tw-rounded-full tw-mt-1"></div>
            </div>
            <p class="tw-text-slate-500 tw-text-sm tw-font-medium tw-mt-3 tw-leading-relaxed">Access and export raw check-in/out data points from the legacy MDB architecture.</p>
        </div>
    </div>

    <div class="tw-max-w-4xl tw-mx-auto">
        <!-- Main Form Panel -->
        <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-relative"
             id="attendance-log-viewer"
             data-search-url="@Url.Action("SearchAttendanceLogEmployees", "Support")"
             data-working-year="@Model.WorkingYear"
             data-working-month="@Model.WorkingMonth">
            
            <div class="tw-absolute tw-top-[-50px] tw-right-[-50px] tw-w-40 tw-h-40 tw-bg-indigo-100/40 tw-blur-2xl tw-rounded-full tw-pointer-events-none"></div>

            <div class="tw-p-6 tw-bg-gradient-to-r tw-from-slate-900 tw-to-slate-800 tw-relative tw-z-10">
                <h3 class="tw-text-amber-400 tw-font-black tw-text-xs tw-uppercase tw-tracking-[0.2em] tw-flex tw-items-center tw-gap-2">
                    <div class="tw-w-6 tw-h-6 tw-bg-white/10 tw-rounded-md tw-flex tw-items-center tw-justify-center">
                        <i class="fas fa-file-export"></i>
                    </div>
                    Export Protocol
                </h3>
            </div>

            <form asp-action="AttLogViewer" method="post" id="attendanceLogForm" class="tw-p-7 tw-space-y-6 tw-relative tw-z-10">
                @Html.AntiForgeryToken()
                
                <div asp-validation-summary="ModelOnly" class="tw-mb-4 tw-p-4 tw-bg-red-50 tw-border tw-border-red-100 tw-rounded-xl tw-text-red-600 tw-text-xs tw-font-bold"></div>

                <div class="tw-grid md:tw-grid-cols-[1fr_auto] tw-gap-4">
                    <!-- Employee Picker -->
                    <div>
                        <label asp-for="EmployeeDescription" class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Targeted Personnel</label>
                        <div class="tw-relative">
                            <i class="fas fa-user-tag tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-sm"></i>
                            <input type="text" asp-for="EmployeeDescription" id="txtEmployeeDescription" placeholder="Search wildcard '%'" 
                                   class="tw-w-full tw-pl-10 tw-pr-3 tw-py-3 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm" />
                        </div>
                        <span asp-validation-for="EmployeeDescription" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                    </div>

                    <!-- Emp Code -->
                    <div>
                        <label asp-for="EmpNo" class="tw-block tw-text-[10px] tw-font-black tw-text-slate-500 tw-uppercase tw-tracking-wide tw-mb-1.5">Pers ID</label>
                        <input type="text" asp-for="EmpNo" id="txtEmployeeCode" readonly 
                               class="tw-w-full md:tw-w-28 tw-px-3 tw-py-3 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-text-center tw-font-mono tw-font-bold tw-text-slate-500 focus:tw-outline-none tw-cursor-not-allowed" />
                        <span asp-validation-for="EmpNo" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                    </div>
                </div>

                <div class="tw-grid sm:tw-grid-cols-2 tw-gap-5">
                    <!-- Temporal Mapping -->
                    <div>
                         <label asp-for="Year" class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Fiscal Year</label>
                         <div class="tw-relative">
                             <i class="fas fa-calendar tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs"></i>
                             <select asp-for="Year" asp-items="Model.Years" id="ddlYear" class="tw-w-full tw-pl-9 tw-pr-3 tw-py-2.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-700 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-appearance-none"
                                     style="background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%2394a3b8%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right 0.75rem top 50%; background-size: 0.65rem auto;">
                             </select>
                         </div>
                    </div>
                    <div>
                         <label asp-for="Month" class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Action Month</label>
                         <div class="tw-relative">
                             <i class="fas fa-clock tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs"></i>
                             <select asp-for="Month" asp-items="Model.Months" id="ddlMonth" class="tw-w-full tw-pl-9 tw-pr-3 tw-py-2.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-700 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-appearance-none"
                               style="background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%2394a3b8%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right 0.75rem top 50%; background-size: 0.65rem auto;">
                             </select>
                         </div>
                         <p class="tw-mt-2 tw-text-[10px] tw-font-black tw-text-slate-400 tw-uppercase tw-tracking-widest">Active System Period: @Model.WorkingMonthName @Model.WorkingYear</p>
                    </div>
                </div>

                <div class="tw-border-t tw-border-slate-100 tw-pt-3 tw-mt-2"></div>

                 <!-- Action Controls -->
                <div class="tw-flex tw-flex-col sm:tw-flex-row tw-gap-4">
                    <button type="submit" name="action" value="Export" 
                            class="tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-text-slate-900 tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase tw-shadow-[0_8px_20px_rgba(245,197,24,0.25)] hover:tw-shadow-[0_8px_25px_rgba(245,197,24,0.35)] hover:tw--translate-y-0.5 tw-transition-all">
                        <i class="fas fa-file-download tw-text-sm"></i> Execute Export
                    </button>
                    <button type="submit" name="action" value="Reset" formnovalidate
                            class="tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-slate-900 tw-text-white tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase hover:tw-bg-slate-800 hover:tw-shadow-[0_8px_20px_rgba(15,23,42,0.2)] hover:tw--translate-y-0.5 tw-transition-all">
                        <i class="fas fa-undo-alt tw-text-sm"></i> Release Form
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/lib/jquery-ui/jquery-ui.min.js"></script>
    <script src="~/js/support/attendance-log-viewer.js"></script>
}
