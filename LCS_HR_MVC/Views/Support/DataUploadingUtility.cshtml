@model LCS_HR_MVC.Models.Support.DataUploadingUtilityViewModel
@{
    ViewData["Title"] = "Data Upload Utility";
    ViewData["PageTitle"] = "Data Upload Utility";
}

@section Styles {
    <style>
        /* Modern Fade Animation */
        @@keyframes slideUp { 
            from { opacity: 0; transform: translateY(15px); } 
            to { opacity: 1; transform: translateY(0); } 
        }
        .animate-main { animation: slideUp 0.4s ease-out; }

        /* Custom Scrollbar */
        .custom-scrollbar::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: #f1f5f9;
            border-radius: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
    </style>
}

<div class="tw-p-4 sm:tw-p-6 tw-bg-transparent tw-min-h-screen animate-main">

    <!-- Messages -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-red-50 tw-border tw-border-red-100 tw-rounded-xl tw-text-red-600 tw-text-sm tw-font-bold tw-shadow-sm">
            <div class="tw-w-6 tw-h-6 tw-bg-red-100 tw-text-red-500 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0">
                <i class="fas fa-exclamation-triangle tw-text-[10px]"></i>
            </div>
            <span class="tw-pt-0.5">@TempData["ErrorMessage"]</span>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-emerald-50 tw-border tw-border-emerald-100 tw-rounded-xl tw-text-emerald-700 tw-text-sm tw-font-bold tw-shadow-sm">
            <div class="tw-w-6 tw-h-6 tw-bg-emerald-100 tw-text-emerald-600 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0">
                <i class="fas fa-check tw-text-[10px]"></i>
            </div>
            <span class="tw-pt-0.5">@TempData["SuccessMessage"]</span>
        </div>
    }

    <!-- Header Map -->
    <div class="tw-flex tw-flex-col sm:tw-flex-row sm:tw-items-end tw-justify-between tw-gap-4 tw-mb-8">
        <div>
            <nav class="tw-flex tw-items-center tw-gap-2.5 tw-text-[11px] tw-font-bold tw-text-slate-400 tw-mb-2 tw-uppercase tw-tracking-widest">
                <div class="tw-flex tw-items-center tw-gap-1.5 hover:tw-text-amber-500 tw-transition-colors tw-cursor-pointer">
                    <i class="fas fa-file-import tw-text-[10px] tw-text-slate-300"></i>
                    <span>Logistics</span>
                </div>
                <i class="fas fa-chevron-right tw-text-[8px] tw-text-slate-300"></i> 
                <span class="tw-text-slate-600 tw-bg-white tw-px-2 tw-py-0.5 tw-rounded-md tw-border tw-border-slate-200 tw-shadow-sm">Data Uploader</span>
            </nav>
            <div class="tw-flex tw-flex-col">
                <h1 class="tw-text-3xl tw-font-black tw-text-slate-900 tw-leading-tight tw-tracking-tight">Bulk Data Nexus</h1>
                <div class="tw-h-1.5 tw-w-10 tw-bg-gradient-to-r tw-from-amber-400 tw-to-transparent tw-rounded-full tw-mt-1"></div>
            </div>
            <p class="tw-text-slate-500 tw-text-sm tw-font-medium tw-mt-3 tw-leading-relaxed">Perform mass systemic injections from validated Excel datasets into the operational grid.</p>
        </div>
    </div>

    <div class="tw-max-w-5xl tw-mx-auto">
        <!-- Main Form Panel -->
        <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-relative">
            <div class="tw-absolute tw-top-[-50px] tw-right-[-50px] tw-w-40 tw-h-40 tw-bg-emerald-100/40 tw-blur-2xl tw-rounded-full tw-pointer-events-none"></div>

            <div class="tw-p-6 tw-bg-gradient-to-r tw-from-emerald-600 tw-to-emerald-700 tw-relative tw-z-10">
                <h3 class="tw-text-white tw-font-black tw-text-xs tw-uppercase tw-tracking-[0.2em] tw-flex tw-items-center tw-gap-2">
                    <div class="tw-w-6 tw-h-6 tw-bg-black/10 tw-rounded-md tw-flex tw-items-center tw-justify-center">
                        <i class="fas fa-upload"></i>
                    </div>
                    Ingestion Controller
                </h3>
            </div>

            <form asp-action="DataUploadingUtility" method="post" enctype="multipart/form-data" class="tw-p-8 tw-space-y-8 tw-relative tw-z-10">
                @Html.AntiForgeryToken()

                <div class="tw-grid lg:tw-grid-cols-2 tw-gap-8">
                    <!-- Left: Connection Meta -->
                    <div class="tw-space-y-6">
                        <div class="tw-bg-slate-50 tw-p-6 tw-rounded-2xl tw-border tw-border-slate-100 tw-space-y-5">
                            <h4 class="tw-text-[10px] tw-font-black tw-text-slate-400 tw-uppercase tw-tracking-[0.2em] tw-mb-2 tw-flex tw-items-center tw-gap-2">
                                <i class="fas fa-link tw-text-emerald-500"></i> Data Connection
                            </h4>
                            
                            <div>
                                <label asp-for="ConnectionMode" class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Target Nexus</label>
                                <div class="tw-relative">
                                    <i class="fas fa-network-wired tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs"></i>
                                    <select asp-for="ConnectionMode" 
                                            class="tw-w-full tw-pl-9 tw-pr-3 tw-py-2.5 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-700 focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-appearance-none"
                                            style="background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%2394a3b8%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right 0.75rem top 50%; background-size: 0.65rem auto;">
                                        <option value="Default">System Default (MVC)</option>
                                        <option value="Custom">Custom Source (Legacy)</option>
                                    </select>
                                </div>
                            </div>

                            <div>
                                <label asp-for="ConnectionString" class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Connection Signature</label>
                                <textarea asp-for="ConnectionString" rows="4" placeholder="Enter custom DB signature..."
                                          class="tw-w-full tw-p-4 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-xs tw-font-mono tw-font-medium tw-text-slate-600 focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-inner custom-scrollbar"></textarea>
                            </div>
                        </div>
                    </div>

                    <!-- Right: Mode & File -->
                    <div class="tw-space-y-6">
                        <div class="tw-bg-slate-50 tw-p-6 tw-rounded-2xl tw-border tw-border-slate-100 tw-space-y-5">
                            <h4 class="tw-text-[10px] tw-font-black tw-text-slate-400 tw-uppercase tw-tracking-[0.2em] tw-mb-2 tw-flex tw-items-center tw-gap-2">
                                <i class="fas fa-cogs tw-text-indigo-500"></i> Operation Logic
                            </h4>

                            <div>
                                <label asp-for="UploadingMode" class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Processing Mode</label>
                                <div class="tw-flex tw-gap-4">
                                    <label class="tw-flex-1 tw-cursor-pointer group">
                                        <input type="radio" asp-for="UploadingMode" value="A" class="tw-sr-only peer" />
                                        <div class="tw-p-3 tw-text-center tw-border-2 tw-border-slate-200 tw-rounded-xl tw-bg-white group-hover:tw-bg-slate-50 peer-checked:tw-border-amber-400 peer-checked:tw-bg-amber-50 tw-transition-all">
                                            <div class="tw-text-[10px] tw-font-black tw-uppercase tw-tracking-widest tw-text-slate-400 peer-checked:tw-text-amber-700">Automatic</div>
                                        </div>
                                    </label>
                                    <label class="tw-flex-1 tw-cursor-pointer group">
                                        <input type="radio" asp-for="UploadingMode" value="M" class="tw-sr-only peer" />
                                        <div class="tw-p-3 tw-text-center tw-border-2 tw-border-slate-200 tw-rounded-xl tw-bg-white group-hover:tw-bg-slate-50 peer-checked:tw-border-amber-400 peer-checked:tw-bg-amber-50 tw-transition-all">
                                            <div class="tw-text-[10px] tw-font-black tw-uppercase tw-tracking-widest tw-text-slate-400 peer-checked:tw-text-amber-700">Manual</div>
                                        </div>
                                    </label>
                                </div>
                            </div>

                            <div>
                                <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Excel Payload (XLS/XLSX)</label>
                                <div class="tw-relative group">
                                    <div class="tw-absolute tw-inset-0 tw-border-2 tw-border-dashed tw-border-slate-200 tw-rounded-xl tw-bg-white group-hover:tw-border-emerald-400 tw-transition-colors"></div>
                                    <div class="tw-relative tw-p-6 tw-text-center">
                                        <i class="fas fa-file-excel tw-text-3xl tw-text-slate-300 tw-mb-3 group-hover:tw-text-emerald-500 tw-transition-colors"></i>
                                        <div class="tw-text-xs tw-text-slate-500 tw-font-bold">Drop dataset here or click to select</div>
                                        <input asp-for="Document" type="file" accept=".xls,.xlsx" 
                                               class="tw-absolute tw-inset-0 tw-w-full tw-h-full tw-opacity-0 tw-cursor-pointer" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="tw-border-t tw-border-slate-100 tw-pt-4"></div>

                <!-- Action Controls -->
                <div class="tw-flex tw-flex-col md:tw-flex-row tw-items-center tw-justify-between tw-gap-4">
                    <div class="tw-flex tw-items-center tw-gap-2 tw-text-[10px] tw-font-black tw-text-slate-400 tw-uppercase tw-tracking-widest">
                        <i class="fas fa-shield-alt tw-text-emerald-500"></i> Data Integrity Check Active
                    </div>
                    <div class="tw-flex tw-flex-wrap tw-gap-3 tw-w-full md:tw-w-auto">
                        <button type="submit" name="action" value="CheckConnection" 
                                class="tw-flex-1 md:tw-flex-none tw-inline-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-px-6 tw-bg-white tw-text-slate-700 tw-border-2 tw-border-slate-200 tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase hover:tw-bg-slate-50 hover:tw-border-slate-300 tw-transition-all shadow-sm">
                            <i class="fas fa-plug tw-text-amber-500"></i> Test Nexus
                        </button>
                        <button type="submit" name="action" value="Upload" 
                                class="tw-flex-1 md:tw-flex-none tw-inline-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-px-10 tw-bg-gradient-to-r tw-from-emerald-500 tw-to-emerald-600 tw-text-white tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase tw-shadow-[0_8px_20px_rgba(16,185,129,0.25)] hover:tw-shadow-[0_8px_25px_rgba(16,185,129,0.35)] hover:tw--translate-y-0.5 tw-transition-all">
                            <i class="fas fa-cloud-upload-alt tw-text-sm"></i> Commit Data
                        </button>
                        <button type="submit" name="action" value="Reset" formnovalidate
                                class="tw-inline-flex tw-items-center tw-justify-center tw-w-12 tw-h-12 tw-bg-white tw-text-slate-400 tw-border tw-border-slate-200 tw-rounded-xl hover:tw-bg-slate-50 hover:tw-text-slate-900 tw-transition-all shadow-sm">
                            <i class="fas fa-undo-alt"></i>
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
