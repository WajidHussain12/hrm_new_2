                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="exclusionType" value="@row.ExclusionType" />
                                    <input type="hidden" name="exclusionValue" value="@row.ExclusionValue" />
                                    <input type="hidden" name="isActive" value="@(row.IsActive ? "false" : "true")" />
                                    <button type="submit" class="@(row.IsActive ? "badge-active" : "badge-inactive")">
                                        <i class="fas @(row.IsActive ? "fa-check" : "fa-xmark")"></i>
                                        @(row.IsActive ? "Active" : "Inactive")
