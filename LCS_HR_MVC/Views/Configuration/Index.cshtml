@* ══ Scalar Edit Modal ══════════════════════════════════════════════════════ *@
<div id="cfgModal" role="dialog" aria-modal="true" aria-labelledby="cfgModalTitle">
    <div class="tw-bg-white tw-rounded-2xl tw-shadow-2xl tw-w-full tw-max-w-md tw-p-6 tw-mx-4">
        <div class="tw-flex tw-items-center tw-justify-between tw-mb-5">
            <h3 id="cfgModalTitle" class="tw-text-base tw-font-bold tw-text-slate-800 tw-m-0">Edit Config Value</h3>
            <button onclick="closeScalarModal()" class="tw-w-8 tw-h-8 tw-rounded-lg tw-flex tw-items-center tw-justify-center tw-text-slate-400 hover:tw-bg-slate-100 hover:tw-text-slate-700 tw-transition-all">
                <i class="fas fa-xmark"></i>
            </button>
        </div>
        <form method="post" asp-action="UpdateScalar" asp-controller="Configuration">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Table" id="modalTable" />
            <input type="hidden" name="ConfigKey" id="modalKey" />
            <div class="tw-mb-4">
                <label class="tw-text-xs tw-font-bold tw-uppercase tw-tracking-wider tw-text-slate-500 tw-block tw-mb-1.5">Config Key</label>
                <div class="tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-lg tw-px-3 tw-py-2">
                    <code id="modalKeyDisplay" class="tw-text-sm tw-font-mono tw-text-slate-700"></code>
                </div>
            </div>
            <div class="tw-mb-5">
                <label for="modalValue" class="tw-text-xs tw-font-bold tw-uppercase tw-tracking-wider tw-text-slate-500 tw-block tw-mb-1.5">New Value <span class="tw-text-red-500">*</span></label>
                <input type="text" id="modalValue" name="ConfigValue" class="form-input tw-w-full tw-text-base" required autocomplete="off" />
                <p class="tw-text-xs tw-text-slate-400 tw-mt-1.5">For comma-separated lists enter values as: 1,2,3 (no spaces).</p>
            </div>
            <div class="tw-flex tw-gap-3 tw-justify-end">
                <button type="button" onclick="closeScalarModal()"
                        class="tw-px-4 tw-py-2 tw-rounded-lg tw-text-sm tw-font-semibold tw-text-slate-600 tw-bg-slate-100 hover:tw-bg-slate-200 tw-transition-all">
                    Cancel
                </button>
                <button type="submit"
                        class="tw-px-5 tw-py-2 tw-rounded-lg tw-text-sm tw-font-bold tw-bg-[#f5c518] tw-text-slate-900 hover:tw-bg-amber-500 hover:tw-text-white tw-transition-all">
                    <i class="fas fa-save tw-mr-1.5"></i>Save
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    // ── Tab switching ─────────────────────────────────────────────────────────
    (function () {
        var buttons = document.querySelectorAll('.cfg-tab-btn');
        var panels  = document.querySelectorAll('.cfg-tab-panel');
        buttons.forEach(function (btn) {
            btn.addEventListener('click', function () {
                var target = btn.dataset.tab;
                buttons.forEach(function (b) { b.classList.remove('active'); });
                panels.forEach(function (p)  { p.classList.remove('active'); });
                btn.classList.add('active');
                document.getElementById(target).classList.add('active');
            });
        });
    })();

    // ── Scalar edit modal ─────────────────────────────────────────────────────
    var _modal = document.getElementById('cfgModal');

    function openScalarModal(table, key, value) {
        document.getElementById('modalTable').value          = table;
        document.getElementById('modalKey').value            = key;
        document.getElementById('modalKeyDisplay').textContent = key;
        document.getElementById('modalValue').value          = value;
        _modal.classList.add('open');
        setTimeout(function () { document.getElementById('modalValue').focus(); }, 50);
    }

    function closeScalarModal() { _modal.classList.remove('open'); }

    _modal.addEventListener('click', function (e) { if (e.target === _modal) closeScalarModal(); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeScalarModal(); });
</script>
}
