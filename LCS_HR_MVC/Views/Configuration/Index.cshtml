@model LCS_HR_MVC.Models.ConfigurationIndexViewModel
@{
    ViewData["Title"] = "Commission & Salary Configuration";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
<style>
    .cfg-tab-btn {
        padding: 0.5rem 1rem; border-radius: 0.5rem 0.5rem 0 0; font-size: 0.8rem;
        font-weight: 600; color: #64748b; border: 1px solid transparent;
        border-bottom: none; cursor: pointer; transition: all 0.2s; white-space: nowrap;
        background: transparent;
    }
    .cfg-tab-btn:hover { background: #f8fafc; color: #0f172a; }
    .cfg-tab-btn.active { background: #ffffff; color: #0f172a; border-color: #e2e8f0; border-bottom-color: #ffffff; margin-bottom: -1px; }
    .cfg-tab-panel { display: none; }
    .cfg-tab-panel.active { display: block; }
    .cfg-tbl th { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: #94a3b8; padding: 0.6rem 0.75rem; background: #f8fafc; border-bottom: 1px solid #e2e8f0; }
    .cfg-tbl td { font-size: 0.82rem; color: #334155; padding: 0.6rem 0.75rem; border-bottom: 1px solid #f1f5f9; vertical-align: middle; }
    .cfg-tbl tr:hover td { background: #fafafa; }
    .badge-active { display: inline-flex; align-items: center; gap: 0.25rem; padding: 0.2rem 0.55rem; border-radius: 9999px; font-size: 0.7rem; font-weight: 700; background: #dcfce7; color: #15803d; border: none; cursor: pointer; }
    .badge-inactive { display: inline-flex; align-items: center; gap: 0.25rem; padding: 0.2rem 0.55rem; border-radius: 9999px; font-size: 0.7rem; font-weight: 700; background: #fee2e2; color: #b91c1c; border: none; cursor: pointer; }
    .btn-edit { font-size: 0.72rem; padding: 0.2rem 0.6rem; border-radius: 0.35rem; background: #eff6ff; color: #1d4ed8; border: 1px solid #bfdbfe; cursor: pointer; transition: all 0.15s; }
    .btn-edit:hover { background: #1d4ed8; color: #fff; }
    .btn-del { font-size: 0.72rem; padding: 0.2rem 0.6rem; border-radius: 0.35rem; background: #fef2f2; color: #b91c1c; border: 1px solid #fecaca; cursor: pointer; transition: all 0.15s; }
    .btn-del:hover { background: #b91c1c; color: #fff; }
    .btn-add { font-size: 0.78rem; padding: 0.4rem 1rem; border-radius: 0.5rem; background: #f5c518; color: #1a1a1a; border: none; font-weight: 700; cursor: pointer; transition: all 0.15s; }
    .btn-add:hover { background: #d97706; color: #fff; }
    .form-input { font-size: 0.82rem; padding: 0.35rem 0.6rem; border: 1px solid #e2e8f0; border-radius: 0.4rem; outline: none; color: #0f172a; }
    .form-input:focus { border-color: #f5c518; box-shadow: 0 0 0 2px rgba(245,197,24,0.2); }
    #cfgModal { display: none; position: fixed; inset: 0; z-index: 999; background: rgba(0,0,0,0.4); align-items: center; justify-content: center; }
    #cfgModal.open { display: flex; }
</style>
}

<div class="tw-px-1 tw-py-2">

    @* ── Flash Messages ─────────────────────────────────────────────────── *@
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="tw-mb-4 tw-flex tw-items-center tw-gap-3 tw-bg-green-50 tw-border tw-border-green-200 tw-text-green-800 tw-rounded-xl tw-px-4 tw-py-3">
            <i class="fas fa-circle-check tw-text-green-500"></i>
            <span class="tw-text-sm tw-font-medium">@Model.SuccessMessage</span>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="tw-mb-4 tw-flex tw-items-center tw-gap-3 tw-bg-red-50 tw-border tw-border-red-200 tw-text-red-800 tw-rounded-xl tw-px-4 tw-py-3">
            <i class="fas fa-circle-exclamation tw-text-red-500"></i>
            <span class="tw-text-sm tw-font-medium">@Model.ErrorMessage</span>
        </div>
    }

    @* ── Validation Bar ──────────────────────────────────────────────────── *@
    <div class="tw-flex tw-items-center tw-justify-between tw-bg-indigo-50 tw-border tw-border-indigo-200 tw-rounded-xl tw-px-4 tw-py-3 tw-mb-4">
        <div class="tw-flex tw-items-center tw-gap-2.5">
            <div class="tw-w-8 tw-h-8 tw-bg-indigo-100 tw-rounded-lg tw-flex tw-items-center tw-justify-center">
                <i class="fas fa-shield-halved tw-text-indigo-500 tw-text-sm"></i>
            </div>
            <div>
                <span class="tw-text-sm tw-font-bold tw-text-indigo-800">Config Validation &amp; Safety Check</span>
                <span class="tw-text-xs tw-text-indigo-400 tw-ml-2">Auto-runs every 6 hours · Validates all commission tables + restores if deleted</span>
            </div>
        </div>
        <form method="post" asp-action="RunSync" asp-controller="Configuration">
            @Html.AntiForgeryToken()
            <button type="submit"
                    class="tw-text-xs tw-font-bold tw-bg-indigo-500 hover:tw-bg-indigo-600 tw-text-white tw-px-4 tw-py-2 tw-rounded-lg tw-transition-all tw-flex tw-items-center tw-gap-1.5">
                <i class="fas fa-shield-halved"></i>
                Validate Now
            </button>
        </form>
    </div>

    @* ── Page Title ──────────────────────────────────────────────────────── *@
    <div class="tw-flex tw-items-center tw-gap-3 tw-mb-6">
        <div class="tw-w-10 tw-h-10 tw-rounded-xl tw-bg-amber-100 tw-flex tw-items-center tw-justify-center tw-border tw-border-amber-200">
            <i class="fas fa-sliders tw-text-amber-500"></i>
        </div>
        <div>
            <h1 class="tw-text-lg tw-font-black tw-text-slate-800 tw-m-0 tw-leading-tight">Commission &amp; Salary Configuration</h1>
            <p class="tw-text-xs tw-text-slate-400 tw-m-0 tw-mt-0.5">All config values are loaded from the database at each process run.</p>
        </div>
    </div>

    @* ── Tab Bar ─────────────────────────────────────────────────────────── *@
    <div class="tw-flex tw-flex-wrap tw-gap-0.5 tw-border-b tw-border-slate-200 tw-mb-0 tw-overflow-x-auto">
        <button class="cfg-tab-btn active" data-tab="tab-comm-scalars"><i class="fas fa-cog tw-mr-1.5"></i>Commission Config</button>
        <button class="cfg-tab-btn" data-tab="tab-sal-scalars"><i class="fas fa-coins tw-mr-1.5"></i>Salary Config</button>
        <button class="cfg-tab-btn" data-tab="tab-cod-clients"><i class="fas fa-ban tw-mr-1.5"></i>COD Excl. Clients</button>
        <button class="cfg-tab-btn" data-tab="tab-cod-cities"><i class="fas fa-city tw-mr-1.5"></i>COD Thresholds</button>
        <button class="cfg-tab-btn" data-tab="tab-vas"><i class="fas fa-box-open tw-mr-1.5"></i>VAS Exclusions</button>
        <button class="cfg-tab-btn" data-tab="tab-tax"><i class="fas fa-file-invoice-dollar tw-mr-1.5"></i>Tax Exclusions</button>
        <button class="cfg-tab-btn" data-tab="tab-shipments"><i class="fas fa-truck tw-mr-1.5"></i>Excl. Shipments</button>
        <button class="cfg-tab-btn" data-tab="tab-sysexcl"><i class="fas fa-shield-halved tw-mr-1.5"></i>System Exclusions</button>
        <button class="cfg-tab-btn" data-tab="tab-typemap"><i class="fas fa-diagram-project tw-mr-1.5"></i>OLE Type Mapping</button>
        <button class="cfg-tab-btn" data-tab="tab-codetypes"><i class="fas fa-table-list tw-mr-1.5"></i>CodeType Rules</button>
    </div>

    <div class="tw-bg-white tw-border tw-border-slate-200 tw-border-t-0 tw-rounded-b-xl tw-shadow-sm">

        @* ══ TAB 1: Commission Scalars ══════════════════════════════════════ *@
        <div id="tab-comm-scalars" class="cfg-tab-panel active tw-p-5">
            <div class="tw-flex tw-items-center tw-justify-between tw-mb-3">
                <h2 class="tw-text-sm tw-font-bold tw-text-slate-700 tw-m-0">Commission Config Scalars <span class="tw-text-slate-400 tw-font-normal">(hr_commission_config)</span></h2>
                <span class="tw-text-xs tw-text-slate-400">@Model.CommissionScalars.Count rows — click Edit to change a value</span>
            </div>
            <div class="tw-overflow-x-auto tw-rounded-lg tw-border tw-border-slate-100">
                <table class="cfg-tbl tw-w-full">
                    <thead><tr>
                        <th class="tw-w-72">Config Key</th>
                        <th>Value</th>
                        <th class="tw-w-16 tw-text-center">Edit</th>
                    </tr></thead>
                    <tbody>
                    @foreach (var row in Model.CommissionScalars)
                    {
                        <tr>
                            <td><code class="tw-text-xs tw-bg-slate-100 tw-px-1.5 tw-py-0.5 tw-rounded tw-font-mono">@row.ConfigKey</code></td>
                            <td class="tw-font-semibold tw-text-slate-800">@row.ConfigValue</td>
                            <td class="tw-text-center">
                                <button class="btn-edit"
                                        onclick="openScalarModal('commission','@Html.Raw(row.ConfigKey.Replace("'","\\'" ))','@Html.Raw(row.ConfigValue.Replace("'","\\'" ))')">
                                    <i class="fas fa-pen"></i>
                                </button>
                            </td>
                        </tr>
                    }
                    @if (!Model.CommissionScalars.Any())
                    {
                        <tr><td colspan="3" class="tw-text-center tw-text-slate-400 tw-py-8">No rows found in hr_commission_config.</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>

        @* ══ TAB 2: Salary Scalars ══════════════════════════════════════════ *@
        <div id="tab-sal-scalars" class="cfg-tab-panel tw-p-5">
            <div class="tw-flex tw-items-center tw-justify-between tw-mb-3">
                <h2 class="tw-text-sm tw-font-bold tw-text-slate-700 tw-m-0">Salary Config Scalars <span class="tw-text-slate-400 tw-font-normal">(hr_salary_config)</span></h2>
                <span class="tw-text-xs tw-text-slate-400">@Model.SalaryScalars.Count rows — click Edit to change a value</span>
            </div>
            <div class="tw-overflow-x-auto tw-rounded-lg tw-border tw-border-slate-100">
                <table class="cfg-tbl tw-w-full">
                    <thead><tr>
                        <th class="tw-w-72">Config Key</th>
                        <th>Value</th>
                        <th class="tw-w-16 tw-text-center">Edit</th>
                    </tr></thead>
                    <tbody>
                    @foreach (var row in Model.SalaryScalars)
                    {
                        <tr>
                            <td><code class="tw-text-xs tw-bg-slate-100 tw-px-1.5 tw-py-0.5 tw-rounded tw-font-mono">@row.ConfigKey</code></td>
                            <td class="tw-font-semibold tw-text-slate-800">@row.ConfigValue</td>
                            <td class="tw-text-center">
                                <button class="btn-edit"
                                        onclick="openScalarModal('salary','@Html.Raw(row.ConfigKey.Replace("'","\\'" ))','@Html.Raw(row.ConfigValue.Replace("'","\\'" ))')">
                                    <i class="fas fa-pen"></i>
                                </button>
                            </td>
                        </tr>
                    }
                    @if (!Model.SalaryScalars.Any())
                    {
                        <tr><td colspan="3" class="tw-text-center tw-text-slate-400 tw-py-8">No rows found in hr_salary_config.</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>

        @* ══ TAB 3: COD Excluded Clients ════════════════════════════════════ *@
        <div id="tab-cod-clients" class="cfg-tab-panel tw-p-5">
            <div class="tw-flex tw-items-center tw-justify-between tw-mb-3">
                <h2 class="tw-text-sm tw-font-bold tw-text-slate-700 tw-m-0">COD Excluded Clients <span class="tw-text-slate-400 tw-font-normal">(hr_cod_excluded_clients)</span></h2>
                <span class="tw-text-xs tw-text-slate-400">@Model.CodExcludedClients.Count records</span>
            </div>
            <div class="tw-overflow-x-auto tw-rounded-lg tw-border tw-border-slate-100 tw-mb-5">
                <table class="cfg-tbl tw-w-full">
                    <thead><tr>
                        <th>Client ID</th>
                        <th class="tw-w-28 tw-text-center">Status</th>
                        <th class="tw-w-24 tw-text-center">Delete</th>
                    </tr></thead>
                    <tbody>
                    @foreach (var row in Model.CodExcludedClients)
                    {
                        <tr>
                            <td class="tw-font-mono tw-text-xs tw-font-semibold">@row.ClientId</td>
                            <td class="tw-text-center">
                                <form method="post" asp-action="ToggleActive" asp-controller="Configuration" class="tw-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="table" value="cod_clients" />
                                    <input type="hidden" name="key" value="@row.ClientId" />
                                    <input type="hidden" name="isActive" value="@(row.IsActive ? "false" : "true")" />
                                    <button type="submit" class="@(row.IsActive ? "badge-active" : "badge-inactive")">
                                        <i class="fas @(row.IsActive ? "fa-check" : "fa-xmark")"></i>
                                        @(row.IsActive ? "Active" : "Inactive")
                                    </button>
                                </form>
                            </td>
                            <td class="tw-text-center">
                                <form method="post" asp-action="DeleteRow" asp-controller="Configuration" class="tw-inline"
                                      onsubmit="return confirm('Delete client @Html.Raw(row.ClientId.Replace("'","\\'" ))? This cannot be undone.')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="table" value="cod_clients" />
                                    <input type="hidden" name="key" value="@row.ClientId" />
                                    <button type="submit" class="btn-del"><i class="fas fa-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.CodExcludedClients.Any())
                    {
                        <tr><td colspan="3" class="tw-text-center tw-text-slate-400 tw-py-8">No excluded clients configured.</td></tr>
                    }
                    </tbody>
                </table>
            </div>
            <div class="tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-p-4">
                <p class="tw-text-xs tw-font-bold tw-text-slate-600 tw-uppercase tw-tracking-wider tw-mb-3">Add New Excluded Client</p>
                <form method="post" asp-action="AddCodClient" asp-controller="Configuration" class="tw-flex tw-flex-wrap tw-gap-2 tw-items-end">
                    @Html.AntiForgeryToken()
                    <div class="tw-flex tw-flex-col tw-gap-1">
                        <label class="tw-text-xs tw-font-semibold tw-text-slate-500">Client ID <span class="tw-text-red-500">*</span></label>
                        <input type="text" name="ClientId" class="form-input tw-w-44" placeholder="e.g. C00123" required />
                    </div>
                    <button type="submit" class="btn-add"><i class="fas fa-plus tw-mr-1"></i>Add</button>
                </form>
            </div>
        </div>

        @* ══ TAB 4: COD Threshold Cities ════════════════════════════════════ *@
        <div id="tab-cod-cities" class="cfg-tab-panel tw-p-5">
            <div class="tw-flex tw-items-center tw-justify-between tw-mb-3">
                <h2 class="tw-text-sm tw-font-bold tw-text-slate-700 tw-m-0">COD Threshold Cities <span class="tw-text-slate-400 tw-font-normal">(hr_commission_cod_threshold_cities)</span></h2>
                <span class="tw-text-xs tw-text-slate-400">Cities not listed use 80% default</span>
            </div>
            <div class="tw-overflow-x-auto tw-rounded-lg tw-border tw-border-slate-100 tw-mb-5">
                <table class="cfg-tbl tw-w-full">
                    <thead><tr>
                        <th class="tw-w-32">City Code</th>
                        <th class="tw-text-right tw-w-36">Threshold %</th>
                        <th class="tw-w-28 tw-text-center">Status</th>
                        <th class="tw-w-24 tw-text-center">Delete</th>
                    </tr></thead>
                    <tbody>
                    @foreach (var row in Model.CodThresholdCities)
                    {
                        <tr>
                            <td class="tw-font-mono tw-text-xs tw-font-bold">@row.CityCode</td>
                            <td class="tw-text-right tw-font-bold tw-text-slate-700">@row.ThresholdPct.ToString("0.##")%</td>
                            <td class="tw-text-center">
                                <form method="post" asp-action="ToggleActive" asp-controller="Configuration" class="tw-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="table" value="cod_cities" />
                                    <input type="hidden" name="key" value="@row.CityCode" />
                                    <input type="hidden" name="isActive" value="@(row.IsActive ? "false" : "true")" />
                                    <button type="submit" class="@(row.IsActive ? "badge-active" : "badge-inactive")">
                                        <i class="fas @(row.IsActive ? "fa-check" : "fa-xmark")"></i>
                                        @(row.IsActive ? "Active" : "Inactive")
                                    </button>
                                </form>
                            </td>
                            <td class="tw-text-center">
                                <form method="post" asp-action="DeleteRow" asp-controller="Configuration" class="tw-inline"
                                      onsubmit="return confirm('Delete city @Html.Raw(row.CityCode.Replace("'","\\'" ))?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="table" value="cod_cities" />
                                    <input type="hidden" name="key" value="@row.CityCode" />
                                    <button type="submit" class="btn-del"><i class="fas fa-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.CodThresholdCities.Any())
                    {
                        <tr><td colspan="4" class="tw-text-center tw-text-slate-400 tw-py-8">No city thresholds configured — all cities use 80% default.</td></tr>
                    }
                    </tbody>
                </table>
            </div>
            <div class="tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-p-4">
                <p class="tw-text-xs tw-font-bold tw-text-slate-600 tw-uppercase tw-tracking-wider tw-mb-3">Add City Threshold Override</p>
                <form method="post" asp-action="AddCodCity" asp-controller="Configuration" class="tw-flex tw-flex-wrap tw-gap-2 tw-items-end">
                    @Html.AntiForgeryToken()
                    <div class="tw-flex tw-flex-col tw-gap-1">
                        <label class="tw-text-xs tw-font-semibold tw-text-slate-500">City Code <span class="tw-text-red-500">*</span></label>
                        <input type="text" name="CityCode" class="form-input tw-w-24" placeholder="001" maxlength="10" required />
                    </div>
                    <div class="tw-flex tw-flex-col tw-gap-1">
                        <label class="tw-text-xs tw-font-semibold tw-text-slate-500">Threshold % <span class="tw-text-red-500">*</span></label>
                        <input type="number" name="ThresholdPct" class="form-input tw-w-24" placeholder="85.00" min="1" max="100" step="0.01" required />
                    </div>
                    <button type="submit" class="btn-add"><i class="fas fa-plus tw-mr-1"></i>Add</button>
                </form>
            </div>
        </div>

        @* ══ TAB 5: VAS Exclusions ══════════════════════════════════════════ *@
        <div id="tab-vas" class="cfg-tab-panel tw-p-5">
            <div class="tw-flex tw-items-center tw-justify-between tw-mb-3">
                <h2 class="tw-text-sm tw-font-bold tw-text-slate-700 tw-m-0">VAS Exclusions <span class="tw-text-slate-400 tw-font-normal">(hr_commission_vas_exclusions)</span></h2>
                <span class="tw-text-xs tw-text-slate-400">@Model.VasExclusions.Count VAS IDs excluded from Cash commission</span>
            </div>
            <div class="tw-overflow-x-auto tw-rounded-lg tw-border tw-border-slate-100 tw-mb-5">
                <table class="cfg-tbl tw-w-full">
                    <thead><tr>
                        <th class="tw-w-32">VAS ID</th>
                        <th class="tw-w-28 tw-text-center">Status</th>
                        <th class="tw-w-24 tw-text-center">Delete</th>
                    </tr></thead>
                    <tbody>
                    @foreach (var row in Model.VasExclusions)
                    {
                        <tr>
                            <td class="tw-font-mono tw-text-xs tw-font-bold">@row.VasId</td>
                            <td class="tw-text-center">
                                <form method="post" asp-action="ToggleActive" asp-controller="Configuration" class="tw-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="table" value="vas" />
                                    <input type="hidden" name="key" value="@row.VasId" />
                                    <input type="hidden" name="isActive" value="@(row.IsActive ? "false" : "true")" />
                                    <button type="submit" class="@(row.IsActive ? "badge-active" : "badge-inactive")">
                                        <i class="fas @(row.IsActive ? "fa-check" : "fa-xmark")"></i>
                                        @(row.IsActive ? "Active" : "Inactive")
                                    </button>
                                </form>
                            </td>
                            <td class="tw-text-center">
                                <form method="post" asp-action="DeleteRow" asp-controller="Configuration" class="tw-inline"
                                      onsubmit="return confirm('Delete VAS ID @row.VasId?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="table" value="vas" />
                                    <input type="hidden" name="key" value="@row.VasId" />
                                    <button type="submit" class="btn-del"><i class="fas fa-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.VasExclusions.Any())
                    {
                        <tr><td colspan="3" class="tw-text-center tw-text-slate-400 tw-py-8">No VAS exclusions configured.</td></tr>
                    }
                    </tbody>
                </table>
            </div>
            <div class="tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-p-4">
                <p class="tw-text-xs tw-font-bold tw-text-slate-600 tw-uppercase tw-tracking-wider tw-mb-3">Add VAS Exclusion</p>
                <form method="post" asp-action="AddVasExclusion" asp-controller="Configuration" class="tw-flex tw-flex-wrap tw-gap-2 tw-items-end">
                    @Html.AntiForgeryToken()
                    <div class="tw-flex tw-flex-col tw-gap-1">
                        <label class="tw-text-xs tw-font-semibold tw-text-slate-500">VAS ID <span class="tw-text-red-500">*</span></label>
                        <input type="number" name="VasId" class="form-input tw-w-28" placeholder="e.g. 48" min="1" required />
                    </div>
                    <button type="submit" class="btn-add"><i class="fas fa-plus tw-mr-1"></i>Add</button>
                </form>
            </div>
        </div>

        @* ══ TAB 6: Salary Tax Exclusions ════════════════════════════════════ *@
        <div id="tab-tax" class="cfg-tab-panel tw-p-5">
            <div class="tw-flex tw-items-center tw-justify-between tw-mb-3">
                <h2 class="tw-text-sm tw-font-bold tw-text-slate-700 tw-m-0">Salary Tax Exclusions <span class="tw-text-slate-400 tw-font-normal">(hr_salary_tax_exclusions)</span></h2>
                <span class="tw-text-xs tw-text-slate-400">Employees whose salary is excluded from tax correction</span>
            </div>
            <div class="tw-overflow-x-auto tw-rounded-lg tw-border tw-border-slate-100 tw-mb-5">
                <table class="cfg-tbl tw-w-full">
                    <thead><tr>
                        <th class="tw-w-56">Employee No</th>
                        <th class="tw-w-28 tw-text-center">Status</th>
                        <th class="tw-w-24 tw-text-center">Delete</th>
                    </tr></thead>
                    <tbody>
                    @foreach (var row in Model.SalaryTaxExclusions)
                    {
