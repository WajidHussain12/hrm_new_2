@model LCS_HR_MVC.Models.IncrementApprovalViewModel
@{
    ViewData["PageTitle"] = "Increment / Decrement Approval";
}

@section Styles {
    
}

<div class="w-full p-6 bg-white">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="text-red-700 bg-red-100 border border-red-400 p-3 rounded mb-4 shadow-sm"><div class="font-medium"><strong>Error! </strong>@TempData["ErrorMessage"]</div></div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="text-green-700 bg-green-100 border border-green-400 p-3 rounded mb-4 shadow-sm"><div class="font-medium"><strong>Success! </strong>@TempData["SuccessMessage"]</div></div>
    }

    <div class="w-full max-w-7xl mx-auto">
        <form asp-controller="Transaction" asp-action="IncrementApproval" method="post" id="approvalForm">
            <table class="w-full shadow-lg bg-white rounded-lg border border-gray-200" style="width:100%;">
                <tr>
                    <td valign="top" width="100%" style="padding-right: 10px;">
                        
                        <div class="p-4 bg-gray-50 border-b border-gray-200 rounded-t-lg" style="margin-bottom: 10px;">
                            <table width="100%" border="0" cellpadding="0" cellspacing="0">
                                <tbody>
                                    <tr>
                                        <td><span class="text-sm font-semibold text-gray-700">Search by City:</span></td>
                                        <td>
                                            <select asp-for="CityCode" asp-items="ViewBag.Cities" class="req bg-[#fdf4b5] border border-gray-300 rounded shadow-inner text-gray-700 text-sm h-[30px] px-2 py-1 focus:outline-none focus:ring-1 focus:ring-blue-500" style="width:200px;">
                                                <option value="">All Cities</option>
                                            </select>
                                        </td>
                                        <td><span class="text-sm font-semibold text-gray-700">Search by Department:</span></td>
                                        <td>
                                            <select asp-for="DepartmentId" asp-items="ViewBag.Depts" class="req bg-[#fdf4b5] border border-gray-300 rounded shadow-inner text-gray-700 text-sm h-[30px] px-2 py-1 focus:outline-none focus:ring-1 focus:ring-blue-500" style="width:200px;">
                                                <option value="">All Departments</option>
                                            </select>
                                        </td>
                                        <td>
                                            <button type="submit" name="action" value="Search" class="button bg-blue-600 hover:bg-blue-700 text-white font-semibold py-1.5 px-4 rounded text-sm transition-colors shadow-sm focus:ring-2 focus:ring-blue-500 focus:outline-none">Search</button>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="buttonWrapper" style="margin-bottom:10px;">
                            <span style="font-weight:bold;">Global Action:</span>
                            <select id="ddlGlobalStatus" class="ddl bg-white border border-gray-300 rounded shadow-inner text-gray-700 text-sm h-[30px] px-2 py-1 focus:outline-none focus:ring-1 focus:ring-blue-500" style="width:150px;">
                                <option value="1">Pending</option>
                                <option value="2">Approve</option>
                                <option value="3">Reject</option>
                            </select>
                            <button type="button" class="button bg-blue-600 hover:bg-blue-700 text-white font-semibold py-1.5 px-4 rounded text-sm transition-colors shadow-sm focus:ring-2 focus:ring-blue-500 focus:outline-none" id="btnApplyGlobal">Apply to All</button>
                            <span style="margin: 0 15px;">|</span>
                            <button type="submit" name="action" value="Process" class="button bg-blue-600 hover:bg-blue-700 text-white font-semibold py-1.5 px-4 rounded text-sm transition-colors shadow-sm focus:ring-2 focus:ring-blue-500 focus:outline-none" id="btnProcess" style="background-color: green;">Save Processed Approvals</button>
                        </div>

                        <div style="max-height: 500px; overflow-y: auto;">
                            <table id="dg1" class="tablesorter w-full border-collapse border border-gray-300 text-sm bg-white shadow-sm rounded-lg overflow-hidden" style="width:100%">
                                <thead>
                                    <tr>
                                        <th class="bg-gray-200 border border-gray-300 p-3 text-left font-semibold text-gray-700 uppercase text-xs tracking-wider">Code</th>
                                        <th class="bg-gray-200 border border-gray-300 p-3 text-left font-semibold text-gray-700 uppercase text-xs tracking-wider">Emp / Dept No</th>
                                        <th class="bg-gray-200 border border-gray-300 p-3 text-left font-semibold text-gray-700 uppercase text-xs tracking-wider">Name</th>
                                        <th class="bg-gray-200 border border-gray-300 p-3 text-left font-semibold text-gray-700 uppercase text-xs tracking-wider">Mode</th>
                                        <th class="bg-gray-200 border border-gray-300 p-3 text-left font-semibold text-gray-700 uppercase text-xs tracking-wider">Type</th>
                                        <th class="bg-gray-200 border border-gray-300 p-3 text-left font-semibold text-gray-700 uppercase text-xs tracking-wider">Date</th>
                                        <th class="bg-gray-200 border border-gray-300 p-3 text-left font-semibold text-gray-700 uppercase text-xs tracking-wider">Amount</th>
                                        <th class="bg-gray-200 border border-gray-300 p-3 text-left font-semibold text-gray-700 uppercase text-xs tracking-wider">Comments</th>
                                        <th class="bg-gray-200 border border-gray-300 p-3 text-left font-semibold text-gray-700 uppercase text-xs tracking-wider">Status</th>
                                        <th class="bg-gray-200 border border-gray-300 p-3 text-left font-semibold text-gray-700 uppercase text-xs tracking-wider">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Increments == null || !Model.Increments.Any())
                                    {
                                        <tr>
                                            <td colspan="10" align="center" class="border border-gray-300 p-2 text-gray-800">No pending increment records found.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        int i = 0;
                                        foreach (var item in Model.Increments)
                                        {
                                            <tr class="gridRow hover:bg-gray-100 border-b border-gray-200 transition-colors">
                                                <td class="border border-gray-300 p-2 text-gray-800 border border-gray-300 p-2 text-gray-800">
                                                    <input type="hidden" name="Increments[@i].Code" value="@item.Code" />
                                                    <input type="hidden" name="Increments[@i].EmpNo" value="@item.EmpNo" />
                                                    @item.Code
                                                </td>
                                                <td class="border border-gray-300 p-2 text-gray-800 border border-gray-300 p-2 text-gray-800">@item.EmpNo</td>
                                                <td class="border border-gray-300 p-2 text-gray-800 border border-gray-300 p-2 text-gray-800">@item.EmployeeName</td>
                                                <td class="border border-gray-300 p-2 text-gray-800 border border-gray-300 p-2 text-gray-800">@item.Mode</td>
                                                <td class="border border-gray-300 p-2 text-gray-800 border border-gray-300 p-2 text-gray-800">@(item.Type == "I" ? "Increment" : "Decrement")</td>
                                                <td class="border border-gray-300 p-2 text-gray-800 border border-gray-300 p-2 text-gray-800">@(item.FromDate?.ToString("dd/MM/yyyy"))</td>
                                                <td class="border border-gray-300 p-2 text-gray-800 border border-gray-300 p-2 text-gray-800">@item.Amount</td>
                                                <td class="border border-gray-300 p-2 text-gray-800 border border-gray-300 p-2 text-gray-800">@item.Comments</td>
                                                <td class="border border-gray-300 p-2 text-gray-800 border border-gray-300 p-2 text-gray-800">@item.StatusName</td>
                                                <td class="border border-gray-300 p-2 text-gray-800 border border-gray-300 p-2 text-gray-800">
                                                    <select name="Increments[@i].SelectedStatusId" class="status-ddl req ddl" style="width:100px;">
                                                        <option value="1" selected>Pending</option>
                                                        <option value="2">Approve</option>
                                                        <option value="3">Reject</option>
                                                    </select>
                                                </td>
                                            </tr>
                                            i++;
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </td>
                </tr>
            </table>
        </form>
    </div>
</div>

@section Scripts {
    <script type="text/javascript">
        $(document).ready(function () {
            $('#btnApplyGlobal').click(function () {
                var selectedVal = $('#ddlGlobalStatus').val();
                $('.status-ddl').val(selectedVal);
            });

            $('#btnProcess').click(function(e) {
                var count = $('.status-ddl').filter(function() { return $(this).val() == "2" || $(this).val() == "3"; }).length;
                if (count === 0) {
                    alert("Please change the status of at least one record to Approve or Reject before processing.");
                    e.preventDefault();
                    return false;
                }
                
                var msg = "Do you want to process " + count + " selected request(s)?";
                if(!confirm(msg)) {
                    e.preventDefault();
                    return false;
                }
            });
        });
    </script>
}