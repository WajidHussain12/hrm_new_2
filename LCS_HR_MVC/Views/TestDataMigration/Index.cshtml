</div>

@* ── SignalR ───────────────────────────────────────────────────────────────────── *@
<script src="~/lib/signalr/dist/browser/signalr.min.js"></script>
<script>
(function () {
    const YEAR  = @Model.Year;
    const MONTH = @Model.Month;
    const GROUP = `migration-${YEAR}-${String(MONTH).padStart(2,'0')}`;

    function statusClass(s) {
        if (s==='Done')    return 'text-green-700 bg-green-50';
        if (s==='Failed')  return 'text-red-700 bg-red-50';
        if (s==='Running') return 'text-blue-700 bg-blue-50 animate-pulse';
        return 'text-gray-500 bg-gray-50';
    }
    function statusIcon(s) {
        if (s==='Done')    return '✅';
        if (s==='Failed')  return '❌';
        if (s==='Running') return '🔄';
        if (s==='Skipped') return '⏭️';
        return '⏳';
    }
    function fmt(n)     { return (n!=null && n>0) ? Number(n).toLocaleString() : '—'; }
    function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    function applyProgress(d) {
        if (d.label) {
            document.querySelectorAll(`tr[data-label="${CSS.escape(d.label)}"]`).forEach(row => {
                const liveEl   = row.querySelector('.liveCount');
                const localEl  = row.querySelector('.localCount');
                const statusEl = row.querySelector('.rowStatus');
                const errorEl  = row.querySelector('.rowError');
                if (liveEl)  liveEl.textContent = fmt(d.liveRowCount);
                if (localEl) {
                    localEl.textContent = fmt(d.localRowCount);
                    localEl.classList.add('text-indigo-600','font-bold');
                    setTimeout(() => localEl.classList.remove('text-indigo-600','font-bold'), 400);
                }
                if (statusEl) {
                    statusEl.className   = `px-2 py-0.5 rounded text-xs font-medium ${statusClass(d.status)} rowStatus`;
                    statusEl.textContent = `${statusIcon(d.status)} ${d.status}`;
                }
                if (errorEl) errorEl.textContent = d.error || '';
            });
        }
        const osel = document.getElementById('overallStatus');
        if (osel) osel.textContent = d.overallStatus;
        const dc = document.getElementById('doneCount'); if (dc) dc.textContent = d.doneTables;
        const fc = document.getElementById('failCount'); if (fc) fc.textContent = d.failedTables;

        const pct = d.progressPercent ?? 0;
        const sec = document.getElementById('progressSection');
        if (sec && pct > 0) sec.style.display = '';
        const bar = document.getElementById('progressBar');
        if (bar) bar.style.width = pct + '%';
        const pctEl = document.getElementById('progressPct');
        if (pctEl) pctEl.textContent = pct + '%';
        const lrEl = document.getElementById('progressLocalRows');
        if (lrEl) lrEl.textContent = Number(d.totalLocalRows).toLocaleString();
        const lvEl = document.getElementById('progressLiveRows');
        if (lvEl) lvEl.textContent = Number(d.totalLiveRows).toLocaleString();
        const doneEl = document.getElementById('progressDone');
        if (doneEl) doneEl.textContent = `${d.doneTables} done`;
        const failEl = document.getElementById('progressFailed');
        if (failEl) failEl.textContent = d.failedTables > 0 ? `${d.failedTables} failed` : '';

        if (d.overallStatus === 'Done' || d.overallStatus === 'Failed') {
            const btn = document.getElementById('startBtn');
            if (btn) { btn.disabled = false; btn.innerHTML = '▶ Start Migration'; }
            if (d.overallStatus === 'Done' && bar) bar.style.width = '100%';
        }
    }

    function appendLog(entry) {
        const logBox = document.getElementById('logBox');
        if (!logBox) return;
        const atBottom = logBox.scrollHeight - logBox.scrollTop <= logBox.clientHeight + 30;
        const ph = logBox.querySelector('.italic');
        if (ph) ph.remove();
        const div = document.createElement('div');
        div.innerHTML = escHtml(entry);
        logBox.appendChild(div);
        if (atBottom) logBox.scrollTop = logBox.scrollHeight;
    }

    const connection = new signalR.HubConnectionBuilder()
        .withUrl('/hubs/data-migration')
        .withAutomaticReconnect()
        .build();
    connection.on('progress', applyProgress);
    connection.on('logEntry', appendLog);

    async function startConnection() {
        try {
            await connection.start();
            await connection.invoke('JoinMigration', GROUP);
        } catch(e) {
            console.warn('[DataMigration] SignalR connect failed:', e);
            setTimeout(startConnection, 3000);
        }
    }
    startConnection();
})();
</script>

@* ── City filter multi-select JS ──────────────────────────────────────────────── *@
<script>
(function () {
    const allChk   = document.getElementById('allCitiesChk');
    const dropBtn  = document.getElementById('cityDropdownBtn');
    const panel    = document.getElementById('cityDropdownPanel');
    const searchEl = document.getElementById('citySearch');
    const countEl  = document.getElementById('citySelectedCount');
    const labelEl  = document.getElementById('cityBtnLabel');

    if (!allChk) return; // city filter not rendered

    // ── Toggle All Cities checkbox ──────────────────────────────────────────
    allChk.addEventListener('change', function () {
        dropBtn.disabled = this.checked;
        if (this.checked) {
            // uncheck all city checkboxes so none are submitted
            document.querySelectorAll('.city-chk').forEach(c => c.checked = false);
            updateLabel();
            panel.classList.add('hidden');
        }
    });

    // ── Open / close panel ──────────────────────────────────────────────────
    dropBtn.addEventListener('click', function (e) {
        e.stopPropagation();
        panel.classList.toggle('hidden');
        if (!panel.classList.contains('hidden')) searchEl.focus();
    });
    document.addEventListener('click', function (e) {
        if (!panel.contains(e.target) && e.target !== dropBtn)
            panel.classList.add('hidden');
    });

    // ── Search filter ───────────────────────────────────────────────────────
    searchEl.addEventListener('input', function () {
        const q = this.value.toLowerCase();
        document.querySelectorAll('.city-item').forEach(item => {
            item.style.display = item.dataset.name.includes(q) ? '' : 'none';
        });
    });

    // ── City checkbox change ────────────────────────────────────────────────
    document.querySelectorAll('.city-chk').forEach(chk => {
        chk.addEventListener('change', updateLabel);
    });

    function updateLabel() {
        const checked = document.querySelectorAll('.city-chk:checked');
        const n = checked.length;
        countEl.textContent = n + ' selected';
        if (n === 0) {
            labelEl.textContent = 'Select cities…';
            labelEl.className = 'text-gray-500 text-xs';
        } else if (n <= 3) {
            const names = Array.from(checked).map(c =>
                c.closest('.city-item').querySelector('span:last-child').textContent.trim()
            );
            labelEl.textContent = names.join(', ');
            labelEl.className = 'text-indigo-700 text-xs font-medium truncate max-w-[160px]';
        } else {
            labelEl.textContent = n + ' cities selected';
            labelEl.className = 'text-indigo-700 text-xs font-medium';
        }
        // If any city selected, auto-uncheck "All Cities"
        if (n > 0) allChk.checked = false;
        dropBtn.disabled = false;
    }

    window.selectAllCities = function () {
        document.querySelectorAll('.city-item:not([style*="none"]) .city-chk').forEach(c => c.checked = true);
        updateLabel();
    };
    window.clearAllCities = function () {
        document.querySelectorAll('.city-chk').forEach(c => c.checked = false);
        updateLabel();
        allChk.checked = true;
        dropBtn.disabled = true;
    };

    // ── On form submit: if All Cities, disable city checkboxes so they don't POST ──
    document.getElementById('startForm').addEventListener('submit', function () {
        if (allChk.checked) {
            document.querySelectorAll('.city-chk').forEach(c => c.disabled = true);
        }
    });

    // Init label on page load (in case previous selection is restored)
    updateLabel();
    if (document.querySelectorAll('.city-chk:checked').length > 0) {
        allChk.checked = false;
        dropBtn.disabled = false;
    }
})();
</script>
