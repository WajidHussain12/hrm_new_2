@model LCS_HR_MVC.Models.MigrationStatusViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["PageTitle"] = "Test Data Migration";

    var monthNames = new[]
    {
        "January","February","March","April","May","June",
        "July","August","September","October","November","December"
    };

    // ── Parse live connection strings → extract server IP, default DB, user ──
    var connMeta = new Dictionary<string, (string Ip, string Db, string User)>(StringComparer.OrdinalIgnoreCase);
    {
        string GetPart(string cs, string key) {
            foreach (var seg in cs.Split(';')) {
                var kv = seg.Trim().Split('=', 2);
                if (kv.Length == 2 && kv[0].Trim().Equals(key, StringComparison.OrdinalIgnoreCase))
                    return kv[1].Trim();
            }
            return "";
        }
        var liveSection = Configuration.GetSection("LiveConnections");
        foreach (var child in liveSection.GetChildren())
        {
            var cs = child.Value ?? "";
            connMeta[child.Key] = (GetPart(cs, "server"), GetPart(cs, "database"), GetPart(cs, "uid"));
        }
    }

    // ── Group tables by CommissionGroup ──────────────────────────────────────
    var cashTables     = Model.TableResults.Where(t => t.CommissionGroup == "Cash").ToList();
    var codTables      = Model.TableResults.Where(t => t.CommissionGroup == "COD").ToList();
    var overlandTables = Model.TableResults.Where(t => t.CommissionGroup == "OverLand").ToList();
    var masterTables   = Model.TableResults.Where(t => t.CommissionGroup == "Master").ToList();
    var sharedTables   = Model.TableResults.Where(t => t.CommissionGroup == "Shared").ToList();

    string StatusIcon(string s) => s switch
    {
        "Done" => "✅", "Failed" => "❌", "Running" => "🔄", "Skipped" => "⏭️", _ => "⏳"
    };
    string StatusClass(string s) => s switch
    {
        "Done"    => "text-green-700 bg-green-50",
        "Failed"  => "text-red-700 bg-red-50",
        "Running" => "text-blue-700 bg-blue-50 animate-pulse",
        _         => "text-gray-500 bg-gray-50"
    };
    string CatBadge(string c) => c switch
    {
        "Source"     => "bg-sky-100 text-sky-700 border border-sky-200",
        "Lookup"     => "bg-violet-100 text-violet-700 border border-violet-200",
        "CnFiltered" => "bg-amber-100 text-amber-700 border border-amber-200",
        "YearMonth"  => "bg-teal-100 text-teal-700 border border-teal-200",
        _            => "bg-gray-100 text-gray-500"
    };
    string CatLabel(string c) => c switch
    {
        "Source"     => "Date-Filtered",
        "Lookup"     => "Lookup",
        "CnFiltered" => "CN-Filtered",
        "YearMonth"  => "Month-Filtered",
        _            => c
    };
    string ServerFriendly(string conn) => conn switch
    {
        "LHR_Billing"       => "LHR Billing Server",
        "Central_OPS"       => "Central OPS Server",
        "Central_OPSNew"    => "Central OPS Server (New)",
        "MIS"               => "MIS Server",
        "DefaultConnection" => "HR Server",
        _                   => conn
    };
    string ServerDot(string conn) => conn switch
    {
        "LHR_Billing"       => "bg-emerald-500",
        "Central_OPS"       => "bg-blue-500",
        "Central_OPSNew"    => "bg-cyan-500",
        "MIS"               => "bg-orange-500",
        "DefaultConnection" => "bg-purple-500",
        _                   => "bg-gray-400"
    };
    string ExtractSchema(string full) => full.Replace("`","").Split('.').FirstOrDefault() ?? "";
    string ExtractTable(string full)  => full.Replace("`","").Split('.').LastOrDefault()  ?? "";

    bool isRunning = Model.OverallStatus == "Running";
}

<div class="max-w-7xl mx-auto px-4 py-6 space-y-6">

    @* ── Header card ─────────────────────────────────────────────────────────── *@
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
        <div class="flex flex-wrap items-center justify-between gap-4">
            <div>
                <h1 class="text-2xl font-bold text-gray-800">Test Data Migration</h1>
                <p class="text-sm text-gray-500 mt-0.5">
                    Copy live server data to localhost for commission testing.
                    <span class="font-medium text-indigo-600">READ-ONLY on live — no writes to production.</span>
                </p>
            </div>
            <div class="flex items-center gap-3 flex-wrap">
                <form method="get" action="" class="flex items-center gap-2">
                    <select name="month" onchange="this.form.submit()"
                            class="text-sm border border-gray-300 rounded-lg px-2 py-1.5 focus:outline-none focus:ring-2 focus:ring-indigo-400">
                        @for (int m = 1; m <= 12; m++)
                        { <option value="@m" selected="@(m == Model.Month)">@monthNames[m-1]</option> }
                    </select>
                    <select name="year" onchange="this.form.submit()"
                            class="text-sm border border-gray-300 rounded-lg px-2 py-1.5 focus:outline-none focus:ring-2 focus:ring-indigo-400">
                        @for (int y = DateTime.Now.Year - 2; y <= DateTime.Now.Year + 1; y++)
                        { <option value="@y" selected="@(y == Model.Year)">@y</option> }
                    </select>
                </form>
                <form method="post" action="/TestDataMigration/StartMigration" id="startForm" class="flex flex-wrap items-end gap-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="year"  value="@Model.Year" />
                    <input type="hidden" name="month" value="@Model.Month" />

                    @* Rows / Table *@
                    <div class="flex flex-col items-start">
                        <label class="text-[10px] text-gray-400 mb-0.5 font-medium uppercase tracking-wide">Rows / Table</label>
                        <select name="rowLimit" @(isRunning ? "disabled" : "")
                                class="text-sm border border-gray-300 rounded-lg px-2 py-1.5 focus:outline-none focus:ring-2 focus:ring-indigo-400 bg-white">
                            @foreach (var o in new (int V,string L)[] {
                                (5_000,"5,000"),(10_000,"10,000"),(50_000,"50,000"),
                                (100_000,"100,000"),(200_000,"200,000"),(300_000,"300,000"),
                                (500_000,"500,000"),(1_000_000,"1,000,000") })
                            { <option value="@o.V" selected="@(o.V == Model.RowLimit || (Model.RowLimit==0 && o.V==500_000))">@o.L</option> }
                        </select>
                    </div>

                    @* City Filter *@
                    <div class="flex flex-col items-start" id="cityFilterWrapper">
                        <label class="text-[10px] text-gray-400 mb-0.5 font-medium uppercase tracking-wide">City Filter</label>
                        <div class="flex items-center gap-1.5">
                            @* All Cities toggle *@
                            <label class="flex items-center gap-1 cursor-pointer text-xs text-gray-600 bg-gray-100 border border-gray-300 rounded-lg px-2 py-1.5 hover:bg-gray-200 select-none">
                                <input type="checkbox" id="allCitiesChk" checked class="accent-indigo-600" @(isRunning ? "disabled" : "") />
                                All Cities
                            </label>
                            @* Multi-select trigger *@
                            <div class="relative" id="cityDropdownWrapper">
                                <button type="button" id="cityDropdownBtn" disabled
                                        class="flex items-center gap-1.5 text-sm border border-gray-300 rounded-lg px-2.5 py-1.5 bg-white hover:bg-gray-50 disabled:opacity-40 disabled:cursor-not-allowed min-w-[130px] justify-between">
                                    <span id="cityBtnLabel" class="text-gray-500 text-xs">Select cities…</span>
                                    <svg class="w-3 h-3 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                                </button>

                                @* Dropdown panel *@
                                <div id="cityDropdownPanel"
                                     class="hidden absolute left-0 top-full mt-1 z-50 bg-white border border-gray-200 rounded-xl shadow-xl w-72 overflow-hidden">
                                    @* Search *@
                                    <div class="p-2 border-b border-gray-100">
                                        <input type="text" id="citySearch" placeholder="Search city…"
                                               class="w-full text-xs border border-gray-300 rounded-lg px-2.5 py-1.5 focus:outline-none focus:ring-2 focus:ring-indigo-400" />
                                    </div>
                                    @* Select All / Clear row *@
                                    <div class="px-3 py-1.5 border-b border-gray-100 flex gap-3 text-xs">
                                        <button type="button" onclick="selectAllCities()" class="text-indigo-600 hover:underline font-medium">Select All</button>
                                        <button type="button" onclick="clearAllCities()" class="text-red-500 hover:underline font-medium">Clear</button>
                                        <span class="ml-auto text-gray-400" id="citySelectedCount">0 selected</span>
                                    </div>
                                    @* City list *@
                                    <div id="cityList" class="max-h-52 overflow-y-auto py-1">
                                        @if (!Model.AvailableCities.Any())
                                        {
                                            <div class="px-3 py-2 text-xs text-gray-400 italic">
                                                No cities available — run migration first to populate lcs_db.city
                                            </div>
                                        }
                                        @foreach (var city in Model.AvailableCities)
                                        {
                                            <label class="city-item flex items-center gap-2.5 px-3 py-1.5 hover:bg-indigo-50 cursor-pointer text-xs text-gray-700"
                                                   data-name="@city.Name.ToLower()">
                                                <input type="checkbox" name="cities" value="@city.Id"
                                                       class="city-chk accent-indigo-600"
                                                       @(Model.SelectedCities.Contains(city.Id) ? "checked" : "") />
                                                <span class="font-mono text-[10px] text-gray-400 w-12 flex-shrink-0">@city.Id</span>
                                                <span>@city.Name</span>
                                            </label>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <button type="submit" id="startBtn" @(isRunning ? "disabled" : "")
                            class="flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 disabled:opacity-50 disabled:cursor-not-allowed">
                        @if (isRunning) { <span class="animate-spin text-xs">🔄</span><span>Running…</span> }
                        else            { <span>▶ Start Migration</span> }
                    </button>
                </form>
            </div>
        </div>

        @* Progress bar *@
        <div class="mt-4" id="progressSection" @(Model.OverallStatus == "Idle" ? "style=display:none" : "")>
            <div class="flex items-center justify-between text-xs text-gray-500 mb-1">
                <span>Overall —
                    <span class="font-semibold text-gray-700" id="progressLocalRows">@Model.TotalLocalRows.ToString("N0")</span> of
                    <span class="font-semibold text-gray-700" id="progressLiveRows">@Model.TotalLiveRows.ToString("N0")</span> rows copied
                </span>
                <span class="font-bold text-indigo-600 text-sm" id="progressPct">@Model.ProgressPercent%</span>
            </div>
            <div class="w-full h-3 bg-gray-200 rounded-full overflow-hidden">
                <div id="progressBar" class="h-3 rounded-full transition-all duration-300 bg-gradient-to-r from-indigo-500 to-cyan-400"
                     style="width:@Model.ProgressPercent%"></div>
            </div>
            <div class="flex justify-between text-[10px] text-gray-400 mt-0.5">
                <span id="progressDone">@Model.DoneTables done</span>
                <span id="progressFailed" class="text-red-400">@(Model.FailedTables > 0 ? $"{Model.FailedTables} failed" : "")</span>
                <span>@Model.TotalTables total tables</span>
            </div>
        </div>

        <div class="mt-3 flex flex-wrap items-center gap-4 text-sm">
            <div class="text-gray-600">Period:
                <span class="font-medium text-gray-800">@Model.RequiredFrom.ToString("MMM dd, yyyy")</span> →
                <span class="font-medium text-gray-800">@Model.RequiredTo.ToString("MMM dd, yyyy")</span>
            </div>
            @if (Model.RowLimit > 0)
            { <div class="text-gray-500">Limit: <span class="font-medium text-amber-700">@Model.RowLimit.ToString("N0") rows/table</span></div> }
            @{
                var obg = Model.OverallStatus switch {
                    "Running" => "bg-blue-100 text-blue-800 border border-blue-300",
                    "Done"    => "bg-green-100 text-green-800 border border-green-300",
                    "Failed"  => "bg-red-100 text-red-800 border border-red-300",
                    _         => "bg-gray-100 text-gray-600 border border-gray-200"
                };
            }
            <span class="px-2.5 py-0.5 rounded-full text-xs font-semibold @obg" id="overallStatus">@Model.OverallStatus</span>
            @if (Model.TotalTables > 0)
            {
                <div class="text-gray-500">Tables:
                    <span id="doneCount" class="font-medium text-green-700">@Model.DoneTables</span> done /
                    <span id="failCount" class="font-medium text-red-600">@Model.FailedTables</span> failed /
                    @Model.TotalTables total
                </div>
            }
        </div>
        @if (TempData["SuccessMessage"] is string sm) { <div class="mt-3 p-3 bg-green-50 border border-green-300 rounded-lg text-sm text-green-800">@sm</div> }
        @if (TempData["ErrorMessage"]   is string em) { <div class="mt-3 p-3 bg-red-50 border border-red-300 rounded-lg text-sm text-red-800">@em</div> }
    </div>

    @* ══════════════════════════════════════════════════════════════════════════
       LIVE SERVER CONNECTIONS CARD
       ══════════════════════════════════════════════════════════════════════ *@
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <div class="px-5 py-3 bg-gray-800 flex items-center justify-between">
            <div>
                <h2 class="text-white font-bold text-sm">Live Server Connections</h2>
                <p class="text-gray-400 text-xs mt-0.5">Read-only connections used during migration — production servers</p>
            </div>
            <span class="text-xs text-gray-400 bg-gray-700 px-2.5 py-1 rounded-full">@connMeta.Count connections</span>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead class="bg-gray-50 text-[11px] text-gray-500 uppercase tracking-wide border-b border-gray-200">
                    <tr>
                        <th class="px-5 py-2.5 text-left">Connection Key</th>
                        <th class="px-4 py-2.5 text-left">Friendly Name</th>
                        <th class="px-4 py-2.5 text-left">Server IP</th>
                        <th class="px-4 py-2.5 text-left">Default Database</th>
                        <th class="px-4 py-2.5 text-left">DB User</th>
                        <th class="px-4 py-2.5 text-left">Used By Commission</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @{
                        var connUsage = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
                        {
                            ["LHR_Billing"]       = "Cash Commission",
                            ["Central_OPS"]       = "COD · OverLand · Shared",
                            ["Central_OPSNew"]    = "(reserved)",
                            ["MIS"]               = "OverLand Commission",
                            ["DefaultConnection"] = "OverLand · Master · Shared",
                        };
                    }
                    @foreach (var conn in connMeta)
                    {
                        var (ip, db, user) = conn.Value;
                        var usage = connUsage.TryGetValue(conn.Key, out var u) ? u : "—";
                        <tr class="hover:bg-gray-50">
                            <td class="px-5 py-2.5">
                                <div class="flex items-center gap-2">
                                    <span class="w-2.5 h-2.5 rounded-full @ServerDot(conn.Key) inline-block flex-shrink-0"></span>
                                    <span class="font-mono text-xs font-bold text-gray-800">@conn.Key</span>
                                </div>
                            </td>
                            <td class="px-4 py-2.5 text-sm text-gray-700">@ServerFriendly(conn.Key)</td>
                            <td class="px-4 py-2.5">
                                <span class="font-mono text-sm font-semibold text-blue-700 bg-blue-50 px-2 py-0.5 rounded border border-blue-200">@ip</span>
                            </td>
                            <td class="px-4 py-2.5 font-mono text-xs text-gray-700">@db</td>
                            <td class="px-4 py-2.5 font-mono text-xs text-gray-500">@user</td>
                            <td class="px-4 py-2.5 text-xs text-gray-600">@usage</td>
                        </tr>
                    }
                    @* Local destination *@
                    <tr class="bg-slate-50 hover:bg-slate-100">
                        <td class="px-5 py-2.5">
                            <div class="flex items-center gap-2">
                                <span class="w-2.5 h-2.5 rounded-full bg-slate-500 inline-block flex-shrink-0"></span>
                                <span class="font-mono text-xs font-bold text-slate-700">localhost (destination)</span>
                            </div>
                        </td>
                        <td class="px-4 py-2.5 text-sm text-slate-600">Local MySQL Server</td>
                        <td class="px-4 py-2.5">
                            <span class="font-mono text-sm font-semibold text-slate-700 bg-slate-100 px-2 py-0.5 rounded border border-slate-300">127.0.0.1:3309</span>
                        </td>
                        <td class="px-4 py-2.5 font-mono text-xs text-slate-600">lcs_hr (local)</td>
                        <td class="px-4 py-2.5 font-mono text-xs text-slate-500">root</td>
                        <td class="px-4 py-2.5 text-xs text-slate-600">Migration destination</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    @* ── Quick-nav legend ─────────────────────────────────────────────────────── *@
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Jump to Commission Section</p>
        <div class="flex flex-wrap gap-2">
            <a href="#sec-cash"     class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm font-medium hover:bg-emerald-100">
                <span class="w-2 h-2 rounded-full bg-emerald-500 inline-block"></span> 1 · Cash Commission
                <span class="text-xs bg-emerald-200 text-emerald-800 px-1.5 rounded-full">@cashTables.Count</span>
            </a>
            <a href="#sec-cod"      class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-orange-50 border border-orange-200 text-orange-800 text-sm font-medium hover:bg-orange-100">
                <span class="w-2 h-2 rounded-full bg-orange-500 inline-block"></span> 2 · COD Commission
                <span class="text-xs bg-orange-200 text-orange-800 px-1.5 rounded-full">@codTables.Count</span>
            </a>
            <a href="#sec-overland" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-blue-50 border border-blue-200 text-blue-800 text-sm font-medium hover:bg-blue-100">
                <span class="w-2 h-2 rounded-full bg-blue-500 inline-block"></span> 3 · OverLand Commission
                <span class="text-xs bg-blue-200 text-blue-800 px-1.5 rounded-full">@overlandTables.Count</span>
            </a>
            <a href="#sec-cod"      class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-purple-50 border border-purple-200 text-purple-800 text-sm font-medium hover:bg-purple-100">
                <span class="w-2 h-2 rounded-full bg-purple-500 inline-block"></span> 4 · Return COD <span class="text-[10px] text-purple-500">(= COD tables)</span>
            </a>
            <a href="#sec-master"   class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-indigo-50 border border-indigo-200 text-indigo-800 text-sm font-medium hover:bg-indigo-100">
                <span class="w-2 h-2 rounded-full bg-indigo-500 inline-block"></span> 5 · Commission Process
                <span class="text-xs bg-indigo-200 text-indigo-800 px-1.5 rounded-full">@masterTables.Count</span>
            </a>
            <a href="#sec-shared"   class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-50 border border-gray-200 text-gray-700 text-sm font-medium hover:bg-gray-100">
                <span class="w-2 h-2 rounded-full bg-gray-400 inline-block"></span> Shared Infrastructure
                <span class="text-xs bg-gray-200 text-gray-600 px-1.5 rounded-full">@sharedTables.Count</span>
            </a>
            <a href="#sec-dest"     class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-slate-50 border border-slate-200 text-slate-700 text-sm font-medium hover:bg-slate-100">
                <span class="w-2 h-2 rounded-full bg-slate-500 inline-block"></span> Destination Tables
                <span class="text-xs bg-slate-200 text-slate-600 px-1.5 rounded-full">@Model.DestinationChecks.Count</span>
            </a>
        </div>
        <div class="flex flex-wrap gap-3 mt-3 pt-3 border-t border-gray-100">
            <span class="text-[10px] text-gray-400 font-semibold uppercase tracking-wide self-center">Filter Type:</span>
            <span class="px-2 py-0.5 rounded text-[11px] font-semibold bg-sky-100 text-sky-700 border border-sky-200">Date-Filtered — by commission period</span>
            <span class="px-2 py-0.5 rounded text-[11px] font-semibold bg-violet-100 text-violet-700 border border-violet-200">Lookup — full copy</span>
            <span class="px-2 py-0.5 rounded text-[11px] font-semibold bg-amber-100 text-amber-700 border border-amber-200">CN-Filtered — by CN list</span>
            <span class="px-2 py-0.5 rounded text-[11px] font-semibold bg-teal-100 text-teal-700 border border-teal-200">Month-Filtered — by Year/Month</span>
        </div>
    </div>

    @* ══════════════════════════════════════════════════════════════════════════
       COMMISSION SECTIONS — Server → Database → Tables tree
       ══════════════════════════════════════════════════════════════════════ *@

    @* ── Reusable server-header partial (inline, avoids local-func Razor issues) *@

    @* ── 1. CASH COMMISSION ──────────────────────────────────────────────────── *@
    <div id="sec-cash" class="rounded-xl shadow-sm border border-emerald-300 overflow-hidden scroll-mt-4">
        <div class="bg-emerald-600 px-5 py-3 flex items-center justify-between">
            <div>
                <h2 class="text-white font-bold text-base">1. Cash Commission</h2>
                <p class="text-emerald-100 text-xs mt-0.5">Billing details, bookings, VAS data — Cash courier commission</p>
            </div>
            <span class="bg-white/20 text-white text-xs font-semibold px-3 py-1 rounded-full">@cashTables.Count tables</span>
        </div>
        @foreach (var cg in cashTables.GroupBy(t => t.LiveConnection).OrderBy(g => g.Key))
        {
            var meta = connMeta.TryGetValue(cg.Key, out var m) ? m : (Ip:"?", Db:"?", User:"?");
            <div class="border-b border-emerald-100 last:border-0">
                <div class="px-5 py-2 bg-emerald-50 flex flex-wrap items-center gap-x-3 gap-y-1">
                    <span class="w-3 h-3 rounded-full @ServerDot(cg.Key) inline-block flex-shrink-0"></span>
                    <span class="text-xs font-bold text-emerald-800 uppercase tracking-wide">Server:</span>
                    <span class="text-sm font-semibold text-emerald-900">@ServerFriendly(cg.Key)</span>
                    <span class="font-mono text-xs text-emerald-700 bg-emerald-100 px-2 py-0.5 rounded border border-emerald-200">@cg.Key</span>
                    <span class="text-gray-300">·</span>
                    <span class="text-xs text-gray-500">IP:</span>
                    <span class="font-mono text-xs font-bold text-blue-700 bg-blue-50 px-2 py-0.5 rounded border border-blue-200">@meta.Ip</span>
                    <span class="text-gray-300">·</span>
                    <span class="text-xs text-gray-400">user: <span class="font-mono text-gray-600">@meta.User</span></span>
                </div>
                @foreach (var dg in cg.GroupBy(t => ExtractSchema(t.FullTableName)).OrderBy(g => g.Key))
                {
                    <div class="ml-6 border-l-2 border-emerald-200 mb-1">
                        <div class="px-4 py-1.5 bg-white flex items-center gap-2">
                            <span class="text-sm">🗄️</span>
                            <span class="text-xs font-bold text-gray-500 uppercase tracking-wide">Database:</span>
                            <span class="font-mono text-sm font-bold text-gray-800">@dg.Key</span>
                            <span class="text-xs text-gray-400">(@dg.Count() table@(dg.Count()==1?"":"s"))</span>
                        </div>
                        <div class="overflow-x-auto">
