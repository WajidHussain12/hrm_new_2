                            <td class="px-4 py-2 text-center destExists text-sm">@(d.Exists ? "✅ Yes" : "❌ No")</td>
                            <td class="px-4 py-2 text-right font-mono text-xs text-gray-600 destCount">@(d.Exists ? d.RowCount.ToString("N0") : "—")</td>
                            <td class="px-4 py-2 text-center destReady">
                                @if (!d.Exists)        { <span class="text-red-600 text-xs font-semibold">❌ Missing</span> }
                                else if (d.RowCount==0){ <span class="text-green-600 text-xs font-semibold">✅ Ready</span> }
                                else                   { <span class="text-amber-600 text-xs font-semibold">⚠️ @d.RowCount.ToString("N0") rows</span> }
