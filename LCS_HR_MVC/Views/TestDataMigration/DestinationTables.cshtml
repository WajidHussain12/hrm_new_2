@model List<LCS_HR_MVC.Models.DestinationTableCheck>
@using System.Text.Json
@{
    ViewData["PageTitle"] = "Destination Tables";

    var createStatus  = TempData["CreateStatus"]  as string ?? "";
    var createSummary = TempData["CreateSummary"] as string ?? "";
    var createResult  = TempData["CreateResult"]  as string ?? "";
    List<string> messages = new();
    if (!string.IsNullOrEmpty(createResult))
    {
        try { messages = JsonSerializer.Deserialize<List<string>>(createResult) ?? new(); }
        catch { }
    }

    // Helper: find a table check by short name
    DestinationTableCheck? Get(string name) =>
        Model.FirstOrDefault(t => t.FullTableName.EndsWith("." + name, StringComparison.OrdinalIgnoreCase));

    // ── Section definitions ────────────────────────────────────────────────────
    // Each section: (title, icon, accent-color-classes, description, table-rows)
    // Table-rows: (tableName, purposeLabel)
    var sections = new[]
    {
        (
            Title: "1 — Cash Commission",
            Icon:  "fas fa-money-bill-wave",
            HeaderBg:    "bg-blue-600",
            HeaderText:  "text-white",
            BadgeBg:     "bg-blue-100 text-blue-700 border-blue-200",
            BorderColor: "border-blue-200",
            Desc: "Input data and incentive breakdowns used to calculate cash delivery commission.",
            Tables: new[]
            {
                ("hr_cash_consignments",   "Cash consignment deliveries — main input"),
                ("hr_vas_incentive_detail","VAS (Value Added Services) incentive breakdown"),
                ("hr_RBI_Incentive_Detail","RBI client incentive detail"),
                ("hr_acknowledgment",      "Delivery acknowledgment records"),
            }
        ),
        (
            Title: "2 — COD Commission",
            Icon:  "fas fa-hand-holding-usd",
            HeaderBg:    "bg-violet-600",
            HeaderText:  "text-white",
            BadgeBg:     "bg-violet-100 text-violet-700 border-violet-200",
            BorderColor: "border-violet-200",
            Desc: "Cash-on-Delivery consignment data and computed COD commission output.",
            Tables: new[]
            {
                ("hr_cod_consignments",    "COD consignments — main input"),
                ("hr_all_cod_consignment", "All COD consignments (merged view)"),
                ("cod_returnshipments",    "COD return shipment records"),
                ("hr_codcommission",       "COD commission result output"),
            }
        ),
        (
            Title: "3 — Overland (OLE) Commission",
            Icon:  "fas fa-truck",
            HeaderBg:    "bg-amber-500",
            HeaderText:  "text-white",
            BadgeBg:     "bg-amber-100 text-amber-700 border-amber-200",
            BorderColor: "border-amber-200",
            Desc: "Overland Express commission calculation and process tracking.",
            Tables: new[]
            {
                ("hr_olecommission",        "OLE commission result output"),
                ("hr_olecommissionprocess", "OLE commission process log"),
            }
        ),
        (
            Title: "4 — Return COD Commission",
            Icon:  "fas fa-undo-alt",
            HeaderBg:    "bg-rose-600",
            HeaderText:  "text-white",
            BadgeBg:     "bg-rose-100 text-rose-700 border-rose-200",
            BorderColor: "border-rose-200",
            Desc: "Return COD consignment data and commission computation for returned shipments.",
            Tables: new[]
            {
                ("hr_codreturn_consignments",      "Return COD consignments — main input"),
                ("hr_codreturncommission",         "Return COD commission result output"),
                ("hr_codreturncommissionprocess",  "Return COD commission process log"),
            }
        ),
        (
            Title: "5 — Commission Process (Master)",
            Icon:  "fas fa-cogs",
            HeaderBg:    "bg-slate-600",
            HeaderText:  "text-white",
            BadgeBg:     "bg-slate-100 text-slate-700 border-slate-200",
            BorderColor: "border-slate-200",
            Desc: "Master commission process table and automation run log — final aggregation.",
            Tables: new[]
            {
                ("hr_commissionprocess",         "Master commission process — final output"),
                ("hr_commission_automation_log", "Automation run log (per year/month)"),
            }
        ),
    };

    int missingCount = Model.Count(t => !t.Exists);
    bool allExist    = missingCount == 0;
}

<div class="max-w-5xl mx-auto px-4 py-6 space-y-6">

    @* ── Header card ──────────────────────────────────────────────────────────── *@
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
        <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
                <h1 class="text-2xl font-bold text-gray-800">Destination Tables</h1>
                <p class="text-sm text-gray-500 mt-1 max-w-2xl">
                    Tables that Automation Commission writes results to. They must exist on
                    <span class="font-semibold text-indigo-600">localhost → lcs_hr</span>
                    with <span class="font-semibold">0 rows</span> before each automation run.
                    Structure is copied from the live server — <span class="text-green-700 font-medium">live server is never modified.</span>
                </p>

                @* ── Overall status badges ──────────────────────────────────── *@
                <div class="mt-3 flex flex-wrap items-center gap-2">
                    <span class="px-3 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-600 border border-gray-200">
                        <i class="fas fa-table mr-1"></i>@Model.Count tables total
                    </span>
                    <span class="px-3 py-1 rounded-full text-xs font-semibold @(allExist ? "bg-green-100 text-green-700 border border-green-300" : "bg-amber-100 text-amber-700 border border-amber-300")">
                        <i class="fas fa-check-circle mr-1"></i>@Model.Count(t => t.Exists) exist
                    </span>
                    @if (missingCount > 0)
                    {
                        <span class="px-3 py-1 rounded-full text-xs font-semibold bg-red-100 text-red-700 border border-red-300">
                            <i class="fas fa-exclamation-circle mr-1"></i>@missingCount missing
                        </span>
                    }
                    <span class="px-3 py-1 rounded-full text-xs font-semibold bg-emerald-100 text-emerald-700 border border-emerald-300">
                        <i class="fas fa-bolt mr-1"></i>@Model.Count(t => t.IsReady) ready
                    </span>
                </div>
            </div>

            <form method="post" action="/TestDataMigration/CreateDestinationTables" id="createForm">
                @Html.AntiForgeryToken()
                <button type="submit" id="createBtn"
                        onclick="this.disabled=true; this.innerHTML='<i class=\'fas fa-spinner fa-spin\'></i> Creating…'; this.form.submit();"
                        class="flex items-center gap-2 px-5 py-2.5 bg-emerald-600 text-white text-sm font-semibold rounded-lg hover:bg-emerald-700 active:bg-emerald-800 disabled:opacity-50 disabled:cursor-not-allowed shadow-sm transition-colors">
                    <i class="fas fa-plus-circle"></i>
                    Create These All Tables
                </button>
                <p class="text-[11px] text-gray-400 mt-1.5 text-center">DDL from live → localhost only</p>
            </form>
        </div>

        @* ── Create result panel ───────────────────────────────────────────── *@
        @if (!string.IsNullOrEmpty(createSummary))
        {
            var alertBg = createStatus == "success" ? "bg-green-50 border-green-300"
                        : createStatus == "failed"  ? "bg-red-50 border-red-300"
                                                    : "bg-sky-50 border-sky-300";
            var alertText = createStatus == "success" ? "text-green-800"
                          : createStatus == "failed"  ? "text-red-800"
                                                      : "text-sky-800";
            <div class="mt-4 p-3 rounded-lg border @alertBg">
                <div class="font-semibold text-sm @alertText flex items-center gap-2 mb-1">
                    @if (createStatus == "success")      { <i class="fas fa-check-circle text-green-500"></i><span>Tables created successfully</span> }
                    else if (createStatus == "failed")   { <i class="fas fa-times-circle text-red-500"></i><span>Some tables failed</span> }
                    else                                  { <i class="fas fa-info-circle text-sky-500"></i><span>No new tables needed</span> }
                    <span class="font-normal text-xs ml-1 opacity-70">— @createSummary</span>
                </div>
                @if (messages.Count > 0)
                {
                    <div class="mt-2 font-mono text-xs space-y-0.5 max-h-36 overflow-y-auto">
                        @foreach (var msg in messages)
                        {
                            var mc = msg.StartsWith("[CREATED]") ? "text-green-700"
                                   : msg.StartsWith("[FAILED]")  ? "text-red-600"
                                                                 : "text-gray-400";
                            <div class="@mc">@msg</div>
                        }
                    </div>
                }
            </div>
        }
    </div>

    @* ── Commission sections ───────────────────────────────────────────────────── *@
    @foreach (var grp in sections)
    {
        var sectionTables = grp.Tables
            .Select((row, idx) => new { Idx = idx, Name = row.Item1, Purpose = row.Item2, Check = Get(row.Item1) })
            .ToList();

        int secMissing = sectionTables.Count(r => r.Check == null || !r.Check.Exists);
        int secReady   = sectionTables.Count(r => r.Check != null && r.Check.IsReady);

        <div class="bg-white rounded-xl shadow-sm border @grp.BorderColor overflow-hidden">

            @* Section header *@
            <div class="@grp.HeaderBg @grp.HeaderText px-5 py-3 flex flex-wrap items-center justify-between gap-3">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-white bg-opacity-20 flex items-center justify-center flex-shrink-0">
                        <i class="@grp.Icon text-sm"></i>
                    </div>
                    <div>
                        <h2 class="font-bold text-base leading-tight">@grp.Title</h2>
                        <p class="text-xs opacity-80 mt-0.5">@grp.Desc</p>
                    </div>
                </div>
                <div class="flex items-center gap-2 flex-shrink-0">
                    @if (secMissing > 0)
                    {
                        <span class="px-2.5 py-0.5 rounded-full text-xs font-bold bg-white bg-opacity-20 border border-white border-opacity-30">
                            ❌ @secMissing missing
                        </span>
                    }
                    <span class="px-2.5 py-0.5 rounded-full text-xs font-bold bg-white bg-opacity-20 border border-white border-opacity-30">
                        ✅ @secReady / @sectionTables.Count ready
                    </span>
                </div>
            </div>

            @* Tables *@
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-gray-50 text-[11px] text-gray-500 uppercase tracking-wide border-b border-gray-100">
                        <tr>
                            <th class="px-4 py-2 text-left w-6">#</th>
                            <th class="px-4 py-2 text-left">Table Name</th>
                            <th class="px-4 py-2 text-left hidden sm:table-cell">Purpose</th>
                            <th class="px-4 py-2 text-center">Exists?</th>
                            <th class="px-4 py-2 text-right">Rows</th>
                            <th class="px-4 py-2 text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                        @foreach (var row in sectionTables)
                        {
                            var d = row.Check;
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-4 py-2.5 text-gray-400 text-xs font-mono">@(row.Idx + 1)</td>
                                <td class="px-4 py-2.5">
                                    <span class="font-mono text-xs text-gray-800 bg-gray-100 px-1.5 py-0.5 rounded">
                                        lcs_hr.<span class="font-semibold">@row.Name</span>
                                    </span>
                                </td>
                                <td class="px-4 py-2.5 text-xs text-gray-500 hidden sm:table-cell">@row.Purpose</td>
                                <td class="px-4 py-2.5 text-center text-sm">
                                    @if (d == null || !d.Exists)
                                    { <span class="text-red-500">❌</span> }
                                    else
                                    { <span class="text-green-600">✅</span> }
                                </td>
                                <td class="px-4 py-2.5 text-right font-mono text-xs text-gray-600">
                                    @(d != null && d.Exists ? d.RowCount.ToString("N0") : "—")
                                </td>
                                <td class="px-4 py-2.5 text-center">
                                    @if (d == null || !d.Exists)
                                    {
                                        <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold bg-red-50 text-red-600 border border-red-200">Missing</span>
                                    }
                                    else if (d.RowCount == 0)
                                    {
                                        <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold bg-green-50 text-green-700 border border-green-200">✅ Ready</span>
                                    }
                                    else
                                    {
                                        <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold bg-amber-50 text-amber-700 border border-amber-200">⚠️ @d.RowCount.ToString("N0") rows</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @* ── Footer note ──────────────────────────────────────────────────────────── *@
    <div class="bg-gray-50 rounded-xl border border-gray-200 px-5 py-3">
        <p class="text-xs text-gray-400">
            <i class="fas fa-info-circle mr-1.5 text-gray-400"></i>
            <strong class="text-gray-500">Create These All Tables</strong> fetches
            <code class="bg-white px-1 rounded border border-gray-200">SHOW CREATE TABLE</code>
            from the <span class="font-medium text-gray-500">live server (172.16.0.10 → lcs_hr)</span>
            and runs the DDL on <span class="font-medium text-gray-500">localhost:3309 → lcs_hr</span>.
            Tables that already exist are skipped. No data is written. Live server is <strong class="text-green-600">never modified</strong>.
        </p>
    </div>

</div>
