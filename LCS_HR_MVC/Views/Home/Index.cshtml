@model LCS_HR_MVC.Models.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "LCS - HR Portal";
    ViewData["PageTitle"] = "Dashboard";
}

<div class="tw-animate-[pageFadeIn_0.5s_ease-out]">
    
    <section class="tw-mb-10">
        <div class="tw-relative tw-overflow-hidden tw-rounded-3xl tw-bg-gradient-to-br tw-from-slate-900 tw-via-slate-800 tw-to-slate-900 tw-p-8 sm:tw-p-10 tw-shadow-[0_8px_30px_rgb(0,0,0,0.12)] tw-border tw-border-slate-700">
            <!-- Modern Decorative Gradients -->
            <div class="tw-absolute tw-top-[-50%] tw-right-[-10%] tw-w-96 tw-h-96 tw-bg-amber-500 tw-opacity-10 tw-blur-[100px] tw-rounded-full tw-pointer-events-none"></div>
            <div class="tw-absolute tw-bottom-[-20%] tw-left-[-10%] tw-w-72 tw-h-72 tw-bg-orange-500 tw-opacity-10 tw-blur-[100px] tw-rounded-full tw-pointer-events-none"></div>
            <div class="tw-absolute tw-inset-0 tw-bg-[url('/images/noise.png')] tw-opacity-5 tw-mix-blend-overlay tw-pointer-events-none"></div>

            <div class="tw-relative tw-z-10 tw-flex tw-flex-col md:tw-flex-row tw-items-center tw-justify-between tw-gap-8">
                <div class="tw-text-center md:tw-text-left tw-flex-1">
                    <div class="tw-inline-flex tw-items-center tw-gap-2.5 tw-px-3.5 tw-py-1.5 tw-rounded-full tw-bg-slate-800/80 tw-border tw-border-slate-600/50 tw-shadow-inner tw-backdrop-blur-sm tw-mb-5">
                        <span class="tw-relative tw-flex tw-h-2.5 tw-w-2.5">
                            <span class="tw-animate-ping tw-absolute tw-inline-flex tw-h-full tw-w-full tw-rounded-full tw-bg-emerald-400 tw-opacity-75"></span>
                            <span class="tw-relative tw-inline-flex tw-rounded-full tw-h-2.5 tw-w-2.5 tw-bg-emerald-500"></span>
                        </span>
                        <span class="tw-text-[10px] tw-font-black tw-text-emerald-400 tw-uppercase tw-tracking-[0.2em]">System Live</span>
                    </div>
                    <h2 class="tw-text-3xl sm:tw-text-4xl lg:tw-text-5xl tw-font-black tw-text-white tw-tracking-tight tw-leading-tight">
                        Welcome, <span class="tw-text-transparent tw-bg-clip-text tw-bg-gradient-to-r tw-from-amber-300 tw-to-amber-500">@User.Identity?.Name</span>! 👋
                    </h2>
                    <p class="tw-text-slate-300 tw-mt-3 tw-text-[15px] sm:tw-text-base tw-font-medium tw-leading-relaxed tw-max-w-2xl">
                        A complete overview of today’s HR operations and analytics is available here. Please monitor the workflows and pending tasks.
                    </p>
                </div>

                <div class="tw-flex tw-items-center tw-gap-5 tw-bg-slate-800/50 tw-p-2 tw-pr-6 tw-rounded-2xl tw-border tw-border-slate-700/50 tw-backdrop-blur-md">
                    <div class="tw-w-14 tw-h-14 tw-bg-gradient-to-br tw-from-amber-400 tw-to-orange-500 tw-rounded-xl tw-flex tw-items-center tw-justify-center tw-shadow-[0_0_20px_rgba(245,197,24,0.3)] tw-rotate-3 group-hover:tw-rotate-0 tw-transition-transform tw-duration-300">
                        <i class="fa-solid fa-chart-line tw-text-slate-900 tw-text-xl"></i>
                    </div>
                    <div class="tw-hidden lg:tw-flex tw-flex-col tw-text-left">
                        <p class="tw-text-slate-400 tw-text-[10px] tw-font-bold tw-uppercase tw-tracking-widest tw-mb-0.5">Current Session</p>
                        <p class="tw-text-white tw-font-mono tw-font-semibold tw-text-sm tw-tracking-tight w-full">@DateTime.Now.ToString("dd MMM yyyy, HH:mm")</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @if (!Model.ShowDashboard)
    {
        <section class="tw-bg-white tw-rounded-3xl tw-border tw-border-slate-200/80 tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-overflow-hidden tw-group">
            <div class="tw-grid tw-gap-0 lg:tw-grid-cols-[1.2fr_0.8fr]">
                <div class="tw-p-8 sm:tw-p-14">
                    <div class="tw-flex tw-items-center tw-gap-3 tw-mb-8">
                        <span class="tw-w-12 tw-h-1.5 tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-rounded-full"></span>
                        <span class="tw-text-xs tw-font-black tw-text-slate-400 tw-uppercase tw-tracking-[0.25em]">Core Enterprise</span>
                    </div>

                    <h2 class="tw-text-4xl sm:tw-text-5xl lg:tw-text-6xl tw-font-black tw-text-slate-900 tw-leading-[1.1] tw-tracking-tight">
                        Next-Gen <br class="tw-hidden sm:tw-block" />
                        <span class="tw-text-transparent tw-bg-clip-text tw-bg-gradient-to-r tw-from-amber-500 tw-to-orange-500">Human Resource</span> <br class="tw-hidden sm:tw-block" />
                        Management.
                    </h2>

                    <p class="tw-mt-6 tw-text-[17px] tw-text-slate-500 tw-leading-relaxed tw-max-w-xl">
                        Aapka active workspace ab optimized hai payroll, commission, aur settlement workflows ke liye. Legacy ERP ki reliability aur modern UI ka behtareen imtizaj.
                    </p>

                    <div class="tw-mt-12 tw-grid tw-gap-5 sm:tw-grid-cols-2">
                        <div class="tw-relative tw-p-6 tw-bg-slate-50 tw-rounded-2xl tw-border tw-border-slate-100 hover:tw-border-amber-300/50 hover:tw-shadow-md hover:tw-bg-white tw-transition-all tw-duration-300">
                            <div class="tw-absolute tw-top-0 tw-right-0 tw-w-24 tw-h-24 tw-bg-gradient-to-bl tw-from-amber-100/50 tw-to-transparent tw-rounded-bl-full tw-opacity-0 group-hover:tw-opacity-100 tw-transition-opacity"></div>
                            <div class="tw-w-12 tw-h-12 tw-bg-white tw-rounded-xl tw-flex tw-items-center tw-justify-center tw-shadow-sm tw-mb-5 tw-border tw-border-slate-100 tw-text-amber-500">
                                <i class="fa-solid fa-calendar-check tw-text-lg"></i>
                            </div>
                            <p class="tw-text-[11px] tw-font-bold tw-text-slate-400 tw-uppercase tw-tracking-widest tw-mb-1">Financial Year</p>
                            <p class="tw-text-2xl tw-font-black tw-text-slate-800">@Model.FiscalRange</p>
                        </div>

                        <div class="tw-relative tw-p-6 tw-bg-slate-50 tw-rounded-2xl tw-border tw-border-slate-100 hover:tw-border-orange-300/50 hover:tw-shadow-md hover:tw-bg-white tw-transition-all tw-duration-300">
                            <div class="tw-absolute tw-top-0 tw-right-0 tw-w-24 tw-h-24 tw-bg-gradient-to-bl tw-from-orange-100/50 tw-to-transparent tw-rounded-bl-full tw-opacity-0 group-hover:tw-opacity-100 tw-transition-opacity"></div>
                            <div class="tw-w-12 tw-h-12 tw-bg-white tw-rounded-xl tw-flex tw-items-center tw-justify-center tw-shadow-sm tw-mb-5 tw-border tw-border-slate-100 tw-text-orange-500">
                                <i class="fa-solid fa-layer-group tw-text-lg"></i>
                            </div>
                            <p class="tw-text-[11px] tw-font-bold tw-text-slate-400 tw-uppercase tw-tracking-widest tw-mb-1">Platform</p>
                            <p class="tw-text-2xl tw-font-black tw-text-slate-800">.NET 8.0</p>
                        </div>
                    </div>
                </div>

                <div class="tw-relative tw-flex tw-items-center tw-justify-center tw-bg-gradient-to-br tw-from-amber-50 tw-to-orange-50/50 tw-p-12 tw-border-l tw-border-slate-100 tw-overflow-hidden">
                    <div class="tw-absolute tw-w-[150%] tw-h-[150%] tw-bg-[url('/images/noise.png')] tw-opacity-[0.03] tw-mix-blend-multiply tw-pointer-events-none"></div>
                    <div class="tw-absolute tw-w-80 tw-h-80 tw-bg-amber-300/20 tw-rounded-full tw-blur-3xl"></div>
                    <img id="Image1" src="~/images/lcs_trans.png" alt="LCS HR" class="tw-relative tw-z-10 tw-max-h-[320px] tw-w-auto tw-object-contain tw-drop-shadow-2xl tw-animate-[pulse_4s_ease-in-out_infinite]" />
                </div>
            </div>
        </section>
    }
    else
    {
        <div id="divDashboard" class="tw-space-y-6">
            
            <div class="tw-grid tw-grid-cols-1 sm:tw-grid-cols-2 lg:tw-grid-cols-4 tw-gap-6">
                <!-- Stat Card 1 -->
                <div class="tw-relative tw-bg-white tw-p-6 tw-rounded-2xl tw-border tw-border-slate-200/80 tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:tw-shadow-[0_8px_30px_rgb(0,0,0,0.08)] hover:-tw-translate-y-1 tw-transition-all tw-duration-300 tw-overflow-hidden tw-group">
                    <div class="tw-absolute tw-top-0 tw-right-0 tw-w-32 tw-h-32 tw-bg-gradient-to-bl tw-from-blue-50/80 tw-to-transparent tw-rounded-bl-full tw-pointer-events-none"></div>
                    <div class="tw-relative tw-z-10">
                        <div class="tw-flex tw-items-center tw-justify-between tw-mb-5">
                            <div class="tw-w-12 tw-h-12 tw-bg-blue-50 tw-border tw-border-blue-100 tw-rounded-xl tw-flex tw-items-center tw-justify-center group-hover:tw-scale-110 tw-transition-transform tw-duration-300"><i class="fa-solid fa-users tw-text-blue-600 tw-text-lg"></i></div>
                            <span class="tw-inline-flex tw-items-center tw-gap-1 tw-text-[11px] tw-font-bold tw-text-emerald-600 tw-bg-emerald-50 tw-border tw-border-emerald-100 tw-px-2 tw-py-1 tw-rounded-lg shadow-sm"><i class="fa-solid fa-arrow-trend-up tw-text-[10px]"></i> +12%</span>
                        </div>
                        <p class="tw-text-[11px] tw-font-bold tw-text-slate-400 tw-uppercase tw-tracking-widest tw-mb-1">Total Workforce</p>
                        <p class="tw-text-3xl tw-font-black tw-text-slate-800 tw-tracking-tight">2,480</p>
                    </div>
                </div>

                <!-- Stat Card 2 -->
                <div class="tw-relative tw-bg-white tw-p-6 tw-rounded-2xl tw-border tw-border-slate-200/80 tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:tw-shadow-[0_8px_30px_rgb(0,0,0,0.08)] hover:-tw-translate-y-1 tw-transition-all tw-duration-300 tw-overflow-hidden tw-group">
                    <div class="tw-absolute tw-top-0 tw-right-0 tw-w-32 tw-h-32 tw-bg-gradient-to-bl tw-from-amber-50/80 tw-to-transparent tw-rounded-bl-full tw-pointer-events-none"></div>
                    <div class="tw-relative tw-z-10">
                        <div class="tw-flex tw-items-center tw-justify-between tw-mb-5">
                            <div class="tw-w-12 tw-h-12 tw-bg-amber-50 tw-border tw-border-amber-100 tw-rounded-xl tw-flex tw-items-center tw-justify-center group-hover:tw-scale-110 tw-transition-transform tw-duration-300"><i class="fa-solid fa-file-invoice-dollar tw-text-amber-500 tw-text-lg"></i></div>
                            <span class="tw-text-[10px] tw-font-black tw-text-slate-500 tw-bg-slate-50 tw-border tw-border-slate-100 tw-px-2 tw-py-1 tw-rounded-lg tw-uppercase tw-tracking-widest">Monthly</span>
                        </div>
                        <p class="tw-text-[11px] tw-font-bold tw-text-slate-400 tw-uppercase tw-tracking-widest tw-mb-1">Pending Payroll</p>
                        <p class="tw-text-3xl tw-font-black tw-text-slate-800 tw-tracking-tight">142</p>
                    </div>
                </div>

                <!-- Stat Card 3 -->
                <div class="tw-relative tw-bg-white tw-p-6 tw-rounded-2xl tw-border tw-border-slate-200/80 tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:tw-shadow-[0_8px_30px_rgb(0,0,0,0.08)] hover:-tw-translate-y-1 tw-transition-all tw-duration-300 tw-overflow-hidden tw-group">
                    <div class="tw-absolute tw-top-0 tw-right-0 tw-w-32 tw-h-32 tw-bg-gradient-to-bl tw-from-emerald-50/80 tw-to-transparent tw-rounded-bl-full tw-pointer-events-none"></div>
                    <div class="tw-relative tw-z-10">
                        <div class="tw-flex tw-items-center tw-justify-between tw-mb-5">
                            <div class="tw-w-12 tw-h-12 tw-bg-emerald-50 tw-border tw-border-emerald-100 tw-rounded-xl tw-flex tw-items-center tw-justify-center group-hover:tw-scale-110 tw-transition-transform tw-duration-300"><i class="fa-solid fa-check-double tw-text-emerald-600 tw-text-lg"></i></div>
                            <span class="tw-inline-flex tw-items-center tw-gap-1 tw-text-[11px] tw-font-bold tw-text-emerald-700 tw-bg-emerald-100/50 tw-border tw-border-emerald-200 tw-px-2 tw-py-1 tw-rounded-lg shadow-sm"><i class="fa-solid fa-medal tw-text-[10px]"></i> 98%</span>
                        </div>
                        <p class="tw-text-[11px] tw-font-bold tw-text-slate-400 tw-uppercase tw-tracking-widest tw-mb-1">Settlements Done</p>
                        <p class="tw-text-3xl tw-font-black tw-text-slate-800 tw-tracking-tight">89</p>
                    </div>
                </div>

                <!-- Stat Card 4 -->
                <div class="tw-relative tw-bg-white tw-p-6 tw-rounded-2xl tw-border tw-border-slate-200/80 tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:tw-shadow-[0_8px_30px_rgb(0,0,0,0.08)] hover:-tw-translate-y-1 tw-transition-all tw-duration-300 tw-overflow-hidden tw-group">
                    <div class="tw-absolute tw-top-0 tw-right-0 tw-w-32 tw-h-32 tw-bg-gradient-to-bl tw-from-red-50/80 tw-to-transparent tw-rounded-bl-full tw-pointer-events-none"></div>
                    <div class="tw-relative tw-z-10">
                        <div class="tw-flex tw-items-center tw-justify-between tw-mb-5">
                            <div class="tw-w-12 tw-h-12 tw-bg-red-50 tw-border tw-border-red-100 tw-rounded-xl tw-flex tw-items-center tw-justify-center group-hover:tw-scale-110 tw-transition-transform tw-duration-300"><i class="fa-solid fa-clock-rotate-left tw-text-red-500 tw-text-lg"></i></div>
                            <span class="tw-inline-flex tw-items-center tw-gap-1 tw-text-[11px] tw-font-bold tw-text-red-600 tw-bg-red-50 tw-border tw-border-red-100 tw-px-2 tw-py-1 tw-rounded-lg shadow-sm"><i class="fa-solid fa-circle-exclamation tw-text-[10px]"></i> High</span>
                        </div>
                        <p class="tw-text-[11px] tw-font-bold tw-text-slate-400 tw-uppercase tw-tracking-widest tw-mb-1">Late Comers</p>
                        <p class="tw-text-3xl tw-font-black tw-text-slate-800 tw-tracking-tight">12</p>
                    </div>
                </div>
            </div>

            <div class="tw-grid tw-gap-6 xl:tw-grid-cols-2">
                <div class="tw-bg-white tw-p-8 tw-rounded-3xl tw-border tw-border-slate-200/80 tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-relative tw-overflow-hidden">
                    <div class="tw-absolute tw-top-[-10%] tw-left-[50%] tw-w-48 tw-h-48 tw-bg-amber-400 tw-opacity-5 tw-blur-3xl tw-rounded-full tw-pointer-events-none"></div>
                    <div class="tw-relative tw-z-10 tw-flex tw-items-center tw-justify-between tw-mb-8">
                        <div>
                            <div class="tw-flex tw-items-center tw-gap-2 tw-mb-1">
                                <span class="tw-w-2 tw-h-2 tw-bg-amber-400 tw-rounded-full"></span>
                                <h3 class="tw-text-lg tw-font-black tw-text-slate-900 tw-tracking-tight">Extras Trend</h3>
                            </div>
                            <p class="tw-text-xs tw-font-semibold tw-text-slate-400">Processed extras by month</p>
                        </div>
                        <div class="tw-w-10 tw-h-10 tw-bg-amber-50 tw-border tw-border-amber-100 tw-rounded-xl tw-flex tw-items-center tw-justify-center tw-shadow-sm">
                            <i class="fa-solid fa-arrow-trend-up tw-text-amber-500"></i>
                        </div>
                    </div>
                    <div id="chartContainerExtras" class="tw-h-[350px] tw-w-full tw-relative tw-z-10"></div>
                </div>

                <div class="tw-bg-white tw-p-8 tw-rounded-3xl tw-border tw-border-slate-200/80 tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-relative tw-overflow-hidden">
                    <div class="tw-absolute tw-top-[-10%] tw-left-[50%] tw-w-48 tw-h-48 tw-bg-red-400 tw-opacity-5 tw-blur-3xl tw-rounded-full tw-pointer-events-none"></div>
                    <div class="tw-relative tw-z-10 tw-flex tw-items-center tw-justify-between tw-mb-8">
                        <div>
                            <div class="tw-flex tw-items-center tw-gap-2 tw-mb-1">
                                <span class="tw-w-2 tw-h-2 tw-bg-red-400 tw-rounded-full"></span>
                                <h3 class="tw-text-lg tw-font-black tw-text-slate-900 tw-tracking-tight">Deductions Trend</h3>
                            </div>
                            <p class="tw-text-xs tw-font-semibold tw-text-slate-400">System recorded monthly deductions</p>
                        </div>
                        <div class="tw-w-10 tw-h-10 tw-bg-red-50 tw-border tw-border-red-100 tw-rounded-xl tw-flex tw-items-center tw-justify-center tw-shadow-sm">
                            <i class="fa-solid fa-arrow-trend-down tw-text-red-500"></i>
                        </div>
                    </div>
                    <div id="chartContainerDeduction" class="tw-h-[350px] tw-w-full tw-relative tw-z-10"></div>
                </div>
            </div>
        </div>

        <script type="text/javascript">
                window.extrasChartData = @Html.Raw(Model.ExtrasChartData);
                window.deductionChartData = @Html.Raw(Model.DeductionChartData);
        </script>
    }
</div>

@section Scripts {
    <script src="~/js/canvasjs.min.js"></script>
    <script src="~/js/home.js"></script>
}