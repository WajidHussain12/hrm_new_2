@model LCS_HR_MVC.Models.ViewModels.ChangePasswordViewModel

@{
    var pageTitle = Model.IsExpired ? "Security Alert: Expired Key" : "Authentication Update";
    ViewData["PageTitle"] = pageTitle;
    ViewData["Title"] = pageTitle;
}

@section Styles {
    <style>
        /* Modern Fade Animation */
        @@keyframes slideUp { 
            from { opacity: 0; transform: translateY(15px); } 
            to { opacity: 1; transform: translateY(0); } 
        }
        .animate-main { animation: slideUp 0.4s ease-out; }
    </style>
}

<div class="tw-p-4 sm:tw-p-6 tw-bg-transparent tw-min-h-screen animate-main">

    <!-- Messages -->
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-red-50 tw-border tw-border-red-100 tw-rounded-xl tw-text-red-600 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(239,68,68,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-red-100 tw-text-red-500 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0">
                <i class="fas fa-exclamation-triangle tw-text-[10px]"></i>
            </div>
            <span class="tw-pt-0.5">@Model.ErrorMessage</span>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-emerald-50 tw-border tw-border-emerald-100 tw-rounded-xl tw-text-emerald-700 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(16,185,129,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-emerald-100 tw-text-emerald-600 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0">
                <i class="fas fa-check tw-text-[10px]"></i>
            </div>
            <span class="tw-pt-0.5">@Model.SuccessMessage</span>
        </div>
    }

    <!-- Header Map -->
    <div class="tw-flex tw-flex-col sm:tw-flex-row sm:tw-items-end tw-justify-between tw-gap-4 tw-mb-8">
        <div>
            <nav class="tw-flex tw-items-center tw-gap-2.5 tw-text-[11px] tw-font-bold tw-text-slate-400 tw-mb-2 tw-uppercase tw-tracking-widest">
                <div class="tw-flex tw-items-center tw-gap-1.5 hover:tw-text-[#eab308] tw-transition-colors tw-cursor-pointer">
                    <i class="fas fa-shield-alt tw-text-[10px] tw-text-slate-300"></i>
                    <span>Account Access</span>
                </div>
                <i class="fas fa-chevron-right tw-text-[8px] tw-text-slate-300"></i> 
                <span class="tw-text-slate-600 tw-bg-white tw-px-2 tw-py-0.5 tw-rounded-md tw-border tw-border-slate-200 tw-shadow-sm">Security Policy</span>
            </nav>
            <div class="tw-flex tw-flex-col">
                <h1 class="tw-text-3xl tw-font-black tw-text-slate-900 tw-leading-tight tw-tracking-tight">Credential Rotation</h1>
                <div class="tw-h-1.5 tw-w-10 tw-bg-gradient-to-r tw-from-[#f5c518] tw-to-transparent tw-rounded-full tw-mt-1"></div>
            </div>
            <p class="tw-text-slate-500 tw-text-sm tw-font-medium tw-mt-3 tw-leading-relaxed">Rotate your system authentication key to maintain strict security compliance.</p>
        </div>
    </div>

    <!-- Main Section Structure -->
    <div class="tw-grid lg:tw-grid-cols-12 tw-gap-6 xl:tw-gap-8 align-top tw-max-w-6xl">
        
        <!-- Left Info Panel -->
        <div class="lg:tw-col-span-5 xl:tw-col-span-5">
             <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-p-8 tw-h-full tw-flex tw-flex-col tw-justify-center tw-relative tw-overflow-hidden">
                <div class="tw-absolute tw-top-0 tw-right-0 tw-w-64 tw-h-64 tw-bg-gradient-to-bl tw-from-amber-50/50 tw-to-transparent tw-rounded-bl-full tw-pointer-events-none z-0"></div>

                <div class="tw-relative tw-z-10">
                    <div class="tw-w-16 tw-h-16 tw-bg-gradient-to-br tw-from-slate-900 tw-to-slate-800 tw-rounded-2xl tw-flex tw-items-center tw-justify-center tw-shadow-[0_8px_20px_rgba(15,23,42,0.2)] tw-mb-6">
                        <i class="fas fa-fingerprint tw-text-3xl tw-text-amber-400"></i>
                    </div>
                    
                    <h3 class="tw-text-xl tw-font-black tw-text-slate-800 tw-mb-2">Security Lifecycle</h3>
                    <p class="tw-text-sm tw-font-medium tw-text-slate-500 tw-mb-8 tw-leading-relaxed">Your authentication token ensures secure access to internal data. Please follow organizational policy for robust key creation.</p>
                    
                    <div class="tw-space-y-4">
                        <div class="tw-flex tw-items-start tw-gap-3 tw-bg-slate-50 tw-p-3.5 tw-rounded-xl tw-border tw-border-slate-100">
                            <i class="fas fa-layer-group tw-text-emerald-500 tw-mt-0.5"></i>
                            <div>
                                <h4 class="tw-text-xs tw-font-bold tw-text-slate-700 tw-uppercase tw-tracking-widest">Complex Hash</h4>
                                <p class="tw-text-[11px] tw-text-slate-500 tw-font-medium tw-mt-1 tw-leading-tight">Combine numbers, symbols, and mixed-case letters.</p>
                            </div>
                        </div>
                        <div class="tw-flex tw-items-start tw-gap-3 tw-bg-slate-50 tw-p-3.5 tw-rounded-xl tw-border tw-border-slate-100">
                            <i class="fas fa-history tw-text-indigo-500 tw-mt-0.5"></i>
                            <div>
                                <h4 class="tw-text-xs tw-font-bold tw-text-slate-700 tw-uppercase tw-tracking-widest">No Recycling</h4>
                                <p class="tw-text-[11px] tw-text-slate-500 tw-font-medium tw-mt-1 tw-leading-tight">Do not repeat previous security patterns.</p>
                            </div>
                        </div>
                        @if(Model.IsExpired)
                        {
                            <div class="tw-flex tw-items-start tw-gap-3 tw-bg-red-50 tw-p-3.5 tw-rounded-xl tw-border tw-border-red-100 tw-mt-2">
                                <i class="fas fa-clock tw-text-red-500 tw-mt-0.5"></i>
                                <div>
                                    <h4 class="tw-text-xs tw-font-bold tw-text-red-700 tw-uppercase tw-tracking-widest">Enforced Timeout</h4>
                                    <p class="tw-text-[11px] tw-text-red-500 tw-font-medium tw-mt-1 tw-leading-tight">Your existing access has expired. Update mandatory.</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
             </div>
        </div>

        <!-- Right Form Panel -->
        <div class="lg:tw-col-span-7 xl:tw-col-span-7">
            <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-relative tw-h-full">
                
                <div class="tw-p-6 tw-bg-gradient-to-r tw-from-slate-900 tw-to-slate-800 tw-relative tw-z-10">
                    <h3 class="tw-text-amber-400 tw-font-black tw-text-xs tw-uppercase tw-tracking-[0.2em] tw-flex tw-items-center tw-gap-2">
                        <div class="tw-w-6 tw-h-6 tw-bg-white/10 tw-rounded-md tw-flex tw-items-center tw-justify-center">
                            <i class="fas fa-key"></i>
                        </div>
                        Authorization Form
                    </h3>
                </div>

                <form asp-controller="Account" asp-action="@(Model.IsExpired ? "ChangePasswordOnExpire" : "ChangePassword")" method="post" class="tw-p-8 tw-space-y-6">
                    
                    <!-- Username -->
                    <div>
                        <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-400 tw-uppercase tw-tracking-wider tw-mb-1.5">Target Account</label>
                        <div class="tw-flex tw-items-center tw-bg-slate-50 tw-rounded-xl tw-px-4 tw-py-4 tw-border tw-border-slate-200 tw-shadow-inner opacity-80 tw-cursor-not-allowed">
                            <i class="fas fa-id-badge tw-text-slate-400 tw-mr-3 tw-text-base"></i>
                            <input type="text" asp-for="Username" disabled class="tw-bg-transparent tw-w-full tw-text-sm tw-font-mono tw-font-bold tw-text-indigo-600 tw-outline-none tw-cursor-not-allowed" />
                        </div>
                        <input type="hidden" asp-for="Username" />
                    </div>

                    <div class="tw-border-t tw-border-slate-100 tw-pt-4 tw-mt-2"></div>

                    <!-- Current Password -->
                    <div>
                        <label asp-for="OldPassword" class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Existing Handshake <span class="tw-text-red-500">*</span></label>
                        <div class="tw-relative">
                            <i class="fas fa-unlock tw-absolute tw-left-4 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-sm"></i>
                            <input asp-for="OldPassword" type="password" class="tw-w-full tw-pl-12 tw-pr-4 tw-py-4 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 placeholder-slate-300 focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm" placeholder="Verify legacy key..." />
                        </div>
                        <span asp-validation-for="OldPassword" class="tw-text-[10px] tw-font-bold tw-text-red-500 tw-mt-1.5 tw-block"></span>
                    </div>

                    <!-- New Password -->
                    <div class="tw-grid sm:tw-grid-cols-2 tw-gap-5">
                        <div>
                            <label asp-for="NewPassword" class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">New Protocol <span class="tw-text-red-500">*</span></label>
                            <div class="tw-relative">
                                <i class="fas fa-lock tw-absolute tw-left-4 tw-top-1/2 tw--translate-y-1/2 tw-text-indigo-500 tw-text-sm"></i>
                                <input asp-for="NewPassword" type="password" class="tw-w-full tw-pl-12 tw-pr-4 tw-py-4 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 placeholder-slate-300 focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm" placeholder="Generate key" />
                            </div>
                            <span asp-validation-for="NewPassword" class="tw-text-[10px] tw-font-bold tw-text-red-500 tw-mt-1.5 tw-block"></span>
                        </div>

                        <div>
                            <label asp-for="ConfirmPassword" class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Verify Protocol <span class="tw-text-red-500">*</span></label>
                            <div class="tw-relative">
                                <i class="fas fa-check-double tw-absolute tw-left-4 tw-top-1/2 tw--translate-y-1/2 tw-text-emerald-500 tw-text-sm"></i>
                                <input asp-for="ConfirmPassword" type="password" class="tw-w-full tw-pl-12 tw-pr-4 tw-py-4 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 placeholder-slate-300 focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm" placeholder="Repeat key" />
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="tw-text-[10px] tw-font-bold tw-text-red-500 tw-mt-1.5 tw-block"></span>
                        </div>
                    </div>

                    <div class="tw-pt-6 tw-mt-2">
                         <div class="tw-space-y-3">
                            <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                                <button type="submit" 
                                        class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-text-slate-900 tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase tw-shadow-[0_8px_20px_rgba(245,197,24,0.25)] hover:tw-shadow-[0_8px_25px_rgba(245,197,24,0.35)] hover:tw--translate-y-0.5 tw-transition-all">
                                    <i class="fas fa-shield-check tw-text-sm"></i> Execute Key
                                </button>
                                <button type="button" disabled
                                        class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-slate-900 tw-text-white tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase hover:tw-bg-slate-800 hover:tw-shadow-[0_8px_20px_rgba(15,23,42,0.2)] hover:tw--translate-y-0.5 tw-transition-all disabled:tw-opacity-40">
                                    <i class="fas fa-sync-alt tw-text-sm"></i> Update Link
                                </button>
                            </div>
                            <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                                <button type="button" disabled
                                        class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-bg-white tw-text-red-500 tw-border tw-border-red-100 tw-shadow-sm tw-rounded-xl tw-font-extrabold tw-text-[11px] tw-tracking-wider tw-uppercase hover:tw-bg-red-50 hover:tw-border-red-200 tw-transition-all disabled:tw-opacity-40">
                                    <i class="fas fa-trash-alt"></i> Revoke
                                </button>
                                <a href="@Url.Action(Model.IsExpired ? "ChangePasswordOnExpire" : "ChangePassword", "Account")" 
                                        class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-bg-white tw-text-slate-600 tw-border tw-border-slate-200 tw-shadow-sm tw-rounded-xl tw-font-extrabold tw-text-[11px] tw-tracking-wider tw-uppercase hover:tw-bg-slate-50 hover:tw-text-slate-900 tw-transition-all">
                                    <i class="fas fa-undo-alt tw-opacity-60"></i> Refresh
                                </a>
                            </div>
                        </div>
                    </div>

                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script type="text/javascript">
        $(window).on('load', function () {
            setTimeout(function () {
                var oldPass = $('#OldPassword');
                if (oldPass.length) {
                    oldPass.val('');
                }
            }, 600);

            var passwordInput = $('#NewPassword');
            if (passwordInput.length > 0) {
                passwordInput.val("");
            }
        });
    </script>
}
