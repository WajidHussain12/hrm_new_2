@model LCS_HR_MVC.Models.ViewModels.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In — Leopards HR</title>
    <link rel="shortcut icon" href="~/images/favicon.ico">
    <link rel="stylesheet" href="~/lib/fontawesome/css/all.min.css">
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <style>
        .glass-panel {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.5);
        }
        .yellow-glow {
            box-shadow: 0 20px 50px -10px rgba(0, 0, 0, 0.1), 0 0 40px rgba(245, 197, 24, 0.15);
        }
        @@keyframes float {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
            100% { transform: translateY(0px); }
        }
        .floating { animation: float 6s ease-in-out infinite; }
        .bg-pattern {
            background-image: 
                radial-gradient(circle at 100% 100%, rgba(245, 197, 24, 0.05) 0, rgba(245, 197, 24, 0.05) 3px, transparent 3px),
                radial-gradient(circle at 0 0, rgba(15, 23, 42, 0.03) 0, rgba(15, 23, 42, 0.03) 3px, transparent 3px);
            background-size: 40px 40px;
        }
        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @@keyframes shake {
            0%, 100% { transform: translateX(0); }
            10%, 30%, 50%, 70%, 90% { transform: translateX(-4px); }
            20%, 40%, 60%, 80% { transform: translateX(4px); }
        }

        /* Modern Floating Label Inputs */
        .modern-input-wrapper {
            position: relative;
            margin-bottom: 1.5rem;
        }
        .modern-input {
            width: 100%;
            padding: 1.25rem 1rem 0.5rem 3rem;
            background-color: #f8fafc;
            border: 2px solid transparent;
            border-radius: 1rem;
            font-size: 0.95rem;
            font-weight: 600;
            color: #0f172a;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);
        }
        .modern-input:focus {
            outline: none;
            background-color: #ffffff;
            border-color: #eab308;
            box-shadow: 0 4px 20px rgba(245, 197, 24, 0.15), inset 0 2px 4px rgba(0,0,0,0.01);
            transform: translateY(-2px);
        }
        .modern-label {
            position: absolute;
            left: 3rem;
            top: 50%;
            transform: translateY(-50%);
            font-size: 0.95rem;
            font-weight: 600;
            color: #94a3b8;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            pointer-events: none;
        }
        .modern-input:focus ~ .modern-label,
        .modern-input:not(:placeholder-shown) ~ .modern-label {
            top: 0.65rem;
            font-size: 0.7rem;
            font-weight: 800;
            color: #eab308;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }
        .input-icon {
            position: absolute;
            left: 1.25rem;
            top: 50%;
            transform: translateY(-50%);
            color: #cbd5e1;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            font-size: 1.1rem;
        }
        .modern-input:focus ~ .input-icon {
            color: #eab308;
            transform: translateY(-50%) scale(1.1);
        }

        /* Select styling matching modern input */
        .modern-select {
            padding: 1rem 1rem 1rem 3rem;
            height: 3.5rem;
        }

    </style>
</head>

<body class="tw-min-h-screen tw-flex tw-items-center tw-justify-center tw-p-4 sm:tw-p-8 tw-bg-slate-50 tw-font-sans tw-antialiased tw-relative tw-overflow-hidden">

    <!-- Ambient Background Effects -->
    <div class="tw-absolute tw-top-[-20%] tw-right-[-10%] tw-w-[800px] tw-h-[800px] tw-bg-amber-400 tw-rounded-full tw-mix-blend-multiply tw-filter tw-blur-[150px] tw-opacity-20 tw-pointer-events-none tw-animate-[pulse_8s_ease-in-out_infinite]"></div>
    <div class="tw-absolute tw-bottom-[-20%] tw-left-[-10%] tw-w-[600px] tw-h-[600px] tw-bg-orange-400 tw-rounded-full tw-mix-blend-multiply tw-filter tw-blur-[120px] tw-opacity-20 tw-pointer-events-none tw-animate-[pulse_10s_ease-in-out_infinite_reverse]"></div>
    <div class="tw-absolute tw-inset-0 bg-pattern tw-opacity-60 tw-pointer-events-none"></div>

    <div class="tw-w-full tw-max-w-5xl glass-panel tw-rounded-[2.5rem] yellow-glow tw-overflow-hidden tw-grid lg:tw-grid-cols-2 tw-relative tw-z-10 tw-animate-[fadeInUp_0.6s_ease-out]">

        <!-- Left Branding Panel -->
        <section class="tw-hidden lg:tw-flex tw-flex-col tw-justify-between tw-p-14 tw-relative tw-overflow-hidden tw-bg-slate-900 border-r border-slate-800">
            <div class="tw-absolute tw-inset-0 tw-bg-gradient-to-br tw-from-amber-500/10 tw-via-transparent tw-to-transparent tw-pointer-events-none"></div>
            <div class="tw-absolute tw-inset-0 tw-bg-[url('/images/noise.png')] tw-opacity-10 tw-mix-blend-overlay tw-pointer-events-none"></div>

            <div class="tw-relative tw-z-10">
                <div class="tw-w-20 tw-h-20 tw-bg-gradient-to-br tw-from-amber-400 tw-to-orange-500 tw-rounded-2xl tw-flex tw-items-center tw-justify-center tw-mb-10 tw-shadow-[0_10px_30px_rgba(245,197,24,0.3)] floating">
                    <img src="~/images/lcs_trans.png" alt="Leopards" class="tw-w-12 tw-h-12 tw-object-contain tw-brightness-0" onerror="this.src='/images/favicon.ico';" />
                </div>

                <div class="tw-inline-flex tw-items-center tw-gap-2.5 tw-px-3.5 tw-py-1.5 tw-rounded-full tw-bg-slate-800/80 tw-border tw-border-slate-700/50 tw-backdrop-blur-sm tw-mb-6">
                    <span class="tw-w-2 tw-h-2 tw-rounded-full tw-bg-amber-400 tw-animate-ping"></span>
                    <span class="tw-text-[0.65rem] tw-font-black tw-tracking-[0.2em] tw-uppercase tw-text-amber-400">Enterprise System</span>
                </div>

                <h1 class="tw-text-5xl lg:tw-text-[3.5rem] tw-font-black tw-text-white tw-leading-[1.1] tw-tracking-tight tw-mb-6">
                    Leopards <br/>
                    <span class="tw-text-transparent tw-bg-clip-text tw-bg-gradient-to-r tw-from-amber-300 tw-to-amber-500">HR Portal</span>
                </h1>
                <p class="tw-text-lg tw-text-slate-400 tw-leading-relaxed tw-font-medium tw-max-w-sm">
                    Streamline your workforce management with our next-generation enterprise platform.
                </p>
            </div>

            <div class="tw-relative tw-z-10 tw-mt-12 tw-flex tw-items-center tw-gap-6 tw-text-slate-500 tw-text-sm tw-font-bold">
                <div class="tw-flex tw-items-center tw-gap-2.5 bg-slate-800/50 px-3 py-1.5 rounded-lg border border-slate-700/50">
                    <i class="fas fa-shield-alt tw-text-amber-500"></i>
                    <span>Secure Access</span>
                </div>
                <div class="tw-flex tw-items-center tw-gap-2.5 bg-slate-800/50 px-3 py-1.5 rounded-lg border border-slate-700/50">
                    <i class="fas fa-bolt tw-text-amber-500"></i>
                    <span>Fast Performance</span>
                </div>
            </div>
        </section>

        <!-- Right Login Form -->
        <section class="tw-p-8 sm:tw-p-14 lg:tw-p-16 tw-bg-white/80 tw-relative tw-flex tw-flex-col tw-justify-center">
            <div class="tw-max-w-sm tw-mx-auto tw-w-full">

                <!-- Mobile Header (Hidden on Desktop) -->
                <div class="lg:tw-hidden tw-text-center tw-mb-10">
                    <div class="tw-w-16 tw-h-16 tw-mx-auto tw-bg-gradient-to-br tw-from-amber-400 tw-to-orange-500 tw-rounded-2xl tw-flex tw-items-center tw-justify-center tw-mb-5 tw-shadow-[0_10px_20px_rgba(245,197,24,0.3)]">
                        <img src="~/images/lcs_trans.png" alt="Leopards" class="tw-w-10 tw-h-10 tw-object-contain tw-brightness-0" onerror="this.src='/images/favicon.ico';" />
                    </div>
                    <h2 class="tw-text-2xl tw-font-black tw-text-slate-900 tw-tracking-tight">Leopards HR</h2>
                    <p class="tw-text-sm tw-text-slate-500 tw-font-bold tw-mt-1">Enterprise Portal</p>
                </div>

                <div class="tw-hidden lg:tw-block tw-mb-10">
                    <div class="tw-inline-block tw-h-1.5 tw-w-10 tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-rounded-full tw-mb-4"></div>
                    <h2 class="tw-text-3xl tw-font-black tw-text-slate-900 tw-tracking-tight">Welcome Back</h2>
                    <p class="tw-text-[15px] tw-text-slate-500 tw-font-semibold tw-mt-2 tw-leading-relaxed">Sign in with your credentials to securely access your workspace.</p>
                </div>

                <form asp-controller="Account" asp-action="Login" method="post" class="tw-mt-6">
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                    <!-- Username -->
                    <div class="modern-input-wrapper">
                        <input asp-for="Username" class="modern-input" placeholder=" " autocomplete="username" />
                        <label asp-for="Username" class="modern-label">Account ID</label>
                        <i class="fas fa-user input-icon"></i>
                        <span asp-validation-for="Username" class="tw-text-xs tw-font-bold tw-text-red-500 tw-absolute tw--bottom-5 tw-left-2"></span>
                    </div>

                    <!-- Password -->
                    <div class="modern-input-wrapper tw-mt-8">
                        <input asp-for="Password" class="modern-input" placeholder=" " autocomplete="current-password" />
                        <label asp-for="Password" class="modern-label">Password</label>
                        <i class="fas fa-lock input-icon"></i>
                        <span asp-validation-for="Password" class="tw-text-xs tw-font-bold tw-text-red-500 tw-absolute tw--bottom-5 tw-left-2"></span>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="tw-flex tw-items-start tw-gap-3 tw-p-4 tw-mt-8 tw-bg-red-50 tw-border tw-border-red-100 tw-rounded-xl tw-text-red-600 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(239,68,68,0.1)] tw-animate-[shake_0.5s_ease-in-out]">
                            <div class="tw-w-6 tw-h-6 tw-bg-red-100 tw-text-red-500 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0">
                                <i class="fas fa-exclamation-triangle tw-text-[10px]"></i>
                            </div>
                            <span class="tw-pt-0.5">@Model.ErrorMessage</span>
                        </div>
                    }

                    <div class="tw-text-red-500 tw-text-xs tw-font-bold tw-space-y-1 tw-mt-5 pl-2">
                        @Html.ValidationSummary(true, "", new { @class = "tw-list-none tw-p-0 tw-m-0" })
                    </div>

                    <div class="tw-pt-10">
                        <button type="submit" class="tw-w-full tw-group tw-relative tw-flex tw-items-center tw-justify-center tw-gap-3 tw-py-4 tw-px-6 tw-bg-gradient-to-r tw-from-slate-900 tw-to-slate-800 tw-text-white tw-rounded-xl tw-font-black tw-text-sm tw-uppercase tw-tracking-widest tw-overflow-hidden tw-transition-all tw-duration-300 hover:tw-shadow-[0_10px_20px_rgba(15,23,42,0.2)] hover:tw--translate-y-1 tw-cursor-pointer border border-slate-700">
                            <!-- Accent Line -->
                            <div class="tw-absolute tw-bottom-0 tw-left-0 tw-h-1 tw-w-0 tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 group-hover:tw-w-full tw-transition-all tw-duration-500 tw-ease-out"></div>

                            <span class="tw-relative tw-z-10">Authorize Access</span>
                            <div class="tw-w-7 tw-h-7 tw-bg-white/10 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-relative tw-z-10 group-hover:tw-bg-amber-400 group-hover:tw-scale-110 tw-transition-all tw-duration-300">
                                <i class="fas fa-arrow-right tw-text-white group-hover:tw-text-slate-900 tw-text-xs tw-transition-colors"></i>
                            </div>
                        </button>
                    </div>
                </form>
            </div>
        </section>

    </div>
</body>
</html>