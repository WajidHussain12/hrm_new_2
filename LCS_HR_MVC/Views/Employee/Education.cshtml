@model LCS_HR_MVC.Models.EmployeeEducationModel
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["PageTitle"] = "Employee Education";
    var educationList = ViewBag.EducationList as IEnumerable<LCS_HR_MVC.Models.EmployeeEducationModel> ?? new List<LCS_HR_MVC.Models.EmployeeEducationModel>();
    var countries = ViewBag.Countries as IEnumerable<SelectListItem> ?? new List<SelectListItem>();
    var cities = ViewBag.Cities as IEnumerable<SelectListItem> ?? new List<SelectListItem>();
    bool isNew = Model.Sno == 0;
}

@section Styles {
    <link href="~/lib/jquery-ui/jquery-ui.min.css" rel="stylesheet" />
    <style>
        @@keyframes slideUp { from { opacity:0; transform:translateY(15px); } to { opacity:1; transform:translateY(0); } }
        .animate-main { animation: slideUp 0.4s ease-out; }
        .custom-scrollbar::-webkit-scrollbar { width:8px; height:8px; } .custom-scrollbar::-webkit-scrollbar-track { background:#f1f5f9; border-radius:4px; } .custom-scrollbar::-webkit-scrollbar-thumb { background:#cbd5e1; border-radius:4px; } .custom-scrollbar::-webkit-scrollbar-thumb:hover { background:#94a3b8; }
        .dataTables_wrapper .dataTables_filter { @@apply tw-relative tw-mb-5; }
        .dataTables_wrapper .dataTables_filter label { @@apply tw-w-full sm:tw-w-auto; }
        .dataTables_wrapper .dataTables_filter input { @@apply tw-w-full sm:tw-w-[300px] tw-border-2 tw-border-slate-100 tw-rounded-2xl tw-px-5 tw-py-2.5 tw-text-sm tw-outline-none tw-transition-all tw-bg-slate-50 focus:tw-bg-white tw-text-slate-700 tw-shadow-inner tw-font-medium; }
        .dataTables_wrapper .dataTables_filter input:focus { @@apply tw-border-amber-400 tw-ring-4 tw-ring-amber-400/20 tw-shadow-lg; }
        table.dataTable { @@apply tw-border-collapse; }
        table.dataTable thead th { @@apply tw-bg-slate-50 tw-text-slate-400 tw-font-black tw-uppercase tw-text-[10px] tw-tracking-[0.15em] tw-py-4 tw-px-5 tw-border-b-2 tw-border-slate-100 !important; }
        table.dataTable tbody tr { @@apply tw-border-b tw-border-slate-50 tw-transition-colors hover:tw-bg-amber-50/30; }
        table.dataTable tbody td { @@apply tw-py-4 tw-px-5 tw-align-middle; }
        .dataTables_info { @@apply tw-text-xs tw-font-semibold tw-text-slate-500 tw-mt-5; }
        .dataTables_wrapper .dataTables_paginate { @@apply tw-flex tw-items-center tw-gap-1 tw-mt-5; }
        .dataTables_wrapper .dataTables_paginate .paginate_button { @@apply tw-min-w-[32px] tw-h-8 tw-flex tw-items-center tw-justify-center tw-rounded-lg tw-text-xs tw-font-bold tw-text-slate-500 tw-border tw-border-slate-200 tw-bg-white tw-cursor-pointer tw-transition-all !important; padding:0 0.5rem !important; margin:0 !important; }
        .dataTables_wrapper .dataTables_paginate .paginate_button:hover { @@apply tw-bg-slate-100 tw-text-slate-800 tw-border-slate-300 !important; background:none !important; }
        .dataTables_wrapper .dataTables_paginate .paginate_button.current, .dataTables_wrapper .dataTables_paginate .paginate_button.current:hover { @@apply tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-text-slate-900 tw-border-transparent tw-shadow-md tw-cursor-default !important; background:none !important; }
        .dataTables_wrapper .dataTables_paginate .paginate_button.disabled { @@apply tw-opacity-50 tw-cursor-not-allowed hover:tw-bg-white hover:tw-text-slate-500 hover:tw-border-slate-200 !important; }
        .field-select { background-image:url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%2394a3b8%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E'); background-repeat:no-repeat; background-position:right 0.75rem top 50%; background-size:0.65rem auto; }
    </style>
}

<div class="tw-p-4 sm:tw-p-6 tw-bg-transparent tw-min-h-screen animate-main">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-red-50 tw-border tw-border-red-100 tw-rounded-xl tw-text-red-600 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(239,68,68,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-red-100 tw-text-red-500 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0"><i class="fas fa-exclamation-triangle tw-text-[10px]"></i></div>
            <span class="tw-pt-0.5">@TempData["ErrorMessage"]</span>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-emerald-50 tw-border tw-border-emerald-100 tw-rounded-xl tw-text-emerald-700 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(16,185,129,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-emerald-100 tw-text-emerald-600 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0"><i class="fas fa-check tw-text-[10px]"></i></div>
            <span class="tw-pt-0.5">@TempData["SuccessMessage"]</span>
        </div>
    }

    <div class="tw-flex tw-flex-col sm:tw-flex-row sm:tw-items-end tw-justify-between tw-gap-4 tw-mb-8">
        <div>
            <nav class="tw-flex tw-items-center tw-gap-2.5 tw-text-[11px] tw-font-bold tw-text-slate-400 tw-mb-2 tw-uppercase tw-tracking-widest">
                <a href="@Url.Action("PersonalDetail", "Employee", new { id = Model.EmpNo })" class="tw-flex tw-items-center tw-gap-1.5 hover:tw-text-[#eab308] tw-transition-colors">
                    <i class="fas fa-users tw-text-[10px] tw-text-slate-300"></i><span>Employees</span>
                </a>
                <i class="fas fa-chevron-right tw-text-[8px] tw-text-slate-300"></i>
                <span class="tw-text-slate-600 tw-bg-white tw-px-2 tw-py-0.5 tw-rounded-md tw-border tw-border-slate-200 tw-shadow-sm">Education</span>
            </nav>
            <div class="tw-flex tw-flex-col">
                <h1 class="tw-text-3xl tw-font-black tw-text-slate-900 tw-leading-tight tw-tracking-tight">Employee Education</h1>
                <div class="tw-h-1.5 tw-w-10 tw-bg-gradient-to-r tw-from-[#f5c518] tw-to-transparent tw-rounded-full tw-mt-1"></div>
            </div>
            @if (!string.IsNullOrEmpty(Model.EmpName))
            {
                <p class="tw-text-slate-500 tw-text-sm tw-font-medium tw-mt-3">
                    <span class="tw-inline-flex tw-items-center tw-gap-1.5 tw-bg-white tw-border tw-border-slate-200 tw-rounded-lg tw-px-3 tw-py-1 tw-shadow-sm">
                        <i class="fas fa-id-badge tw-text-slate-400 tw-text-xs"></i>
                        <span class="tw-font-black tw-text-slate-700">@Model.EmpName</span>
                        <span class="tw-text-slate-400 tw-font-mono tw-text-xs">(@Model.EmpNo)</span>
                    </span>
                </p>
            }
        </div>
    </div>

    <div class="tw-grid lg:tw-grid-cols-12 tw-gap-6 xl:tw-gap-8 align-top">
        <!-- Left: List -->
        <div class="lg:tw-col-span-6 xl:tw-col-span-7">
            <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-relative tw-h-full">
                <div class="tw-absolute tw-top-0 tw-right-0 tw-w-64 tw-h-64 tw-bg-gradient-to-bl tw-from-amber-50/50 tw-to-transparent tw-rounded-bl-full tw-pointer-events-none" style="z-index:0"></div>
                <div class="tw-relative tw-z-10 tw-px-6 tw-py-5 tw-border-b tw-border-slate-100 tw-flex tw-items-center tw-gap-4 tw-bg-white/50">
                    <div class="tw-w-10 tw-h-10 tw-rounded-xl tw-bg-gradient-to-br tw-from-slate-700 tw-to-slate-900 tw-flex tw-items-center tw-justify-center tw-shadow-[0_4px_10px_rgba(15,23,42,0.25)]">
                        <i class="fas fa-graduation-cap tw-text-amber-400 tw-text-lg"></i>
                    </div>
                    <div>
                        <h2 class="tw-font-black tw-text-base tw-text-slate-800 tw-tracking-tight">Education Records</h2>
                        <p class="tw-text-[10px] tw-font-bold tw-text-slate-400 tw-uppercase tw-tracking-widest">Academic History</p>
                    </div>
                </div>
                <div class="tw-relative tw-z-10 tw-p-6">
                    <div class="tw-overflow-x-auto custom-scrollbar">
                        <table id="dg1" class="tw-w-full dataTable tw-text-xs">
                            <thead>
                                <tr>
                                    <th class="tw-text-center tw-w-16">Sno</th>
                                    <th>Degree</th>
                                    <th>Institution</th>
                                    <th class="tw-text-center">From</th>
                                    <th class="tw-text-center">To</th>
                                </tr>
                            </thead>
                            <tbody class="tw-divide-y tw-divide-slate-100">
                                @foreach (var item in educationList)
                                {
                                    <tr class="hover:tw-bg-slate-50 tw-transition-colors group tw-text-sm">
                                        <td class="tw-py-3 tw-text-center tw-align-middle">
                                            <a href="@Url.Action("Education", "Employee", new { empNo = item.EmpNo, sno = item.Sno })"
                                               class="tw-px-2.5 tw-py-1 tw-bg-slate-100 group-hover:tw-bg-white tw-border tw-border-slate-200 tw-rounded-lg tw-font-mono tw-font-black tw-text-slate-600 tw-shadow-sm tw-transition-colors hover:tw-border-amber-400 hover:tw-text-amber-600">@item.Sno</a>
                                        </td>
                                        <td class="tw-py-3 tw-align-middle tw-font-bold tw-text-slate-800 group-hover:tw-text-amber-600 tw-transition-colors">@item.DegreeTitle</td>
                                        <td class="tw-py-3 tw-align-middle tw-text-slate-600 tw-font-medium">@item.InstitutionName</td>
                                        <td class="tw-py-3 tw-text-center tw-align-middle"><span class="tw-text-xs tw-font-bold tw-text-slate-500">@(item.FromDate?.ToString("dd/MM/yyyy"))</span></td>
                                        <td class="tw-py-3 tw-text-center tw-align-middle"><span class="tw-text-xs tw-font-bold tw-text-slate-500">@(item.ToDate?.ToString("dd/MM/yyyy"))</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Form -->
        <div class="lg:tw-col-span-6 xl:tw-col-span-5">
            <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-sticky tw-top-24 tw-relative">
                <div class="tw-absolute tw-top-[-50px] tw-right-[-50px] tw-w-40 tw-h-40 tw-bg-amber-100/40 tw-blur-2xl tw-rounded-full tw-pointer-events-none"></div>
                <div class="tw-p-6 tw-bg-gradient-to-r tw-from-slate-900 tw-to-slate-800 tw-relative tw-z-10">
                    <h3 class="tw-text-amber-400 tw-font-black tw-text-xs tw-uppercase tw-tracking-[0.2em] tw-flex tw-items-center tw-gap-2">
                        <div class="tw-w-6 tw-h-6 tw-bg-white/10 tw-rounded-md tw-flex tw-items-center tw-justify-center"><i class="fas fa-pen-nib"></i></div>
                        Education Entry
                    </h3>
                </div>
                <form asp-controller="Employee" asp-action="Education" method="post" class="tw-p-6 tw-space-y-4 tw-relative tw-z-10 tw-overflow-y-auto custom-scrollbar" style="max-height:75vh">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="EmpNo" />
                    <input type="hidden" asp-for="Sno" />
                    <input type="hidden" asp-for="EmpName" />

                    @foreach (var field in new[] {
                        new { Label="Degree Title", Name="DegreeTitle", Type="text", Required=true },
                        new { Label="Area / Subject", Name="Area", Type="text", Required=false },
                        new { Label="Institution", Name="InstitutionName", Type="text", Required=true },
                        new { Label="Institution Type", Name="InstitutionType", Type="text", Required=false },
                    })
                    {
                        <div>
                            <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">
                                @field.Label @if (field.Required) { <span class="tw-text-red-500">*</span> }
                            </label>
                            <input type="text" name="@field.Name" value="@(field.Name == "DegreeTitle" ? Model.DegreeTitle : field.Name == "Area" ? Model.Area : field.Name == "InstitutionName" ? Model.InstitutionName : Model.InstitutionType)"
                                   class="tw-w-full tw-px-4 tw-py-3 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm" />
                        </div>
                    }

                    <!-- Country -->
                    <div>
                        <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Country</label>
                        <div class="tw-relative">
                            <i class="fas fa-globe tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-sm tw-pointer-events-none" style="z-index:1"></i>
                            <select asp-for="CountryCode" id="ddlEduCountry" asp-items="@(new SelectList(countries, "Value", "Text", Model.CountryCode))"
                                    onchange="loadEduCities(this.value)"
                                    class="field-select tw-w-full tw-pl-10 tw-pr-8 tw-py-3 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-700 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-appearance-none">
                                <option value="00">-- Select --</option>
                            </select>
                        </div>
                    </div>
                    <!-- City -->
                    <div>
                        <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">City</label>
                        <div class="tw-relative">
                            <i class="fas fa-city tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-sm tw-pointer-events-none" style="z-index:1"></i>
                            <select asp-for="CityCode" id="ddlEduCity" asp-items="@(new SelectList(cities, "Value", "Text", Model.CityCode))"
                                    class="field-select tw-w-full tw-pl-10 tw-pr-8 tw-py-3 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-700 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-appearance-none">
                                <option value="00">-- Select --</option>
                            </select>
                        </div>
                    </div>
                    <!-- From / To Date -->
                    <div class="tw-grid tw-grid-cols-2 tw-gap-4">
                        <div>
                            <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">From Date <span class="tw-text-red-500">*</span></label>
                            <input type="date" asp-for="FromDate" value="@(Model.FromDate?.ToString("yyyy-MM-dd"))"
                                   class="tw-w-full tw-px-3 tw-py-3 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-shadow-sm" />
                            <span asp-validation-for="FromDate" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                        </div>
                        <div>
                            <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">To Date <span class="tw-text-red-500">*</span></label>
                            <input type="date" asp-for="ToDate" value="@(Model.ToDate?.ToString("yyyy-MM-dd"))"
                                   class="tw-w-full tw-px-3 tw-py-3 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-shadow-sm" />
                            <span asp-validation-for="ToDate" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                        </div>
                    </div>
                    <!-- Grade / Status -->
                    <div class="tw-grid tw-grid-cols-2 tw-gap-4">
                        <div>
                            <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Grade</label>
                            <input type="text" asp-for="Grade" class="tw-w-full tw-px-4 tw-py-3 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-shadow-sm" />
                        </div>
                        <div>
                            <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Status</label>
                            <input type="text" asp-for="Status" class="tw-w-full tw-px-4 tw-py-3 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-shadow-sm" />
                        </div>
                    </div>
                    <!-- Comments -->
                    <div>
                        <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Comments</label>
                        <textarea asp-for="Comments" class="tw-w-full tw-px-4 tw-py-3 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-medium tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm tw-min-h-[80px] custom-scrollbar"></textarea>
                    </div>

                    <div class="tw-pt-2 tw-border-t tw-border-slate-100"></div>
                    <div class="tw-flex tw-flex-wrap tw-gap-3">
                        @if (isNew)
                        {
                            <button type="submit" name="action" value="Save"
                                    class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-px-5 tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-text-slate-900 tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase tw-shadow-[0_8px_20px_rgba(245,197,24,0.25)] hover:tw-shadow-[0_8px_25px_rgba(245,197,24,0.35)] hover:tw--translate-y-0.5 tw-transition-all">
                                <i class="fas fa-check-circle tw-text-sm"></i> Save
                            </button>
                        }
                        else
                        {
                            <button type="submit" name="action" value="Update"
                                    class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-px-5 tw-bg-slate-900 tw-text-white tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase hover:tw-bg-slate-800 hover:tw--translate-y-0.5 tw-transition-all">
                                <i class="fas fa-sync-alt tw-text-sm"></i> Update
                            </button>
                            <button type="submit" name="action" value="Delete" onclick="return confirm('Delete this record?');"
                                    class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-px-5 tw-bg-white tw-text-red-500 tw-border tw-border-red-100 tw-shadow-sm tw-rounded-xl tw-font-extrabold tw-text-[11px] tw-tracking-wider tw-uppercase hover:tw-bg-red-50 hover:tw-border-red-200 tw-transition-all">
                                <i class="fas fa-trash-alt"></i> Delete
                            </button>
                        }
                        <button type="submit" name="action" value="Reset" formnovalidate
                                class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-px-5 tw-bg-white tw-text-slate-600 tw-border tw-border-slate-200 tw-shadow-sm tw-rounded-xl tw-font-extrabold tw-text-[11px] tw-tracking-wider tw-uppercase hover:tw-bg-slate-50 hover:tw-text-slate-900 tw-transition-all">
                            <i class="fas fa-undo-alt tw-opacity-60"></i> Reset
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function loadEduCities(countryCode) {
            if (!countryCode || countryCode === '00') { $('#ddlEduCity').html('<option value="00">-- Select --</option>'); return; }
            $.getJSON('@Url.Action("GetCitiesByCountry", "Employee")', { countryCode: countryCode }, function (data) {
                var opts = '<option value="00">-- Select --</option>';
                $.each(data, function (i, item) { opts += '<option value="' + item.value + '">' + item.text + '</option>'; });
                $('#ddlEduCity').html(opts);
            });
        }
        $(document).ready(function () {
            if ($.fn.DataTable) {
                $('#dg1').DataTable({
                    "pageLength": 10, "lengthChange": false,
                    "dom": '<"tw-flex tw-flex-col sm:tw-flex-row tw-justify-between tw-items-center tw-mb-2"f>rt<"tw-flex tw-flex-col sm:tw-flex-row tw-justify-between tw-items-center"ip>',
                    "language": { "search": "", "searchPlaceholder": "Search records...", "paginate": { "previous": "<i class='fas fa-chevron-left tw-text-[10px]'></i>", "next": "<i class='fas fa-chevron-right tw-text-[10px]'></i>" } }
                });
                $('.dataTables_filter label').addClass('tw-relative tw-block tw-w-full');
                $('.dataTables_filter input').addClass('tw-pl-10');
                $('.dataTables_filter label').append('<i class="fas fa-search tw-absolute tw-left-4 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400"></i>');
            }
        });
    </script>
}
