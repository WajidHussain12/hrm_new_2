                                    <select asp-for="JobTypeId" asp-items="@(new SelectList(jobTypes, "Value", "Text", Model.JobTypeId))" class="field-select tw-w-full tw-pl-9 tw-pr-6 tw-py-2.5 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-appearance-none">
                                        <option value="0">-- Select --</option>
                                    </select>
                                </div>
                            </div>
                            <div>
                                <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1">Third Party</label>
                                <div class="tw-relative">
                                    <i class="fas fa-handshake tw-absolute tw-left-3 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs tw-pointer-events-none" style="z-index:1"></i>
                                    <select asp-for="ThirdPartyId" asp-items="@(new SelectList(thirdParties, "Value", "Text", Model.ThirdPartyId))" class="field-select tw-w-full tw-pl-9 tw-pr-6 tw-py-2.5 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-appearance-none">
                                        <option value="">-- None --</option>
                                    </select>
                                </div>
                            </div>
                            <div>
                                <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1">Generate Salary</label>
                                <div class="tw-relative">
                                    <i class="fas fa-money-check-alt tw-absolute tw-left-3 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs tw-pointer-events-none" style="z-index:1"></i>
                                    <select asp-for="GenerateSalary" class="field-select tw-w-full tw-pl-9 tw-pr-6 tw-py-2.5 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-appearance-none">
                                        <option value="Y">Yes</option>
                                        <option value="N">No</option>
                                    </select>
                                </div>
                            </div>
                            <div class="tw-flex tw-items-center tw-gap-3 tw-pt-4">
                                <input type="checkbox" asp-for="IsExecutive" class="tw-w-4 tw-h-4 tw-accent-amber-500" />
                                <label class="tw-text-sm tw-font-bold tw-text-slate-700">Is Executive</label>
                            </div>
                            <div>
                                <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1">Replacement Employee</label>
                                <div class="tw-relative">
                                    <i class="fas fa-user-plus tw-absolute tw-left-3 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs tw-pointer-events-none" style="z-index:1"></i>
                                    <input type="text" asp-for="ReplacementEmpName" id="txtReplacementName" placeholder="Search name or emp no" autocomplete="off" class="tw-w-full tw-pl-9 tw-pr-3 tw-py-2.5 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none" />
                                    <input type="hidden" asp-for="ReplacementEmpNo" id="txtReplacementEmpNo" />
                                </div>
                            </div>
                            <div>
                                <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1">Report To</label>
                                <div class="tw-relative">
                                    <i class="fas fa-user-check tw-absolute tw-left-3 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs tw-pointer-events-none" style="z-index:1"></i>
                                    <input type="text" asp-for="ReportToEmpName" id="txtReportToName" placeholder="Search name or emp no" autocomplete="off" class="tw-w-full tw-pl-9 tw-pr-3 tw-py-2.5 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none" />
                                    <input type="hidden" asp-for="ReportToEmpNo" id="txtReportToEmpNo" />
                                </div>
                            </div>
                        </div>
                        <div class="tw-mt-3">
                            <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1">Comments</label>
                            <div class="tw-relative">
                                <i class="fas fa-comment-alt tw-absolute tw-left-3 tw-top-3.5 tw-text-slate-400 tw-text-xs tw-pointer-events-none" style="z-index:1"></i>
                                <textarea asp-for="Comments" rows="3" class="tw-w-full tw-pl-9 tw-pr-3 tw-py-2.5 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none custom-scrollbar"></textarea>
                            </div>
                        </div>
                        <div class="tw-mt-3">
                            <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1">Photo</label>
                            <div class="tw-flex tw-items-center tw-gap-3 tw-p-3 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl">
                                <i class="fas fa-camera tw-text-slate-400 tw-text-sm"></i>
                                <input type="file" asp-for="PhotoFile" id="photoFile" accept="image/*" class="tw-text-sm tw-text-slate-600 tw-font-medium" />
                            </div>
                        </div>
                    </div>

                    <!-- Buttons -->
                    <div class="tw-pt-2 tw-border-t tw-border-slate-100"></div>
                    <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                        @if (isNewRecord)
                        {
                            <button type="submit" name="action" value="Save"
                                    class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-text-slate-900 tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase tw-shadow-[0_8px_20px_rgba(245,197,24,0.25)] hover:tw-shadow-[0_8px_25px_rgba(245,197,24,0.35)] hover:tw--translate-y-0.5 tw-transition-all">
                                <i class="fas fa-save tw-text-sm"></i> Save
                            </button>
                            <button type="submit" name="action" value="Reset" formnovalidate
                                    class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-white tw-text-slate-600 tw-border tw-border-slate-200 tw-shadow-sm tw-rounded-xl tw-font-extrabold tw-text-[11px] tw-tracking-wider tw-uppercase hover:tw-bg-slate-50 hover:tw-text-slate-900 tw-transition-all">
                                <i class="fas fa-undo-alt tw-opacity-60"></i> Reset
                            </button>
                        }
                        else
                        {
                            <button type="submit" name="action" value="Update"
                                    class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-slate-900 tw-text-white tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase hover:tw-bg-slate-800 hover:tw--translate-y-0.5 tw-transition-all tw-shadow-md">
                                <i class="fas fa-sync tw-text-sm"></i> Update
                            </button>
                            <button type="submit" name="action" value="Delete"
                                    onclick="return confirm('Delete this employee record?');"
                                    class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-white tw-text-red-600 tw-border tw-border-red-300 tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase hover:tw-bg-red-50 hover:tw--translate-y-0.5 tw-transition-all tw-shadow-sm">
                                <i class="fas fa-trash-alt tw-text-sm"></i> Delete
                            </button>
                            <button type="submit" name="action" value="Reset" formnovalidate
                                    class="tw-col-span-2 tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-bg-white tw-text-slate-600 tw-border tw-border-slate-200 tw-shadow-sm tw-rounded-xl tw-font-extrabold tw-text-[11px] tw-tracking-wider tw-uppercase hover:tw-bg-slate-50 hover:tw-text-slate-900 tw-transition-all">
                                <i class="fas fa-undo-alt tw-opacity-60"></i> Reset
                            </button>
                        }
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery-ui/jquery-ui.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    <script type="text/javascript">
        $(document).ready(function () {
            var table = $('#dg1').DataTable({
                "pageLength": 12,
                "lengthChange": false,
                "searching": true,
                "info": true,
                "dom": '<"tw-flex tw-items-center tw-justify-between tw-mb-2"i>t<"tw-flex tw-items-center tw-justify-end tw-mt-3"p>'
            });
            $('#dtSearch').on('keyup', function () { table.search(this.value).draw(); });

            $('#txtReplacementName').autocomplete({
                source: function (request, response) {
                    $.getJSON('@Url.Action("SearchActiveEmployees", "Setup")', { term: request.term }, function (data) {
                        response($.map(data, function (item) {
                            return { label: item.text, value: item.text, empNo: item.value };
                        }));
                    });
                },
                minLength: 2,
                select: function (event, ui) { $('#txtReplacementEmpNo').val(ui.item.empNo); }
            });

            $('#txtReportToName').autocomplete({
                source: function (request, response) {
                    $.getJSON('@Url.Action("SearchActiveEmployees", "Setup")', { term: request.term }, function (data) {
                        response($.map(data, function (item) {
                            return { label: item.text, value: item.text, empNo: item.value };
                        }));
                    });
                },
                minLength: 2,
                select: function (event, ui) { $('#txtReportToEmpNo').val(ui.item.empNo); }
            });

            $('#ddlMaritalStatus').change(function () {
                $('#marriageDateRow').toggle($(this).val() === 'M');
            });
            $('#ddlMaritalStatus').trigger('change');
        });

        function loadCities(countryCode) {
            if (!countryCode || countryCode === '00') {
                $('#ddlCity').html('<option value="00">-- Select City --</option>');
                $('#ddlLocation').html('<option value="0">-- Select Location --</option>');
                return;
            }
            $.getJSON('@Url.Action("GetCitiesByCountry", "Employee")', { countryCode: countryCode }, function (data) {
                var opts = '<option value="00">-- Select City --</option>';
                $.each(data, function (i, item) { opts += '<option value="' + item.value + '">' + item.text + '</option>'; });
                $('#ddlCity').html(opts);
                $('#ddlLocation').html('<option value="0">-- Select Location --</option>');
            });
        }

        function loadLocations(cityCode) {
            if (!cityCode || cityCode === '00') {
                $('#ddlLocation').html('<option value="0">-- Select Location --</option>');
                return;
            }
            $.getJSON('@Url.Action("GetLocationsByCity", "Employee")', { cityCode: cityCode }, function (data) {
                var opts = '<option value="0">-- Select Location --</option>';
                $.each(data, function (i, item) { opts += '<option value="' + item.value + '">' + item.text + '</option>'; });
                $('#ddlLocation').html(opts);
            });
        }

        function loadDesignations(deptId) {
            if (!deptId || deptId === '0') {
                $('#ddlDesignation').html('<option value="0">-- Select --</option>');
                return;
            }
            $.getJSON('@Url.Action("GetDesignationsByDept", "Employee")', { deptId: deptId }, function (data) {
                var opts = '<option value="0">-- Select --</option>';
                $.each(data, function (i, item) { opts += '<option value="' + item.value + '">' + item.text + '</option>'; });
                $('#ddlDesignation').html(opts);
            });
        }
    </script>
}
