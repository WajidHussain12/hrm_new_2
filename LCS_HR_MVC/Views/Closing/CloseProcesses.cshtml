@model LCS_HR_MVC.Models.Closing.CloseProcessModel
@{
    ViewData["Title"] = "Close Processes";
    ViewData["PageTitle"] = "Close Processes";
    var dataList = ViewBag.ProcessList as IEnumerable<LCS_HR_MVC.Models.Closing.CloseProcessModel> ?? new List<LCS_HR_MVC.Models.Closing.CloseProcessModel>();
}

@section Styles {
    <style>
        /* Modern Fade Animation */
        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(15px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .animate-main { animation: slideUp 0.4s ease-out; }

        /* Custom Scrollbar */
        .custom-scrollbar::-webkit-scrollbar { width: 8px; height: 8px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f1f5f9; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

        /* DataTable Overrides */
        .dataTables_wrapper .dataTables_filter { @@apply tw-relative tw-mb-5; }
        .dataTables_wrapper .dataTables_filter label { @@apply tw-w-full sm:tw-w-auto; }
        .dataTables_wrapper .dataTables_filter input {
            @@apply tw-w-full sm:tw-w-[300px] tw-border-2 tw-border-slate-100 tw-rounded-2xl tw-px-5 tw-py-2.5 tw-text-sm tw-outline-none tw-transition-all tw-bg-slate-50 focus:tw-bg-white tw-text-slate-700 tw-shadow-inner tw-font-medium;
        }
        .dataTables_wrapper .dataTables_filter input:focus {
            @@apply tw-border-amber-400 tw-ring-4 tw-ring-amber-400/20 tw-shadow-lg;
        }
        table.dataTable { @@apply tw-border-collapse; }
        table.dataTable thead th {
            @@apply tw-bg-slate-50 tw-text-slate-400 tw-font-black tw-uppercase tw-text-[10px] tw-tracking-[0.15em] tw-py-4 tw-px-5 tw-border-b-2 tw-border-slate-100 !important;
        }
        table.dataTable tbody tr {
            @@apply tw-border-b tw-border-slate-50 tw-transition-colors hover:tw-bg-amber-50/30;
        }
        table.dataTable tbody td { @@apply tw-py-4 tw-px-5 tw-align-middle; }
        .dataTables_info { @@apply tw-text-xs tw-font-semibold tw-text-slate-500 tw-mt-5; }

        /* Modern Pagination */
        .dataTables_wrapper .dataTables_paginate { @@apply tw-flex tw-items-center tw-gap-1 tw-mt-5; }
        .dataTables_wrapper .dataTables_paginate .paginate_button {
            @@apply tw-min-w-[32px] tw-h-8 tw-flex tw-items-center tw-justify-center tw-rounded-lg tw-text-xs tw-font-bold tw-text-slate-500 tw-border tw-border-slate-200 tw-bg-white tw-cursor-pointer tw-transition-all !important;
            padding: 0 0.5rem !important;
            margin: 0 !important;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
            @@apply tw-bg-slate-100 tw-text-slate-800 tw-border-slate-300 !important;
            background: none !important;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button.current,
        .dataTables_wrapper .dataTables_paginate .paginate_button.current:hover {
            @@apply tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-text-slate-900 tw-border-transparent tw-shadow-md tw-cursor-default !important;
            background: none !important;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button.disabled {
            @@apply tw-opacity-50 tw-cursor-not-allowed hover:tw-bg-white hover:tw-text-slate-500 hover:tw-border-slate-200 !important;
        }

        /* Custom Select Styling */
        .field-select {
            background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%2394a3b8%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E');
            background-repeat: no-repeat;
            background-position: right 0.75rem top 50%;
            background-size: 0.65rem auto;
        }
    </style>
}

<div class="tw-p-4 sm:tw-p-6 tw-bg-transparent tw-min-h-screen animate-main">

    <!-- Notification Banners -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-red-50 tw-border tw-border-red-100 tw-rounded-xl tw-text-red-600 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(239,68,68,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-red-100 tw-text-red-500 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0">
                <i class="fas fa-exclamation-triangle tw-text-[10px]"></i>
            </div>
            <span class="tw-pt-0.5">@TempData["ErrorMessage"]</span>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-emerald-50 tw-border tw-border-emerald-100 tw-rounded-xl tw-text-emerald-700 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(16,185,129,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-emerald-100 tw-text-emerald-600 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0">
                <i class="fas fa-check tw-text-[10px]"></i>
            </div>
            <span class="tw-pt-0.5">@TempData["SuccessMessage"]</span>
        </div>
    }

    <!-- Page Header -->
    <div class="tw-flex tw-flex-col sm:tw-flex-row sm:tw-items-end tw-justify-between tw-gap-4 tw-mb-8">
        <div>
            <nav class="tw-flex tw-items-center tw-gap-2.5 tw-text-[11px] tw-font-bold tw-text-slate-400 tw-mb-2 tw-uppercase tw-tracking-widest">
                <div class="tw-flex tw-items-center tw-gap-1.5 hover:tw-text-[#eab308] tw-transition-colors tw-cursor-pointer">
                    <i class="fas fa-calendar-times tw-text-[10px] tw-text-slate-300"></i>
                    <span>Payroll Operations</span>
                </div>
                <i class="fas fa-chevron-right tw-text-[8px] tw-text-slate-300"></i>
                <span class="tw-text-slate-600 tw-bg-white tw-px-2 tw-py-0.5 tw-rounded-md tw-border tw-border-slate-200 tw-shadow-sm">Period Closure</span>
            </nav>
            <div class="tw-flex tw-flex-col">
                <h1 class="tw-text-3xl tw-font-black tw-text-slate-900 tw-leading-tight tw-tracking-tight">Close Processes</h1>
                <div class="tw-h-1.5 tw-w-10 tw-bg-gradient-to-r tw-from-[#f5c518] tw-to-transparent tw-rounded-full tw-mt-1"></div>
            </div>
            <p class="tw-text-slate-500 tw-text-sm tw-font-medium tw-mt-3 tw-leading-relaxed">Seal payroll periods by zone and city to prevent further modifications to processed records.</p>
        </div>
    </div>

    <!-- Main Two-Column Layout -->
    <div class="tw-grid lg:tw-grid-cols-12 tw-gap-6 xl:tw-gap-8 align-top">

        <!-- Left: Closed Periods DataTable -->
        <div class="lg:tw-col-span-7 xl:tw-col-span-8">
            <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-relative tw-h-full">
                <div class="tw-absolute tw-top-0 tw-right-0 tw-w-64 tw-h-64 tw-bg-gradient-to-bl tw-from-amber-50/50 tw-to-transparent tw-rounded-bl-full tw-pointer-events-none" style="z-index:0"></div>

                <div class="tw-relative tw-z-10 tw-px-6 tw-py-5 tw-border-b tw-border-slate-100 tw-flex tw-items-center tw-gap-4 tw-bg-white/50 tw-backdrop-blur-sm">
                    <div class="tw-w-10 tw-h-10 tw-rounded-xl tw-bg-gradient-to-br tw-from-slate-700 tw-to-slate-900 tw-flex tw-items-center tw-justify-center tw-shadow-[0_4px_10px_rgba(15,23,42,0.25)]">
                        <i class="fas fa-lock tw-text-amber-400 tw-text-lg"></i>
                    </div>
                    <div>
                        <h2 class="tw-font-black tw-text-base tw-text-slate-800 tw-tracking-tight">Sealed Period Registry</h2>
                        <p class="tw-text-[10px] tw-font-bold tw-text-slate-400 tw-uppercase tw-tracking-widest">Closed Payroll Cycles</p>
                    </div>
                </div>

                <div class="tw-relative tw-z-10 tw-p-6">
                    <div class="tw-overflow-x-auto custom-scrollbar">
                        <table id="dg1" class="tw-w-full dataTable tw-text-xs">
                            <thead>
                                <tr>
                                    <th class="tw-text-center tw-w-24">Code</th>
                                    <th>City</th>
                                    <th class="tw-text-center">Year</th>
                                    <th class="tw-text-center">Month</th>
                                    <th class="tw-text-center">Closed Date</th>
                                </tr>
                            </thead>
                            <tbody class="tw-divide-y tw-divide-slate-100">
                                @foreach (var item in dataList)
                                {
                                    <tr class="hover:tw-bg-slate-50 tw-transition-colors group tw-text-sm">
                                        <td class="tw-py-4 tw-text-center tw-align-middle">
                                            <a href="#" class="process-link tw-px-2.5 tw-py-1 tw-bg-slate-100 group-hover:tw-bg-white tw-border tw-border-slate-200 tw-rounded-lg tw-font-mono tw-font-black tw-text-slate-600 tw-shadow-sm tw-transition-colors hover:tw-border-amber-400 hover:tw-text-amber-600"
                                               data-city="@item.CityName" data-year="@item.Year" data-month="@item.Month">
                                                @item.Code
                                            </a>
                                        </td>
                                        <td class="tw-py-4 tw-align-middle">
                                            <div class="tw-font-bold tw-text-slate-800 group-hover:tw-text-amber-600 tw-transition-colors tw-flex tw-items-center tw-gap-2">
                                                <i class="fas fa-city tw-text-slate-300 tw-text-xs"></i>
                                                @item.CityName
                                            </div>
                                        </td>
                                        <td class="tw-py-4 tw-align-middle tw-text-center">
                                            <span class="tw-text-xs tw-font-black tw-text-slate-600 tw-bg-slate-50 tw-border tw-border-slate-200 tw-px-2.5 tw-py-1 tw-rounded-md">@item.Year</span>
                                        </td>
                                        <td class="tw-py-4 tw-align-middle tw-text-center">
                                            <span class="tw-text-xs tw-font-black tw-text-slate-600 tw-bg-slate-50 tw-border tw-border-slate-200 tw-px-2.5 tw-py-1 tw-rounded-md">@item.Month</span>
                                        </td>
                                        <td class="tw-py-4 tw-align-middle tw-text-center">
                                            <span class="tw-text-[11px] tw-font-semibold tw-text-slate-500">@(item.UpdatedDate?.ToString("dd/MM/yyyy"))</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Close Period Form -->
        <div class="lg:tw-col-span-5 xl:tw-col-span-4">
            <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-sticky tw-top-24 tw-relative">
                <div class="tw-absolute tw-top-[-50px] tw-right-[-50px] tw-w-40 tw-h-40 tw-bg-amber-100/40 tw-blur-2xl tw-rounded-full tw-pointer-events-none"></div>

                <!-- Panel Header -->
                <div class="tw-p-6 tw-bg-gradient-to-r tw-from-slate-900 tw-to-slate-800 tw-relative tw-z-10">
                    <h3 class="tw-text-amber-400 tw-font-black tw-text-xs tw-uppercase tw-tracking-[0.2em] tw-flex tw-items-center tw-gap-2">
                        <div class="tw-w-6 tw-h-6 tw-bg-white/10 tw-rounded-md tw-flex tw-items-center tw-justify-center">
                            <i class="fas fa-calendar-check"></i>
                        </div>
                        Period Closure Engine
                    </h3>
                </div>

                <form asp-controller="Closing" asp-action="CloseProcesses" method="post" id="closeForm" class="tw-p-7 tw-space-y-5 tw-relative tw-z-10">

                    <!-- Zone -->
                    <div>
                        <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">
                            Zone <span class="tw-text-red-500">*</span>
                        </label>
                        <div class="tw-relative">
                            <i class="fas fa-map-marked-alt tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-amber-500 tw-text-sm tw-pointer-events-none" style="z-index:1"></i>
                            <select asp-for="ZoneCode" asp-items="ViewBag.Zones" id="ddlZone"
                                    class="field-select tw-w-full tw-pl-10 tw-pr-8 tw-py-3 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm tw-appearance-none">
                                <option value="0">All Zones</option>
                            </select>
                        </div>
                    </div>

                    <!-- City -->
                    <div>
                        <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">
                            City <span class="tw-text-red-500">*</span>
                        </label>
                        <div class="tw-relative">
                            <i class="fas fa-city tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-amber-500 tw-text-sm tw-pointer-events-none" style="z-index:1"></i>
                            <select asp-for="CityCode" id="ddlCity"
                                    class="field-select tw-w-full tw-pl-10 tw-pr-8 tw-py-3 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm tw-appearance-none">
                                <option value="00">All Cities</option>
                            </select>
                            <input type="hidden" id="hdnCityCode" />
                        </div>
                    </div>

                    <!-- Year / Month Row -->
                    <div class="tw-grid tw-grid-cols-2 tw-gap-4">
                        <div>
                            <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Fiscal Year</label>
                            <div class="tw-relative">
                                <i class="fas fa-calendar-alt tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs tw-pointer-events-none" style="z-index:1"></i>
                                <select asp-for="Year" id="ddlYear"
                                        class="field-select tw-w-full tw-pl-9 tw-pr-6 tw-py-3 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-700 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-appearance-none">
                                    @for (int i = DateTime.Now.Year - 5; i <= DateTime.Now.Year + 1; i++)
                                    {
                                        <option value="@i">@i</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div>
                            <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Period Month</label>
                            <div class="tw-relative">
                                <i class="fas fa-clock tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs tw-pointer-events-none" style="z-index:1"></i>
                                <select asp-for="Month" id="ddlMonth"
                                        class="field-select tw-w-full tw-pl-9 tw-pr-6 tw-py-3 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-700 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-appearance-none">
                                    <option value="1">January</option>
                                    <option value="2">February</option>
                                    <option value="3">March</option>
                                    <option value="4">April</option>
                                    <option value="5">May</option>
                                    <option value="6">June</option>
                                    <option value="7">July</option>
                                    <option value="8">August</option>
                                    <option value="9">September</option>
                                    <option value="10">October</option>
                                    <option value="11">November</option>
                                    <option value="12">December</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="tw-pt-2 tw-border-t tw-border-slate-100"></div>

                    <!-- Action Controls -->
                    <div class="tw-space-y-3">
                        <!-- Save: full width -->
                        <button type="submit" name="action" value="Save" id="btnSave"
                                class="tw-w-full tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-text-slate-900 tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase tw-shadow-[0_8px_20px_rgba(245,197,24,0.25)] hover:tw-shadow-[0_8px_25px_rgba(245,197,24,0.35)] hover:tw--translate-y-0.5 tw-transition-all disabled:tw-opacity-50 disabled:tw-cursor-not-allowed">
                            <i class="fas fa-lock tw-text-sm"></i> Seal Period
                        </button>
                        <!-- Delete + Reset -->
                        <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                            <button type="submit" name="action" value="Delete" id="btnDelete" disabled="disabled"
                                    onclick="return confirm('Do you want to delete this closed period?');"
                                    class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-bg-white tw-text-red-500 tw-border tw-border-red-100 tw-shadow-sm tw-rounded-xl tw-font-extrabold tw-text-[11px] tw-tracking-wider tw-uppercase hover:tw-bg-red-50 hover:tw-border-red-200 tw-transition-all disabled:tw-opacity-40 disabled:tw-cursor-not-allowed">
                                <i class="fas fa-trash-alt"></i> Revoke
                            </button>
                            <button type="submit" name="action" value="Reset" id="btnReset" formnovalidate
                                    class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-bg-white tw-text-slate-600 tw-border tw-border-slate-200 tw-shadow-sm tw-rounded-xl tw-font-extrabold tw-text-[11px] tw-tracking-wider tw-uppercase hover:tw-bg-slate-50 hover:tw-text-slate-900 tw-transition-all">
                                <i class="fas fa-undo-alt tw-opacity-60"></i> Deselect
                            </button>
                        </div>
                    </div>

                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script type="text/javascript">
        $(document).ready(function () {

            // Initialize DataTable
            if ($.fn.DataTable) {
                $('#dg1').DataTable({
                    "pageLength": 10,
                    "lengthChange": false,
                    "dom": '<"tw-flex tw-flex-col sm:tw-flex-row tw-justify-between tw-items-center tw-mb-2"f>rt<"tw-flex tw-flex-col sm:tw-flex-row tw-justify-between tw-items-center"ip>',
                    "language": {
                        "search": "",
                        "searchPlaceholder": "Search periods...",
                        "paginate": {
                            "previous": "<i class='fas fa-chevron-left tw-text-[10px]'></i>",
                            "next": "<i class='fas fa-chevron-right tw-text-[10px]'></i>"
                        }
                    }
                });

                $('.dataTables_filter label').addClass('tw-relative tw-block tw-w-full');
                $('.dataTables_filter input').addClass('tw-pl-10');
                $('.dataTables_filter label').append('<i class="fas fa-search tw-absolute tw-left-4 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400"></i>');
            }

            // Zone → Cities cascade
            $("#ddlZone").change(function () {
                var zoneId = $(this).val();
                var ddlCity = $("#ddlCity");
                ddlCity.empty().append('<option value="00">All Cities</option>');

                if (zoneId && zoneId !== "0") {
                    $.ajax({
                        url: '@Url.Action("GetCitiesByZoneUser", "Closing")',
                        type: "GET",
                        data: { zoneCode: zoneId },
                        success: function (res) {
                            if (res && res.length > 0) {
                                $.each(res, function (i, item) {
                                    ddlCity.append('<option value="' + item.value + '">' + item.text + '</option>');
                                });
                            }
                            var hdn = $("#hdnCityCode").val();
                            if (hdn) {
                                ddlCity.val(hdn);
                                $("#hdnCityCode").val('');
                            }
                        }
                    });
                }
            });

            // Row click: populate form and lock fields
            $('.process-link').click(function (e) {
                e.preventDefault();
                var city  = $(this).data('city');
                var year  = $(this).data('year');
                var month = $(this).data('month');

                $('#ddlYear').val(year);
                $('#ddlMonth').val(month);
                $('#btnSave').prop('disabled', true);
                $('#btnDelete').prop('disabled', false);
                $("#hdnCityCode").val(city);

                $('#ddlYear').prop('disabled', true);
                $('#ddlMonth').prop('disabled', true);
                $('#ddlZone').prop('disabled', true);
                $('#ddlCity').prop('disabled', true);

                $('html, body').animate({ scrollTop: 0 }, 'fast');
            });

        });
    </script>
}
