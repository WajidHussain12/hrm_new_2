                                    <td class="tw-px-3 tw-py-2 tw-font-mono tw-text-slate-600">@(row.CourierId?.ToString() ?? "—")</td>
                                    <td class="tw-px-3 tw-py-2 tw-font-mono tw-font-bold tw-text-purple-600">@(row.RateId?.ToString() ?? "—")</td>
                                    <td class="tw-px-3 tw-py-2 tw-text-slate-500">@(row.RateTypeName ?? "—")</td>
                                    <td class="tw-px-3 tw-py-2 tw-text-right tw-font-mono tw-font-bold tw-text-purple-600">@Fmt(row.OleCommission)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

    </div>

    <!-- ══════════════════════════════════════════════════════════════════
         TAB: Adjustments & SR Bonus
    ════════════════════════════════════════════════════════════════════ -->
    <div id="tab-adjbonus" class="tab-content tw-hidden">

        <!-- ── Adjustments ──────────────────────────────────────────── -->
        <div class="tw-bg-white tw-rounded-2xl tw-border tw-border-slate-200 tw-shadow-sm tw-mb-4">
            <div class="tw-p-4 tw-border-b tw-border-slate-100 tw-flex tw-items-center tw-justify-between">
                <div class="tw-flex tw-items-center tw-gap-2">
                    <i class="fas fa-balance-scale tw-text-indigo-500"></i>
                    <div>
                        <span class="tw-text-sm tw-font-bold tw-text-slate-700">Commission Adjustments</span>
                        <div class="tw-text-xs tw-text-slate-400">hr_empcommadjdtl + adjusment_policy  (Server 10)</div>
                    </div>
                </div>
                <div class="tw-text-right">
                    <div class="tw-text-xs tw-text-slate-400">@Model.Adjustments.Count records</div>
                    @if (Model.Adjustments.Any())
                    {
                        <div class="tw-text-sm tw-font-bold @(Model.AdjustmentTotal >= 0 ? "tw-text-emerald-600" : "tw-text-red-600")">
                            Rs @Fmt(Model.AdjustmentTotal)
                        </div>
                    }
                </div>
            </div>
            @if (Model.Adjustments.Count == 0)
            {
                <div class="tw-p-5 tw-text-center tw-text-slate-400 tw-text-sm">
                    <i class="fas fa-inbox tw-text-xl tw-mb-2 tw-block"></i>
                    Is period mein koi adjustment nahi hai.
                </div>
            }
            else
            {
                <div class="tw-overflow-x-auto">
                    <table class="tw-w-full tw-text-xs">
                        <thead class="tw-bg-indigo-50 tw-border-b tw-border-indigo-100">
                            <tr>
                                <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">#</th>
                                <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">Type</th>
                                <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">Remarks</th>
                                <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">Date</th>
                                <th class="tw-px-3 tw-py-2 tw-text-right tw-font-bold tw-text-indigo-600">Amount</th>
                            </tr>
                        </thead>
                        <tbody class="tw-divide-y tw-divide-slate-100">
                            @foreach (var a in Model.Adjustments)
                            {
                                <tr class="hover:tw-bg-indigo-50/30">
                                    <td class="tw-px-3 tw-py-2 tw-font-mono tw-text-slate-500">@a.Id</td>
                                    <td class="tw-px-3 tw-py-2">
                                        <span class="tw-bg-indigo-100 tw-text-indigo-700 tw-px-2 tw-py-0.5 tw-rounded tw-font-semibold">@(a.AdjustmentType ?? "—")</span>
                                    </td>
                                    <td class="tw-px-3 tw-py-2 tw-text-slate-600">@(a.Remarks ?? "—")</td>
                                    <td class="tw-px-3 tw-py-2 tw-text-slate-400">@(a.CreatedDate?.ToString("dd MMM yyyy") ?? "—")</td>
                                    <td class="tw-px-3 tw-py-2 tw-text-right tw-font-mono tw-font-bold @(a.Amount >= 0 ? "tw-text-emerald-600" : "tw-text-red-600")">
                                        @Fmt(a.Amount)
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="tw-bg-indigo-50 tw-border-t tw-border-indigo-200">
                            <tr>
                                <td colspan="4" class="tw-px-3 tw-py-2 tw-text-right tw-font-bold tw-text-slate-600">Adjustment Total</td>
                                <td class="tw-px-3 tw-py-2 tw-text-right tw-font-bold @(Model.AdjustmentTotal >= 0 ? "tw-text-emerald-700" : "tw-text-red-700")">
                                    Rs @Fmt(Model.AdjustmentTotal)
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
        </div>

        <!-- ── SR / Ecom Overall Bonus ───────────────────────────────── -->
        <div class="tw-bg-white tw-rounded-2xl tw-border tw-border-slate-200 tw-shadow-sm">
            <div class="tw-p-4 tw-border-b tw-border-slate-100 tw-flex tw-items-center tw-justify-between">
                <div class="tw-flex tw-items-center tw-gap-2">
                    <i class="fas fa-award tw-text-amber-500"></i>
                    <div>
                        <span class="tw-text-sm tw-font-bold tw-text-slate-700">Ecom SR Overall Bonus</span>
                        <div class="tw-text-xs tw-text-slate-400">hr_incentive_overall_SR  (Server 10)</div>
                    </div>
                </div>
                @if (Model.SrBonus != null && Model.SrBonus.BonusAmount > 0)
                {
                    <span class="tw-text-sm tw-font-bold tw-text-amber-600">Rs @FmtI(Model.SrBonus.BonusAmount)</span>
                }
            </div>
            @if (Model.SrBonus == null)
            {
                <div class="tw-p-5 tw-text-center tw-text-slate-400 tw-text-sm">
                    <i class="fas fa-inbox tw-text-xl tw-mb-2 tw-block"></i>
                    Is period mein koi SR Bonus record nahi mila.
                </div>
            }
            else
            {
                <div class="tw-p-4 tw-grid tw-grid-cols-2 sm:tw-grid-cols-4 tw-gap-3">
                    @{
                        var srEligColor = Model.SrBonus.IsEligible == "Eligible"
                            ? "tw-bg-emerald-50 tw-border-emerald-200 tw-text-emerald-700"
                            : "tw-bg-red-50 tw-border-red-200 tw-text-red-700";
                    }
                    <div class="tw-col-span-2 sm:tw-col-span-1 tw-border tw-rounded-xl tw-p-3 @srEligColor">
                        <div class="tw-text-xs tw-opacity-70 tw-mb-1">Eligibility</div>
                        <div class="tw-text-sm tw-font-bold">
                            <i class="fas @(Model.SrBonus.IsEligible == "Eligible" ? "fa-check-circle" : "fa-times-circle") tw-mr-1"></i>
                            @(Model.SrBonus.IsEligible ?? "—")
                        </div>
                    </div>
                    <div class="tw-border tw-rounded-xl tw-p-3 tw-bg-amber-50 tw-border-amber-200">
                        <div class="tw-text-xs tw-text-amber-500 tw-mb-1">Bonus Amount</div>
                        <div class="tw-text-sm tw-font-bold tw-text-amber-700">Rs @FmtI(Model.SrBonus.BonusAmount)</div>
                    </div>
                    <div class="tw-border tw-rounded-xl tw-p-3 tw-bg-slate-50 tw-border-slate-200">
                        <div class="tw-text-xs tw-text-slate-500 tw-mb-1">Total CNs</div>
                        <div class="tw-text-sm tw-font-bold tw-text-slate-700">@(Model.SrBonus.TotalCn?.ToString() ?? "—")</div>
                    </div>
                    <div class="tw-border tw-rounded-xl tw-p-3 tw-bg-emerald-50 tw-border-emerald-200">
                        <div class="tw-text-xs tw-text-emerald-500 tw-mb-1">Eligible CNs</div>
                        <div class="tw-text-sm tw-font-bold tw-text-emerald-700">@(Model.SrBonus.EligibleCn?.ToString() ?? "—")</div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.SrBonus.Remarks))
                    {
                        <div class="tw-col-span-2 sm:tw-col-span-4 tw-border tw-rounded-xl tw-p-3 tw-bg-slate-50 tw-border-slate-200 tw-text-xs tw-text-slate-600">
                            <i class="fas fa-comment-alt tw-mr-1 tw-text-slate-400"></i>@Model.SrBonus.Remarks
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════════════
         TAB 5: Server 6 — Billing CNs
    ════════════════════════════════════════════════════════════════════ -->
    <div id="tab-s6" class="tab-content tw-hidden">
        <div class="tw-bg-white tw-rounded-2xl tw-border tw-border-slate-200 tw-shadow-sm">
            <div class="tw-p-4 tw-border-b tw-border-slate-100">
                <div class="tw-flex tw-items-center tw-justify-between tw-flex-wrap tw-gap-2">
                    <div class="tw-flex tw-items-center tw-gap-2">
                        <i class="fas fa-server tw-text-blue-500"></i>
                        <div>
                            <span class="tw-text-sm tw-font-bold tw-text-slate-700">Server 6 — Raw Billing CNs</span>
                            <div class="tw-text-xs tw-text-slate-400">lcs_billing.billing_details (172.16.0.6)</div>
                        </div>
                    </div>
                    @if (Model.S6Connected)
                    {
                        <div class="tw-flex tw-flex-wrap tw-gap-2 tw-text-xs">
                            <span class="tw-bg-slate-100 tw-text-slate-600 tw-px-2 tw-py-1 tw-rounded-lg">
                                Total CNs (CASH only): <strong>@Model.S6TotalBillingCns</strong>
                            </span>
                            <span class="tw-bg-emerald-100 tw-text-emerald-600 tw-px-2 tw-py-1 tw-rounded-lg">
                                In Commission: <strong>@Model.S6MatchedCns</strong>
                            </span>
                            @if (Model.S6MissingCns > 0)
                            {
                                <span class="tw-bg-red-100 tw-text-red-600 tw-px-2 tw-py-1 tw-rounded-lg">
                                    Missing: <strong>@Model.S6MissingCns</strong>
                                </span>
                                <span class="tw-bg-amber-50 tw-text-amber-700 tw-border tw-border-amber-200 tw-px-2 tw-py-1 tw-rounded-lg tw-text-xs">
                                    <i class="fas fa-info-circle tw-mr-1"></i>
                                    Yeh @Model.S6MissingCns CNs S6 (Billing Server) par hain lekin S10 (hr_cash_consignments) mein match nahi hue —
                                    wajah: Retail COD CNs sirf S10 mein hote hain S6 mein nahi, ya CN tagged alag courier hai, ya commission period mismatch.
                                </span>
                            }
                            else
                            {
                                <span class="tw-bg-emerald-50 tw-text-emerald-700 tw-px-2 tw-py-1 tw-rounded-lg">
                                    <i class="fas fa-check tw-mr-1"></i>Missing: 0
                                </span>
                            }
                        </div>
                    }
                </div>
                @if (Model.S6Connected && Model.RetailCodCount > 0)
                {
                    <div class="tw-mt-2 tw-text-xs tw-bg-blue-50 tw-border tw-border-blue-100 tw-rounded-lg tw-px-3 tw-py-1.5 tw-text-blue-700">
                        <i class="fas fa-info-circle tw-mr-1"></i>
                        S10 mein <strong>@Model.TotalCashCns CNs</strong> hain (@Model.CashOnlyCount CASH + @Model.RetailCodCount Retail COD).
                        S6 billing_details sirf <strong>CASH</strong> type track karta hai — Retail COD CNs yahan nahi aate. Yeh normal hai, koi error nahi.
                    </div>
                }
                @if (!Model.S6RouteCodesMatch && Model.S6Connected)
                {
                    <div class="tw-mt-2 tw-text-xs tw-bg-amber-50 tw-border tw-border-amber-200 tw-rounded-lg tw-px-3 tw-py-1.5 tw-text-amber-700">
                        <i class="fas fa-exclamation-triangle tw-mr-1"></i>
                        Server 6 route codes: [@string.Join(", ", Model.S6RouteCodes)] — Main Server se different!
                    </div>
                }
            </div>
            @if (!Model.S6Connected)
            {
                <div class="tw-p-4 tw-m-3 tw-bg-amber-50 tw-border tw-border-amber-200 tw-rounded-xl tw-text-sm tw-text-amber-700">
                    <i class="fas fa-plug tw-mr-2"></i>Server 6 (LHR_Billing) unavailable: @Model.S6Error
                    <p class="tw-text-xs tw-mt-1 tw-text-amber-600">Server 10 ka data show ho raha hai. Server 6 ka raw billing verify nahi ho sakta.</p>
                </div>
            }
            else if (Model.S6SampleCns.Count == 0)
            {
                <div class="tw-p-6 tw-text-center tw-text-slate-400 tw-text-sm">
                    <i class="fas fa-inbox tw-text-2xl tw-mb-2 tw-block"></i>
                    Server 6 par is route code ke liye koi billing CN nahi mila is period mein.
                </div>
            }
            else
            {
                <div class="tw-p-3 tw-bg-blue-50 tw-border-b tw-border-blue-100 tw-text-xs tw-text-blue-700">
                    <i class="fas fa-info-circle tw-mr-1"></i>
                    Sample CNs (first 50) — Green = Commission mein hai, Red = Commission se missing
                </div>
                <div class="tw-overflow-x-auto">
                    <table class="tw-w-full tw-text-xs">
                        <thead class="tw-bg-slate-50 tw-border-b tw-border-slate-200">
                            <tr>
                                <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">CN #</th>
                                <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">Billing Date</th>
                                <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">Ship Type</th>
                                <th class="tw-px-3 tw-py-2 tw-text-right tw-font-bold tw-text-slate-500">Billed Amt</th>
                                <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">Cour ID</th>
                                <th class="tw-px-3 tw-py-2 tw-text-center tw-font-bold tw-text-slate-500">In Comm?</th>
                            </tr>
                        </thead>
                        <tbody class="tw-divide-y tw-divide-slate-100">
                            @foreach (var cn in Model.S6SampleCns)
                            {
                                <tr class="@(cn.IsInCommission ? "tw-bg-emerald-50/30" : "tw-bg-red-50/30") hover:tw-opacity-90">
                                    <td class="tw-px-3 tw-py-2 tw-font-mono tw-font-bold @(cn.IsInCommission ? "tw-text-emerald-700" : "tw-text-red-600")">@cn.CnNumber</td>
                                    <td class="tw-px-3 tw-py-2 tw-text-slate-600">@(cn.BillingDate?.ToString("dd MMM yy") ?? "—")</td>
                                    <td class="tw-px-3 tw-py-2 tw-text-slate-500" title="ID: @cn.ShipmentTypeId">@(cn.ShipmentLabel ?? cn.ShipmentTypeId?.ToString() ?? "—")</td>
                                    <td class="tw-px-3 tw-py-2 tw-text-right tw-font-mono">@Fmt(cn.BilledAmount)</td>
                                    <td class="tw-px-3 tw-py-2 tw-font-mono tw-text-slate-500">@cn.CourId</td>
                                    <td class="tw-px-3 tw-py-2 tw-text-center">
                                        @if (cn.IsInCommission)
                                        {
                                            <i class="fas fa-check-circle tw-text-emerald-500"></i>
                                        }
                                        else
                                        {
                                            <i class="fas fa-times-circle tw-text-red-400"></i>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════════════
         TAB 6: Server 7 — Location
    ════════════════════════════════════════════════════════════════════ -->
    <div id="tab-s7" class="tab-content tw-hidden">
        <div class="tw-bg-white tw-rounded-2xl tw-border tw-border-slate-200 tw-shadow-sm">
            <div class="tw-p-4 tw-border-b tw-border-slate-100">
                <div class="tw-flex tw-items-center tw-gap-2">
                    <i class="fas fa-map-marker-alt tw-text-purple-500"></i>
                    <div>
                        <span class="tw-text-sm tw-font-bold tw-text-slate-700">Employee Location Details</span>
                        <div class="tw-text-xs tw-text-slate-400">lcs_hr.hr_employeelocationdetails (Server 10 — 172.16.0.10)</div>
                    </div>
                </div>
            </div>
            @if (!Model.S7Connected)
            {
                <div class="tw-p-4 tw-m-3 tw-bg-amber-50 tw-border tw-border-amber-200 tw-rounded-xl tw-text-sm tw-text-amber-700">
                    <i class="fas fa-plug tw-mr-2"></i>Server 7 (MIS) unavailable: @Model.S7Error
                </div>
            }
            else
            {
                <div class="tw-p-4">
                    <!-- Location presence -->
                    <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
                        <span class="tw-text-xs tw-font-semibold tw-text-slate-600">Location Record (Server 10 — hr_employeelocationdetails):</span>
                        @if (Model.S7LocationPresent)
                        {
                            <span class="tw-text-xs tw-bg-emerald-100 tw-text-emerald-700 tw-px-2 tw-py-0.5 tw-rounded-full tw-font-bold">
                                <i class="fas fa-check-circle tw-mr-1"></i>Present
                            </span>
                        }
                        else
                        {
                            <span class="tw-text-xs tw-bg-red-100 tw-text-red-700 tw-px-2 tw-py-0.5 tw-rounded-full tw-font-bold">
                                <i class="fas fa-times-circle tw-mr-1"></i>Not Found — OLE commission affected
                            </span>
                        }
                    </div>
                    <div class="tw-text-xs tw-text-slate-400 tw-mb-3 tw-italic">
                        Note: Location master S10 par hota hai — S7 is table mein replicate nahi hota. Route Code alag table (hr_employeeroutecode) mein hota hai.
                    </div>

                    @if (Model.S7Locations.Count > 0)
                    {
                        <div class="tw-overflow-x-auto tw-mb-4">
                            <table class="tw-w-full tw-text-xs">
                                <thead class="tw-bg-slate-50 tw-border tw-border-slate-200">
                                    <tr>
                                        <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">Location ID</th>
                                        <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">City</th>
                                        <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">From – To</th>
                                        <th class="tw-px-3 tw-py-2 tw-text-center tw-font-bold tw-text-slate-500">Active</th>
                                    </tr>
                                </thead>
                                <tbody class="tw-divide-y tw-divide-slate-100">
                                    @foreach (var loc in Model.S7Locations)
                                    {
                                        <tr class="@(loc.IsActive ? "" : "tw-opacity-60 tw-bg-slate-50")">
                                            <td class="tw-px-3 tw-py-2 tw-font-mono tw-text-purple-600 tw-font-bold">@loc.LocationId</td>
                                            <td class="tw-px-3 tw-py-2 tw-text-slate-600">@(loc.CityName ?? loc.CityCode)</td>
                                            <td class="tw-px-3 tw-py-2 tw-text-slate-500">
                                                @(loc.FromDate?.ToString("dd MMM yy") ?? "—") – @(loc.ToDate?.ToString("dd MMM yy") ?? "Present")
                                            </td>
                                            <td class="tw-px-3 tw-py-2 tw-text-center">
                                                @if (loc.IsActive)
                                                {
                                                    <i class="fas fa-check-circle tw-text-emerald-500"></i>
                                                }
                                                else
                                                {
                                                    <i class="fas fa-times-circle tw-text-red-400"></i>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════════════
         TAB 7: Final Commission Breakdown
    ════════════════════════════════════════════════════════════════════ -->
    <div id="tab-final" class="tab-content tw-hidden">

        <!-- ── Cross-source summary (always visible) ─────────────────── -->
        @{
            // Final commission column values (from hr_commissionprocess S10 — compiled amounts)
            decimal fcOverland  = Model.FinalComm?.NonZeroColumns.GetValueOrDefault("OVERLAND") ?? 0;
            decimal fcVas       = Model.FinalComm?.NonZeroColumns.GetValueOrDefault("VAS") ?? 0;
            decimal fcReturnEC  = Model.FinalComm?.NonZeroColumns.GetValueOrDefault("Return_E_Com") ?? 0;
            decimal fcCodBonus  = Model.FinalComm?.NonZeroColumns.GetValueOrDefault("COD_Bonus") ?? 0;
        }
        <div class="tw-bg-white tw-rounded-2xl tw-border tw-border-slate-200 tw-shadow-sm tw-mb-4 tw-p-4">
            <div class="tw-flex tw-items-center tw-justify-between tw-mb-1">
                <div class="tw-flex tw-items-center tw-gap-2">
                    <i class="fas fa-layer-group tw-text-violet-500"></i>
                    <span class="tw-text-sm tw-font-bold tw-text-slate-700">Commission Sources — Cross-Server Summary</span>
                </div>
            </div>
            <div class="tw-text-xs tw-text-slate-400 tw-mb-3">
                <i class="fas fa-info-circle tw-mr-1"></i>
                <strong>2 alag cheezein hain:</strong>
                "Per-CN Detail" = source tables mein actual CN records (RBI/OLE tab se) |
                "Final Compiled" = <code>hr_commissionprocess</code> columns (S10 Main Server — processed amount)
            </div>
            <div class="tw-grid tw-grid-cols-2 sm:tw-grid-cols-3 lg:tw-grid-cols-6 tw-gap-2 tw-text-xs">
                <div class="tw-border tw-rounded-xl tw-p-3 tw-bg-blue-50 tw-border-blue-200">
                    <div class="tw-text-blue-500 tw-mb-1"><i class="fas fa-money-bill tw-mr-1"></i>Cash CNs</div>
                    <div class="tw-font-mono tw-font-bold tw-text-blue-700">@Model.TotalCashCns CNs</div>
                    <div class="tw-text-slate-400 tw-text-xs">hr_cash_consignments</div>
                    <div class="tw-font-mono tw-text-blue-600 tw-mt-1">Rs @FmtI(Model.CashTotal)</div>
                </div>
                <div class="tw-border tw-rounded-xl tw-p-3 tw-bg-green-50 tw-border-green-200">
                    <div class="tw-text-green-500 tw-mb-1"><i class="fas fa-hand-holding-usd tw-mr-1"></i>COD CNs</div>
                    <div class="tw-font-mono tw-font-bold tw-text-green-700">@Model.TotalCodCns CNs</div>
                    <div class="tw-text-slate-400 tw-text-xs">hr_cod_consignments</div>
                    <div class="tw-font-mono tw-text-green-600 tw-mt-1">Rs @FmtI(Model.CodTotal)</div>
                </div>
                <div class="tw-border tw-rounded-xl tw-p-3 @(fcOverland > 0 || Model.RbiRows.Count > 0 ? "tw-bg-purple-50 tw-border-purple-300" : "tw-bg-slate-50 tw-border-slate-200")">
                    <div class="tw-text-purple-500 tw-mb-1"><i class="fas fa-box-open tw-mr-1"></i>RBI / Overland</div>
                    @if (Model.RbiRows.Count > 0)
                    {
                        <div class="tw-font-mono tw-font-bold tw-text-purple-700">@Model.RbiRows.Count CNs (detail)</div>
                        <div class="tw-font-mono tw-text-purple-600">Rs @FmtI(Model.RbiTotal)</div>
                    }
                    else
                    {
                        <div class="tw-text-slate-400 tw-text-xs">Per-CN detail: nahi mila</div>
                    }
                    @if (fcOverland > 0)
                    {
                        <div class="tw-mt-1 tw-pt-1 tw-border-t tw-border-purple-200">
                            <div class="tw-text-purple-400 tw-text-xs">Final compiled:</div>
                            <div class="tw-font-mono tw-font-bold tw-text-purple-700">Rs @FmtI(fcOverland)</div>
                        </div>
                    }
                </div>
                <div class="tw-border tw-rounded-xl tw-p-3 @(fcVas > 0 || Model.VasRows.Count > 0 ? "tw-bg-teal-50 tw-border-teal-300" : "tw-bg-slate-50 tw-border-slate-200")">
                    <div class="tw-text-teal-500 tw-mb-1"><i class="fas fa-star tw-mr-1"></i>VAS / General</div>
                    @if (Model.VasRows.Count > 0)
                    {
                        <div class="tw-font-mono tw-font-bold tw-text-teal-700">@Model.VasRows.Count CNs (detail)</div>
                        <div class="tw-font-mono tw-text-teal-600">Rs @FmtI(Model.VasTotal)</div>
                    }
                    else
                    {
                        <div class="tw-text-slate-400 tw-text-xs">Per-CN detail: nahi mila</div>
                    }
                    @if (fcVas > 0)
                    {
                        <div class="tw-mt-1 tw-pt-1 tw-border-t tw-border-teal-200">
                            <div class="tw-text-teal-400 tw-text-xs">Final compiled:</div>
                            <div class="tw-font-mono tw-font-bold tw-text-teal-700">Rs @FmtI(fcVas)</div>
                        </div>
                    }
                </div>
                <div class="tw-border tw-rounded-xl tw-p-3 @(fcReturnEC > 0 || Model.CodReturnRows.Count > 0 ? "tw-bg-orange-50 tw-border-orange-300" : "tw-bg-slate-50 tw-border-slate-200")">
                    <div class="tw-text-orange-500 tw-mb-1"><i class="fas fa-undo-alt tw-mr-1"></i>COD Return</div>
                    @if (Model.CodReturnRows.Count > 0)
                    {
                        <div class="tw-font-mono tw-font-bold tw-text-orange-700">@Model.CodReturnRows.Count CNs (detail)</div>
                        <div class="tw-font-mono tw-text-orange-600">Rs @FmtI(Model.CodReturnTotal)</div>
                    }
                    else
                    {
                        <div class="tw-text-slate-400 tw-text-xs">Per-CN detail: nahi mila</div>
                    }
                    @if (fcReturnEC > 0)
                    {
                        <div class="tw-mt-1 tw-pt-1 tw-border-t tw-border-orange-200">
                            <div class="tw-text-orange-400 tw-text-xs">Final compiled:</div>
                            <div class="tw-font-mono tw-font-bold tw-text-orange-700">Rs @FmtI(fcReturnEC)</div>
                        </div>
                    }
                </div>
                <div class="tw-border tw-rounded-xl tw-p-3 tw-bg-indigo-50 tw-border-indigo-200">
                    <div class="tw-text-indigo-500 tw-mb-1"><i class="fas fa-balance-scale tw-mr-1"></i>Adjustments</div>
                    <div class="tw-font-mono tw-font-bold tw-text-indigo-700">@Model.Adjustments.Count records</div>
                    @if (Model.Adjustments.Any())
                    {
                        <div class="tw-font-mono @(Model.AdjustmentTotal >= 0 ? "tw-text-emerald-600" : "tw-text-red-600")">Rs @Fmt(Model.AdjustmentTotal)</div>
                    }
                    else
                    {
                        <div class="tw-text-slate-400 tw-text-xs">Koi adjustment nahi</div>
                    }
                </div>
            </div>
            @if (fcOverland > 0 && Model.RbiRows.Count == 0)
            {
                <div class="tw-mt-3 tw-p-3 tw-bg-amber-50 tw-border tw-border-amber-200 tw-rounded-xl tw-text-xs tw-text-amber-800">
                    <i class="fas fa-exclamation-triangle tw-mr-1 tw-text-amber-500"></i>
                    <strong>RBI/Overland discrepancy:</strong>
                    Final commission mein <strong>OVERLAND = Rs @FmtI(fcOverland)</strong> hai — lekin
                    <code>hr_rbi_incentive_detail</code> mein is employee ke route codes ka koi per-CN record nahi mila.
                    Yeh amount S6/S7 se process hokar directly <code>hr_commissionprocess</code> mein compile hua — per-CN detail trace nahi ho sakti.
                </div>
            }
            @if (fcVas > 0 && Model.VasRows.Count == 0)
            {
                <div class="tw-mt-2 tw-p-3 tw-bg-amber-50 tw-border tw-border-amber-200 tw-rounded-xl tw-text-xs tw-text-amber-800">
                    <i class="fas fa-exclamation-triangle tw-mr-1 tw-text-amber-500"></i>
                    <strong>VAS discrepancy:</strong>
                    Final commission mein <strong>VAS = Rs @FmtI(fcVas)</strong> hai — lekin
                    <code>hr_ole_vas_incentive_detail</code> mein koi per-CN record nahi mila.
                    Yeh amount commission process ne directly compile kiya — source CNs is view mein traceable nahi hain.
                </div>
            }
            @if (Model.SrBonus != null)
            {
                <div class="tw-mt-2 tw-flex tw-items-center tw-gap-2 tw-text-xs tw-p-2 tw-rounded-lg tw-bg-amber-50 tw-border tw-border-amber-200">
                    <i class="fas fa-award tw-text-amber-500"></i>
                    <span class="tw-font-bold tw-text-amber-700">SR Bonus:</span>
                    <span class="tw-text-amber-600">@(Model.SrBonus.IsEligible ?? "—")</span>
                    @if (Model.SrBonus.BonusAmount > 0)
                    {
                        <span class="tw-font-mono tw-font-bold tw-text-amber-700">— Rs @FmtI(Model.SrBonus.BonusAmount)</span>
                    }
                    @if (Model.SrBonus.TotalCn.HasValue)
                    {
                        <span class="tw-text-slate-500">(@(Model.SrBonus.EligibleCn) / @(Model.SrBonus.TotalCn) eligible CNs)</span>
                    }
                </div>
            }
        </div>

        @if (Model.HasFinalCommission && Model.FinalComm?.GrandTotal == 0)
        {
            <div class="tw-bg-red-50 tw-border tw-border-red-200 tw-rounded-2xl tw-p-4 tw-mb-4">
                <div class="tw-flex tw-items-start tw-gap-3">
                    <i class="fas fa-exclamation-circle tw-text-red-500 tw-text-2xl tw-mt-0.5 tw-flex-shrink-0"></i>
                    <div>
                        <div class="tw-text-base tw-font-bold tw-text-red-700 tw-mb-1">
                            Commission Record Exists — Lekin Grand Total = Rs 0
                        </div>
                        <div class="tw-text-sm tw-text-red-600 tw-mb-2">
                            <code>hr_commissionprocess</code> mein @ML(Model.Month) @Model.Year ka record hai
                            (Cour_id = <span class="tw-font-mono tw-font-bold">@(Model.FinalComm?.CourId ?? "NULL")</span>)
                            lekin saare commission columns zero hain.
                        </div>
                        <div class="tw-text-xs tw-text-red-700 tw-bg-red-100 tw-rounded-lg tw-p-3 tw-space-y-1">
                            @if (string.IsNullOrEmpty(Model.FinalComm?.CourId))
                            {
                                <div><i class="fas fa-times-circle tw-mr-1"></i> <strong>Cour_id = NULL</strong> — Process ne koi route code link nahi kiya. Route code assign nahi tha jab process chali.</div>
                            }
                            @if (!Model.HasRouteCodes)
                            {
                                <div><i class="fas fa-times-circle tw-mr-1"></i> <strong>No Route Code</strong> — hr_employeeroutecode mein koi active route code nahi. Yahi root cause hai.</div>
                            }
                            @if (Model.IsEligible == null)
                            {
                                <div><i class="fas fa-times-circle tw-mr-1"></i> <strong>No Eligibility Record</strong> — hr_empcommissioneligibility mein koi record nahi.</div>
                            }
                        </div>
                        <div class="tw-mt-2 tw-text-xs tw-text-red-600 tw-font-semibold">
                            <i class="fas fa-tools tw-mr-1"></i>
                            Fix: Issues tab mein saare Critical issues resolve karein, phir Commission Process Master se REPROCESS chalayein.
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (Model.ZeroMonthsList.Count > 0)
        {
            var rpMonthNames = new[]{"","Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"};
            <div class="tw-bg-white tw-rounded-2xl tw-border tw-border-orange-200 tw-shadow-sm tw-mb-4">
                <div class="tw-p-4 tw-border-b tw-border-orange-100 tw-flex tw-items-center tw-justify-between tw-flex-wrap tw-gap-2">
                    <div class="tw-flex tw-items-center tw-gap-2">
                        <i class="fas fa-history tw-text-orange-500"></i>
                        <span class="tw-text-sm tw-font-bold tw-text-orange-700">
                            @Model.ZeroMonthsList.Count Months — Rs 0 Commission — Reprocess Karein
                        </span>
                    </div>
                    <span class="tw-text-xs tw-text-orange-500 tw-bg-orange-50 tw-border tw-border-orange-200 tw-px-2 tw-py-1 tw-rounded-lg">
                        <i class="fas fa-exclamation-triangle tw-mr-1"></i>
                        Route Code assign karne ke BAAD reprocess karein
                    </span>
                </div>
                <div class="tw-p-4">
                    <div class="tw-text-xs tw-text-slate-500 tw-mb-3">
                        Neeche har zero-commission month ke liye individual "Reprocess" button hai.
                        <strong class="tw-text-orange-600">Pehle Route Code + Eligibility fix karein</strong>, phir yahan se reprocess chalayein.
                    </div>
                    <div class="tw-overflow-x-auto">
                        <table class="tw-w-full tw-text-xs">
                            <thead class="tw-bg-slate-50 tw-border-b tw-border-slate-200">
                                <tr>
                                    <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">Period</th>
                                    <th class="tw-px-3 tw-py-2 tw-text-center tw-font-bold tw-text-slate-500">Year</th>
                                    <th class="tw-px-3 tw-py-2 tw-text-center tw-font-bold tw-text-slate-500">Month</th>
                                    <th class="tw-px-3 tw-py-2 tw-text-center tw-font-bold tw-text-slate-500">Status</th>
                                    <th class="tw-px-3 tw-py-2 tw-text-center tw-font-bold tw-text-slate-500">Action</th>
                                </tr>
                            </thead>
                            <tbody class="tw-divide-y tw-divide-slate-100">
                                @foreach (var zm in Model.ZeroMonthsList)
                                {
                                    var isCurrent = zm.Year == Model.Year && zm.Month == Model.Month;
                                    <tr class="@(isCurrent ? "tw-bg-orange-50" : "") hover:tw-bg-slate-50">
                                        <td class="tw-px-3 tw-py-2 tw-font-semibold tw-text-slate-700">
                                            @rpMonthNames[zm.Month] @zm.Year
                                            @if (isCurrent) { <span class="tw-text-xs tw-bg-orange-200 tw-text-orange-800 tw-px-1.5 tw-py-0.5 tw-rounded-full tw-ml-1">Current</span> }
                                        </td>
                                        <td class="tw-px-3 tw-py-2 tw-text-center tw-font-mono">@zm.Year</td>
                                        <td class="tw-px-3 tw-py-2 tw-text-center tw-font-mono">@zm.Month</td>
                                        <td class="tw-px-3 tw-py-2 tw-text-center" id="rp-status-@zm.Year-@zm.Month">
                                            <span class="tw-text-red-500 tw-font-bold">Rs 0</span>
                                        </td>
                                        <td class="tw-px-3 tw-py-2 tw-text-center">
                                            <button onclick="reprocessMonth(@zm.Year, @zm.Month, this)"
                                                    class="tw-text-xs tw-font-bold tw-px-3 tw-py-1 tw-rounded-lg tw-bg-orange-500 hover:tw-bg-orange-600 tw-text-white tw-transition">
                                                <i class="fas fa-redo-alt tw-mr-1"></i>Reprocess
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="tw-mt-3 tw-p-3 tw-bg-amber-50 tw-border tw-border-amber-200 tw-rounded-xl tw-text-xs tw-text-amber-700">
                        <i class="fas fa-info-circle tw-mr-1 tw-text-amber-500"></i>
                        <strong>Note:</strong> Reprocess sirf <code>hr_commissionprocess</code> update karta hai — CNs ka data billing server se re-fetch hota hai.
                        Agar Route Code S6 par bhi assign nahi toh CNs nahi milenge aur commission phir bhi zero rahega.
                    </div>
                </div>
            </div>
        }

        @if (!Model.HasFinalCommission || Model.FinalComm == null)
        {
            bool periodPending = Model.PeriodTo > DateTime.Today;
            <div class="tw-bg-white tw-rounded-2xl tw-border @(periodPending ? "tw-border-blue-200" : "tw-border-red-200") tw-p-8 tw-text-center">
                <i class="fas @(periodPending ? "fa-clock" : "fa-file-invoice") tw-text-4xl @(periodPending ? "tw-text-blue-300" : "tw-text-red-300") tw-mb-3 tw-block"></i>
                @if (periodPending)
                {
                    <h3 class="tw-text-lg tw-font-bold tw-text-blue-600 tw-mb-2">Commission Period Not Yet Complete</h3>
                    <p class="tw-text-sm tw-text-slate-500">
                        Commission period ends <strong>@Model.PeriodTo.ToString("dd MMM yyyy")</strong> — abhi @((Model.PeriodTo - DateTime.Today).Days) din baaki hain.
                    </p>
                    <p class="tw-text-xs tw-text-slate-400 tw-mt-2">
                        @Model.PeriodTo.ToString("dd MMM yyyy") ke baad Commission Process Master run karo.
                    </p>
                }
                else
                {
                    <h3 class="tw-text-lg tw-font-bold tw-text-red-600 tw-mb-2">Final Commission Record Missing</h3>
                    <p class="tw-text-sm tw-text-slate-500">
                        hr_commissionprocess mein is employee ke liye @ML(Model.Month) @Model.Year ka koi record nahi mila.
                    </p>
                    <p class="tw-text-xs tw-text-slate-400 tw-mt-2">
                        Commission Process run nahi hua, ya employee eligible nahi thi.
                    </p>
                }
            </div>
        }
        else
        {
            var fc = Model.FinalComm;
            // Category mappings for per-route commission breakdown
            var _cashCols  = new HashSet<string>(StringComparer.OrdinalIgnoreCase) {
                "DOM_CREDIT","LOCAL_CREDIT","LOCAL_DLD","PMCL","DomesticDelivery","INTL_CREDIT","INTL_CASH",
                "OVERNIGHT","YB1KG","YB2KG","YB5KG","YB10KG","YB15KG","YB25KG","FLAYER","DETAIN",
                "PREPAID","LOVELINE","AllInOne","DocumnetCare","MTD","EconomyRetail",
                "YB1KGRetail","YB2KGRetail","YB5KGRetail","YB10KGRetail","YB15KGRetail","YB25KGRetail",
                "ONUpto1kg","ONAbove1kg","ONUpto1kgRetailCOD","ONAbove1kgRetailCOD",
                "CASH_EXP_BKG_UpTo_2Kg","CASH_EXP_BKG_Above_2Kg","CASH_Leop_BOX_Above_2Kg",
                "CASH_Economy_Booking","CASH_OLE_Booking","MyCollect","Attestation","Pickup_Leopard"
            };
            var _codCols   = new HashSet<string>(StringComparer.OrdinalIgnoreCase) {
                "COD","COD_Deduction","Porter","Rms_Cod_Booking"
            };
            var _oleCols   = new HashSet<string>(StringComparer.OrdinalIgnoreCase) {
                "OVERLAND","OLE_Credit_Booking","OLE_Dispatch_Proper","OLE_Transit_Dispatch",
                "OLE_Delivery_OPS","OLE_Delivery","MOFA_OTO","MOFA_OTD",
                "Cor_Economy_Booking","Cor_Ole_Booking",
                "CEB_UpTo_2Kg","CEB_Above_2Kg","CEB_Upto_2KG_Exis","CEB_Upto_2KG_New",
                "CEB_Above_2Kg_Exis","CEB_Above_2Kg_New",
                "ECON_Credit_Booking_Exis","ECON_Credit_Booking_New",
                "OLE_CORP_Booking_Exis","OLE_CORP_Booking_New",
                "Project_Local_Exis","Project_Local_New","Project_Domestic_Exis","Project_Domestic_New",
                "MTD_Delivery","General_Light_Delivery","General_Heavy_Delivery","Giftwifts_Delivery"
            };
            var _vasCols   = new HashSet<string>(StringComparer.OrdinalIgnoreCase) {
                "VAS","ECommerce_Zero_COD","Passport","CNIC_Card","SOA","Utility_Bill",
                "Return_E_Com","Insurance_Com","Retail_Deduction","Credit_Debit_Card",
                "IntlDox","IntlEconomy","IntlParcel"
            };
            var _bonusCols = new HashSet<string>(StringComparer.OrdinalIgnoreCase) {
                "Ecom_overall_SR_Bonus","COD_Bonus"
            };
            Func<string,string> ColCat = col =>
                _cashCols.Contains(col)  ? "Cash" :
                _codCols.Contains(col)   ? "COD" :
                _oleCols.Contains(col)   ? "OLE / Overland" :
                _vasCols.Contains(col)   ? "VAS / General" :
                _bonusCols.Contains(col) ? "Bonus / SR" : "Other";
            <div class="tw-grid tw-grid-cols-1 lg:tw-grid-cols-3 tw-gap-4">

                <!-- Grand Total Card -->
                <div class="tw-bg-gradient-to-br tw-from-violet-600 tw-to-violet-800 tw-rounded-2xl tw-p-5 tw-text-white">
                    <div class="tw-text-xs tw-font-bold tw-uppercase tw-tracking-wider tw-opacity-80 tw-mb-1">Grand Total</div>
                    <div class="tw-text-3xl tw-font-bold">Rs @FmtI(fc.GrandTotal)</div>
                    <div class="tw-text-xs tw-opacity-70 tw-mt-1">@ML(Model.Month) @Model.Year</div>

                    <!-- Route code info -->
                    @if (!string.IsNullOrEmpty(fc.CourId))
                    {
                        var rcIsActive = Model.RouteCodes.Any(r => r.RouteCode == fc.CourId && r.ToDate == null);
                        <div class="tw-mt-2 tw-bg-white/10 tw-rounded-xl tw-px-3 tw-py-2 tw-text-xs">
                            <div class="tw-opacity-70 tw-mb-0.5">Processed Route Code (Cour_id)</div>
                            <div class="tw-flex tw-items-center tw-gap-2">
                                <span class="tw-font-mono tw-font-bold tw-text-base">@fc.CourId</span>
                                <span class="tw-px-1.5 tw-py-0.5 tw-rounded-full tw-text-xs tw-font-bold
                                    @(rcIsActive ? "tw-bg-emerald-400/30 tw-text-emerald-100" : "tw-bg-white/20 tw-text-white/70")">
                                    @(rcIsActive ? "Active" : "Inactive/Old")
                                </span>
                            </div>
                            @{
                                var otherRoutes = Model.RouteCodes.Where(r => r.RouteCode != fc.CourId).ToList();
                            }
                            @if (otherRoutes.Any())
                            {
                                <div class="tw-mt-1 tw-opacity-70">
                                    Other routes: @string.Join(", ", otherRoutes.Select(r => r.RouteCode))
                                    <span class="tw-italic">(not in this Final record)</span>
                                </div>
                            }
                        </div>
                    }

                    <div class="tw-mt-3 tw-grid tw-grid-cols-2 tw-gap-2 tw-text-xs">
                        <div class="tw-bg-white/10 tw-rounded-lg tw-p-2">
                            <div class="tw-opacity-70">Cash Group</div>
                            <div class="tw-font-bold">Rs @FmtI(fc.CashGroup)</div>
                        </div>
                        <div class="tw-bg-white/10 tw-rounded-lg tw-p-2">
                            <div class="tw-opacity-70">COD Group</div>
                            <div class="tw-font-bold">Rs @FmtI(fc.CodGroup)</div>
                        </div>
                        <div class="tw-bg-white/10 tw-rounded-lg tw-p-2">
                            <div class="tw-opacity-70">OLE Group</div>
                            <div class="tw-font-bold">Rs @FmtI(fc.OleGroup)</div>
                        </div>
                        <div class="tw-bg-white/10 tw-rounded-lg tw-p-2">
                            <div class="tw-opacity-70">Extra Group</div>
                            <div class="tw-font-bold">Rs @FmtI(fc.ExtraGroup)</div>
                        </div>
                    </div>
                </div>

                <!-- All non-zero columns -->
                <div class="tw-bg-white tw-rounded-2xl tw-border tw-border-slate-200 tw-shadow-sm lg:tw-col-span-2">
                    <div class="tw-p-4 tw-border-b tw-border-slate-100">
                        <div class="tw-flex tw-items-start tw-gap-2">
                            <i class="fas fa-list-ul tw-text-emerald-500 tw-mt-0.5"></i>
                            <div>
                                <span class="tw-text-sm tw-font-bold tw-text-slate-700">Commission Breakdown — Non-Zero Fields</span>
                                <div class="tw-text-xs tw-text-slate-400 tw-mt-0.5">
                                    hr_commissionprocess table mein 80+ columns hain — her column ek alag commission type ka amount store karta hai.
                                    Yahan sirf woh columns show hain jin mein amount &gt; 0 hai.
                                    <strong class="tw-text-violet-600">Kisi bhi row par click karein — us commission type ki detail dekhein.</strong>
                                </div>
                            </div>
                        </div>
                    </div>
                    @if (fc.NonZeroColumns.Count == 0)
                    {
                        <div class="tw-p-5 tw-text-center tw-text-slate-400 tw-text-sm">Sab columns zero hain.</div>
                    }
                    else
                    {
                        <div class="tw-overflow-x-auto">
                            <table class="tw-w-full tw-text-xs">
                                <thead class="tw-bg-slate-50 tw-border-b tw-border-slate-200">
                                    <tr>
                                        <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">Commission Type <span class="tw-text-violet-500 tw-font-normal">(click = detail)</span></th>
                                        <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">Source</th>
                                        <th class="tw-px-3 tw-py-2 tw-text-right tw-font-bold tw-text-slate-500">Amount</th>
                                    </tr>
                                </thead>
                                <tbody class="tw-divide-y tw-divide-slate-100">
                                    @foreach (var col in fc.NonZeroColumns.OrderByDescending(kv => kv.Value))
                                    {
                                        <tr class="@(col.Value < 0 ? "tw-bg-red-50/30" : "") hover:tw-bg-violet-50/40 tw-cursor-pointer tw-transition"
                                            onclick="showCommColDetail('@col.Key', '@col.Value.ToString("N2")')">
                                            <td class="tw-px-3 tw-py-2 tw-font-mono tw-text-slate-700 tw-font-semibold">
                                                <i class="fas fa-info-circle tw-text-violet-400 tw-mr-1 tw-opacity-60"></i>@col.Key
                                            </td>
                                            <td class="tw-px-3 tw-py-2 tw-text-slate-400 tw-text-xs" id="src-@col.Key.Replace("_","")">@CommColSource(col.Key)</td>
                                            <td class="tw-px-3 tw-py-2 tw-text-right tw-font-mono tw-font-bold @(col.Value < 0 ? "tw-text-red-600" : "tw-text-emerald-600")">
                                                Rs @col.Value.ToString("N2")
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="tw-bg-slate-50 tw-border-t-2 tw-border-slate-300">
                                    <tr>
                                        <td colspan="2" class="tw-px-3 tw-py-2 tw-font-bold tw-text-slate-700 tw-text-right">Grand Total</td>
                                        <td class="tw-px-3 tw-py-2 tw-text-right tw-font-bold tw-text-violet-700">Rs @FmtI(fc.GrandTotal)</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <!-- ── Per Route Code Commission Detail ──────────────────────── -->
            <div class="tw-mt-4 tw-bg-white tw-rounded-2xl tw-border tw-border-violet-200 tw-shadow-sm">
                <div class="tw-p-4 tw-border-b tw-border-violet-100 tw-flex tw-items-center tw-gap-2">
                    <i class="fas fa-route tw-text-violet-500"></i>
                    <span class="tw-text-sm tw-font-bold tw-text-slate-700">Per Route Code — Commission Detail</span>
                    <span class="tw-text-xs tw-text-slate-400 tw-ml-2">Har route code ka commission alag alag — hr_commissionprocess se</span>
                </div>
                <div class="tw-p-4 tw-space-y-4">
                    @foreach (var rc in Model.RouteCodes.OrderByDescending(r => r.IsActive).ThenByDescending(r => r.FromDate))
                    {
                        bool isProcessedRoute = fc.CourId == rc.RouteCode;
                        var routeHdr = rc.IsActive
                            ? "tw-bg-emerald-50 tw-border-emerald-300"
                            : "tw-bg-slate-50 tw-border-slate-200";
                        <div class="tw-rounded-xl tw-border @routeHdr tw-overflow-hidden">
                            <!-- Route header -->
                            <div class="tw-px-4 tw-py-2 tw-flex tw-items-center tw-justify-between tw-flex-wrap tw-gap-2">
                                <div class="tw-flex tw-items-center tw-gap-2">
                                    <span class="tw-font-mono tw-font-bold tw-text-base @(rc.IsActive ? "tw-text-emerald-700" : "tw-text-slate-600")">
                                        @rc.RouteCode
                                    </span>
                                    <span class="tw-text-xs tw-px-2 tw-py-0.5 tw-rounded-full tw-font-bold @(rc.IsActive ? "tw-bg-emerald-200 tw-text-emerald-800" : "tw-bg-slate-200 tw-text-slate-600")">
                                        @(rc.IsActive ? "Active" : "Inactive")
                                    </span>
                                    @if (isProcessedRoute)
                                    {
                                        <span class="tw-text-xs tw-px-2 tw-py-0.5 tw-rounded-full tw-font-bold tw-bg-violet-200 tw-text-violet-800">
                                            <i class="fas fa-check-circle tw-mr-1"></i>Processed — Commission Yahan Hai
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="tw-text-xs tw-px-2 tw-py-0.5 tw-rounded-full tw-font-bold tw-bg-amber-100 tw-text-amber-700">
                                            <i class="fas fa-minus-circle tw-mr-1"></i>Alag Commission Record Nahi
                                        </span>
                                    }
                                </div>
                                <div class="tw-text-xs tw-text-slate-400">
                                    @(rc.FromDate?.ToString("dd MMM yy") ?? "?") – @(rc.ToDate?.ToString("dd MMM yy") ?? "Present")
                                    @if (!string.IsNullOrEmpty(rc.CodeTypeName)) { <span class="tw-ml-2 tw-text-slate-500">(@rc.CodeTypeName)</span> }
                                </div>
                            </div>

                            @if (isProcessedRoute && fc.NonZeroColumns.Any())
                            {
                                <div class="tw-px-4 tw-pb-3 tw-space-y-2">
                                    @foreach (var grp in fc.NonZeroColumns.GroupBy(kv => ColCat(kv.Key)).OrderBy(g => g.Key == "Cash" ? 0 : g.Key == "COD" ? 1 : g.Key == "OLE / Overland" ? 2 : g.Key == "VAS / General" ? 3 : g.Key == "Bonus / SR" ? 4 : 5))
                                    {
                                        var grpTotal = grp.Sum(kv => kv.Value);
                                        var grpColor = grp.Key == "Cash" ? "tw-text-blue-600 tw-bg-blue-50 tw-border-blue-200"
                                            : grp.Key == "COD" ? "tw-text-green-600 tw-bg-green-50 tw-border-green-200"
                                            : grp.Key == "OLE / Overland" ? "tw-text-purple-600 tw-bg-purple-50 tw-border-purple-200"
                                            : grp.Key == "VAS / General" ? "tw-text-teal-600 tw-bg-teal-50 tw-border-teal-200"
                                            : "tw-text-amber-600 tw-bg-amber-50 tw-border-amber-200";
                                        <details class="tw-border tw-rounded-xl @grpColor tw-overflow-hidden" open>
                                            <summary class="tw-px-3 tw-py-2 tw-cursor-pointer tw-flex tw-items-center tw-justify-between tw-font-bold tw-text-xs">
                                                <span><i class="fas fa-tag tw-mr-1 tw-opacity-60"></i>@grp.Key</span>
                                                <span class="tw-font-mono">Rs @FmtI(grpTotal)</span>
                                            </summary>
                                            <div class="tw-px-3 tw-pb-2 tw-grid tw-grid-cols-2 sm:tw-grid-cols-3 lg:tw-grid-cols-4 tw-gap-1.5 tw-text-xs">
                                                @foreach (var kv in grp.OrderByDescending(k => k.Value))
                                                {
                                                    <div class="tw-bg-white/70 tw-rounded-lg tw-px-2 tw-py-1.5">
                                                        <div class="tw-text-slate-500 tw-font-mono" style="font-size:10px">@kv.Key</div>
                                                        <div class="tw-font-bold tw-font-mono @(kv.Value < 0 ? "tw-text-red-600" : "")">Rs @kv.Value.ToString("N0")</div>
                                                    </div>
                                                }
                                            </div>
                                        </details>
                                    }
                                    <div class="tw-flex tw-justify-end tw-text-sm tw-font-bold tw-text-violet-700 tw-pt-1 tw-border-t tw-border-violet-100">
                                        Total: Rs @FmtI(fc.GrandTotal)
                                    </div>
                                </div>
                            }
                            else if (!isProcessedRoute)
                            {
                                <div class="tw-px-4 tw-pb-3 tw-text-xs tw-text-slate-500 tw-space-y-1">
                                    <div>
                                        <i class="fas fa-info-circle tw-mr-1 tw-text-amber-500"></i>
                                        <strong class="tw-text-amber-700">hr_commissionprocess mein is route ka alag record nahi.</strong>
                                        Commission process sirf active route ke liye run karta hai.
                                    </div>
                                    @if (Model.CashCns.Any(c => c.RouteCode == rc.RouteCode))
                                    {
                                        <div class="tw-text-slate-400">
                                            <i class="fas fa-receipt tw-mr-1"></i>
                                            S10 hr_cash_consignments mein is route ke
                                            <strong class="tw-text-slate-600">@Model.CashCns.Count(c => c.RouteCode == rc.RouteCode) CNs</strong>
                                            hain is period mein — lekin inactive route hone ki wajah se final commission mein include nahi hue.
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                    @if (!Model.RouteCodes.Any())
                    {
                        <div class="tw-p-5 tw-text-center tw-text-slate-400 tw-text-sm">
                            <i class="fas fa-route tw-text-xl tw-mb-2 tw-block"></i>
                            Koi route code assign nahi — commission detail show nahi ho sakti.
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <!-- ══════════════════════════════════════════════════════════════════
         TAB 8: Issues
    ════════════════════════════════════════════════════════════════════ -->
    <div id="tab-issues" class="tab-content tw-hidden">

        @if (Model.Issues.Count == 0)
        {
            <div class="tw-bg-white tw-rounded-2xl tw-border tw-border-emerald-200 tw-p-8 tw-text-center">
                <i class="fas fa-check-circle tw-text-4xl tw-text-emerald-400 tw-mb-3 tw-block"></i>
                <h3 class="tw-text-lg tw-font-bold tw-text-emerald-600 tw-mb-2">Koi Issues Nahi!</h3>
                <p class="tw-text-sm tw-text-slate-500">Auto-detection mein koi anomaly nahi mili.</p>
            </div>
        }
        else
        {
            <!-- Summary bar -->
            <div class="tw-mb-4 tw-flex tw-flex-wrap tw-gap-2 tw-items-center tw-bg-white tw-rounded-xl tw-border tw-border-slate-200 tw-px-4 tw-py-3">
                <i class="fas fa-flag tw-text-slate-400"></i>
                <span class="tw-text-sm tw-font-bold tw-text-slate-700">@Model.Issues.Count Issues Detected</span>
                @if (Model.CriticalIssues.Count > 0)
                {
                    <span class="tw-text-xs tw-font-bold tw-bg-red-100 tw-text-red-700 tw-px-3 tw-py-1 tw-rounded-full tw-border tw-border-red-200">
                        <i class="fas fa-times-circle tw-mr-1"></i>@Model.CriticalIssues.Count Critical
                    </span>
                }
                @if (Model.Warnings.Count > 0)
                {
                    <span class="tw-text-xs tw-font-bold tw-bg-amber-100 tw-text-amber-700 tw-px-3 tw-py-1 tw-rounded-full tw-border tw-border-amber-200">
                        <i class="fas fa-exclamation-triangle tw-mr-1"></i>@Model.Warnings.Count Warning
                    </span>
                }
                @if (Model.InfoItems.Count > 0)
                {
                    <span class="tw-text-xs tw-font-bold tw-bg-blue-100 tw-text-blue-700 tw-px-3 tw-py-1 tw-rounded-full tw-border tw-border-blue-200">
                        <i class="fas fa-info-circle tw-mr-1"></i>@Model.InfoItems.Count Info
                    </span>
                }
                <span class="tw-ml-auto tw-text-xs tw-text-slate-400">Har issue ke neeche step-by-step fix guide diya gaya hai</span>
            </div>

            <div class="tw-space-y-4">
                @{int issueIdx = 0;}
                @foreach (var issue in Model.Issues.OrderBy(i => (int)i.Severity))
                {
                    issueIdx++;
                    bool hasSteps = issue.FixSteps.Count > 0;
                    string panelId = $"fix-panel-{issueIdx}";

                    <!-- Issue card -->
                    <div class="tw-bg-white tw-rounded-2xl tw-border tw-border-slate-200 tw-shadow-sm tw-overflow-hidden">

                        <!-- Issue header (always visible) -->
                        <div class="tw-flex tw-items-start tw-gap-3 tw-p-4 tw-border-b tw-border-slate-100">
                            <!-- severity icon -->
                            <div class="tw-w-10 tw-h-10 tw-rounded-xl tw-flex tw-items-center tw-justify-center tw-flex-shrink-0
                                @(issue.Severity == LCS_HR_MVC.Models.IssueSeverity.Critical ? "tw-bg-red-100" :
                                  issue.Severity == LCS_HR_MVC.Models.IssueSeverity.Warning  ? "tw-bg-amber-100" :
                                                                                                "tw-bg-blue-100")">
                                <i class="fas @issue.SeverityIcon tw-text-lg
                                    @(issue.Severity == LCS_HR_MVC.Models.IssueSeverity.Critical ? "tw-text-red-500" :
                                      issue.Severity == LCS_HR_MVC.Models.IssueSeverity.Warning  ? "tw-text-amber-500" :
                                                                                                    "tw-text-blue-500")"></i>
                            </div>
                            <div class="tw-flex-1 tw-min-w-0">
                                <div class="tw-flex tw-items-center tw-gap-2 tw-flex-wrap tw-mb-1">
                                    <span class="tw-font-bold tw-text-slate-800 tw-text-sm">#@issueIdx — @issue.Title</span>
                                    <span class="tw-text-xs tw-font-bold tw-px-2 tw-py-0.5 tw-rounded-full tw-border
                                        @(issue.Severity == LCS_HR_MVC.Models.IssueSeverity.Critical ? "tw-bg-red-50 tw-text-red-700 tw-border-red-200" :
                                          issue.Severity == LCS_HR_MVC.Models.IssueSeverity.Warning  ? "tw-bg-amber-50 tw-text-amber-700 tw-border-amber-200" :
                                                                                                        "tw-bg-blue-50 tw-text-blue-700 tw-border-blue-200")">
                                        @issue.SeverityLabel
                                    </span>
                                    @if (!string.IsNullOrEmpty(issue.Category))
                                    {
                                        <span class="tw-text-xs tw-text-slate-400 tw-bg-slate-100 tw-px-2 tw-py-0.5 tw-rounded-full">@issue.Category</span>
                                    }
                                </div>
                                <p class="tw-text-sm tw-text-slate-600 tw-mb-1">@issue.Description</p>
                                @if (!string.IsNullOrEmpty(issue.Server))
                                {
                                    <div class="tw-text-xs tw-text-slate-400 tw-flex tw-flex-wrap tw-gap-3">
                                        <span><i class="fas fa-server tw-mr-1"></i>@issue.Server</span>
                                        @if (!string.IsNullOrEmpty(issue.SourceTable))
                                        {
                                            <span><i class="fas fa-table tw-mr-1"></i><code class="tw-bg-slate-100 tw-px-1 tw-rounded">@issue.SourceTable</code></span>
                                        }
                                    </div>
                                }
                            </div>
                            <div class="tw-flex tw-flex-col tw-gap-2 tw-flex-shrink-0">
                                @if (!string.IsNullOrEmpty(issue.FixModalId))
                                {
                                    <button onclick="openFixModal('@issue.FixModalId')"
                                            class="tw-text-xs tw-font-bold tw-px-3 tw-py-1.5 tw-rounded-lg tw-border tw-transition tw-flex tw-items-center tw-gap-1.5 tw-whitespace-nowrap
                                                   @(issue.Severity == LCS_HR_MVC.Models.IssueSeverity.Critical
                                                        ? "tw-bg-emerald-600 hover:tw-bg-emerald-700 tw-text-white tw-border-emerald-700"
                                                        : "tw-bg-emerald-500 hover:tw-bg-emerald-600 tw-text-white tw-border-emerald-600")">
                                        <i class="fas fa-wrench"></i>@(issue.FixModalLabel ?? "Fix Now")
                                    </button>
                                }
                                @if (hasSteps)
                                {
                                    <button onclick="toggleFixPanel('@panelId', this)"
                                            class="tw-text-xs tw-font-bold tw-px-3 tw-py-1.5 tw-rounded-lg tw-border tw-transition tw-flex tw-items-center tw-gap-1.5 tw-whitespace-nowrap
                                                   tw-bg-slate-100 hover:tw-bg-slate-200 tw-text-slate-700 tw-border-slate-300">
                                        <i class="fas fa-list-ol"></i>Step Guide
                                        <i class="fas fa-chevron-down tw-ml-0.5 fix-chevron tw-transition-transform"></i>
                                    </button>
                                }
                            </div>
                        </div>

                        @if (hasSteps)
                        {
                            <!-- Fix guide panel (collapsible, open by default for Critical) -->
                            <div id="@panelId"
                                 class="@(issue.Severity == LCS_HR_MVC.Models.IssueSeverity.Critical ? "" : "tw-hidden")">
                                <div class="tw-p-4 tw-bg-gradient-to-b tw-from-violet-50 tw-to-white tw-border-t tw-border-violet-100">
                                    <div class="tw-flex tw-items-center tw-gap-2 tw-mb-3">
                                        <i class="fas fa-list-ol tw-text-violet-500"></i>
                                        <span class="tw-text-sm tw-font-bold tw-text-violet-700">Step-by-Step Fix Guide</span>
                                        <span class="tw-text-xs tw-text-slate-400 tw-ml-1">(@issue.FixSteps.Count steps)</span>
                                    </div>
                                    <ol class="tw-space-y-2">
                                        @{int stepNo = 0;}
                                        @foreach (var step in issue.FixSteps)
                                        {
                                            stepNo++;
                                            <li class="tw-flex tw-items-start tw-gap-3">
                                                <span class="tw-flex-shrink-0 tw-w-6 tw-h-6 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-text-xs tw-font-bold
                                                    @(issue.Severity == LCS_HR_MVC.Models.IssueSeverity.Critical
                                                        ? "tw-bg-red-500 tw-text-white"
                                                        : "tw-bg-violet-500 tw-text-white")">@stepNo</span>
                                                <span class="tw-text-sm tw-text-slate-700 tw-leading-relaxed">@step</span>
                                            </li>
                                        }
                                    </ol>
                                    @if (!string.IsNullOrEmpty(issue.FixPageUrl))
                                    {
                                        <div class="tw-mt-4 tw-pt-3 tw-border-t tw-border-violet-100 tw-flex tw-items-center tw-gap-3">
                                            <a href="@issue.FixPageUrl"
                                               class="tw-text-xs tw-font-bold tw-bg-violet-600 hover:tw-bg-violet-700 tw-text-white tw-px-4 tw-py-2 tw-rounded-lg tw-transition tw-inline-flex tw-items-center tw-gap-2">
                                                <i class="fas fa-external-link-alt"></i>@issue.FixPageLabel
                                            </a>
                                            <span class="tw-text-xs tw-text-slate-400">Direct link to Setup page</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(issue.SuggestedAction))
                        {
                            <div class="tw-px-4 tw-py-3 tw-bg-blue-50 tw-border-t tw-border-blue-100 tw-text-xs tw-text-blue-700">
                                <i class="fas fa-lightbulb tw-mr-1"></i><strong>Action:</strong> @issue.SuggestedAction
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>

    <!-- ══════════════════════════════════════════════════════════════════
         FIX MODAL 1: Assign Route Code
    ════════════════════════════════════════════════════════════════════ -->
    <div id="modal-fix-route" class="tw-hidden tw-fixed tw-inset-0 tw-z-[9999] tw-flex tw-items-center tw-justify-center tw-p-4"
         onclick="if(event.target===this) closeFixModal('modal-fix-route')">
        <!-- Backdrop -->
        <div class="tw-absolute tw-inset-0 tw-bg-black/50 tw-backdrop-blur-sm tw-w-full tw-h-full"></div>
        <!-- Panel -->
        <div class="tw-relative tw-bg-white tw-rounded-2xl tw-shadow-2xl tw-w-full tw-max-w-lg tw-overflow-hidden tw-max-h-[90vh] tw-flex tw-flex-col">
            <!-- Header -->
            <div class="tw-bg-emerald-600 tw-px-5 tw-py-4 tw-flex tw-items-center tw-justify-between">
                <div class="tw-flex tw-items-center tw-gap-3">
                    <div class="tw-w-9 tw-h-9 tw-bg-white/20 tw-rounded-xl tw-flex tw-items-center tw-justify-center">
                        <i class="fas fa-route tw-text-white"></i>
                    </div>
                    <div>
                        <h3 class="tw-text-white tw-font-bold tw-text-sm">Route Code Assign Karein</h3>
                        <p class="tw-text-emerald-100 tw-text-xs">Employee: @Model.EmpNo — @Model.Name</p>
                    </div>
                </div>
                <button onclick="closeFixModal('modal-fix-route')" class="tw-text-white/70 hover:tw-text-white tw-text-xl"><i class="fas fa-times"></i></button>
            </div>
            <!-- Body -->
            <div class="tw-overflow-y-auto tw-flex-1">

                <!-- ── SUGGESTIONS PANEL (loaded on open) ─────────────────── -->
                <div id="rc-suggestion-panel" class="tw-border-b tw-border-slate-100 tw-bg-slate-50">

                    <!-- Loading state -->
                    <div id="rc-sug-loading" class="tw-px-5 tw-py-4 tw-flex tw-items-center tw-gap-2 tw-text-sm tw-text-slate-500">
                        <i class="fas fa-spinner fa-spin tw-text-emerald-500"></i> 3 servers se data check ho raha hai...
                    </div>

                    <!-- Loaded state (hidden until data arrives) -->
                    <div id="rc-sug-content" class="tw-hidden tw-p-4 tw-space-y-3">

                        <!-- Employee job info + suggestion headline -->
                        <div id="rc-sug-headline" class="tw-rounded-xl tw-border tw-p-3 tw-text-sm tw-bg-white tw-border-slate-200"></div>

                        <!-- Server findings (S10 commission + S6 + S7) -->
                        <div id="rc-sug-servers" class="tw-grid tw-grid-cols-3 tw-gap-2"></div>

                        <!-- Notes list -->
                        <div id="rc-sug-notes" class="tw-space-y-1"></div>

                        <!-- Similar colleagues table -->
                        <div id="rc-sug-similar" class="tw-hidden">
                            <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
                                <i class="fas fa-users tw-text-violet-500 tw-text-xs"></i>
                                <span class="tw-text-xs tw-font-bold tw-text-slate-700">Is City ke Active Employees — Reference ke liye</span>
                            </div>
                            <div class="tw-overflow-x-auto tw-rounded-xl tw-border tw-border-slate-200">
                                <table class="tw-w-full tw-text-xs">
                                    <thead class="tw-bg-slate-100">
                                        <tr>
                                            <th class="tw-px-2 tw-py-1.5 tw-text-left tw-font-semibold tw-text-slate-600">Employee</th>
                                            <th class="tw-px-2 tw-py-1.5 tw-text-left tw-font-semibold tw-text-slate-600">Route Code</th>
                                            <th class="tw-px-2 tw-py-1.5 tw-text-left tw-font-semibold tw-text-slate-600">Code Type</th>
                                            <th class="tw-px-2 tw-py-1.5 tw-text-left tw-font-semibold tw-text-slate-600 tw-text-amber-700"><i class="fas fa-map-pin tw-mr-1"></i>Location</th>
                                            <th class="tw-px-2 tw-py-1.5 tw-text-left tw-font-semibold tw-text-slate-600">Job</th>
                                            <th class="tw-px-2 tw-py-1.5 tw-text-center tw-font-semibold tw-text-slate-600">Use</th>
                                        </tr>
                                    </thead>
                                    <tbody id="rc-sug-similar-rows" class="tw-divide-y tw-divide-slate-100"></tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Available Route Codes in city -->
                        <div id="rc-sug-available" class="tw-hidden">
                            <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
                                <i class="fas fa-list tw-text-blue-500 tw-text-xs"></i>
                                <span class="tw-text-xs tw-font-bold tw-text-slate-700">Is City ke Valid Route Codes — Koi Bhi Select Karein</span>
                            </div>
                            <div class="tw-rounded-xl tw-border tw-border-blue-200 tw-bg-blue-50 tw-p-2 tw-max-h-32 tw-overflow-y-auto" id="rc-sug-available-rows"></div>
                        </div>

                    </div>
                </div>

                <!-- ── FORM ────────────────────────────────────────────────── -->
                <div class="tw-p-5">
                    <div id="route-alert" class="tw-hidden tw-mb-3 tw-p-3 tw-rounded-xl tw-text-sm tw-flex tw-items-start tw-gap-2"></div>
                    <div class="tw-space-y-3">
                        <!-- Employee info (readonly) -->
                        <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                            <div>
                                <label class="tw-text-xs tw-font-semibold tw-text-slate-600 tw-block tw-mb-1">Employee No</label>
                                <input type="text" value="@Model.EmpNo" readonly class="tw-w-full tw-text-xs tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-lg tw-px-3 tw-py-2 tw-text-slate-500" />
                            </div>
                            <div>
                                <label class="tw-text-xs tw-font-semibold tw-text-slate-600 tw-block tw-mb-1">City Code</label>
                                <input type="text" value="@Model.CityCode" readonly class="tw-w-full tw-text-xs tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-lg tw-px-3 tw-py-2 tw-text-slate-500" />
                            </div>
                        </div>
                        <!-- Route Code with suggestion badge -->
                        <div>
                            <div class="tw-flex tw-items-center tw-justify-between tw-mb-1">
                                <label class="tw-text-xs tw-font-semibold tw-text-slate-700">Route Code <span class="tw-text-red-500">*</span></label>
                                <span id="rc-sug-badge" class="tw-hidden tw-text-xs tw-bg-emerald-100 tw-text-emerald-700 tw-px-2 tw-py-0.5 tw-rounded-full tw-font-semibold">
                                    <i class="fas fa-magic tw-mr-1"></i>Suggested
                                </span>
                            </div>
                            <input id="rc-routecode" type="text" maxlength="5" placeholder="5-char route code (e.g. 00200)"
                                   class="tw-w-full tw-text-sm tw-border tw-border-slate-300 tw-rounded-lg tw-px-3 tw-py-2 focus:tw-border-emerald-400 focus:tw-outline-none tw-uppercase tw-font-mono" />
                            <p class="tw-text-xs tw-text-slate-400 tw-mt-1">Exactly 5 characters — hr_routecodes_hdr mein exist karna chahiye</p>
                        </div>
                        <!-- Code Type -->
