    function showCommColDetail(colName, amount) {
        const info = _commColInfo[colName] || { label: colName, src: "hr_commissionprocess (S10)", desc: "Yeh column hr_commissionprocess table mein ek specific commission type store karta hai." };
        document.getElementById('commcol-title').textContent    = info.label;
        document.getElementById('commcol-dbfield').textContent  = colName;
        document.getElementById('commcol-amount').textContent   = 'Rs ' + amount;
        document.getElementById('commcol-source').textContent   = info.src;
        document.getElementById('commcol-desc').textContent     = info.desc;
        document.getElementById('commcol-modal').classList.remove('tw-hidden');
    }
    function closeCommColModal() {
        document.getElementById('commcol-modal').classList.add('tw-hidden');
    }

    // ── Reprocess Commission ────────────────────────────────────────────────
    function reprocessMonth(year, month, btnEl) {
        if (!confirm(`Commission process ${year}/${month} ko reprocess karein? (Employee: ${_fixEmpNo})`)) return;

        const origHtml = btnEl.innerHTML;
        btnEl.disabled = true;
        btnEl.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';

        fetch('/CommissionInvestigation/ReprocessCommission', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ empNo: _fixEmpNo, year: year, month: month })
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                btnEl.innerHTML = '<i class="fas fa-check"></i> Done!';
                btnEl.classList.remove('tw-bg-orange-500','hover:tw-bg-orange-600');
                btnEl.classList.add('tw-bg-emerald-500');
                // Reload page after short delay if processing current month
                if (year == @Model.Year && month == @Model.Month) {
                    setTimeout(() => window.location.reload(), 1500);
                }
                // Update status cell
                const statusCell = document.getElementById('rp-status-' + year + '-' + month);
                if (statusCell) statusCell.innerHTML = '<span class="tw-text-emerald-600 tw-font-bold">✓ Done — Refresh</span>';
            } else {
                btnEl.disabled = false;
                btnEl.innerHTML = origHtml;
                alert('Reprocess failed: ' + (data.error || data.message || 'Unknown error'));
            }
        })
        .catch(err => {
            btnEl.disabled = false;
            btnEl.innerHTML = origHtml;
            alert('Network error: ' + err.message);
        });
    }

    // ── Delete Phantom Commission Record ───────────────────────────────────
    function deletePhantomRecord(empNo, year, month) {
        const btn = document.getElementById('phantom-submit-btn');
        const alertEl = document.getElementById('phantom-alert');

        const origHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Deleting...';
        alertEl.classList.add('tw-hidden');

        fetch('/CommissionInvestigation/DeletePhantomCommissionRecord', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ empNo: empNo, year: year, month: month })
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                alertEl.className = 'tw-mb-3 tw-p-3 tw-rounded-xl tw-text-sm tw-flex tw-items-start tw-gap-2 tw-bg-emerald-50 tw-border tw-border-emerald-200 tw-text-emerald-700';
                alertEl.innerHTML = '<i class="fas fa-check-circle tw-mt-0.5"></i><span>' + data.message + ' Page reload ho rha hai...</span>';
                alertEl.classList.remove('tw-hidden');
                btn.innerHTML = '<i class="fas fa-check"></i> Done!';
                btn.classList.remove('tw-bg-red-600', 'hover:tw-bg-red-700');
                btn.classList.add('tw-bg-emerald-500');
                setTimeout(() => window.location.reload(), 1800);
            } else {
                alertEl.className = 'tw-mb-3 tw-p-3 tw-rounded-xl tw-text-sm tw-flex tw-items-start tw-gap-2 tw-bg-red-50 tw-border tw-border-red-200 tw-text-red-700';
                alertEl.innerHTML = '<i class="fas fa-exclamation-circle tw-mt-0.5"></i><span>' + (data.error || 'Unknown error') + '</span>';
                alertEl.classList.remove('tw-hidden');
                btn.disabled = false;
                btn.innerHTML = origHtml;
            }
        })
        .catch(err => {
            alertEl.className = 'tw-mb-3 tw-p-3 tw-rounded-xl tw-text-sm tw-flex tw-items-start tw-gap-2 tw-bg-red-50 tw-border tw-border-red-200 tw-text-red-700';
            alertEl.innerHTML = '<i class="fas fa-exclamation-circle tw-mt-0.5"></i><span>Network error: ' + err.message + '</span>';
            alertEl.classList.remove('tw-hidden');
            btn.disabled = false;
            btn.innerHTML = origHtml;
        });
    }

    // ── Cash CNs route code filter ──────────────────────────────────────────
    let _activeCashFilter = 'ALL';
    function filterCashCns(routeCode) {
        _activeCashFilter = routeCode;
        const rows = document.querySelectorAll('.cash-cn-row');
        rows.forEach(row => {
            if (routeCode === 'ALL' || row.dataset.route === routeCode) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
        // Update button styles
        document.querySelectorAll('.cash-filter-btn').forEach(btn => {
            btn.classList.remove('tw-bg-violet-600','tw-text-white','tw-border-violet-700');
            btn.classList.add('tw-bg-white','tw-border-slate-300','tw-text-slate-600');
        });
        const activeBtn = document.getElementById('cash-filter-' + routeCode);
        if (activeBtn) {
            activeBtn.classList.remove('tw-bg-white','tw-border-slate-300','tw-text-slate-600');
            activeBtn.classList.add('tw-bg-violet-600','tw-text-white','tw-border-violet-700');
        }
    }

    // Status dropdown toggle
    function toggleStatusMenu(noteId) {
        const menu = document.getElementById('status-menu-' + noteId);
        if (!menu) return;
        menu.classList.toggle('tw-hidden');
        // Close on outside click
        const close = (e) => {
            if (!menu.contains(e.target) && !e.target.closest(`[onclick="toggleStatusMenu(${noteId})"]`)) {
                menu.classList.add('tw-hidden');
                document.removeEventListener('click', close);
            }
        };
        setTimeout(() => document.addEventListener('click', close), 100);
    }
