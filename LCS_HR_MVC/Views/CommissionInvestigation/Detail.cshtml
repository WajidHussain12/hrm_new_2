        <div class="tw-mb-3 tw-text-xs tw-bg-blue-50 tw-border tw-border-blue-200 tw-rounded-xl tw-p-3 tw-text-blue-700">
            <i class="fas fa-info-circle tw-mr-1"></i>
            Yeh queries SQLyog ya HeidiSQL mein directly copy-paste kar ke cross-verify kar sakte hain.
            Har query ke header mein server/database info diya gaya hai.
        </div>
        <div class="tw-space-y-3">
            @foreach (var q in Model.SqlQueries)
            {
                <div class="tw-bg-white tw-rounded-xl tw-border tw-border-slate-200 tw-shadow-sm tw-overflow-hidden">
                    <div class="tw-bg-slate-800 tw-px-4 tw-py-2 tw-flex tw-items-center tw-justify-between">
                        <div>
                            <span class="tw-font-mono tw-text-xs tw-text-emerald-400 tw-font-bold">[@q.QueryKey]</span>
                            <span class="tw-text-white tw-text-sm tw-font-semibold tw-ml-2">@q.Title</span>
                        </div>
                        <div class="tw-flex tw-items-center tw-gap-2">
                            <span class="tw-text-xs tw-text-slate-300">@q.Server — <code class="tw-text-yellow-300">@q.Database</code></span>
                            <button onclick="copySql('@q.QueryKey')"
                                    class="tw-text-xs tw-bg-slate-600 hover:tw-bg-slate-500 tw-text-white tw-px-2 tw-py-1 tw-rounded tw-transition">
                                <i class="fas fa-copy tw-mr-1"></i>Copy
                            </button>
                        </div>
                    </div>
                    <div class="tw-p-1 tw-bg-slate-50 tw-text-xs tw-text-slate-500 tw-border-b tw-border-slate-200 tw-px-4 tw-py-1.5">
                        <i class="fas fa-info-circle tw-mr-1"></i>@q.Purpose
                        @if (!string.IsNullOrEmpty(q.SourceTable))
                        {
                            <span class="tw-ml-2"><i class="fas fa-table tw-mr-1"></i><code>@q.SourceTable</code></span>
                        }
                    </div>
                    <pre id="sql-@q.QueryKey" class="tw-bg-slate-900 tw-text-emerald-300 tw-text-xs tw-p-4 tw-overflow-x-auto tw-m-0 tw-max-h-60">@q.SqlText</pre>
                </div>
            }
        </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════════════
         TAB 10: Investigation Notes (CRUD)
    ════════════════════════════════════════════════════════════════════ -->
    <div id="tab-notes" class="tab-content tw-hidden">
        <div class="tw-grid tw-grid-cols-1 lg:tw-grid-cols-3 tw-gap-4">

            <!-- Add New Note -->
            <div class="tw-bg-white tw-rounded-2xl tw-border tw-border-slate-200 tw-shadow-sm">
                <div class="tw-p-4 tw-border-b tw-border-slate-100">
                    <div class="tw-flex tw-items-center tw-gap-2">
                        <i class="fas fa-plus-circle tw-text-violet-500"></i>
                        <span class="tw-text-sm tw-font-bold tw-text-slate-700">Add Investigation Note</span>
                    </div>
                </div>
                <div class="tw-p-4">
                    <form method="post" action="@Url.Action("CreateNote", "CommissionInvestigation")" id="createNoteForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="EmpNo"    value="@Model.EmpNo" />
                        <input type="hidden" name="Year"     value="@Model.Year" />
                        <input type="hidden" name="Month"    value="@Model.Month" />
                        <input type="hidden" name="CityCode" value="@Model.CityCode" />

                        <div class="tw-space-y-3">
                            <div>
                                <label class="tw-block tw-text-xs tw-font-semibold tw-text-slate-500 tw-mb-1">Action Type</label>
                                <select name="ActionType"
                                        class="tw-w-full tw-text-sm tw-border tw-border-slate-300 tw-rounded-lg tw-px-3 tw-py-2 focus:tw-outline-none focus:tw-ring-2 focus:tw-ring-violet-400">
                                    @foreach (var at in new[] { "Investigation","Issue Found","Resolved","Escalated","Reprocessed","Verified","Pending","Other" })
                                    {
                                        <option value="@at">@at</option>
                                    }
                                </select>
                            </div>
                            <div>
                                <label class="tw-block tw-text-xs tw-font-semibold tw-text-slate-500 tw-mb-1">Status</label>
                                <select name="Status"
                                        class="tw-w-full tw-text-sm tw-border tw-border-slate-300 tw-rounded-lg tw-px-3 tw-py-2 focus:tw-outline-none focus:tw-ring-2 focus:tw-ring-violet-400">
                                    @foreach (var st in new[] { "Open","In Progress","Resolved","Closed" })
                                    {
                                        <option value="@st">@st</option>
                                    }
                                </select>
                            </div>
                            <div>
                                <label class="tw-block tw-text-xs tw-font-semibold tw-text-slate-500 tw-mb-1">
                                    Notes <span class="tw-text-red-400">*</span>
                                    <span class="tw-text-slate-400 tw-font-normal">(3–2000 chars)</span>
                                </label>
                                <textarea name="Notes" rows="5" required minlength="3" maxlength="2000"
                                          placeholder="Yahan investigation notes likhein..."
                                          class="tw-w-full tw-text-sm tw-border tw-border-slate-300 tw-rounded-lg tw-px-3 tw-py-2 focus:tw-outline-none focus:tw-ring-2 focus:tw-ring-violet-400 tw-resize-none"></textarea>
                            </div>
                            <button type="submit"
                                    class="tw-w-full tw-bg-violet-600 hover:tw-bg-violet-700 tw-text-white tw-font-semibold tw-py-2 tw-rounded-lg tw-transition tw-text-sm">
                                <i class="fas fa-save tw-mr-1"></i> Save Note
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Notes List -->
            <div class="tw-bg-white tw-rounded-2xl tw-border tw-border-slate-200 tw-shadow-sm lg:tw-col-span-2">
                <div class="tw-p-4 tw-border-b tw-border-slate-100 tw-flex tw-items-center tw-justify-between">
                    <div class="tw-flex tw-items-center tw-gap-2">
                        <i class="fas fa-list tw-text-slate-500"></i>
                        <span class="tw-text-sm tw-font-bold tw-text-slate-700">Investigation History</span>
                    </div>
                    <span class="tw-text-xs tw-text-slate-400">@Model.Notes.Count note(s)</span>
                </div>

                @if (Model.Notes.Count == 0)
                {
                    <div class="tw-p-8 tw-text-center tw-text-slate-400 tw-text-sm">
                        <i class="fas fa-sticky-note tw-text-2xl tw-mb-2 tw-block"></i>
                        Abhi tak koi investigation note nahi.
                    </div>
                }
                else
                {
                    <div class="tw-divide-y tw-divide-slate-100">
                        @foreach (var note in Model.Notes)
                        {
                            <div class="tw-p-4 @(note.IsDeleted ? "tw-opacity-50 tw-bg-slate-50" : "")">
                                <div class="tw-flex tw-items-start tw-justify-between tw-gap-2">
                                    <div class="tw-flex tw-items-start tw-gap-2 tw-flex-1 tw-min-w-0">
                                        <span class="tw-text-base tw-flex-shrink-0 tw-mt-0.5">
                                            <i class="fas @note.ActionIcon tw-text-slate-400"></i>
                                        </span>
                                        <div class="tw-flex-1 tw-min-w-0">
                                            <div class="tw-flex tw-flex-wrap tw-items-center tw-gap-2 tw-mb-1">
                                                <span class="tw-text-xs tw-font-bold tw-text-slate-700">@note.ActionType</span>
                                                <span class="tw-text-xs @note.StatusBadgeClass tw-px-2 tw-py-0.5 tw-rounded-full tw-font-semibold tw-border">@note.Status</span>
                                                @if (note.IsDeleted)
                                                {
                                                    <span class="tw-text-xs tw-bg-red-100 tw-text-red-600 tw-px-2 tw-py-0.5 tw-rounded-full tw-font-semibold">DELETED</span>
                                                }
                                                <span class="tw-text-xs tw-text-slate-400">
                                                    by @note.CreatedBy — @note.CreatedDate.ToString("dd MMM yyyy HH:mm")
                                                </span>
                                            </div>
                                            <p class="tw-text-sm tw-text-slate-700 tw-whitespace-pre-line">@note.Notes</p>
                                            @if (!string.IsNullOrEmpty(note.ResolvedBy))
                                            {
                                                <div class="tw-text-xs tw-text-emerald-600 tw-mt-1">
                                                    <i class="fas fa-check tw-mr-1"></i>Resolved by @note.ResolvedBy
                                                    @(note.ResolvedDate.HasValue ? " on " + note.ResolvedDate.Value.ToString("dd MMM yyyy") : "")
                                                </div>
                                            }
                                        </div>
                                    </div>

                                    @if (!note.IsDeleted)
                                    {
                                        <div class="tw-flex tw-gap-1 tw-flex-shrink-0">
                                            <!-- Status update dropdown -->
                                            <div class="tw-relative group">
                                                <button class="tw-text-xs tw-bg-slate-100 hover:tw-bg-slate-200 tw-text-slate-600 tw-px-2 tw-py-1.5 tw-rounded-lg tw-transition"
                                                        onclick="toggleStatusMenu(@note.Id)">
                                                    <i class="fas fa-edit"></i>
                                                </button>
                                                <div id="status-menu-@note.Id" class="tw-hidden tw-absolute tw-right-0 tw-mt-1 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-shadow-lg tw-z-10 tw-min-w-32">
                                                    @foreach (var st in new[] { "Open","In Progress","Resolved","Closed" })
                                                    {
                                                        <form method="post" action="@Url.Action("UpdateNoteStatus","CommissionInvestigation")">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="noteId"   value="@note.Id" />
                                                            <input type="hidden" name="newStatus" value="@st" />
                                                            <input type="hidden" name="empNo"     value="@Model.EmpNo" />
                                                            <input type="hidden" name="year"      value="@Model.Year" />
                                                            <input type="hidden" name="month"     value="@Model.Month" />
                                                            <input type="hidden" name="cityCode"  value="@Model.CityCode" />
                                                            <button type="submit"
                                                                    class="tw-block tw-w-full tw-text-left tw-text-xs tw-px-3 tw-py-2 hover:tw-bg-slate-50 tw-text-slate-700 @(note.Status == st ? "tw-font-bold tw-text-violet-600" : "")">
                                                                @st
                                                            </button>
                                                        </form>
                                                    }
                                                </div>
                                            </div>
                                            <!-- Delete -->
                                            <form method="post" action="@Url.Action("DeleteNote","CommissionInvestigation")"
                                                  onsubmit="return confirm('Note #@note.Id delete karein?')">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="noteId"   value="@note.Id" />
                                                <input type="hidden" name="empNo"    value="@Model.EmpNo" />
                                                <input type="hidden" name="year"     value="@Model.Year" />
                                                <input type="hidden" name="month"    value="@Model.Month" />
                                                <input type="hidden" name="cityCode" value="@Model.CityCode" />
                                                <button type="submit"
                                                        class="tw-text-xs tw-bg-red-50 hover:tw-bg-red-100 tw-text-red-500 tw-px-2 tw-py-1.5 tw-rounded-lg tw-transition">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

        </div>
    </div>

</div>

<!-- ══════════════════════════════════════════════════════════════════
     JAVASCRIPT — Tab switching, SQL copy
════════════════════════════════════════════════════════════════════ -->
<script>
    // Tab navigation
    function showTab(tabId) {
        document.querySelectorAll('.tab-content').forEach(t => t.classList.add('tw-hidden'));
        document.querySelectorAll('.tab-btn').forEach(b => {
            b.classList.remove('tw-bg-violet-600', 'tw-text-white', 'tw-border-violet-600');
            b.classList.add('tw-bg-white', 'tw-text-slate-600', 'tw-border-slate-200');
        });
        const tab = document.getElementById(tabId);
        if (tab) tab.classList.remove('tw-hidden');
        // Highlight active button
        document.querySelectorAll('.tab-btn').forEach(b => {
            if (b.getAttribute('onclick') === `showTab('${tabId}')`) {
                b.classList.remove('tw-bg-white', 'tw-text-slate-600', 'tw-border-slate-200');
                b.classList.add('tw-bg-violet-600', 'tw-text-white', 'tw-border-violet-600');
            }
        });
    }

    // Initialize first tab active
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.tab-btn').forEach(b => {
            b.classList.add('tw-bg-white', 'tw-text-slate-600', 'tw-border-slate-200');
        });
        showTab('tab-routes');

        // If there are critical issues, highlight the issues tab badge
        @if (Model.CriticalIssues.Count > 0)
        {
            <text>
            // Auto-scroll hint to issues if critical
            setTimeout(() => {
                const issueBadge = document.querySelector('[onclick="showTab(\'tab-issues\')"]');
                if (issueBadge) issueBadge.classList.add('tw-ring-2', 'tw-ring-red-400', 'tw-ring-offset-1');
            }, 500);
            </text>
        }
    });

    // ── Fix modal data ────────────────────────────────────────────────────
    const _fixEmpNo   = '@Html.Raw(Model.EmpNo)';
    const _fixEmpName = '@Html.Raw(Model.Name?.Replace("'", "\\'"))';
    const _fixCity    = '@Html.Raw(Model.CityCode)';
    const _fixYear    = @Model.Year;
    const _fixMonth   = @Model.Month;
    const _detailUrl  = '@Url.Action("Detail","CommissionInvestigation",new{empNo=Model.EmpNo,year=Model.Year,month=Model.Month,cityCode=Model.CityCode})';

    // Open modal
    function openFixModal(modalId) {
        document.getElementById(modalId).classList.remove('tw-hidden');
        if (modalId === 'modal-fix-route') initRouteModal();
    }

    // Close modal
    function closeFixModal(modalId) {
        document.getElementById(modalId).classList.add('tw-hidden');
    }

    // ── Route Code Modal ─────────────────────────────────────────────────
    let _dropdownsLoaded = false;
    let _suggestionsLoaded = false;

    function initRouteModal() {
        // Set default from date = today
        const today = new Date().toISOString().split('T')[0];
        document.getElementById('rc-fromdate').value = today;

        // Load dropdowns
        if (!_dropdownsLoaded) {
            fetch(`/CommissionInvestigation/GetFixDropdowns?cityCode=${encodeURIComponent(_fixCity)}`)
                .then(r => r.json())
                .then(data => {
                    const ctSel = document.getElementById('rc-codetype');
                    ctSel.innerHTML = '<option value="">-- Select Code Type --</option>';
                    (data.codeTypes || []).forEach(ct => {
                        const opt = document.createElement('option');
                        opt.value = ct.value; opt.textContent = ct.text;
                        ctSel.appendChild(opt);
                    });
                    const locSel = document.getElementById('rc-location');
                    locSel.innerHTML = '<option value="0">-- Select Location --</option>';
                    (data.locations || []).forEach(loc => {
                        const opt = document.createElement('option');
                        opt.value = loc.value; opt.textContent = loc.text;
                        locSel.appendChild(opt);
                    });
                    _dropdownsLoaded = true;
                    // Apply suggestion to CodeType dropdown if suggestion already arrived
                    if (window._rcSuggestedCodeType) selectCodeType(window._rcSuggestedCodeType);
                    // Apply pending location selection if user clicked a location before dropdown loaded
                    if (window._pendingLocationId) { applyLocation(window._pendingLocationId); window._pendingLocationId = null; }
                })
                .catch(err => showModalAlert('route-alert', 'error', 'Dropdowns load karne mein masla: ' + err.message));
        }

        // Load suggestions (separate call — queries all 3 servers)
        if (!_suggestionsLoaded) {
            fetch(`/CommissionInvestigation/GetRouteCodeSuggestions?empNo=${encodeURIComponent(_fixEmpNo)}&cityCode=${encodeURIComponent(_fixCity)}`)
                .then(r => r.json())
                .then(renderSuggestions)
                .catch(err => {
                    document.getElementById('rc-sug-loading').innerHTML =
                        `<i class="fas fa-exclamation-circle tw-text-red-400"></i> <span class="tw-text-red-600">Suggestions load nahi hue: ${err.message}</span>`;
                });
            _suggestionsLoaded = true;
        }
    }

    function selectCodeType(codeTypeValue) {
        const sel = document.getElementById('rc-codetype');
        if (!sel) return;
        for (const opt of sel.options) {
            if (opt.value == codeTypeValue) { sel.value = codeTypeValue; break; }
        }
    }

    function applySuggestion(routeCode, codeType) {
        const rcInput = document.getElementById('rc-routecode');
        if (rcInput) { rcInput.value = routeCode.toUpperCase(); rcInput.style.borderColor = '#10b981'; }
        if (codeType) {
            window._rcSuggestedCodeType = codeType;
            selectCodeType(codeType);
        }
        document.getElementById('rc-sug-badge').classList.remove('tw-hidden');
    }

    function applyLocation(locationId) {
        const sel = document.getElementById('rc-location');
        if (!sel) return;
        // Try to select the matching option
        for (let i = 0; i < sel.options.length; i++) {
            if (parseInt(sel.options[i].value) === parseInt(locationId)) {
                sel.value = sel.options[i].value;
                sel.style.borderColor = '#f59e0b';
                // Flash highlight
                sel.classList.add('tw-bg-amber-50');
                setTimeout(() => { sel.style.borderColor = ''; sel.classList.remove('tw-bg-amber-50'); }, 1500);
                return;
            }
        }
        // Option not yet loaded — store for when dropdown populates
        window._pendingLocationId = locationId;
    }

    function renderSuggestions(data) {
        document.getElementById('rc-sug-loading').classList.add('tw-hidden');
        document.getElementById('rc-sug-content').classList.remove('tw-hidden');

        const monthNames = ['','Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

        // ── Headline: employee job info + best suggestion ─────────────────
        const headline = document.getElementById('rc-sug-headline');
        let hlHtml = '';

        // Job/Type row
        if (data.jobTitle || data.employeeTypeName) {
            hlHtml += `<div class="tw-flex tw-flex-wrap tw-gap-3 tw-mb-2">`;
            if (data.employeeTypeName)
                hlHtml += `<span class="tw-text-xs tw-bg-indigo-50 tw-text-indigo-700 tw-px-2 tw-py-1 tw-rounded-lg tw-border tw-border-indigo-100"><i class="fas fa-id-badge tw-mr-1"></i>${data.employeeTypeName}</span>`;
            if (data.jobTitle)
                hlHtml += `<span class="tw-text-xs tw-bg-violet-50 tw-text-violet-700 tw-px-2 tw-py-1 tw-rounded-lg tw-border tw-border-violet-100"><i class="fas fa-briefcase tw-mr-1"></i>${data.jobTitle}</span>`;
            hlHtml += `</div>`;
        }

        // Best suggestion
        if (data.suggestedRouteCode || data.suggestedCodeType) {
            hlHtml += `<div class="tw-flex tw-flex-wrap tw-items-center tw-gap-2 tw-p-2 tw-bg-emerald-50 tw-rounded-lg tw-border tw-border-emerald-200">
                <i class="fas fa-magic tw-text-emerald-500"></i>
                <span class="tw-text-xs tw-font-bold tw-text-emerald-700">Best Suggestion:</span>`;
            if (data.suggestedRouteCode)
                hlHtml += `<span class="tw-font-mono tw-text-sm tw-font-bold tw-bg-white tw-text-emerald-800 tw-px-2 tw-py-0.5 tw-rounded tw-border tw-border-emerald-300">${data.suggestedRouteCode}</span>`;
            if (data.suggestedCodeTypeName)
                hlHtml += `<span class="tw-text-xs tw-text-emerald-700">(CodeType ${data.suggestedCodeType} — ${data.suggestedCodeTypeName})</span>`;
            hlHtml += `<button onclick="applySuggestion('${data.suggestedRouteCode || ''}', ${data.suggestedCodeType || 'null'})"
                               class="tw-ml-auto tw-text-xs tw-font-bold tw-bg-emerald-600 hover:tw-bg-emerald-700 tw-text-white tw-px-3 tw-py-1 tw-rounded-lg tw-transition">
                           <i class="fas fa-check tw-mr-1"></i>Apply
                       </button>`;
            hlHtml += `</div>`;

            // Auto-apply to form
            if (data.suggestedRouteCode) applySuggestion(data.suggestedRouteCode, data.suggestedCodeType);
        } else {
            hlHtml += `<div class="tw-p-2 tw-bg-slate-50 tw-rounded-lg tw-border tw-border-slate-200 tw-text-xs tw-text-slate-500">
                <i class="fas fa-search tw-mr-1"></i>Kisi bhi server par confirmed Route Code nahi mila — neechay similar employees ka reference dekheein.
            </div>`;
        }
        headline.innerHTML = hlHtml;

        // ── Server cards (S10 commission + S6 + S7) ───────────────────────
        const servers = document.getElementById('rc-sug-servers');
        function serverCard(label, icon, color, routeCode, codeType, codeTypeName) {
            const found = !!routeCode;
            const applyBtn = found
                ? `<button onclick="applySuggestion('${routeCode}', ${codeType || 'null'})"
                           class="tw-mt-1.5 tw-w-full tw-text-xs tw-font-semibold tw-bg-white tw-border tw-border-${color}-300 tw-text-${color}-700 tw-rounded tw-py-0.5 tw-transition hover:tw-bg-${color}-50">
                       <i class="fas fa-check tw-mr-1"></i>Apply
                   </button>` : '';
            return `<div class="tw-rounded-xl tw-border tw-p-2.5 tw-text-center ${found ? `tw-bg-${color}-50 tw-border-${color}-200` : 'tw-bg-slate-50 tw-border-slate-200'}">
                <div class="tw-text-xs tw-font-bold tw-text-slate-600 tw-mb-1"><i class="fas ${icon} tw-mr-1 tw-text-${color}-${found?'500':'300'}"></i>${label}</div>
                ${found
                    ? `<div class="tw-font-mono tw-text-sm tw-font-bold tw-text-${color}-700">${routeCode}</div>
                       <div class="tw-text-xs tw-text-slate-500">${codeType ? `Type ${codeType}` : ''} ${codeTypeName ? `— ${codeTypeName}` : ''}</div>
                       ${applyBtn}`
                    : `<div class="tw-text-xs tw-text-slate-400 tw-mt-1">Record nahi mila</div>`}
            </div>`;
        }

        // S10 commission history: most recent non-null Cour_id
        const lastCourId = (data.commissionHistory || []).find(h => h.courId);
        servers.innerHTML =
            serverCard('S10 Commission', 'fa-file-invoice-dollar', 'blue',
                lastCourId?.courId, null, lastCourId ? `${monthNames[lastCourId.month] || ''} ${lastCourId.year}` : null) +
            serverCard('S6 Billing', 'fa-database', 'violet',
                data.s6RouteCode, data.s6CodeType, data.s6CodeTypeName) +
            serverCard('S7 MIS', 'fa-network-wired', 'indigo',
                data.s7RouteCode, data.s7CodeType, data.s7CodeTypeName);

        // ── Investigation notes ────────────────────────────────────────────
        const notesEl = document.getElementById('rc-sug-notes');
        if (data.notes && data.notes.length) {
            notesEl.innerHTML = data.notes.map(n =>
                `<div class="tw-text-xs tw-text-slate-500 tw-flex tw-items-start tw-gap-1.5">
                    <i class="fas fa-info-circle tw-text-slate-400 tw-mt-0.5 tw-flex-shrink-0"></i><span>${n}</span>
                </div>`).join('');
        }

        // ── Similar colleagues table ───────────────────────────────────────
        if (data.similarEmployees && data.similarEmployees.length) {
            const simDiv = document.getElementById('rc-sug-similar');
            const tbody  = document.getElementById('rc-sug-similar-rows');
            simDiv.classList.remove('tw-hidden');
            tbody.innerHTML = data.similarEmployees.map(e =>
                `<tr class="hover:tw-bg-slate-50">
                    <td class="tw-px-2 tw-py-1.5">
                        <div class="tw-font-semibold tw-text-slate-700 tw-text-xs">${e.name || ''}</div>
                        <div class="tw-text-slate-400 tw-font-mono" style="font-size:10px">${e.empNo}</div>
                    </td>
                    <td class="tw-px-2 tw-py-1.5 tw-font-mono tw-font-bold tw-text-slate-700">${e.routeCode}</td>
                    <td class="tw-px-2 tw-py-1.5">
                        <span class="tw-bg-violet-100 tw-text-violet-700 tw-px-1.5 tw-py-0.5 tw-rounded tw-text-xs tw-font-semibold">
                            ${e.codeType || '?'} — ${e.codeTypeName || '?'}
                        </span>
                    </td>
                    <td class="tw-px-2 tw-py-1.5">
                        ${e.locationId
                            ? `<button onclick="applyLocation(${e.locationId})"
                                       class="tw-text-xs tw-bg-amber-100 hover:tw-bg-amber-200 tw-text-amber-800 tw-px-1.5 tw-py-0.5 tw-rounded tw-font-semibold tw-transition tw-w-full tw-text-left">
                                   <i class="fas fa-map-pin tw-mr-1 tw-text-amber-500"></i>
                                   <span class="tw-font-mono">${e.locationId}</span>
                                   ${e.locationName ? `<div style="font-size:10px" class="tw-text-amber-700 tw-truncate tw-max-w-24">${e.locationName}</div>` : ''}
                               </button>`
                            : '<span class="tw-text-slate-300 tw-text-xs">—</span>'}
                    </td>
                    <td class="tw-px-2 tw-py-1.5 tw-text-slate-500 tw-text-xs">${e.jobTitle || e.employeeType || '—'}</td>
                    <td class="tw-px-2 tw-py-1.5 tw-text-center">
                        <button onclick="applySuggestion('${e.routeCode}', ${e.codeType || 'null'})"
                                class="tw-text-xs tw-bg-emerald-100 hover:tw-bg-emerald-200 tw-text-emerald-700 tw-px-2 tw-py-0.5 tw-rounded tw-font-semibold tw-transition">
                            Use
                        </button>
                    </td>
                </tr>`
            ).join('');
        }

        // ── Available Route Codes in this city ────────────────────────────
        if (data.availableRouteCodes && data.availableRouteCodes.length) {
            const avDiv = document.getElementById('rc-sug-available');
            if (avDiv) {
                avDiv.classList.remove('tw-hidden');
                document.getElementById('rc-sug-available-rows').innerHTML =
                    data.availableRouteCodes.map(r =>
                        `<div class="tw-flex tw-items-center tw-justify-between tw-py-1 tw-border-b tw-border-slate-100 last:tw-border-0">
                            <div>
                                <span class="tw-font-mono tw-font-bold tw-text-slate-700 tw-text-sm">${r.routeCode}</span>
                                <span class="tw-text-xs tw-text-slate-500 tw-ml-2">${r.description || ''}</span>
                            </div>
                            <button onclick="applySuggestion('${r.routeCode}', null)"
                                    class="tw-text-xs tw-bg-blue-100 hover:tw-bg-blue-200 tw-text-blue-700 tw-px-2 tw-py-0.5 tw-rounded tw-font-semibold tw-transition">
                                Select
                            </button>
                        </div>`
                    ).join('');
            }
        }
    }

    function submitFixRouteCode() {
        const routeCode = document.getElementById('rc-routecode').value.trim().toUpperCase();
        const codeType  = document.getElementById('rc-codetype').value;
        const locationId = parseInt(document.getElementById('rc-location').value) || 0;
        const fromDate  = document.getElementById('rc-fromdate').value;
        const toDate    = document.getElementById('rc-todate').value;
        const comments  = document.getElementById('rc-comments').value;

        if (!routeCode || routeCode.length !== 5) {
            showModalAlert('route-alert', 'error', 'Route Code exactly 5 characters ka hona chahiye.');
            return;
        }
        if (!fromDate) {
            showModalAlert('route-alert', 'error', 'From Date select karein.');
            return;
        }

        const btn = document.getElementById('rc-submit-btn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';

        fetch('/CommissionInvestigation/FixRouteCode', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                empNo: _fixEmpNo,
                employeeName: _fixEmpName,
                routeCode: routeCode,
                cityCode: _fixCity,
                locationId: locationId,
                codeType: codeType || '0',
                fromDate: fromDate ? new Date(fromDate).toISOString() : null,
                toDate: toDate ? new Date(toDate).toISOString() : null,
                comments: comments
            })
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                // Show sync results for all 3 servers
                const s6ok = data.s6 === 'ok';
                const s7ok = data.s7 === 'ok';
                const allOk = s6ok && s7ok;
                const syncHtml = `
                    <div class="tw-mt-2 tw-text-xs tw-space-y-1">
                        <div class="tw-flex tw-items-center tw-gap-2">
                            <span class="tw-text-emerald-500 tw-font-bold">✓ S10</span> — Main HR: Saved
                        </div>
                        <div class="tw-flex tw-items-center tw-gap-2">
                            <span class="${s6ok ? 'tw-text-emerald-500' : 'tw-text-red-500'} tw-font-bold">${s6ok ? '✓' : '✗'} S6</span>
                            — Billing: ${s6ok ? 'Synced' : (data.s6 || 'Failed — manually add karein')}
                        </div>
                        <div class="tw-flex tw-items-center tw-gap-2">
                            <span class="${s7ok ? 'tw-text-emerald-500' : 'tw-text-red-500'} tw-font-bold">${s7ok ? '✓' : '✗'} S7</span>
                            — MIS: ${s7ok ? 'Synced' : (data.s7 || 'Failed — manually add karein')}
                        </div>
                    </div>`;
                showModalAlert('route-alert', allOk ? 'success' : 'warning',
                    data.message + syncHtml);
                btn.innerHTML = '<i class="fas fa-check"></i> Saved!';
                setTimeout(() => { window.location.href = _detailUrl; }, allOk ? 1800 : 4000);
            } else {
                showModalAlert('route-alert', 'error', data.error || 'Save nahi hua.');
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-save"></i> Route Code Assign Karein';
            }
        })
        .catch(err => {
            showModalAlert('route-alert', 'error', 'Network error: ' + err.message);
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-save"></i> Route Code Assign Karein';
        });
    }

    // ── Eligibility Modal ────────────────────────────────────────────────

    function submitFixEligibility() {
        const id2 = document.getElementById('elig-id2').checked;
        const id3 = document.getElementById('elig-id3').checked;
        const id4 = document.getElementById('elig-id4').checked;

        if (!id2 && !id3 && !id4) {
            showModalAlert('elig-alert', 'error', 'Kam az kam ek commission type select karein.');
            return;
        }

        const btn = document.getElementById('elig-submit-btn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';

        fetch('/CommissionInvestigation/FixEligibility', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                empNo: _fixEmpNo,
                employeeName: _fixEmpName,
                commissionId2: id2,
                commissionId3: id3,
                commissionId4: id4
            })
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                showModalAlert('elig-alert', 'success', data.message);
                btn.innerHTML = '<i class="fas fa-check"></i> Saved!';
                setTimeout(() => { window.location.href = _detailUrl; }, 1800);
            } else {
                showModalAlert('elig-alert', 'error', data.error || 'Save nahi hua.');
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-save"></i> Eligibility Save Karein';
            }
        })
        .catch(err => {
            showModalAlert('elig-alert', 'error', 'Network error: ' + err.message);
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-save"></i> Eligibility Save Karein';
        });
    }

    // ── Shared modal alert helper ────────────────────────────────────────

    function showModalAlert(alertId, type, msg) {
        const el = document.getElementById(alertId);
        if (!el) return;
        const isSuccess = type === 'success';
        el.className = `tw-mb-3 tw-p-3 tw-rounded-xl tw-text-sm tw-flex tw-items-start tw-gap-2 ${
            isSuccess ? 'tw-bg-emerald-50 tw-border tw-border-emerald-200 tw-text-emerald-700'
                      : 'tw-bg-red-50 tw-border tw-border-red-200 tw-text-red-700'}`;
        el.innerHTML = `<i class="fas ${isSuccess ? 'fa-check-circle' : 'fa-exclamation-circle'} tw-mt-0.5 tw-flex-shrink-0"></i><span>${msg}</span>`;
    }

    // Fix guide panel toggle
    function toggleFixPanel(panelId, btn) {
        const panel = document.getElementById(panelId);
        if (!panel) return;
        const hidden = panel.classList.toggle('tw-hidden');
        const chevron = btn.querySelector('.fix-chevron');
        if (chevron) chevron.style.transform = hidden ? '' : 'rotate(180deg)';
    }

    // Auto-open fix panels for Critical issues on page load
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('[id^="fix-panel-"]').forEach(panel => {
            if (!panel.classList.contains('tw-hidden')) {
                // Already open (Critical) — rotate its chevron
                const btn = document.querySelector(`[onclick="toggleFixPanel('${panel.id}', this)"]`);
                if (btn) {
                    const chevron = btn.querySelector('.fix-chevron');
                    if (chevron) chevron.style.transform = 'rotate(180deg)';
                }
            }
        });
    });

    // SQL copy
    function copySql(key) {
        const pre = document.getElementById('sql-' + key);
        if (!pre) return;
        navigator.clipboard.writeText(pre.innerText).then(() => {
            const btn = event.target.closest('button');
            if (btn) {
                const orig = btn.innerHTML;
                btn.innerHTML = '<i class="fas fa-check mr-1"></i>Copied!';
                btn.classList.add('tw-bg-emerald-600');
                setTimeout(() => { btn.innerHTML = orig; btn.classList.remove('tw-bg-emerald-600'); }, 1500);
            }
        });
    }

