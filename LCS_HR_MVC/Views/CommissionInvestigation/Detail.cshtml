@model LCS_HR_MVC.Models.EmployeeCommissionInvestigationVm
@{
    ViewData["Title"] = $"Commission Investigation — {Model.EmpNo}";
    var monthNames = new[] { "January","February","March","April","May","June",
                             "July","August","September","October","November","December" };
    string ML(int m) => m >= 1 && m <= 12 ? monthNames[m - 1] : m.ToString();
    string Fmt(decimal? v) => v.HasValue ? v.Value.ToString("N2") : "—";
    string FmtI(decimal? v) => v.HasValue ? v.Value.ToString("N0") : "—";

    // Maps hr_commissionprocess column names to source info for clickable detail
    string CommColSource(string col) => col switch {
        "EconomyRetail"      => "Cash CN — Economy Retail (S10)",
        "LOVELINE"           => "Cash CN — Love Line service (S10)",
        "DETAIN"             => "Cash CN — Detained shipments (S10)",
        "FLAYER"             => "Cash CN — Flayer shipments (S10)",
        "OVERLAND"           => "RBI — Overland commission (S7)",
        "VAS"                => "VAS incentive (S7 / S10)",
        "YB1KG"              => "Cash CN — YB 1Kg slab (S10)",
        "YB2KG"              => "Cash CN — YB 2Kg slab (S10)",
        "YB5KG"              => "Cash CN — YB 5Kg slab (S10)",
        "YB10KG"             => "Cash CN — YB 10Kg slab (S10)",
        "YB15KG"             => "Cash CN — YB 15Kg slab (S10)",
        "YB25KG"             => "Cash CN — YB 25Kg slab (S10)",
        "MTD"                => "OLE — MTD commission (S7)",
        "DocumnetCare"       => "Cash CN — Document Care (S10)",
        "IntlDox"            => "Cash CN — International Dox (S10)",
        "IntlEconomy"        => "Cash CN — International Economy (S10)",
        "IntlParcel"         => "Cash CN — International Parcel (S10)",
        "Insurance_Com"      => "Cash CN — Insurance Commission (S10)",
        "COD"                => "COD commission (S10)",
        "COD_Bonus"          => "COD Bonus (S10)",
        "ONUpto1kg"          => "Cash CN — Overnight up to 1Kg (S10)",
        "ONAbove1kg"         => "Cash CN — Overnight above 1Kg (S10)",
        "ONUpto1kgRetailCOD" => "Cash CN — ON 1Kg Retail COD (S10)",
        "ONAbove1kgRetailCOD"=> "Cash CN — ON 1Kg+ Retail COD (S10)",
        "AllInOne"           => "Cash CN — All-in-One (S10)",
        "PREPAID"            => "Cash CN — Prepaid (S10)",
        "PMCL"               => "Cash CN — PMCL (S10)",
        "OLE_Delivery"       => "OLE — Delivery commission (S7)",
        "OLE_Credit_Booking" => "OLE — Credit Booking (S7)",
        "OLE_Dispatch_Proper"=> "OLE — Dispatch (S7)",
        "OLE_Delivery_OPS"   => "OLE — Delivery OPS (S7)",
        "Ecom_overall_SR_Bonus"=> "SR Bonus — hr_incentive_overall_SR (S10)",
        "Return_E_Com"       => "COD Return — Ecom (S7)",
        "ECommerce_Zero_COD" => "VAS — Ecom Zero COD (S7)",
        "SOA"                => "VAS — SOA (S7)",
        "Utility_Bill"       => "VAS — Utility Bill (S7)",
        "Passport"           => "VAS — Passport (S7)",
        "CNIC_Card"          => "VAS — CNIC Card (S7)",
        "General_Light_Delivery"  => "OLE — General Light Delivery (S7)",
        "General_Heavy_Delivery"  => "OLE — General Heavy Delivery (S7)",
        "MTD_Delivery"       => "OLE — MTD Delivery (S7)",
        "Giftwifts_Delivery" => "OLE — Giftwifts (S7)",
        "Retail_Deduction"   => "Deduction — Retail (S10) [MINUS]",
        "COD_Deduction"      => "Deduction — COD (S10) [MINUS]",
        "Cour_id"            => "Route Code — (yeh commission column nahi, data mismatch ho sakta hai)",
        _                    => "hr_commissionprocess (S10)"
    };
}

<div class="tw-min-h-screen tw-bg-slate-50 tw-p-3 lg:tw-p-5">

    <!-- ── Breadcrumb ──────────────────────────────────────────────────── -->
    <nav class="tw-flex tw-items-center tw-gap-2 tw-text-xs tw-text-slate-400 tw-mb-4">
        <a href="@Url.Action("Index","CommissionInvestigation")" class="hover:tw-text-violet-600 tw-transition tw-flex tw-items-center tw-gap-1">
            <i class="fas fa-arrow-left"></i> Employee Commission Process
        </a>
        <span>/</span>
        <span class="tw-text-slate-600 tw-font-semibold">@Model.EmpNo — @ML(Model.Month) @Model.Year</span>
    </nav>

    <!-- ── Alert Messages ─────────────────────────────────────────────── -->
    @if (TempData["SuccessMessage"] is string sMsg)
    {
        <div class="tw-mb-3 tw-p-3 tw-bg-emerald-50 tw-border tw-border-emerald-200 tw-rounded-xl tw-text-sm tw-text-emerald-700 tw-flex tw-items-start tw-gap-2">
            <i class="fas fa-check-circle tw-mt-0.5 tw-text-emerald-500"></i><span>@sMsg</span>
        </div>
    }
    @if (TempData["ErrorMessage"] is string eMsg)
    {
        <div class="tw-mb-3 tw-p-3 tw-bg-red-50 tw-border tw-border-red-200 tw-rounded-xl tw-text-sm tw-text-red-700 tw-flex tw-items-start tw-gap-2">
            <i class="fas fa-exclamation-triangle tw-mt-0.5 tw-text-red-500"></i><span>@eMsg</span>
        </div>
    }

    <!-- ══════════════════════════════════════════════════════════════════
         HEADER — Employee card + server health + commission status
    ════════════════════════════════════════════════════════════════════ -->
    <div class="tw-bg-white tw-rounded-2xl tw-border tw-border-slate-200 tw-shadow-sm tw-mb-4">
        <div class="tw-p-4 tw-border-b tw-border-slate-100">
            <div class="tw-flex tw-flex-wrap tw-items-start tw-justify-between tw-gap-3">

                <!-- Left: employee info -->
                <div class="tw-flex tw-items-start tw-gap-3">
                    <div class="tw-w-12 tw-h-12 tw-bg-violet-100 tw-rounded-xl tw-flex tw-items-center tw-justify-center tw-flex-shrink-0">
                        <i class="fas fa-user tw-text-violet-600 tw-text-xl"></i>
                    </div>
                    <div>
                        <div class="tw-flex tw-items-center tw-gap-2 tw-flex-wrap">
                            <h2 class="tw-text-lg tw-font-bold tw-text-slate-800 tw-mb-0">@Model.Name</h2>
                            <span class="tw-font-mono tw-text-xs tw-font-bold tw-text-violet-700 tw-bg-violet-50 tw-px-2 tw-py-0.5 tw-rounded tw-border tw-border-violet-200">#@Model.EmpNo</span>
                            @if (!Model.IsActive)
                            {
                                <span class="tw-text-xs tw-bg-red-100 tw-text-red-600 tw-px-2 tw-py-0.5 tw-rounded-full tw-border tw-border-red-200 tw-font-semibold">LEFT</span>
                            }
                        </div>
                        <div class="tw-text-xs tw-text-slate-500 tw-mt-0.5 tw-flex tw-flex-wrap tw-gap-x-3 tw-gap-y-0.5">
                            @if (!string.IsNullOrEmpty(Model.Designation))
                            {
                                <span class="tw-font-semibold tw-text-violet-700">
                                    <i class="fas fa-briefcase tw-text-violet-400 tw-mr-1"></i>@Model.Designation
                                </span>
                                <span class="tw-text-slate-300">|</span>
                            }
                            @if (!string.IsNullOrEmpty(Model.EmployeeTypeName ?? Model.EmployeeType))
                            {
                                <span class="tw-font-semibold tw-text-slate-700">
                                    <i class="fas fa-id-badge tw-text-indigo-400 tw-mr-1"></i>@(Model.EmployeeTypeName ?? Model.EmployeeType)
                                    @if (!string.IsNullOrEmpty(Model.EmployeeType))
                                    {
                                        <span class="tw-text-slate-400">(Type @Model.EmployeeType)</span>
                                    }
                                </span>
                            }
                            @if (Model.AppointDate.HasValue)
                            {
                                <span class="tw-text-slate-400">|</span>
                                <span class="tw-text-slate-500"><i class="fas fa-calendar-plus tw-text-slate-400 tw-mr-1"></i>Joined @Model.AppointDate.Value.ToString("dd MMM yyyy")</span>
                            }
                            @{
                                var headerRC = Model.RouteCodes.FirstOrDefault(r => r.IsActive) ?? Model.RouteCodes.FirstOrDefault();
                            }
                            @if (headerRC != null)
                            {
                                <span class="tw-text-violet-700 tw-font-semibold">
                                    <i class="fas fa-route tw-text-violet-400 tw-mr-1"></i>@headerRC.CodeTypeLabel
                                </span>
                            }
                            <span class="@Model.EmpStatusClass tw-font-semibold">
                                <i class="fas fa-circle tw-text-xs tw-mr-1"></i>@Model.EmpStatusLabel
                            </span>
                            <span><i class="fas fa-map-marker-alt tw-text-violet-400 tw-mr-1"></i>@(Model.CityName ?? Model.CityCode)</span>
                            <span class="tw-font-semibold tw-text-violet-600">
                                <i class="fas fa-calendar tw-mr-1"></i>@ML(Model.Month) @Model.Year
                                (@Model.PeriodFrom.ToString("dd MMM") – @Model.PeriodTo.ToString("dd MMM yyyy"))
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Right: commission status badge -->
                <div class="tw-text-right">
                    <div class="tw-text-xs tw-text-slate-400 tw-mb-1">Commission Status</div>
                    @{
                        var statusLabel = Model.CommissionStatus switch {
                            "Processed"   => "Processed ✓",
                            "Missing"     => "Missing ✗",
                            "Partial"     => "Partial ⚠",
                            "NotEligible" => "Not Eligible",
                            "Pending"     => "Pending…",
                            "ZeroNoRoute" => "Zero — No Route Code ✗",
                            "ZeroAmount"  => "Processed (Rs 0) ✗",
                            _             => Model.CommissionStatus
                        };
                    }
                    <span class="tw-inline-flex tw-items-center tw-gap-1.5 tw-text-sm tw-font-bold tw-px-3 tw-py-1.5 tw-rounded-xl tw-border @Model.CommissionStatusClass">
                        @statusLabel
                    </span>
                    @if (Model.HasFinalCommission)
                    {
                        <div class="tw-text-xs tw-mt-1">
                            Grand Total:
                            <span class="tw-font-bold @(Model.FinalComm?.GrandTotal > 0 ? "tw-text-emerald-600" : "tw-text-red-600")">
                                Rs @FmtI(Model.FinalComm?.GrandTotal)
                            </span>
                            @if (Model.FinalComm?.GrandTotal == 0)
                            {
                                <span class="tw-text-red-400 tw-text-xs tw-ml-1">(no commission!)</span>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Data Sources panel (collapsible) -->
        <details class="tw-border-b tw-border-slate-100">
            <summary class="tw-px-4 tw-py-2 tw-cursor-pointer tw-flex tw-items-center tw-gap-2 tw-text-xs tw-text-slate-500 hover:tw-bg-slate-50 tw-select-none">
                <i class="fas fa-database tw-text-slate-400"></i>
                <span class="tw-font-semibold">Data Sources — kahan se aaya yeh data?</span>
                <span class="tw-text-slate-400 tw-ml-1">(click to expand)</span>
            </summary>
            <div class="tw-px-4 tw-py-3 tw-bg-slate-50/60">
                <div class="tw-overflow-x-auto">
                    <table class="tw-w-full tw-text-xs tw-border-collapse">
                        <thead>
                            <tr class="tw-bg-slate-100 tw-text-slate-600">
                                <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-border tw-border-slate-200">Field (Displayed)</th>
                                <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-border tw-border-slate-200">Value</th>
                                <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-border tw-border-slate-200">Table</th>
                                <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-border tw-border-slate-200">Column</th>
                                <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-border tw-border-slate-200">Server</th>
                            </tr>
                        </thead>
                        <tbody class="tw-divide-y tw-divide-slate-100">
                            @{
                                var headerRC2 = Model.RouteCodes.FirstOrDefault(r => r.IsActive) ?? Model.RouteCodes.FirstOrDefault();
                                // helper to render one row
                                void SrcRow(string field, string value, string table, string column, string server, string serverColor = "blue") {
                                    // rendered inline below
                                }
                            }
                            <tr class="tw-bg-white hover:tw-bg-slate-50">
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-semibold tw-text-slate-700">Employee Name</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-violet-700">@Model.Name</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-blue-700">hr_employeepersonaldetail</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-slate-600">NAME</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100"><span class="tw-bg-blue-100 tw-text-blue-700 tw-px-2 tw-py-0.5 tw-rounded-full tw-font-bold">S10 — 172.16.0.10</span></td>
                            </tr>
                            <tr class="tw-bg-white hover:tw-bg-slate-50">
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-semibold tw-text-slate-700">Employee No</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-violet-700">@Model.EmpNo</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-blue-700">hr_employeepersonaldetail</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-slate-600">EMP_NO</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100"><span class="tw-bg-blue-100 tw-text-blue-700 tw-px-2 tw-py-0.5 tw-rounded-full tw-font-bold">S10 — 172.16.0.10</span></td>
                            </tr>
                            <tr class="tw-bg-white hover:tw-bg-slate-50">
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-semibold tw-text-slate-700">Designation</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-violet-700">@(Model.Designation ?? "—")</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-blue-700">hr_jobs ← hr_employeepersonaldetail.JobTypeId</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-slate-600">hr_jobs.FullName</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100"><span class="tw-bg-blue-100 tw-text-blue-700 tw-px-2 tw-py-0.5 tw-rounded-full tw-font-bold">S10 — 172.16.0.10</span></td>
                            </tr>
                            <tr class="tw-bg-white hover:tw-bg-slate-50">
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-semibold tw-text-slate-700">Employee Type</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-violet-700">@(Model.EmployeeTypeName ?? "—") (Type @Model.EmployeeType)</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-blue-700">hr_employeetype ← hr_employeepersonaldetail.EMPLOYEE_TYPE</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-slate-600">hr_employeetype.FullName</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100"><span class="tw-bg-blue-100 tw-text-blue-700 tw-px-2 tw-py-0.5 tw-rounded-full tw-font-bold">S10 — 172.16.0.10</span></td>
                            </tr>
                            <tr class="tw-bg-white hover:tw-bg-slate-50">
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-semibold tw-text-slate-700">Joined Date</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-violet-700">@(Model.AppointDate?.ToString("dd MMM yyyy") ?? "—")</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-blue-700">hr_employeepersonaldetail</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-slate-600">APPOINT_DATE</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100"><span class="tw-bg-blue-100 tw-text-blue-700 tw-px-2 tw-py-0.5 tw-rounded-full tw-font-bold">S10 — 172.16.0.10</span></td>
                            </tr>
                            <tr class="tw-bg-white hover:tw-bg-slate-50">
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-semibold tw-text-slate-700">Route Code</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-violet-700">@(headerRC2?.RouteCode ?? "—")</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-blue-700">hr_employeeroutecode</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-slate-600">RouteCode</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100"><span class="tw-bg-blue-100 tw-text-blue-700 tw-px-2 tw-py-0.5 tw-rounded-full tw-font-bold">S10 — 172.16.0.10</span></td>
                            </tr>
                            <tr class="tw-bg-white hover:tw-bg-slate-50">
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-semibold tw-text-slate-700">Code Type (Express Center)</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-violet-700">@(headerRC2?.CodeTypeLabel ?? "—")</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-blue-700">couriercodetype ← hr_employeeroutecode.CodeType</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-slate-600">couriercodetype.Name</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100"><span class="tw-bg-blue-100 tw-text-blue-700 tw-px-2 tw-py-0.5 tw-rounded-full tw-font-bold">S10 — 172.16.0.10</span></td>
                            </tr>
                            <tr class="tw-bg-white hover:tw-bg-slate-50">
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-semibold tw-text-slate-700">Route Active/Inactive</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-violet-700">@(headerRC2?.IsActive == true ? "Active" : "Inactive")</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-blue-700">hr_employeeroutecode</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-slate-600">ToDate (NULL = Active)</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100"><span class="tw-bg-blue-100 tw-text-blue-700 tw-px-2 tw-py-0.5 tw-rounded-full tw-font-bold">S10 — 172.16.0.10</span></td>
                            </tr>
                            <tr class="tw-bg-white hover:tw-bg-slate-50">
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-semibold tw-text-slate-700">City</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-violet-700">@(Model.CityName ?? Model.CityCode ?? "—")</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-blue-700">hr_city ← hr_employeeroutecode.citycode</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-slate-600">hr_city.FullName</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100"><span class="tw-bg-blue-100 tw-text-blue-700 tw-px-2 tw-py-0.5 tw-rounded-full tw-font-bold">S10 — 172.16.0.10</span></td>
                            </tr>
                            <tr class="tw-bg-white hover:tw-bg-slate-50">
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-semibold tw-text-slate-700">Commission Period</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-violet-700">@ML(Model.Month) @Model.Year (@Model.PeriodFrom.ToString("dd MMM") – @Model.PeriodTo.ToString("dd MMM yyyy"))</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-slate-500 tw-italic">Computed (21st prev month – 20th current)</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100 tw-font-mono tw-text-slate-400 tw-italic">—</td>
                                <td class="tw-px-3 tw-py-1.5 tw-border tw-border-slate-100"><span class="tw-bg-slate-100 tw-text-slate-600 tw-px-2 tw-py-0.5 tw-rounded-full tw-font-bold">Derived</span></td>
                            </tr>
                            <tr class="tw-bg-slate-50/80 hover:tw-bg-slate-50">
                                <td colspan="5" class="tw-px-3 tw-py-2 tw-text-slate-500 tw-italic tw-border tw-border-slate-100">
                                    <i class="fas fa-info-circle tw-mr-1 tw-text-blue-400"></i>
                                    Baaki tab ka data (Cash CNs, COD, RBI, VAS, Final Commission etc.) — har tab ke header mein source table aur server already likha hota hai (e.g. "hr_cash_consignments (Server 10)", "hr_commissionprocess (S10)").
                                    Yeh panel sirf employee identity fields ke liye hai.
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </details>

        <!-- Server health row -->
        <div class="tw-p-3 tw-bg-slate-50/60 tw-flex tw-flex-wrap tw-gap-2 tw-border-b tw-border-slate-100">
            @{
                var servers = new[] { Model.S6Health, Model.S7Health, Model.S10Health };
            }
            @foreach (var srv in servers)
            {
                var srvBorder = srv.IsConnected
                    ? (srv.HasQueryError ? "tw-border-amber-300" : "tw-border-emerald-200")
                    : "tw-border-red-200";
                var srvIconColor = srv.IsConnected
                    ? (srv.HasQueryError ? "tw-text-amber-500" : "tw-text-emerald-500")
                    : "tw-text-red-500";
                var srvTextColor = srv.IsConnected
                    ? (srv.HasQueryError ? "tw-text-amber-600" : "tw-text-emerald-600")
                    : "tw-text-red-500";
                <div class="tw-flex tw-items-center tw-gap-2 tw-text-xs tw-bg-white tw-border @srvBorder tw-rounded-lg tw-px-3 tw-py-1.5">
                    <span class="@srvIconColor tw-text-sm"><i class="fas @srv.StatusIcon"></i></span>
                    <div>
                        <div class="tw-font-bold tw-text-slate-700">@srv.ServerLabel</div>
                        <div class="tw-text-slate-400">@srv.IpAddress</div>
                    </div>
                    <span class="@srvTextColor tw-font-semibold tw-ml-1">@srv.StatusText</span>
                    @if (!string.IsNullOrEmpty(srv.ErrorMessage))
                    {
                        <span class="@(srv.IsConnected ? "tw-text-amber-400" : "tw-text-red-400")" title="@srv.ErrorMessage">
                            <i class="fas fa-info-circle"></i>
                        </span>
                    }
                </div>
            }
        </div>

        <!-- Issues summary row -->
        @if (Model.IssueCount > 0)
        {
            <div class="tw-p-3 tw-flex tw-flex-wrap tw-gap-2 tw-items-center">
                <span class="tw-text-xs tw-font-bold tw-text-slate-600"><i class="fas fa-flag tw-text-slate-400 tw-mr-1"></i>Issues Detected:</span>
                @if (Model.CriticalIssues.Count > 0)
                {
                    <span class="tw-text-xs tw-font-bold tw-bg-red-100 tw-text-red-700 tw-px-2 tw-py-0.5 tw-rounded-full tw-border tw-border-red-200">
                        <i class="fas fa-times-circle tw-mr-1"></i>@Model.CriticalIssues.Count Critical
                    </span>
                }
                @if (Model.Warnings.Count > 0)
                {
                    <span class="tw-text-xs tw-font-bold tw-bg-amber-100 tw-text-amber-700 tw-px-2 tw-py-0.5 tw-rounded-full tw-border tw-border-amber-200">
                        <i class="fas fa-exclamation-triangle tw-mr-1"></i>@Model.Warnings.Count Warnings
                    </span>
                }
                @if (Model.InfoItems.Count > 0)
                {
                    <span class="tw-text-xs tw-font-bold tw-bg-blue-100 tw-text-blue-700 tw-px-2 tw-py-0.5 tw-rounded-full tw-border tw-border-blue-200">
                        <i class="fas fa-info-circle tw-mr-1"></i>@Model.InfoItems.Count Info
                    </span>
                }
                <a href="#issues-section" class="tw-text-xs tw-text-violet-600 hover:tw-underline tw-ml-1">
                    <i class="fas fa-arrow-down"></i> Details dekhein
                </a>
            </div>
        }
        else
        {
            <div class="tw-p-3 tw-text-xs tw-text-emerald-600 tw-flex tw-items-center tw-gap-2">
                <i class="fas fa-check-circle tw-text-emerald-500"></i>
                Koi issues detect nahi hue — data consistent lag raha hai.
            </div>
        }
    </div>

    <!-- ══════════════════════════════════════════════════════════════════
         TAB NAVIGATION
    ════════════════════════════════════════════════════════════════════ -->
    <div class="tw-flex tw-gap-1 tw-mb-4 tw-overflow-x-auto tw-pb-1" id="tabNav">
        <button onclick="showTab('tab-routes')"   class="tab-btn tw-active tw-text-xs tw-font-semibold tw-whitespace-nowrap tw-px-3 tw-py-2 tw-rounded-lg tw-border tw-transition">
            <i class="fas fa-route tw-mr-1"></i> Routes &amp; Setup
        </button>
        <button onclick="showTab('tab-cash')"     class="tab-btn tw-text-xs tw-font-semibold tw-whitespace-nowrap tw-px-3 tw-py-2 tw-rounded-lg tw-border tw-transition">
            <i class="fas fa-money-bill tw-mr-1"></i> Cash CNs
            @if (Model.TotalCashCns > 0)
            {
                <span class="tw-bg-violet-200 tw-text-violet-800 tw-rounded-full tw-px-1.5 tw-ml-1">@Model.TotalCashCns</span>
            }
        </button>
        <button onclick="showTab('tab-cod')"      class="tab-btn tw-text-xs tw-font-semibold tw-whitespace-nowrap tw-px-3 tw-py-2 tw-rounded-lg tw-border tw-transition">
            <i class="fas fa-hand-holding-usd tw-mr-1"></i> COD CNs
            @if (Model.TotalCodCns > 0)
            {
                <span class="tw-bg-violet-200 tw-text-violet-800 tw-rounded-full tw-px-1.5 tw-ml-1">@Model.TotalCodCns</span>
            }
        </button>
        <button onclick="showTab('tab-ole')"      class="tab-btn tw-text-xs tw-font-semibold tw-whitespace-nowrap tw-px-3 tw-py-2 tw-rounded-lg tw-border tw-transition">
            <i class="fas fa-truck tw-mr-1"></i> RBI / VAS / OLE
            @{
                // Use TotalCount (actual DB count) for the badge; fall back to loaded rows count
                var rbiDisplayCount  = Model.RbiTotalCount  > 0 ? Model.RbiTotalCount  : Model.RbiRows.Count;
                var vasDisplayCount  = Model.VasTotalCount  > 0 ? Model.VasTotalCount  : Model.VasRows.Count;
                var crDisplayCount   = Model.CodReturnTotalCount > 0 ? Model.CodReturnTotalCount : Model.CodReturnRows.Count;
                var s7CnCount        = rbiDisplayCount + vasDisplayCount + crDisplayCount;
                // Show "+" if actual count exceeds loaded rows (data was limited)
                var rbiLimited = Model.RbiTotalCount > Model.RbiRows.Count;
                var vasLimited = Model.VasTotalCount > Model.VasRows.Count;
                var crLimited  = Model.CodReturnTotalCount > Model.CodReturnRows.Count;
                var s7Limited  = rbiLimited || vasLimited || crLimited;
            }
            @if (s7CnCount > 0)
            {
                <span class="tw-bg-purple-200 tw-text-purple-800 tw-rounded-full tw-px-1.5 tw-ml-1">@s7CnCount@(s7Limited ? "+" : "")</span>
            }
            @if (!Model.S7Connected)
            {
                <span class="tw-text-red-400 tw-ml-1"><i class="fas fa-exclamation-circle"></i></span>
            }
        </button>
        <button onclick="showTab('tab-adjbonus')" class="tab-btn tw-text-xs tw-font-semibold tw-whitespace-nowrap tw-px-3 tw-py-2 tw-rounded-lg tw-border tw-transition">
            <i class="fas fa-sliders-h tw-mr-1"></i> Adjust &amp; Bonus
            @if (Model.Adjustments.Any() || Model.SrBonus != null)
            {
                <span class="tw-bg-teal-200 tw-text-teal-800 tw-rounded-full tw-px-1.5 tw-ml-1">
                    @(Model.Adjustments.Count + (Model.SrBonus != null ? 1 : 0))
                </span>
            }
        </button>
        <button onclick="showTab('tab-s6')"       class="tab-btn tw-text-xs tw-font-semibold tw-whitespace-nowrap tw-px-3 tw-py-2 tw-rounded-lg tw-border tw-transition">
            <i class="fas fa-server tw-mr-1"></i> Server 6 Billing
            @if (!Model.S6Connected)
            {
                <span class="tw-text-red-400 tw-ml-1"><i class="fas fa-exclamation-circle"></i></span>
            }
        </button>
        <button onclick="showTab('tab-s7')"       class="tab-btn tw-text-xs tw-font-semibold tw-whitespace-nowrap tw-px-3 tw-py-2 tw-rounded-lg tw-border tw-transition">
            <i class="fas fa-map-marker-alt tw-mr-1"></i> Location / OLE
            @if (!Model.S7Connected)
            {
                <span class="tw-text-red-400 tw-ml-1"><i class="fas fa-exclamation-circle"></i></span>
            }
        </button>
        <button onclick="showTab('tab-final')"    class="tab-btn tw-text-xs tw-font-semibold tw-whitespace-nowrap tw-px-3 tw-py-2 tw-rounded-lg tw-border tw-transition">
            <i class="fas fa-file-invoice-dollar tw-mr-1"></i> Final Commission
        </button>
        <button onclick="showTab('tab-issues')"   class="tab-btn tw-text-xs tw-font-semibold tw-whitespace-nowrap tw-px-3 tw-py-2 tw-rounded-lg tw-border tw-transition">
            <i class="fas fa-flag tw-mr-1"></i> Issues
            @if (Model.CriticalIssues.Count > 0)
            {
                <span class="tw-bg-red-200 tw-text-red-800 tw-rounded-full tw-px-1.5 tw-ml-1">@Model.CriticalIssues.Count</span>
            }
        </button>
        <button onclick="showTab('tab-sql')"      class="tab-btn tw-text-xs tw-font-semibold tw-whitespace-nowrap tw-px-3 tw-py-2 tw-rounded-lg tw-border tw-transition">
            <i class="fas fa-code tw-mr-1"></i> SQL Queries
        </button>
        <button onclick="showTab('tab-notes')"    class="tab-btn tw-text-xs tw-font-semibold tw-whitespace-nowrap tw-px-3 tw-py-2 tw-rounded-lg tw-border tw-transition">
            <i class="fas fa-sticky-note tw-mr-1"></i> Notes
            @if (Model.Notes.Count > 0)
            {
                <span class="tw-bg-slate-200 tw-text-slate-700 tw-rounded-full tw-px-1.5 tw-ml-1">@Model.Notes.Count</span>
            }
        </button>
    </div>

    <!-- ══════════════════════════════════════════════════════════════════
         TAB 1: Routes & Setup (Eligibility, Attendance, Route Codes)
    ════════════════════════════════════════════════════════════════════ -->
    <div id="tab-routes" class="tab-content">
        <div class="tw-grid tw-grid-cols-1 lg:tw-grid-cols-3 tw-gap-4">

            <!-- Eligibility & Attendance card -->
            <div class="tw-bg-white tw-rounded-2xl tw-border tw-border-slate-200 tw-shadow-sm">
                <div class="tw-p-4 tw-border-b tw-border-slate-100">
                    <div class="tw-flex tw-items-center tw-gap-2">
                        <i class="fas fa-user-check tw-text-indigo-500"></i>
                        <span class="tw-text-sm tw-font-bold tw-text-slate-700">Eligibility &amp; Attendance</span>
                    </div>
                </div>
                <div class="tw-p-4 tw-space-y-3 tw-text-sm">

                    @{
                        var isElig = Model.IsEligible;
                        var eligBadge = isElig == true   ? "tw-bg-emerald-100 tw-text-emerald-700"
                                      : isElig == false  ? "tw-bg-red-100 tw-text-red-700"
                                      : "tw-bg-slate-100 tw-text-slate-600";
                        var eligLabel = isElig == true ? "Eligible" : isElig == false ? "Not Eligible" : "Unknown";
                        // Determine if D&P employee (CodeType=1) — they don't use eligibility table
                        var codeType1 = Model.RouteCodes.Any(r => r.CodeType == 1);
                        bool hasNoEligRecord = !Model.EligibilityBreakdown.Any();
                    }

                    <!-- Overall eligibility badge -->
                    <div class="tw-flex tw-justify-between tw-items-center">
                        <span class="tw-text-slate-500 tw-font-medium">Commission Eligibility</span>
                        <span class="tw-text-xs tw-font-bold tw-px-2 tw-py-0.5 tw-rounded-full @eligBadge">@eligLabel</span>
                    </div>

                    <!-- Explain Unknown for D&P employees -->
                    @if (hasNoEligRecord && codeType1)
                    {
                        <div class="tw-text-xs tw-text-blue-600 tw-bg-blue-50 tw-rounded-lg tw-p-2 tw-border tw-border-blue-100">
                            <i class="fas fa-info-circle tw-mr-1"></i>
                            <strong>Delivery &amp; Pickup</strong> employees ka record <code>hr_empcommissioneligibility</code> mein nahi hota — inki eligibility per-shipment rate se automatically determine hoti hai (CodeType=1).
                        </div>
                    }
                    else if (hasNoEligRecord)
                    {
                        <div class="tw-text-xs tw-text-amber-600 tw-bg-amber-50 tw-rounded-lg tw-p-2 tw-border tw-border-amber-100">
                            <i class="fas fa-exclamation-triangle tw-mr-1"></i>
                            <code>hr_empcommissioneligibility</code> mein koi record nahi. Setup → Commission Eligibility mein assign karo.
                        </div>
                    }

                    <!-- Per-category eligibility breakdown -->
                    @if (Model.EligibilityBreakdown.Any())
                    {
                        <div class="tw-border tw-border-slate-100 tw-rounded-lg tw-overflow-hidden">
                            <div class="tw-bg-slate-50 tw-px-3 tw-py-1.5 tw-text-xs tw-font-bold tw-text-slate-500 tw-uppercase tw-tracking-wide">
                                Category-wise Eligibility
                            </div>
                            @foreach (var cat in Model.EligibilityBreakdown)
                            {
                                <div class="tw-flex tw-justify-between tw-items-center tw-px-3 tw-py-2 tw-border-t tw-border-slate-100">
                                    <div>
                                        <span class="tw-text-xs tw-font-semibold tw-text-slate-700">@cat.CategoryName</span>
                                        <span class="tw-text-xs tw-text-slate-400 tw-ml-1">(ID:@cat.CommissionId)</span>
                                    </div>
                                    <span class="tw-flex tw-items-center tw-gap-1 tw-text-xs tw-font-bold @cat.StatusClass">
                                        <i class="fas @cat.StatusIcon"></i> @cat.StatusLabel
                                    </span>
                                </div>
                            }
                        </div>
                    }

                    <!-- Attendance -->
                    @if (Model.Attendance != null)
                    {
                        var att = Model.Attendance;
                        <div class="tw-border-t tw-border-slate-100 tw-pt-3 tw-space-y-2">
                            <div class="tw-text-xs tw-font-bold tw-text-slate-500 tw-uppercase tw-tracking-wide tw-mb-2">Attendance</div>
                            <div class="tw-flex tw-justify-between">
                                <span class="tw-text-slate-500 tw-text-xs">Processed</span>
                                <span class="tw-text-xs @(att.IsProcessed ? "tw-text-emerald-600 tw-font-semibold" : "tw-text-amber-600 tw-font-semibold")">
                                    @(att.IsProcessed ? "Yes" : "Not yet")
                                </span>
                            </div>
                            @if (att.TotalDays.HasValue)
                            {
                                <div class="tw-flex tw-justify-between tw-text-xs">
                                    <span class="tw-text-slate-500">Total / Sundays</span>
                                    <span class="tw-text-slate-700 tw-font-mono">@att.TotalDays / @att.SundayDays</span>
                                </div>
                                <div class="tw-flex tw-justify-between tw-text-xs">
                                    <span class="tw-text-slate-500">Absent / Adj</span>
                                    <span class="tw-text-slate-700 tw-font-mono">@att.AbsentDays / @att.Adjustments</span>
                                </div>
                                <div class="tw-flex tw-justify-between tw-text-xs tw-border-t tw-border-slate-100 tw-pt-2 tw-mt-2">
                                    <span class="tw-font-semibold tw-text-slate-600">Effective Days</span>
                                    <span class="tw-font-bold tw-text-indigo-600">@att.EffectiveDays</span>
                                </div>
                                <div class="tw-text-xs tw-text-slate-400 tw-italic">
                                    (@att.TotalDays - @att.SundayDays - @att.AbsentDays + @att.Adjustments)
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(att.Comments))
                            {
                                <div class="tw-text-xs tw-text-slate-500 tw-bg-slate-50 tw-rounded tw-p-2 tw-mt-2">@att.Comments</div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="tw-text-xs tw-text-amber-600 tw-bg-amber-50 tw-rounded tw-p-2 tw-mt-2">
                            <i class="fas fa-exclamation-triangle tw-mr-1"></i>
                            Attendance data nahi mila is month ke liye.
                        </div>
                    }
                </div>
            </div>

            <!-- Route Codes -->
            <div class="tw-bg-white tw-rounded-2xl tw-border tw-border-slate-200 tw-shadow-sm lg:tw-col-span-2">
                <div class="tw-p-4 tw-border-b tw-border-slate-100">
                    <div class="tw-flex tw-items-center tw-justify-between">
                        <div class="tw-flex tw-items-center tw-gap-2">
                            <i class="fas fa-route tw-text-violet-500"></i>
                            <span class="tw-text-sm tw-font-bold tw-text-slate-700">Route Codes</span>
                        </div>
                        <span class="tw-text-xs tw-text-slate-400">@Model.RouteCodes.Count route(s) found on Server 10</span>
                    </div>
                </div>
                @if (Model.RouteCodes.Count == 0)
                {
                    <div class="tw-p-6 tw-text-center tw-text-sm tw-text-red-500">
                        <i class="fas fa-exclamation-circle tw-text-2xl tw-mb-2 tw-block"></i>
                        Koi route code nahi mila is employee ke liye.<br/>
                        <span class="tw-text-xs tw-text-slate-400">Commission calculate nahi ho sakti without route codes.</span>
                    </div>
                }
                else
                {
                    @if (Model.RouteCodes.Count > 1)
                    {
                        <div class="tw-mx-4 tw-mt-3 tw-p-3 tw-bg-amber-50 tw-border tw-border-amber-200 tw-rounded-xl tw-text-xs tw-text-amber-800">
                            <i class="fas fa-info-circle tw-mr-1 tw-text-amber-500"></i>
                            <strong>Multiple Route Codes — Confusion clear karein:</strong>
                            Cash CNs tab mein <strong>sab route codes</strong> (@string.Join(", ", Model.RouteCodes.Select(r => r.RouteCode))) ke CNs show hote hain kyunki
                            <code>hr_cash_consignments</code> mein data <code>cour_id</code> se query hota hai.
                            Inactive route codes (ToDate set hai) ke CNs bhi us period ka data dikhate hain jab wo active the.
                            Commission process mein sirf woh CNs count hote hain jo commission period (@ML(Model.Month) @Model.Year) mein active route code par the.
                            Final Commission tab mein <code>Cour_id</code> column check karein — jo value wahan hai woh active route code hai.
                        </div>
                    }
                    <div class="tw-overflow-x-auto">
                        <table class="tw-w-full tw-text-xs">
                            <thead class="tw-bg-slate-50 tw-border-b tw-border-slate-200">
                                <tr>
                                    <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500 tw-uppercase">Route Code</th>
                                    <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500 tw-uppercase">City</th>
                                    <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500 tw-uppercase">Station ID</th>
                                    <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500 tw-uppercase">Type</th>
                                    <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500 tw-uppercase">From – To</th>
                                    <th class="tw-px-3 tw-py-2 tw-text-center tw-font-bold tw-text-slate-500 tw-uppercase">Active</th>
                                </tr>
                            </thead>
                            <tbody class="tw-divide-y tw-divide-slate-100">
                                @foreach (var rc in Model.RouteCodes)
                                {
                                    <tr class="@(rc.IsActive ? "" : "tw-opacity-60 tw-bg-slate-50")">
                                        <td class="tw-px-3 tw-py-2">
                                            <span class="tw-font-mono tw-font-bold tw-text-violet-700">@rc.RouteCode</span>
                                            @if (!rc.IsActive)
                                            {
                                                <span class="tw-ml-1 tw-text-slate-400 tw-text-xs">(inactive)</span>
                                            }
                                        </td>
                                        <td class="tw-px-3 tw-py-2 tw-text-slate-600">@(rc.CityName ?? rc.CityCode)</td>
                                        <td class="tw-px-3 tw-py-2 tw-font-mono tw-text-slate-500">@rc.StationId</td>
                                        <td class="tw-px-3 tw-py-2">
                                            <span class="tw-text-slate-700 tw-font-semibold">@rc.CodeTypeLabel</span>
                                        </td>
                                        <td class="tw-px-3 tw-py-2 tw-text-slate-500">
                                            @(rc.FromDate.HasValue ? rc.FromDate.Value.ToString("dd MMM yy") : "—")
                                            @(rc.ToDate.HasValue ? " – " + rc.ToDate.Value.ToString("dd MMM yy") : " – Abhi tak")
                                        </td>
                                        <td class="tw-px-3 tw-py-2 tw-text-center">
                                            @if (rc.IsActive)
                                            {
                                                <i class="fas fa-check-circle tw-text-emerald-500"></i>
                                            }
                                            else
                                            {
                                                <i class="fas fa-times-circle tw-text-red-400"></i>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

        </div>

        <!-- Commission Categories by Designation / CodeType -->
        @if (Model.CommissionCategories.Any())
        {
            var activeRC = Model.RouteCodes.FirstOrDefault(r => r.IsActive) ?? Model.RouteCodes.FirstOrDefault();
            <div class="tw-bg-white tw-rounded-2xl tw-border tw-border-indigo-100 tw-shadow-sm tw-mt-4">
                <div class="tw-p-4 tw-border-b tw-border-indigo-100 tw-bg-indigo-50 tw-rounded-t-2xl">
                    <div class="tw-flex tw-items-center tw-justify-between">
                        <div class="tw-flex tw-items-center tw-gap-2">
                            <i class="fas fa-layer-group tw-text-indigo-500"></i>
                            <span class="tw-text-sm tw-font-bold tw-text-indigo-700">Commission Categories Applicable to This Employee</span>
                        </div>
                        @if (activeRC != null)
                        {
                            <span class="tw-text-xs tw-bg-indigo-100 tw-text-indigo-600 tw-px-2 tw-py-1 tw-rounded-lg tw-font-semibold">
                                CodeType @activeRC.CodeTypeLabel
                            </span>
                        }
                    </div>
                    <div class="tw-text-xs tw-text-indigo-500 tw-mt-1">
                        Employee Type: <strong>@(Model.EmployeeTypeName ?? Model.EmployeeType ?? "—")</strong>
                        &nbsp;|&nbsp; Status: <strong class="@Model.EmpStatusClass">@Model.EmpStatusLabel</strong>
                    </div>
                </div>
                <div class="tw-p-4">
                    <div class="tw-grid tw-grid-cols-1 md:tw-grid-cols-2 tw-gap-3">
                        @foreach (var cat in Model.CommissionCategories)
                        {
                            <div class="tw-border tw-border-slate-200 tw-rounded-xl tw-p-3 tw-bg-slate-50 hover:tw-bg-white tw-transition-colors">
                                <div class="tw-flex tw-items-start tw-gap-2">
                                    <i class="fas @cat.Icon tw-text-indigo-400 tw-mt-0.5 tw-text-sm"></i>
                                    <div class="tw-flex-1">
                                        <div class="tw-text-xs tw-font-bold tw-text-slate-700">@cat.Category</div>
                                        <div class="tw-text-xs tw-text-slate-500 tw-mt-0.5">@cat.Description</div>
                                        <div class="tw-flex tw-items-center tw-gap-1 tw-mt-1.5">
                                            <span class="tw-text-xs tw-bg-emerald-100 tw-text-emerald-700 tw-px-1.5 tw-py-0.5 tw-rounded tw-font-mono">@cat.RateDisplay</span>
                                        </div>
                                        <div class="tw-text-xs tw-text-slate-400 tw-mt-1 tw-font-mono">@cat.Source</div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Commission Rate Policies: Applied (from CNs) OR All (when no CNs) -->
        @{
            var ratesToShow = Model.UsedRates.Count > 0 ? Model.UsedRates : Model.AllRatePolicies;
            var ratesTitle  = Model.UsedRates.Count > 0
                ? "Commission Rate Policies (Applied to This Employee's CNs)"
                : "Commission Rate Policies — New System (hr_commissionpolicy)";
            var ratesNote   = Model.UsedRates.Count > 0 ? "" :
                "Route Code nahi hai isliye actual applied rates nahi mili. Yeh table hr_commissionpolicy ke SAARE active rates show kar rahi hai reference ke liye.";
        }
        @if (ratesToShow.Count > 0)
        {
            <div class="tw-bg-white tw-rounded-2xl tw-border tw-border-slate-200 tw-shadow-sm tw-mt-4">
                <div class="tw-p-4 tw-border-b tw-border-slate-100">
                    <div class="tw-flex tw-items-center tw-gap-2">
                        <i class="fas fa-percentage tw-text-amber-500"></i>
                        <span class="tw-text-sm tw-font-bold tw-text-slate-700">@ratesTitle</span>
                        @if (Model.UsedRates.Count == 0)
                        {
                            <span class="tw-text-xs tw-bg-blue-100 tw-text-blue-700 tw-px-2 tw-py-0.5 tw-rounded-full tw-font-semibold">Reference Only</span>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(ratesNote))
                    {
                        <div class="tw-text-xs tw-text-slate-500 tw-mt-1"><i class="fas fa-info-circle tw-mr-1 tw-text-blue-400"></i>@ratesNote</div>
                    }
                </div>
                <div class="tw-overflow-x-auto">
                    <table class="tw-w-full tw-text-xs">
                        <thead class="tw-bg-slate-50 tw-border-b tw-border-slate-200">
                            <tr>
                                <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">Rate ID</th>
                                <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">Type</th>
                                <th class="tw-px-3 tw-py-2 tw-text-right tw-font-bold tw-text-slate-500">Rate</th>
                                <th class="tw-px-3 tw-py-2 tw-text-center tw-font-bold tw-text-slate-500">Is %</th>
                                <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">RateType</th>
                                <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">Comments</th>
                            </tr>
                        </thead>
                        <tbody class="tw-divide-y tw-divide-slate-100">
                            @foreach (var rate in ratesToShow)
                            {
                                <tr class="hover:tw-bg-slate-50">
                                    <td class="tw-px-3 tw-py-2 tw-font-mono tw-font-bold tw-text-slate-600">@rate.RateId</td>
                                    <td class="tw-px-3 tw-py-2 tw-text-slate-600">@rate.Type</td>
                                    <td class="tw-px-3 tw-py-2 tw-text-right tw-font-mono tw-text-slate-700">@rate.RateDisplay</td>
                                    <td class="tw-px-3 tw-py-2 tw-text-center">
                                        @if (rate.IsPercent) { <i class="fas fa-check tw-text-emerald-500"></i> }
                                        else { <i class="fas fa-times tw-text-slate-300"></i> }
                                    </td>
                                    <td class="tw-px-3 tw-py-2 tw-text-slate-500">
                                        @if (rate.RateType.HasValue)
                                        {
                                            <span class="tw-bg-slate-100 tw-px-1.5 tw-py-0.5 tw-rounded tw-font-mono">@rate.RateType</span>
                                        }
                                    </td>
                                    <td class="tw-px-3 tw-py-2 tw-text-slate-500 tw-italic">@rate.Comments</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <!-- Old Incentive Rates (hr_comm_insentives — legacy) -->
        @if (Model.OldIncentiveRates.Count > 0)
        {
            <div class="tw-bg-white tw-rounded-2xl tw-border tw-border-amber-200 tw-shadow-sm tw-mt-4">
                <div class="tw-p-4 tw-border-b tw-border-amber-100 tw-bg-amber-50 tw-rounded-t-2xl">
                    <div class="tw-flex tw-items-center tw-gap-2">
                        <i class="fas fa-history tw-text-amber-600"></i>
                        <span class="tw-text-sm tw-font-bold tw-text-amber-800">Old Incentive Rates (hr_comm_insentives — Legacy System)</span>
                    </div>
                    <div class="tw-text-xs tw-text-amber-700 tw-mt-1">
                        <i class="fas fa-info-circle tw-mr-1"></i>
                        Yeh purana system hai. Kuch CodeTypes ke liye aaj bhi apply hota hai. New system = hr_commissionpolicy, Old system = hr_comm_insentives.
                    </div>
                </div>
                <div class="tw-overflow-x-auto">
                    <table class="tw-w-full tw-text-xs">
                        <thead class="tw-bg-amber-50 tw-border-b tw-border-amber-100">
                            <tr>
                                <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-amber-600">ID</th>
                                <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-amber-600">Type</th>
                                <th class="tw-px-3 tw-py-2 tw-text-right tw-font-bold tw-text-amber-600">Rate</th>
                                <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-amber-600">Comments</th>
                            </tr>
                        </thead>
                        <tbody class="tw-divide-y tw-divide-amber-100">
                            @foreach (var r in Model.OldIncentiveRates)
                            {
                                <tr class="hover:tw-bg-amber-50">
                                    <td class="tw-px-3 tw-py-2 tw-font-mono tw-font-bold tw-text-amber-700">@r.Id</td>
                                    <td class="tw-px-3 tw-py-2 tw-text-slate-600">@r.Type</td>
                                    <td class="tw-px-3 tw-py-2 tw-text-right tw-font-mono tw-text-slate-700">@r.RateDisplay</td>
                                    <td class="tw-px-3 tw-py-2 tw-text-slate-500 tw-italic">@r.Comments</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>

    <!-- ══════════════════════════════════════════════════════════════════
         TAB 2: Cash CNs
    ════════════════════════════════════════════════════════════════════ -->
    <div id="tab-cash" class="tab-content tw-hidden">
        <div class="tw-bg-white tw-rounded-2xl tw-border tw-border-slate-200 tw-shadow-sm">
            <div class="tw-p-4 tw-border-b tw-border-slate-100">
                <div class="tw-flex tw-items-center tw-justify-between tw-flex-wrap tw-gap-2">
                    <div class="tw-flex tw-items-center tw-gap-2">
                        <i class="fas fa-money-bill tw-text-emerald-500"></i>
                        <span class="tw-text-sm tw-font-bold tw-text-slate-700">Cash Commission CNs — Server 10</span>
                    </div>
                    <div class="tw-text-sm tw-font-bold tw-text-emerald-600">
                        Total: Rs @FmtI(Model.CashTotal) &nbsp;|&nbsp; @Model.TotalCashCns CNs
                    </div>
                </div>
                @if (Model.CashBillingTypes.Any())
                {
                    <div class="tw-flex tw-flex-wrap tw-gap-2 tw-mt-2">
                        @foreach (var bt in Model.CashBillingTypes)
                        {
                            <span class="tw-text-xs tw-px-2 tw-py-1 tw-rounded-lg @(bt.BillingType == "CASH" ? "tw-bg-emerald-50 tw-text-emerald-700 tw-border tw-border-emerald-200" : "tw-bg-blue-50 tw-text-blue-700 tw-border tw-border-blue-200")">
                                <strong>@bt.BillingType</strong>: @bt.Count CNs
                            </span>
                        }
                        @if (Model.RetailCodCount > 0)
                        {
                            <span class="tw-text-xs tw-text-slate-400 tw-flex tw-items-center">
                                <i class="fas fa-info-circle tw-mr-1"></i>
                                Retail COD CNs S6 billing_details mein nahi hote — isliye S6 count kam hai
                            </span>
                        }
                    </div>
                }
            </div>
            @if (!string.IsNullOrEmpty(Model.NoCnReason))
            {
                <div class="tw-p-4 tw-bg-amber-50 tw-border tw-border-amber-200 tw-rounded-xl tw-mx-4 tw-my-3">
                    <div class="tw-flex tw-items-start tw-gap-3">
                        <i class="fas fa-exclamation-triangle tw-text-amber-500 tw-mt-0.5 tw-text-lg tw-flex-shrink-0"></i>
                        <div>
                            <div class="tw-text-sm tw-font-bold tw-text-amber-800 tw-mb-1">CN Data Available Nahi — Route Code Required</div>
                            <div class="tw-text-xs tw-text-amber-700">@Model.NoCnReason</div>
                            <div class="tw-text-xs tw-text-amber-600 tw-mt-2 tw-font-semibold">
                                <i class="fas fa-info-circle tw-mr-1"></i>
                                Database mein CNs <code>cour_id</code> (Route Code) se store hote hain, employee number se nahi. Route Code assign karne ke liye upar Issues tab mein "Fix Now" button use karein.
                            </div>
                        </div>
                    </div>
                </div>
            }
            else @if (Model.CashCns.Count == 0)
            {
                <div class="tw-p-6 tw-text-center tw-text-slate-400 tw-text-sm">
                    <i class="fas fa-inbox tw-text-2xl tw-mb-2 tw-block"></i>
                    Is period mein koi cash commission CN nahi mila.
                </div>
            }
            else
            {
                // Per-route-code breakdown (computed in view for display purposes)
                var cashByRoute = Model.CashCns
                    .GroupBy(c => c.RouteCode ?? "?")
                    .Select(g => new {
                        RouteCode    = g.Key,
                        CnCount      = g.Count(),
                        CashCount    = g.Count(c => (c.BillingCategory ?? "CASH") == "CASH"),
                        RetailCodCnt = g.Count(c => (c.BillingCategory ?? "CASH") != "CASH"),
                        BilledTotal  = g.Sum(c => c.BilledAmount),
                        CommTotal    = g.Sum(c => c.CommissionAmount),
                        IsActive     = Model.RouteCodes.Any(r => r.RouteCode == g.Key && r.ToDate == null)
                    })
                    .OrderByDescending(x => x.IsActive)
                    .ThenByDescending(x => x.CommTotal)
                    .ToList();

                <!-- Per-route-code breakdown strip -->
                <div class="tw-mx-4 tw-mt-3 tw-mb-2">
                    <div class="tw-text-xs tw-font-bold tw-text-slate-500 tw-uppercase tw-mb-2 tw-tracking-wide">
                        <i class="fas fa-route tw-mr-1 tw-text-violet-400"></i> Per Route Code — S10 vs S6 Breakdown
                    </div>
                    <div class="tw-flex tw-flex-wrap tw-gap-3">
                        @foreach (var rg in cashByRoute)
                        {
                            var rcBadge = rg.IsActive
                                ? "tw-bg-emerald-50 tw-border-emerald-300 tw-text-emerald-800"
                                : "tw-bg-slate-50 tw-border-slate-300 tw-text-slate-600";
                            int s6Count  = Model.S6Connected && Model.S6CnCountByRoute.ContainsKey(rg.RouteCode)
                                           ? Model.S6CnCountByRoute[rg.RouteCode] : -1;
                            int s10Cash  = rg.CashCount;
                            int s10Rcod  = rg.RetailCodCnt;
                            // S6 only has CASH — so diff = S10 CASH - S6 (negative = S6 has more, positive = S10 has more)
                            int cashDiff = s6Count >= 0 ? (s10Cash - s6Count) : 0;
                            <div class="tw-rounded-xl tw-border tw-p-3 @rcBadge" style="min-width:210px">
                                <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
                                    <span class="tw-font-mono tw-font-bold tw-text-sm">@rg.RouteCode</span>
                                    <span class="tw-text-xs tw-px-1.5 tw-py-0.5 tw-rounded-full @(rg.IsActive ? "tw-bg-emerald-200 tw-text-emerald-800" : "tw-bg-slate-200 tw-text-slate-600")">
                                        @(rg.IsActive ? "Active" : "Inactive")
                                    </span>
                                </div>
                                <!-- S10 breakdown -->
                                <div class="tw-text-xs tw-font-semibold tw-text-slate-500 tw-mb-1">S10 (hr_cash_consignments)</div>
                                <div class="tw-grid tw-grid-cols-2 tw-gap-1 tw-text-xs tw-mb-2">
                                    <div class="tw-bg-white/60 tw-rounded-lg tw-px-2 tw-py-1">
                                        <div class="tw-text-slate-400">CASH CNs</div>
                                        <div class="tw-font-bold tw-text-blue-700">@s10Cash</div>
                                    </div>
                                    <div class="tw-bg-white/60 tw-rounded-lg tw-px-2 tw-py-1">
                                        <div class="tw-text-slate-400">Retail COD</div>
                                        <div class="tw-font-bold tw-text-orange-600">@s10Rcod</div>
                                        <div class="tw-text-slate-400 tw-text-xs" style="font-size:10px">S6 mein nahi</div>
                                    </div>
                                    <div class="tw-bg-white/60 tw-rounded-lg tw-px-2 tw-py-1">
                                        <div class="tw-text-slate-400">Billed Amt</div>
                                        <div class="tw-font-bold tw-text-slate-700">@FmtI(rg.BilledTotal)</div>
                                    </div>
                                    <div class="tw-bg-white/60 tw-rounded-lg tw-px-2 tw-py-1">
                                        <div class="tw-text-slate-400">Commission</div>
                                        <div class="tw-font-bold tw-text-emerald-600">@FmtI(rg.CommTotal)</div>
                                    </div>
                                </div>
                                <!-- S6 comparison -->
                                @if (s6Count >= 0)
                                {
                                    <div class="tw-text-xs tw-font-semibold tw-text-slate-500 tw-mb-1">S6 (billing_details — CASH only)</div>
                                    <div class="tw-flex tw-items-center tw-gap-2 tw-text-xs">
                                        <span class="tw-bg-white/70 tw-rounded-lg tw-px-2 tw-py-1">
                                            <span class="tw-text-slate-400">CNs: </span>
                                            <span class="tw-font-bold tw-text-blue-700">@s6Count</span>
                                        </span>
                                        @if (cashDiff != 0)
                                        {
                                            var diffColor = cashDiff > 0 ? "tw-text-amber-600 tw-bg-amber-50" : "tw-text-red-600 tw-bg-red-50";
                                            <span class="tw-rounded-lg tw-px-2 tw-py-1 @diffColor tw-font-bold">
                                                @(cashDiff > 0 ? "+" : "")@cashDiff vs S6
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="tw-text-emerald-600 tw-font-bold"><i class="fas fa-check-circle tw-mr-1"></i>Match</span>
                                        }
                                    </div>
                                }
                                else if (!Model.S6Connected)
                                {
                                    <div class="tw-text-xs tw-text-slate-400 tw-italic">S6 unavailable</div>
                                }
                            </div>
                        }
                    </div>
                    @if (Model.CashOnlyCount > 0 || Model.RetailCodCount > 0)
                    {
                        <div class="tw-mt-2 tw-p-2 tw-bg-blue-50 tw-border tw-border-blue-200 tw-rounded-xl tw-text-xs tw-text-blue-700">
                            <i class="fas fa-info-circle tw-mr-1 tw-text-blue-500"></i>
                            <strong>S6 vs S10 Farq kyun?</strong>
                            S10 mein <strong>@Model.RetailCodCount Retail COD CNs</strong> extra hain —
                            yeh by design hain: S6 billing_details sirf CASH type track karta hai, Retail COD nahi.
                            S10 CASH count (@Model.CashOnlyCount) ≈ S6 total (@Model.S6TotalBillingCns) — minor difference = S6 par jo CNs hain lekin S10 process mein nahi aaye.
                        </div>
                    }
                </div>

                <!-- Route code filter buttons -->
                @if (cashByRoute.Count > 1)
                {
                    <div class="tw-mx-4 tw-mb-2 tw-flex tw-flex-wrap tw-items-center tw-gap-1.5">
                        <span class="tw-text-xs tw-text-slate-400 tw-mr-1">Filter:</span>
                        <button onclick="filterCashCns('ALL')" id="cash-filter-ALL"
                                class="cash-filter-btn tw-text-xs tw-font-bold tw-px-3 tw-py-1 tw-rounded-lg tw-border tw-transition tw-bg-violet-600 tw-text-white tw-border-violet-700">
                            All (@Model.TotalCashCns)
                        </button>
                        @foreach (var rg in cashByRoute)
                        {
                            var isAct = rg.IsActive;
                            <button onclick="filterCashCns('@rg.RouteCode')" id="cash-filter-@rg.RouteCode"
                                    class="cash-filter-btn tw-text-xs tw-font-semibold tw-px-3 tw-py-1 tw-rounded-lg tw-border tw-transition tw-bg-white tw-border-slate-300 tw-text-slate-600 hover:tw-border-violet-400">
                                @rg.RouteCode
                                <span class="tw-ml-1 @(isAct ? "tw-text-emerald-600" : "tw-text-slate-400")">(@rg.CnCount)</span>
                                @if (isAct) { <span class="tw-text-emerald-500 tw-ml-0.5">●</span> }
                            </button>
                        }
                    </div>
                }

                <!-- Explanation banner -->
                <div class="tw-mx-4 tw-mb-1 tw-p-3 tw-bg-blue-50 tw-border tw-border-blue-200 tw-rounded-xl tw-text-xs tw-text-blue-700">
                    <i class="fas fa-info-circle tw-mr-1 tw-text-blue-500"></i>
                    <strong>Total Rs @FmtI(Model.CashTotal) Commission Amount hai</strong> — yeh <code>hr_cash_consignments.TotalCommission</code> column ka sum hai jo per-CN commission amount store karta hai.
                    Agar Final Commission (Grand Total) kam hai, toh wajah: (1) Sirf processed commission Final mein jaati hai — kuch CNs reprocess se pehle zero hote hain.
                    (2) Deductions (Retail_Deduction, COD_Deduction) Final se minus hote hain.
                    (3) Inactive route codes ke CNs Cash tab mein show hote hain lekin Final mein sirf active period ka hota hai.
                    (4) CASH aur Retail COD dono par commission hoti hai — donon yahan hain.
                </div>
                <div class="tw-overflow-x-auto">
                    <table class="tw-w-full tw-text-xs" id="cash-cns-table">
                        <thead class="tw-bg-slate-50 tw-border-b tw-border-slate-200">
                            <tr>
                                <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">CN #</th>
                                <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">Billing Date</th>
                                <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">Category</th>
                                <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">Shipment Type</th>
                                <th class="tw-px-3 tw-py-2 tw-text-right tw-font-bold tw-text-slate-500">Billed Amt</th>
                                <th class="tw-px-3 tw-py-2 tw-text-right tw-font-bold tw-text-slate-500">Commission</th>
                                <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">Route</th>
                            </tr>
                        </thead>
                        <tbody class="tw-divide-y tw-divide-slate-100">
                            @foreach (var cn in Model.CashCns)
                            {
                                var catLabel = cn.BillingCategory ?? "CASH";
                                var isCash   = catLabel.Equals("CASH", StringComparison.OrdinalIgnoreCase);
                                var catClass = isCash
                                    ? "tw-bg-emerald-100 tw-text-emerald-700 tw-border tw-border-emerald-200"
                                    : "tw-bg-blue-100 tw-text-blue-700 tw-border tw-border-blue-200";
                                var rcIsActive = Model.RouteCodes.Any(r => r.RouteCode == cn.RouteCode && r.ToDate == null);
                                <tr class="@(isCash ? "" : "tw-bg-blue-50/20") hover:tw-bg-slate-50 cash-cn-row"
                                    data-route="@cn.RouteCode">
                                    <td class="tw-px-3 tw-py-2 tw-font-mono tw-text-violet-700 tw-font-bold">@cn.CnNumber</td>
                                    <td class="tw-px-3 tw-py-2 tw-text-slate-600">@(cn.BillingDate?.ToString("dd MMM yy") ?? "—")</td>
                                    <td class="tw-px-3 tw-py-2">
                                        <span class="tw-rounded tw-px-2 tw-py-0.5 tw-text-xs tw-font-bold @catClass">@catLabel</span>
                                    </td>
                                    <td class="tw-px-3 tw-py-2">
                                        <span class="tw-bg-slate-100 tw-text-slate-600 tw-rounded tw-px-1.5 tw-py-0.5">
                                            @(cn.ShipmentLabel ?? cn.ShipmentTypeId?.ToString() ?? "—")
                                        </span>
                                    </td>
                                    <td class="tw-px-3 tw-py-2 tw-text-right tw-font-mono">@Fmt(cn.BilledAmount)</td>
                                    <td class="tw-px-3 tw-py-2 tw-text-right tw-font-mono tw-font-bold tw-text-emerald-600">@Fmt(cn.CommissionAmount)</td>
                                    <td class="tw-px-3 tw-py-2 tw-font-mono">
                                        <span class="@(rcIsActive ? "tw-text-emerald-600 tw-font-bold" : "tw-text-slate-400")">@cn.RouteCode</span>
                                        @if (!rcIsActive) { <span class="tw-text-slate-300 tw-text-xs tw-ml-0.5">(old)</span> }
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="tw-bg-slate-50 tw-border-t-2 tw-border-slate-300" id="cash-footer-all">
                                <td colspan="5" class="tw-px-3 tw-py-2 tw-font-bold tw-text-slate-700 tw-text-right">Cash Commission Total:</td>
                                <td class="tw-px-3 tw-py-2 tw-text-right tw-font-bold tw-text-emerald-600">Rs @FmtI(Model.CashTotal)</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════════════
         TAB 3: COD CNs
    ════════════════════════════════════════════════════════════════════ -->
    <div id="tab-cod" class="tab-content tw-hidden">
        <div class="tw-grid tw-grid-cols-1 lg:tw-grid-cols-3 tw-gap-4">

            <!-- COD CN list -->
            <div class="tw-bg-white tw-rounded-2xl tw-border tw-border-slate-200 tw-shadow-sm lg:tw-col-span-2">
                <div class="tw-p-4 tw-border-b tw-border-slate-100 tw-flex tw-items-center tw-justify-between">
                    <div class="tw-flex tw-items-center tw-gap-2">
                        <i class="fas fa-hand-holding-usd tw-text-blue-500"></i>
                        <span class="tw-text-sm tw-font-bold tw-text-slate-700">COD Commission CNs</span>
                    </div>
                    <span class="tw-text-sm tw-font-bold tw-text-blue-600">Total: Rs @FmtI(Model.CodTotal)</span>
                </div>
                @if (!string.IsNullOrEmpty(Model.NoCnReason))
                {
                    <div class="tw-p-4 tw-bg-amber-50 tw-border tw-border-amber-200 tw-rounded-xl tw-mx-4 tw-my-3">
                        <div class="tw-flex tw-items-start tw-gap-3">
                            <i class="fas fa-exclamation-triangle tw-text-amber-500 tw-mt-0.5 tw-flex-shrink-0"></i>
                            <div class="tw-text-xs tw-text-amber-700">
                                <strong>COD CN data bhi nahi mila — Route Code Required.</strong> hr_cod_consignments bhi cour_id se query hoti hai, Emp_No se nahi.
                            </div>
                        </div>
                    </div>
                }
                else @if (Model.CodCns.Count == 0)
                {
                    <div class="tw-p-6 tw-text-center tw-text-slate-400 tw-text-sm">
                        <i class="fas fa-inbox tw-text-2xl tw-mb-2 tw-block"></i>
                        Koi COD CN nahi mila.
                    </div>
                }
                else
                {
                    <div class="tw-overflow-x-auto">
                        <table class="tw-w-full tw-text-xs">
                            <thead class="tw-bg-slate-50 tw-border-b tw-border-slate-200">
                                <tr>
                                    <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">CN #</th>
                                    <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">COUR Date</th>
                                    <th class="tw-px-3 tw-py-2 tw-text-left tw-font-bold tw-text-slate-500">Delivery</th>
