@model IEnumerable<LCS_HR_MVC.Models.TaxHeadModel>
@{
    ViewData["PageTitle"] = "Tax Slab Registry";
}

@section Styles {
    <style>
        /* Modern Fade Animation */
        @@keyframes slideUp { 
            from { opacity: 0; transform: translateY(15px); } 
            to { opacity: 1; transform: translateY(0); } 
        }
        .animate-main { animation: slideUp 0.4s ease-out; }

        /* DataTable Overrides - Modern & Balanced */
        .dataTables_wrapper .dataTables_filter {
            @@apply tw-relative tw-mb-5;
        }
        .dataTables_wrapper .dataTables_filter label {
            @@apply tw-w-full sm:tw-w-auto;
        }
        .dataTables_wrapper .dataTables_filter input {
            @@apply tw-w-full sm:tw-w-[300px] tw-border-2 tw-border-slate-100 tw-rounded-2xl tw-px-5 tw-py-2.5 tw-text-sm tw-outline-none tw-transition-all tw-bg-slate-50 focus:tw-bg-white tw-text-slate-700 tw-shadow-inner tw-font-medium;
        }
        .dataTables_wrapper .dataTables_filter input:focus { 
            @@apply tw-border-amber-400 tw-ring-4 tw-ring-amber-400/20 tw-shadow-lg; 
        }
        
        table.dataTable {
            @@apply tw-border-collapse;
        }
        table.dataTable thead th {
            @@apply tw-bg-slate-50 tw-text-slate-400 tw-font-black tw-uppercase tw-text-[10px] tw-tracking-[0.15em] tw-py-4 tw-px-5 tw-border-b-2 tw-border-slate-100 !important;
        }
        
        table.dataTable tbody tr {
            @@apply tw-border-b tw-border-slate-50 tw-transition-colors hover:tw-bg-amber-50/30;
        }
        table.dataTable tbody td {
            @@apply tw-py-4 tw-px-5 tw-align-middle;
        }
        
        .dataTables_info {
            @@apply tw-text-xs tw-font-semibold tw-text-slate-500 tw-mt-5;
        }
        
        /* Modern Pagination */
        .dataTables_wrapper .dataTables_paginate {
            @@apply tw-flex tw-items-center tw-gap-1 tw-mt-5;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button {
            @@apply tw-min-w-[32px] tw-h-8 tw-flex tw-items-center tw-justify-center tw-rounded-lg tw-text-xs tw-font-bold tw-text-slate-500 tw-border tw-border-slate-200 tw-bg-white tw-cursor-pointer tw-transition-all !important;
            padding: 0 0.5rem !important;
            margin: 0 !important;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
            @@apply tw-bg-slate-100 tw-text-slate-800 tw-border-slate-300 !important;
            background: none !important;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button.current,
        .dataTables_wrapper .dataTables_paginate .paginate_button.current:hover {
            @@apply tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-text-slate-900 tw-border-transparent tw-shadow-md tw-cursor-default !important;
            background: none !important;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button.disabled {
            @@apply tw-opacity-50 tw-cursor-not-allowed hover:tw-bg-white hover:tw-text-slate-500 hover:tw-border-slate-200 !important;
        }

        /* Detail Scrollbar */
        .custom-scrollbar::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: #f1f5f9;
            border-radius: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
    </style>
}

<div class="tw-p-4 sm:tw-p-6 tw-bg-transparent tw-min-h-screen animate-main">

    <!-- Messages -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-red-50 tw-border tw-border-red-100 tw-rounded-xl tw-text-red-600 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(239,68,68,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-red-100 tw-text-red-500 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0">
                <i class="fas fa-exclamation-triangle tw-text-[10px]"></i>
            </div>
            <span class="tw-pt-0.5">@TempData["ErrorMessage"]</span>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-emerald-50 tw-border tw-border-emerald-100 tw-rounded-xl tw-text-emerald-700 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(16,185,129,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-emerald-100 tw-text-emerald-600 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0">
                <i class="fas fa-check tw-text-[10px]"></i>
            </div>
            <span class="tw-pt-0.5">@TempData["SuccessMessage"]</span>
        </div>
    }

    <div class="tw-flex tw-flex-col sm:tw-flex-row sm:tw-items-end tw-justify-between tw-gap-4 tw-mb-8">
        <div>
            <nav class="tw-flex tw-items-center tw-gap-2.5 tw-text-[11px] tw-font-bold tw-text-slate-400 tw-mb-2 tw-uppercase tw-tracking-widest">
                <div class="tw-flex tw-items-center tw-gap-1.5 hover:tw-text-[#eab308] tw-transition-colors tw-cursor-pointer">
                    <i class="fas fa-cogs tw-text-[10px] tw-text-slate-300"></i>
                    <span>Setup</span>
                </div>
                <i class="fas fa-chevron-right tw-text-[8px] tw-text-slate-300"></i> 
                <span class="tw-text-slate-600 tw-bg-white tw-px-2 tw-py-0.5 tw-rounded-md tw-border tw-border-slate-200 tw-shadow-sm">Payroll Operations</span>
            </nav>
            <div class="tw-flex tw-flex-col">
                <h1 class="tw-text-3xl tw-font-black tw-text-slate-900 tw-leading-tight tw-tracking-tight">Tax Slab Registry</h1>
                <div class="tw-h-1.5 tw-w-10 tw-bg-gradient-to-r tw-from-[#f5c518] tw-to-transparent tw-rounded-full tw-mt-1"></div>
            </div>
            <p class="tw-text-slate-500 tw-text-sm tw-font-medium tw-mt-3 tw-leading-relaxed">Browse historical and active fiscal year taxation matrices applied to payroll.</p>
        </div>
    </div>

    <div class="tw-grid xl:tw-grid-cols-[1fr_0.8fr] tw-gap-6 xl:tw-gap-8 align-top">
        
        <!-- Left Side: Data Table -->
        <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-relative tw-h-full">
            <div class="tw-absolute tw-top-0 tw-right-0 tw-w-64 tw-h-64 tw-bg-gradient-to-bl tw-from-amber-50/50 tw-to-transparent tw-rounded-bl-full tw-pointer-events-none z-0"></div>

            <div class="tw-relative tw-z-10 tw-px-6 tw-py-5 tw-border-b tw-border-slate-100 tw-flex tw-items-center tw-gap-4 tw-bg-slate-50/80">
                <div class="tw-w-10 tw-h-10 tw-rounded-xl tw-bg-gradient-to-br tw-from-slate-900 tw-to-slate-800 tw-flex tw-items-center tw-justify-center tw-shadow-[0_4px_10px_rgba(15,23,42,0.3)]">
                    <i class="fas fa-landmark tw-text-amber-400 tw-text-lg"></i>
                </div>
                <div>
                    <h2 class="tw-font-black tw-text-base tw-text-slate-800 tw-tracking-tight">System Records</h2>
                    <p class="tw-text-[10px] tw-font-bold tw-text-slate-400 tw-uppercase tw-tracking-widest">Active Fiscal Slabs</p>
                </div>
            </div>

            <div class="tw-relative tw-z-10 tw-p-6">
                <div class="tw-overflow-x-auto custom-scrollbar">
                    <table id="dg1" class="tw-w-full dataTable tw-text-xs">
                        <thead>
                            <tr>
                                <th class="tw-w-20 tw-text-center">Code</th>
                                <th>Fiscal Year Node</th>
                                <th>Operational Lifecycle</th>
                                <th class="tw-text-right tw-pr-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="tw-divide-y tw-divide-slate-100">
                            @foreach (var tax in Model)
                            {
                                <tr class="hover:tw-bg-slate-50 tw-transition-colors group tw-text-sm">
                                    <td class="tw-py-4 tw-text-center">
                                        <span class="tw-px-2.5 tw-py-1 tw-bg-slate-100 group-hover:tw-bg-white tw-border tw-border-slate-200 tw-rounded-lg tw-font-mono tw-font-black tw-text-slate-600 tw-shadow-sm tw-transition-colors">@tax.Code</span>
                                    </td>
                                    <td class="tw-py-4">
                                        <div class="tw-font-black tw-text-slate-800 group-hover:tw-text-amber-500 tw-transition-colors tw-flex tw-items-center tw-gap-2">
                                            <i class="fas fa-calendar-alt tw-text-slate-300"></i>
                                            FY-@tax.TaxYear
                                        </div>
                                    </td>
                                    <td class="tw-py-4">
                                         <div class="tw-flex tw-items-center tw-gap-2">
                                            <div class="tw-flex tw-items-center tw-gap-1.5 tw-bg-emerald-50 tw-border tw-border-emerald-100 tw-px-2 tw-py-0.5 tw-rounded-md">
                                                <i class="far fa-calendar-check tw-text-emerald-500 tw-text-[10px]"></i>
                                                <span class="tw-font-mono tw-font-bold tw-text-emerald-700 tw-text-[10px]">@(tax.DateFrom?.ToString("dd MMM yy") ?? "N/A")</span>
                                            </div>
                                            <i class="fas fa-arrow-right tw-text-[10px] tw-text-slate-300"></i>
                                            <div class="tw-flex tw-items-center tw-gap-1.5 tw-bg-red-50 tw-border tw-border-red-100 tw-px-2 tw-py-0.5 tw-rounded-md">
                                                <i class="far fa-calendar-times tw-text-red-500 tw-text-[10px]"></i>
                                                <span class="tw-font-mono tw-font-bold tw-text-red-700 tw-text-[10px]">@(tax.DateTo?.ToString("dd MMM yy") ?? "N/A")</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="tw-py-4 tw-text-right tw-pr-4">
                                        <a href="@Url.Action("TaxDetailEntry", "Setup", new { code = tax.Code })" 
                                           class="tw-inline-flex tw-items-center tw-justify-center tw-w-8 tw-h-8 tw-rounded-lg tw-bg-slate-50 tw-border tw-border-slate-200 tw-text-slate-400 hover:tw-bg-amber-400 hover:tw-border-amber-400 hover:tw-text-slate-900 tw-shadow-sm hover:tw-shadow-md hover:tw--translate-y-0.5 tw-transition-all"
                                           title="Inspect Tax Matrix">
                                            <i class="fas fa-edit tw-text-[11px]"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Right Side: Create/Brief Form -->
        <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-sticky tw-top-24 tw-relative tw-h-fit">
            <div class="tw-absolute tw-top-[-50px] tw-right-[-50px] tw-w-40 tw-h-40 tw-bg-emerald-100/40 tw-blur-2xl tw-rounded-full tw-pointer-events-none"></div>

            <div class="tw-p-6 tw-bg-gradient-to-r tw-from-emerald-600 tw-to-emerald-500 tw-relative tw-z-10">
                <h3 class="tw-text-white tw-font-black tw-text-xs tw-uppercase tw-tracking-[0.2em] tw-flex tw-items-center tw-gap-2">
                    <div class="tw-w-6 tw-h-6 tw-bg-black/10 tw-rounded-md tw-flex tw-items-center tw-justify-center">
                        <i class="fas fa-plus"></i>
                    </div>
                    New Tax Node
                </h3>
            </div>

            <form asp-controller="Setup" asp-action="TaxDetailEntry" method="get" class="tw-p-7 tw-space-y-5 tw-relative tw-z-10">
                
                <div>
                     <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Action Protocol</label>
                     <p class="tw-text-xs tw-text-slate-500 tw-font-medium tw-leading-relaxed">To create or modify a tax matrix, initiate a session. You will be redirected to the Slab Designer for granular boundary configuration.</p>
                </div>

                <div class="tw-border-t tw-border-slate-100 tw-pt-2"></div>

                <div>
                    <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Fiscal Target Year</label>
                    <div class="tw-relative">
                        <i class="far fa-calendar-alt tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-emerald-500 tw-text-sm"></i>
                        <input type="text" name="taxYear" placeholder="e.g. 2024" 
                               class="tw-w-full tw-pl-10 tw-pr-3 tw-py-3 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm" />
                    </div>
                </div>

                <div class="tw-space-y-3 tw-pt-2">
                    <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                        <button type="submit" class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-text-slate-900 tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase tw-shadow-[0_8px_20px_rgba(245,197,24,0.25)] hover:tw-shadow-[0_8px_25px_rgba(245,197,24,0.35)] hover:tw--translate-y-0.5 tw-transition-all">
                            <i class="fas fa-plus-circle tw-text-sm"></i> Initialize
                        </button>
                        <button type="button" class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-slate-900 tw-text-white tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase hover:tw-bg-slate-800 hover:tw--translate-y-0.5 tw-transition-all">
                            <i class="fas fa-search tw-text-sm"></i> Analyze
                        </button>
                    </div>
                    <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                        <button type="button" disabled class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-bg-white tw-text-red-500 tw-border tw-border-red-100 tw-shadow-sm tw-rounded-xl tw-font-extrabold tw-text-[11px] tw-tracking-wider tw-uppercase tw-opacity-40 tw-cursor-not-allowed">
                            <i class="fas fa-trash-alt"></i> Revoke
                        </button>
                        <button type="reset" class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-bg-white tw-text-slate-600 tw-border tw-border-slate-200 tw-shadow-sm tw-rounded-xl tw-font-extrabold tw-text-[11px] tw-tracking-wider tw-uppercase hover:tw-bg-slate-50 hover:tw-text-slate-900 tw-transition-all">
                            <i class="fas fa-undo-alt tw-opacity-60"></i> Clear
                        </button>
                    </div>
                </div>

            </form>
        </div>
    </div>
</div>

</div>

@section Scripts {
    <script type="text/javascript">
        $(document).ready(function () {
            if ($.fn.DataTable) {
                $('#dg1').DataTable({
                    "pageLength": 16,
                    "lengthChange": false,
                    "dom": '<"tw-flex tw-flex-col sm:tw-flex-row tw-justify-between tw-items-center tw-mb-2"f>rt<"tw-flex tw-flex-col sm:tw-flex-row tw-justify-between tw-items-center"ip>',
                    "language": { 
                        "search": "", 
                        "searchPlaceholder": "Search Tax Matrices...",
                        "paginate": {
                            "previous": "<i class='fas fa-chevron-left tw-text-[10px]'></i>",
                            "next": "<i class='fas fa-chevron-right tw-text-[10px]'></i>"
                        }
                    }
                });

                // Add search icon inside datatable filter
                $('.dataTables_filter label').addClass('tw-relative tw-block tw-w-full');
                $('.dataTables_filter input').addClass('tw-pl-10');
                $('.dataTables_filter label').append('<i class="fas fa-search tw-absolute tw-left-4 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400"></i>');
            }
        });
    </script>
}
