@model LCS_HR_MVC.Models.TaxHeadModel
@{
    ViewData["PageTitle"] = "Tax Slab Configuration";
}

@section Styles {
    <style>
        /* Modern Fade Animation */
        @@keyframes slideUp { 
            from { opacity: 0; transform: translateY(15px); } 
            to { opacity: 1; transform: translateY(0); } 
        }
        .animate-main { animation: slideUp 0.4s ease-out; }

        /* Detail Scrollbar */
        .custom-scrollbar::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: #f1f5f9;
            border-radius: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
    </style>
}

<div class="tw-p-4 sm:tw-p-6 tw-bg-transparent tw-min-h-screen animate-main">

    <!-- Messages -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-red-50 tw-border tw-border-red-100 tw-rounded-xl tw-text-red-600 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(239,68,68,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-red-100 tw-text-red-500 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0">
                <i class="fas fa-exclamation-triangle tw-text-[10px]"></i>
            </div>
            <span class="tw-pt-0.5">@TempData["ErrorMessage"]</span>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-emerald-50 tw-border tw-border-emerald-100 tw-rounded-xl tw-text-emerald-700 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(16,185,129,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-emerald-100 tw-text-emerald-600 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0">
                <i class="fas fa-check tw-text-[10px]"></i>
            </div>
            <span class="tw-pt-0.5">@TempData["SuccessMessage"]</span>
        </div>
    }

    <div class="tw-flex tw-flex-col sm:tw-flex-row sm:tw-items-end tw-justify-between tw-gap-4 tw-mb-8">
        <div>
            <nav class="tw-flex tw-items-center tw-gap-2.5 tw-text-[11px] tw-font-bold tw-text-slate-400 tw-mb-2 tw-uppercase tw-tracking-widest">
                <div class="tw-flex tw-items-center tw-gap-1.5 hover:tw-text-[#eab308] tw-transition-colors tw-cursor-pointer">
                    <i class="fas fa-cogs tw-text-[10px] tw-text-slate-300"></i>
                    <span>Setup</span>
                </div>
                <i class="fas fa-chevron-right tw-text-[8px] tw-text-slate-300"></i> 
                <span class="tw-text-slate-600 tw-bg-white tw-px-2 tw-py-0.5 tw-rounded-md tw-border tw-border-slate-200 tw-shadow-sm">Payroll Operations</span>
            </nav>
            <div class="tw-flex tw-flex-col">
                <h1 class="tw-text-3xl tw-font-black tw-text-slate-900 tw-leading-tight tw-tracking-tight">Tax Slab Designer</h1>
                <div class="tw-h-1.5 tw-w-10 tw-bg-gradient-to-r tw-from-[#f5c518] tw-to-transparent tw-rounded-full tw-mt-1"></div>
            </div>
            <p class="tw-text-slate-500 tw-text-sm tw-font-medium tw-mt-3 tw-leading-relaxed">Define annual tax structures and their hierarchical deduction matrices.</p>
        </div>
        
        <div>
             <a asp-action="Taxes" class="tw-inline-flex tw-items-center tw-justify-center tw-gap-2 tw-py-2.5 tw-px-6 tw-bg-white tw-text-slate-600 tw-border tw-border-slate-200 tw-shadow-sm tw-rounded-xl tw-font-bold tw-text-xs tw-tracking-wide tw-uppercase hover:tw-bg-slate-50 hover:tw-text-slate-900 tw-transition-all">
                <i class="fas fa-arrow-left"></i> Return to Registry
            </a>
        </div>
    </div>


    <form asp-controller="Setup" asp-action="TaxDetailEntry" method="post" id="taxForm" class="tw-grid xl:tw-grid-cols-[1fr_0.8fr] tw-gap-6 xl:tw-gap-8 align-top">
        
        <!-- Left Side: Slab Matrix Table -->
        <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-relative">
            <div class="tw-absolute tw-top-0 tw-right-0 tw-w-64 tw-h-64 tw-bg-gradient-to-bl tw-from-amber-50/50 tw-to-transparent tw-rounded-bl-full tw-pointer-events-none z-0"></div>

            <div class="tw-px-6 tw-py-5 tw-border-b tw-border-slate-100 tw-flex tw-items-center tw-justify-between tw-bg-slate-50/80 tw-relative tw-z-10">
                <div class="tw-flex tw-items-center tw-gap-3">
                    <div class="tw-w-10 tw-h-10 tw-rounded-xl tw-bg-gradient-to-br tw-from-slate-900 tw-to-slate-800 tw-flex tw-items-center tw-justify-center tw-shadow-[0_4px_10px_rgba(15,23,42,0.3)]">
                        <i class="fas fa-layer-group tw-text-amber-400 tw-text-lg"></i>
                    </div>
                    <div>
                        <h2 class="tw-font-black tw-text-base tw-text-slate-800 tw-tracking-tight">Slab Matrix Editor</h2>
                        <p class="tw-text-[10px] tw-font-bold tw-text-slate-400 tw-uppercase tw-tracking-widest">Boundary Tiers</p>
                    </div>
                </div>
                <button type="button" id="btnAddRow" class="tw-inline-flex tw-items-center tw-justify-center tw-gap-2 tw-py-2 tw-px-4 tw-bg-slate-900 tw-text-amber-400 tw-rounded-lg tw-font-bold tw-text-[10px] tw-tracking-wider tw-uppercase hover:tw-bg-slate-800 tw-transition-colors">
                    <i class="fas fa-plus"></i> Add Scale Node
                </button>
            </div>

            <div class="tw-relative tw-z-10 tw-p-6">
                <div class="tw-overflow-x-auto custom-scrollbar">
                    <table class="tw-w-full tw-text-left tw-whitespace-nowrap">
                        <thead class="tw-bg-slate-50">
                            <tr>
                                <th class="tw-py-3 tw-px-4 tw-text-[10px] tw-font-black tw-text-slate-400 tw-uppercase tw-tracking-widest tw-w-10 tw-text-center">Del</th>
                                <th class="tw-py-3 tw-px-4 tw-text-[10px] tw-font-black tw-text-slate-400 tw-uppercase tw-tracking-widest">Min Earned Boundary</th>
                                <th class="tw-py-3 tw-px-4 tw-text-[10px] tw-font-black tw-text-slate-400 tw-uppercase tw-tracking-widest">Max Earned Boundary</th>
                                <th class="tw-py-3 tw-px-4 tw-text-[10px] tw-font-black tw-text-slate-400 tw-uppercase tw-tracking-widest">Rate %</th>
                                <th class="tw-py-3 tw-px-4 tw-text-[10px] tw-font-black tw-text-slate-400 tw-uppercase tw-tracking-widest">Fixed Factor</th>
                            </tr>
                        </thead>
                        <tbody id="detailGridBody" class="tw-divide-y tw-divide-slate-50 tw-bg-white">
                            @for (int i = 0; i < Model.Details.Count; i++)
                            {
                                <tr class="hover:tw-bg-amber-50/20 tw-transition-colors group" data-index="@i">
                                    <td class="tw-py-3 tw-px-4 tw-text-center tw-align-top tw-pt-4">
                                        <button type="button" class="tw-w-7 tw-h-7 tw-rounded-lg tw-bg-red-50 tw-text-red-500 hover:tw-bg-red-500 hover:tw-text-white tw-transition-colors tw-inline-flex tw-items-center tw-justify-center" onclick="removeRow(this)" title="Remove Node"><i class="fas fa-times tw-text-xs"></i></button>
                                    </td>
                                    <td class="tw-py-3 tw-px-4 tw-align-top">
                                        <div class="tw-relative">
                                            <span class="tw-absolute tw-left-3 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs tw-font-bold">$</span>
                                            <input type="number" step="0.01" asp-for="Details[i].LimitFrom" value="@Model.Details[i].LimitFrom"
                                               class="tw-w-full tw-pl-7 tw-pr-3 tw-py-2 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-lg tw-text-xs tw-font-mono tw-font-bold tw-text-slate-800 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-transition-all" />
                                        </div>
                                    </td>
                                    <td class="tw-py-3 tw-px-4 tw-align-top">
                                        <div class="tw-relative">
                                            <span class="tw-absolute tw-left-3 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs tw-font-bold">$</span>
                                            <input type="number" step="0.01" asp-for="Details[i].LimitTo" value="@Model.Details[i].LimitTo"
                                               class="tw-w-full tw-pl-7 tw-pr-3 tw-py-2 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-lg tw-text-xs tw-font-mono tw-font-bold tw-text-slate-800 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-transition-all" />
                                        </div>
                                    </td>
                                    <td class="tw-py-3 tw-px-4 tw-align-top">
                                        <div class="tw-relative">
                                            <span class="tw-absolute tw-right-3 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-[10px]"><i class="fas fa-percent"></i></span>
                                            <input type="number" step="0.01" asp-for="Details[i].PctAmount" value="@Model.Details[i].PctAmount"
                                               class="tw-w-full tw-pl-3 tw-pr-8 tw-py-2 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-lg tw-text-xs tw-font-mono tw-font-bold tw-text-indigo-600 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-transition-all" />
                                        </div>
                                    </td>
                                    <td class="tw-py-3 tw-px-4 tw-align-top">
                                        <div class="tw-relative">
                                            <span class="tw-absolute tw-left-3 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-[10px] tw-font-bold"><i class="fas fa-plus"></i></span>
                                            <input type="number" step="0.01" asp-for="Details[i].FixAmount" value="@Model.Details[i].FixAmount"
                                                class="tw-w-full tw-pl-8 tw-pr-3 tw-py-2 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-lg tw-text-xs tw-font-mono tw-font-bold tw-text-slate-800 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-transition-all" />
                                        </div>
                                        <input type="hidden" asp-for="Details[i].Comments" value="@Model.Details[i].Comments" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Right Side: Metadata Form -->
        <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-sticky tw-top-24 tw-relative">
            <div class="tw-absolute tw-top-[-50px] tw-right-[-50px] tw-w-40 tw-h-40 tw-bg-amber-100/40 tw-blur-2xl tw-rounded-full tw-pointer-events-none"></div>

            <div class="tw-p-6 tw-bg-gradient-to-r tw-from-slate-900 tw-to-slate-800 tw-relative tw-z-10">
                <h3 class="tw-text-amber-400 tw-font-black tw-text-xs tw-uppercase tw-tracking-[0.2em] tw-flex tw-items-center tw-gap-2">
                    <div class="tw-w-6 tw-h-6 tw-bg-white/10 tw-rounded-md tw-flex tw-items-center tw-justify-center">
                        <i class="fas fa-file-invoice-dollar"></i>
                    </div>
                    Base Metadata
                </h3>
            </div>

            <div class="tw-p-7 tw-space-y-5 tw-relative tw-z-10">
                
                <!-- Code Banner -->
                <div>
                     <label class="tw-block tw-text-[10px] tw-font-black tw-text-slate-400 tw-uppercase tw-tracking-widest tw-mb-1.5">Tax Node Token</label>
                     <div class="tw-flex tw-items-center tw-bg-slate-50 tw-rounded-xl tw-px-3 tw-py-2.5 tw-border tw-border-slate-200 tw-shadow-inner opacity-80">
                         <i class="fas fa-fingerprint tw-text-slate-400 tw-mr-1.5 tw-text-[10px]"></i>
                         <input type="text" value="@Model.Code" disabled class="tw-bg-transparent tw-w-full tw-text-sm tw-font-mono tw-font-bold tw-text-slate-600 tw-outline-none" />
                         <input type="hidden" asp-for="Code" id="Code" />
                     </div>
                </div>

                <!-- Fiscal Year -->
                <div>
                    <label asp-for="TaxYear" class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Fiscal Target Year <span class="tw-text-red-500">*</span></label>
                    <div class="tw-relative">
                        <i class="far fa-calendar-alt tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-amber-500 tw-text-sm"></i>
                        <input type="text" asp-for="TaxYear" id="TaxYear" maxlength="4" placeholder="YYYY" 
                               class="tw-w-full tw-pl-10 tw-pr-3 tw-py-3 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm" />
                    </div>
                    <span asp-validation-for="TaxYear" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                </div>

                <!-- Date Boundaries -->
                <div class="tw-grid tw-grid-cols-2 tw-gap-4 tw-bg-slate-50 tw-p-4 tw-rounded-xl tw-border tw-border-slate-200">
                    <div>
                        <label class="tw-block tw-text-[10px] tw-font-black tw-text-slate-500 tw-uppercase tw-tracking-wide tw-mb-1.5">FY Start</label>
                        <input type="date" asp-for="DateFrom" id="DateFrom" readonly class="tw-w-full tw-px-3 tw-py-2 tw-bg-emerald-50 tw-border tw-border-emerald-100 tw-rounded-lg tw-text-xs tw-font-bold tw-text-emerald-700 tw-outline-none tw-cursor-not-allowed" />
                    </div>
                    <div>
                        <label class="tw-block tw-text-[10px] tw-font-black tw-text-slate-500 tw-uppercase tw-tracking-wide tw-mb-1.5">FY End</label>
                        <input type="date" asp-for="DateTo" id="DateTo" readonly class="tw-w-full tw-px-3 tw-py-2 tw-bg-red-50 tw-border tw-border-red-100 tw-rounded-lg tw-text-xs tw-font-bold tw-text-red-700 tw-outline-none tw-cursor-not-allowed" />
                    </div>
                </div>

                <!-- Comments -->
                <div>
                     <label asp-for="Comments" class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Administrative Details</label>
                     <div class="tw-relative">
                        <i class="far fa-comment-alt tw-absolute tw-left-3.5 tw-top-3.5 tw-text-slate-400 tw-text-sm"></i>
                        <textarea asp-for="Comments" maxlength="45" rows="2" placeholder="Optional descriptor..." 
                                  class="tw-w-full tw-pl-10 tw-pr-3 tw-py-2.5 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-medium tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm"></textarea>
                     </div>
                     <span asp-validation-for="Comments" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                </div>

                <div class="tw-border-t tw-border-slate-100 tw-pt-2"></div>

                <!-- Action Controls (2x2 Grid) -->
                <div class="tw-space-y-3">
                    <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                        <button type="submit" name="action" value="Save" id="btnSave" @(Model.Code != "Auto Generated" ? "disabled" : "")
                                class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-text-slate-900 tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase tw-shadow-[0_8px_20px_rgba(245,197,24,0.25)] hover:tw-shadow-[0_8px_25px_rgba(245,197,24,0.35)] hover:tw--translate-y-0.5 tw-transition-all disabled:tw-opacity-50 disabled:tw-cursor-not-allowed">
                            <i class="fas fa-save tw-text-sm"></i> Construct
                        </button>
                        <button type="submit" name="action" value="Update" id="btnUpdate" @(Model.Code == "Auto Generated" ? "disabled" : "")
                                class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-slate-900 tw-text-white tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase hover:tw-bg-slate-800 hover:tw-shadow-[0_8px_20px_rgba(15,23,42,0.2)] hover:tw--translate-y-0.5 tw-transition-all disabled:tw-opacity-40 disabled:hover:tw-transform-none disabled:hover:tw-shadow-none">
                            <i class="fas fa-sync-alt tw-text-sm"></i> Publish Update
                        </button>
                    </div>
                    <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                        <button type="submit" name="action" value="Delete" id="btnDelete" @(Model.Code == "Auto Generated" ? "disabled" : "") onclick="return confirm('Are you sure you want to completely remove this fiscal structure policy?');"
                                class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-bg-white tw-text-red-500 tw-border tw-border-red-100 tw-shadow-sm tw-rounded-xl tw-font-extrabold tw-text-[11px] tw-tracking-wider tw-uppercase hover:tw-bg-red-50 hover:tw-border-red-200 tw-transition-all disabled:tw-opacity-40 disabled:tw-cursor-not-allowed">
                            <i class="fas fa-trash-alt"></i> Nullify
                        </button>
                        <button type="button" onclick="window.location.reload();"
                                class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-bg-white tw-text-slate-600 tw-border tw-border-slate-200 tw-shadow-sm tw-rounded-xl tw-font-extrabold tw-text-[11px] tw-tracking-wider tw-uppercase hover:tw-bg-slate-50 hover:tw-text-slate-900 tw-transition-all">
                            <i class="fas fa-undo-alt tw-opacity-50"></i> Deselect
                        </button>
                    </div>
                </div>

            </div>
        </div>

    </form>
</div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script type="text/javascript">
        $(document).ready(function () {
            
            // Auto calculate dates based on tax year
            $('#TaxYear').on('input change', function() {
                var year = $(this).val();
                if(year && year.length === 4 && !isNaN(year)) {
                    var y = parseInt(year);
                    // Fiscal Start: July 1st of year, End: June 30th Next year
                    var dFrom = y + "-07-01";
                    var dTo = (y + 1) + "-06-30";
                    $('#DateFrom').val(dFrom);
                    $('#DateTo').val(dTo);
                } else {
                    $('#DateFrom').val('');
                    $('#DateTo').val('');
                }
            });

            $('#btnAddRow').click(function() {
                var index = $('#detailGridBody tr').length;
                var row = `
                     <tr class="hover:tw-bg-amber-50/20 tw-transition-colors group" data-index="${index}">
                        <td class="tw-py-3 tw-px-4 tw-text-center tw-align-top tw-pt-4">
                            <button type="button" class="tw-w-7 tw-h-7 tw-rounded-lg tw-bg-red-50 tw-text-red-500 hover:tw-bg-red-500 hover:tw-text-white tw-transition-colors tw-inline-flex tw-items-center tw-justify-center" onclick="removeRow(this)"><i class="fas fa-times tw-text-xs"></i></button>
                        </td>
                        <td class="tw-py-3 tw-px-4 tw-align-top">
                            <div class="tw-relative">
                                <span class="tw-absolute tw-left-3 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs tw-font-bold">$</span>
                                <input type="number" step="0.01" name="Details[${index}].LimitFrom" class="tw-w-36 tw-pl-7 tw-pr-3 tw-py-2 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-lg tw-text-xs tw-font-mono tw-font-bold tw-text-slate-800 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-transition-all" value="0" />
                            </div>
                        </td>
                        <td class="tw-py-3 tw-px-4 tw-align-top">
                            <div class="tw-relative">
                                <span class="tw-absolute tw-left-3 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs tw-font-bold">$</span>
                                <input type="number" step="0.01" name="Details[${index}].LimitTo" class="tw-w-36 tw-pl-7 tw-pr-3 tw-py-2 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-lg tw-text-xs tw-font-mono tw-font-bold tw-text-slate-800 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-transition-all" value="0" />
                            </div>
                        </td>
                         <td class="tw-py-3 tw-px-4 tw-align-top">
                            <div class="tw-relative">
                                <span class="tw-absolute tw-right-3 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-[10px]"><i class="fas fa-percent"></i></span>
                                <input type="number" step="0.01" name="Details[${index}].PctAmount" class="tw-w-28 tw-pl-3 tw-pr-8 tw-py-2 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-lg tw-text-xs tw-font-mono tw-font-bold tw-text-indigo-600 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-transition-all" value="0" />
                            </div>
                        </td>
                         <td class="tw-py-3 tw-px-4 tw-align-top">
                            <div class="tw-relative">
                                <span class="tw-absolute tw-left-3 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-[10px] tw-font-bold"><i class="fas fa-plus"></i></span>
                                <input type="number" step="0.01" name="Details[${index}].FixAmount" class="tw-w-32 tw-pl-8 tw-pr-3 tw-py-2 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-lg tw-text-xs tw-font-mono tw-font-bold tw-text-slate-800 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-transition-all" value="0" />
                            </div>
                        </td>
                        <td class="tw-py-3 tw-px-4 tw-align-top">
                            <input type="text" name="Details[${index}].Comments" maxlength="45" class="tw-w-44 tw-px-3 tw-py-2 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-lg tw-text-xs tw-font-medium tw-text-slate-800 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-2 focus:tw-ring-amber-400/20 tw-outline-none tw-transition-all" placeholder="Optional Focus" />
                        </td>
                    </tr>
                `;
                $('#detailGridBody').append(row);
            });
        });

        function removeRow(btn) {
            $(btn).closest('tr').remove();
            // Re-index to maintain model binding array sequence
            $('#detailGridBody tr').each(function(index) {
                $(this).find('input[type="number"]').eq(0).attr('name', 'Details[' + index + '].LimitFrom');
                $(this).find('input[type="number"]').eq(1).attr('name', 'Details[' + index + '].LimitTo');
                $(this).find('input[type="number"]').eq(2).attr('name', 'Details[' + index + '].PctAmount');
                $(this).find('input[type="number"]').eq(3).attr('name', 'Details[' + index + '].FixAmount');
                $(this).find('input[type="text"]').attr('name', 'Details[' + index + '].Comments');
            });
            
            // if all removed, add one blank row
            if($('#detailGridBody tr').length === 0) {
                $('#btnAddRow').click();
            }
        }
    </script>
}
