@model LCS_HR_MVC.Models.GazettedHolidayModel
@{
    ViewData["Title"] = "Gazetted Holidays Setup";
    ViewData["PageTitle"] = "Gazetted Holidays Setup";
    var dataList = ViewBag.GazettedHolidaysList as IEnumerable<LCS_HR_MVC.Models.GazettedHolidayModel> ?? new List<LCS_HR_MVC.Models.GazettedHolidayModel>();
    var isNewRecord = Model.Code == "Auto Generated" || string.IsNullOrEmpty(Model.Code);
}

@section Styles {
    <link href="~/lib/jquery-ui/jquery-ui.min.css" rel="stylesheet" />
    <style>
        /* Modern Fade Animation */
        @@keyframes slideUp { 
            from { opacity: 0; transform: translateY(15px); } 
            to { opacity: 1; transform: translateY(0); } 
        }
        .animate-main { animation: slideUp 0.4s ease-out; }

        /* Detail Scrollbar */
        .custom-scrollbar::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: #f1f5f9;
            border-radius: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }

        /* Modern UI Autocomplete Override */
        .ui-autocomplete {
            @@apply tw-max-h-60 tw-overflow-y-auto tw-rounded-xl tw-border-slate-200 tw-shadow-xl tw-text-sm tw-font-medium tw-font-sans tw-bg-white !important;
            z-index: 1000 !important;
        }
        .ui-menu-item-wrapper {
            @@apply tw-py-2 tw-px-3 tw-transition-colors tw-text-slate-700 !important;
        }
        .ui-menu-item-wrapper.ui-state-active {
            @@apply tw-bg-amber-400 tw-text-slate-900 tw-border-transparent tw-rounded-md tw-font-bold !important;
            margin: 0 !important;
        }
        
        /* DataTable Overrides - Modern & Balanced */
        .dataTables_wrapper .dataTables_filter {
            @@apply tw-relative tw-mb-5;
        }
        .dataTables_wrapper .dataTables_filter label {
            @@apply tw-w-full sm:tw-w-auto;
        }
        .dataTables_wrapper .dataTables_filter input {
            @@apply tw-w-full sm:tw-w-[300px] tw-border-2 tw-border-slate-100 tw-rounded-2xl tw-px-5 tw-py-2.5 tw-text-sm tw-outline-none tw-bg-slate-50 focus:tw-bg-white tw-text-slate-700 tw-shadow-inner tw-font-medium;
        }
        .dataTables_wrapper .dataTables_filter input:focus { 
            @@apply tw-border-amber-400 tw-ring-4 tw-ring-amber-400/20 tw-shadow-lg; 
        }
        
        table.dataTable {
            @@apply tw-border-collapse;
        }
        table.dataTable thead th {
            @@apply tw-bg-slate-50 tw-text-slate-400 tw-font-black tw-uppercase tw-text-[10px] tw-tracking-[0.15em] tw-py-4 tw-px-5 tw-border-b-2 tw-border-slate-100 !important;
        }
        
        table.dataTable tbody tr {
            @@apply tw-border-b tw-border-slate-50 tw-transition-colors hover:tw-bg-amber-50/30;
        }
        table.dataTable tbody td {
            @@apply tw-py-4 tw-px-5 tw-align-middle;
        }
        
        .dataTables_info {
            @@apply tw-text-xs tw-font-semibold tw-text-slate-500 tw-mt-5;
        }
        
        /* Modern Pagination */
        .dataTables_wrapper .dataTables_paginate {
            @@apply tw-flex tw-items-center tw-gap-1 tw-mt-5;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button {
            @@apply tw-min-w-[32px] tw-h-8 tw-flex tw-items-center tw-justify-center tw-rounded-lg tw-text-xs tw-font-bold tw-text-slate-500 tw-border tw-border-slate-200 tw-bg-white tw-cursor-pointer tw-transition-all !important;
            padding: 0 0.5rem !important;
            margin: 0 !important;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
            @@apply tw-bg-slate-100 tw-text-slate-800 tw-border-slate-300 !important;
            background: none !important;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button.current,
        .dataTables_wrapper .dataTables_paginate .paginate_button.current:hover {
            @@apply tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-text-slate-900 tw-border-transparent tw-shadow-md tw-cursor-default !important;
            background: none !important;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button.disabled {
            @@apply tw-opacity-50 tw-cursor-not-allowed hover:tw-bg-white hover:tw-text-slate-500 hover:tw-border-slate-200 !important;
        }
    </style>
}

<div class="tw-p-4 sm:tw-p-6 tw-bg-transparent tw-min-h-screen animate-main">

    <!-- Messages -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-red-50 tw-border tw-border-red-100 tw-rounded-xl tw-text-red-600 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(239,68,68,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-red-100 tw-text-red-500 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0">
                <i class="fas fa-exclamation-triangle tw-text-[10px]"></i>
            </div>
            <span class="tw-pt-0.5">@TempData["ErrorMessage"]</span>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-emerald-50 tw-border tw-border-emerald-100 tw-rounded-xl tw-text-emerald-700 tw-text-sm tw-font-bold tw-shadow-[0_2px_10_rgba(16,185,129,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-emerald-100 tw-text-emerald-600 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0">
                <i class="fas fa-check tw-text-[10px]"></i>
            </div>
            <span class="tw-pt-0.5">@TempData["SuccessMessage"]</span>
        </div>
    }

    <!-- Header Map -->
    <div class="tw-flex tw-flex-col sm:tw-flex-row sm:tw-items-end tw-justify-between tw-gap-4 tw-mb-8">
        <div>
            <nav class="tw-flex tw-items-center tw-gap-2.5 tw-text-[11px] tw-font-bold tw-text-slate-400 tw-mb-2 tw-uppercase tw-tracking-widest">
                <div class="tw-flex tw-items-center tw-gap-1.5 hover:tw-text-[#eab308] tw-transition-colors tw-cursor-pointer">
                    <i class="fas fa-cogs tw-text-[10px] tw-text-slate-300"></i>
                    <span>Setup</span>
                </div>
                <i class="fas fa-chevron-right tw-text-[8px] tw-text-slate-300"></i> 
                <span class="tw-text-slate-600 tw-bg-white tw-px-2 tw-py-0.5 tw-rounded-md tw-border tw-border-slate-200 tw-shadow-sm">Attendance Calendar</span>
            </nav>
            <div class="tw-flex tw-flex-col">
                <h1 class="tw-text-3xl tw-font-black tw-text-slate-900 tw-leading-tight tw-tracking-tight">Gazetted Holidays</h1>
                <div class="tw-h-1.5 tw-w-10 tw-bg-gradient-to-r tw-from-[#f5c518] tw-to-transparent tw-rounded-full tw-mt-1"></div>
            </div>
            <p class="tw-text-slate-500 tw-text-sm tw-font-medium tw-mt-3 tw-leading-relaxed">Configure national constraints and local public holidays exceptions.</p>
        </div>
    </div>

    <div class="tw-grid xl:tw-grid-cols-[1fr_0.9fr] tw-gap-6 xl:tw-gap-8 align-top">
        
        <!-- Left Side: Table View -->
        <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-relative tw-h-full">
            <div class="tw-absolute tw-top-0 tw-right-0 tw-w-64 tw-h-64 tw-bg-gradient-to-bl tw-from-amber-50/50 tw-to-transparent tw-rounded-bl-full tw-pointer-events-none z-0"></div>

            <div class="tw-relative tw-z-10 tw-px-6 tw-py-5 tw-border-b tw-border-slate-100 tw-flex tw-items-center tw-gap-4 tw-bg-slate-50/80">
                <div class="tw-w-10 tw-h-10 tw-rounded-xl tw-bg-gradient-to-br tw-from-slate-900 tw-to-slate-800 tw-flex tw-items-center tw-justify-center tw-shadow-[0_4px_10px_rgba(15,23,42,0.3)]">
                    <i class="fas fa-calendar-check tw-text-amber-400 tw-text-lg"></i>
                </div>
                <div>
                    <h2 class="tw-font-black tw-text-base tw-text-slate-800 tw-tracking-tight">Public Holidays Outline</h2>
                    <p class="tw-text-[10px] tw-font-bold tw-text-slate-400 tw-uppercase tw-tracking-widest">Global &amp; Local Scope</p>
                </div>
            </div>

            <div class="tw-relative tw-z-10 tw-p-6">
                <div class="tw-overflow-x-auto custom-scrollbar">
                    <table id="dg1" class="tw-w-full dataTable tw-text-xs">
                        <thead>
                            <tr>
                                <th class="tw-w-20 tw-text-center">ID</th>
                                <th>Timeline Span</th>
                                <th>Event / Scope</th>
                                <th class="tw-text-right tw-pr-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="tw-divide-y tw-divide-slate-100">
                            @foreach (var item in dataList)
                            {
                                <tr class="hover:tw-bg-slate-50 tw-transition-colors group tw-text-sm">
                                    <td class="tw-py-4 tw-text-center tw-align-middle">
                                        <span class="tw-px-2.5 tw-py-1 tw-bg-slate-100 group-hover:tw-bg-white tw-border tw-border-slate-200 tw-rounded-lg tw-font-mono tw-font-black tw-text-slate-600 tw-shadow-sm tw-transition-colors">@item.Code</span>
                                    </td>
                                    <td class="tw-py-4 tw-align-middle">
                                        <div class="tw-flex tw-items-center tw-gap-2">
                                            <span class="tw-font-bold tw-text-slate-700">@(item.FromDate?.ToString("dd MMM yyyy"))</span>
                                            <i class="fas fa-arrow-right tw-text-[10px] tw-text-slate-300"></i>
                                            <span class="tw-font-bold tw-text-slate-700">@(item.ToDate?.ToString("dd MMM yyyy"))</span>
                                        </div>
                                        <div class="tw-text-[10px] tw-font-bold tw-text-amber-600 tw-mt-1">
                                            <i class="fas fa-clock tw-mr-1 tw-text-amber-400"></i> @item.Days Day(s) 
                                        </div>
                                    </td>
                                    <td class="tw-py-4 tw-align-middle">
                                        <div class="tw-font-bold tw-text-slate-800 tw-mb-0.5">@item.Reason</div>
                                        @if(item.IsAllLocations)
                                        {
                                            <span class="tw-text-[9px] tw-font-black tw-text-blue-600 tw-bg-blue-50 tw-border tw-border-blue-100 tw-px-2 tw-py-0.5 tw-rounded tw-uppercase">Global Scope</span>
                                        }
                                        else
                                        {
                                             <span class="tw-text-[9px] tw-font-black tw-text-emerald-600 tw-bg-emerald-50 tw-border tw-border-emerald-100 tw-px-2 tw-py-0.5 tw-rounded tw-uppercase">Local: @item.DisplayLocation</span>
                                        }
                                    </td>
                                    <td class="tw-py-4 tw-text-right tw-pr-4 tw-align-middle">
                                        <button class="hol-link tw-inline-flex tw-items-center tw-justify-center tw-w-8 tw-h-8 tw-rounded-lg tw-bg-slate-50 tw-border tw-border-slate-200 tw-text-slate-400 hover:tw-bg-amber-400 hover:tw-border-amber-400 hover:tw-text-slate-900 tw-shadow-sm hover:tw-shadow-md hover:tw--translate-y-0.5 tw-transition-all"
                                                data-code="@item.Code" 
                                                data-from="@(item.FromDate?.ToString("yyyy-MM-dd"))"
                                                data-to="@(item.ToDate?.ToString("yyyy-MM-dd"))"
                                                data-loc="@item.LocationID"
                                                data-locdesc="@item.LocationDescription"
                                                data-all="@(item.IsAllLocations ? "true" : "false")"
                                                data-reason="@item.Reason"
                                                title="Edit Schedule Entry">
                                            <i class="fas fa-edit tw-text-[11px]"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Right Side: Config Form -->
        <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-sticky tw-top-24 tw-relative">
            <div class="tw-absolute tw-top-[-50px] tw-right-[-50px] tw-w-40 tw-h-40 tw-bg-amber-100/40 tw-blur-2xl tw-rounded-full tw-pointer-events-none"></div>

            <div class="tw-p-6 tw-bg-gradient-to-r tw-from-slate-900 tw-to-slate-800 tw-relative tw-z-10">
                <h3 class="tw-text-amber-400 tw-font-black tw-text-xs tw-uppercase tw-tracking-[0.2em] tw-flex tw-items-center tw-gap-2">
                    <div class="tw-w-6 tw-h-6 tw-bg-white/10 tw-rounded-md tw-flex tw-items-center tw-justify-center">
                        <i class="fas fa-map-marked-alt"></i>
                    </div>
                    Holiday Maker
                </h3>
            </div>

            <form asp-controller="Setup" asp-action="GazettedHolidays" method="post" id="holForm" class="tw-p-7 tw-space-y-4 tw-relative tw-z-10">
                
                <div class="tw-bg-amber-50 tw-border tw-border-amber-100 tw-rounded-xl tw-p-3 tw-mb-2">
                    <p class="tw-text-[10px] tw-font-bold tw-text-amber-700 tw-leading-relaxed"><i class="fas fa-info-circle tw-mr-1"></i> If crossing months, please create two separate spanning entries.</p>
                </div>

                <!-- ID Banner -->
                <div>
                    <label class="tw-block tw-text-[10px] tw-font-black tw-text-slate-400 tw-uppercase tw-tracking-widest tw-mb-1.5">Schedule ID</label>
                    <div class="tw-flex tw-items-center tw-bg-slate-50 tw-rounded-xl tw-px-3 tw-py-2.5 tw-border tw-border-slate-200 tw-shadow-inner opacity-80">
                        <i class="fas fa-fingerprint tw-text-slate-400 tw-mr-1.5 tw-text-[10px]"></i>
                        <input type="text" id="displayCode" value="@Model.Code" disabled class="tw-bg-transparent tw-w-full tw-text-sm tw-font-mono tw-font-bold tw-text-slate-600 tw-outline-none" />
                        <input type="hidden" asp-for="Code" id="Code" />
                    </div>
                </div>

                <!-- Scope Selection -->
                <div>
                    <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-2">Holiday Enforcement Scope <span class="tw-text-red-500">*</span></label>
                    <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                        <label class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-2 tw-bg-white tw-border tw-border-slate-200 tw-rounded-lg tw-cursor-pointer hover:tw-bg-slate-50 tw-transition-colors">
                            <input type="radio" asp-for="IsAllLocations" value="true" id="rdball" class="tw-w-3.5 tw-h-3.5 tw-accent-amber-500" />
                            <span class="tw-text-xs tw-font-bold tw-text-slate-700">Global (All City)</span>
                        </label>
                        <label class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-2 tw-bg-white tw-border tw-border-slate-200 tw-rounded-lg tw-cursor-pointer hover:tw-bg-slate-50 tw-transition-colors">
                            <input type="radio" asp-for="IsAllLocations" value="false" id="rdbcity" class="tw-w-3.5 tw-h-3.5 tw-accent-amber-500" />
                            <span class="tw-text-xs tw-font-bold tw-text-slate-700">Specific City</span>
                        </label>
                    </div>
                </div>

                <!-- Dependent Location Field -->
                <div id="loctr" style="display:none;">
                    <label asp-for="LocationDescription" class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Target Location</label>
                    <div class="tw-flex tw-gap-2">
                        <div class="tw-flex-1 tw-relative">
                            <i class="fas fa-search tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs"></i>
                            <input asp-for="LocationDescription" id="LocationDescription" 
                                   class="tw-w-full tw-pl-9 tw-pr-3 tw-py-2.5 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 placeholder-slate-400 focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm" placeholder="Search Location %" />
                        </div>
                        <input asp-for="LocationID" id="LocationID" readonly="readonly" 
                               class="tw-w-20 tw-text-center tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-mono tw-font-bold tw-text-slate-500 tw-outline-none" placeholder="LOC_ID" />
                    </div>
                    <span asp-validation-for="LocationDescription" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                </div>

                <!-- Date Range -->
                <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                    <div>
                        <label asp-for="FromDate" class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Init Date <span class="tw-text-red-500">*</span></label>
                        <div class="tw-relative">
                            <i class="fas fa-calendar-alt tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-amber-500 tw-text-sm"></i>
                            <input asp-for="FromDate" id="FromDate" type="date" 
                                   class="tw-w-full tw-pl-10 tw-pr-3 tw-py-2.5 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm" />
                        </div>
                        <span asp-validation-for="FromDate" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                    </div>
                    <div>
                        <label asp-for="ToDate" class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">End Date <span class="tw-text-red-500">*</span></label>
                        <div class="tw-relative">
                            <i class="fas fa-calendar-check tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-amber-500 tw-text-sm"></i>
                            <input asp-for="ToDate" id="ToDate" type="date" 
                                   class="tw-w-full tw-pl-10 tw-pr-3 tw-py-2.5 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm" />
                        </div>
                        <span asp-validation-for="ToDate" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                    </div>
                </div>

                <!-- Reason -->
                <div>
                    <label asp-for="Reason" class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Description Context <span class="tw-text-red-500">*</span></label>
                    <div class="tw-relative">
                        <i class="fas fa-info-circle tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-sm"></i>
                        <input asp-for="Reason" id="Reason" maxlength="100" 
                               class="tw-w-full tw-pl-10 tw-pr-4 tw-py-3 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 placeholder-slate-400 focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm" placeholder="e.g. Independence Day" />
                    </div>
                    <span asp-validation-for="Reason" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                </div>

                <div class="tw-border-t tw-border-slate-100 tw-pt-3 tw-mt-2"></div>

                 <!-- Action Controls -->
                <div class="tw-space-y-3">
                    <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                        <button type="submit" name="action" value="Save" id="btnSave" @(!isNewRecord ? "disabled" : null)
                                class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-text-slate-900 tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase tw-shadow-[0_8px_20px_rgba(245,197,24,0.25)] hover:tw-shadow-[0_8px_25px_rgba(245,197,24,0.35)] hover:tw--translate-y-0.5 tw-transition-all disabled:tw-opacity-50 disabled:tw-cursor-not-allowed">
                            <i class="fas fa-check-circle tw-text-sm"></i> Add Scope
                        </button>
                        <button type="submit" name="action" value="Update" id="btnUpdate" @(isNewRecord ? "disabled" : null)
                                class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-slate-900 tw-text-white tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase hover:tw-bg-slate-800 hover:tw-shadow-[0_8px_20px_rgba(15,23,42,0.2)] hover:tw--translate-y-0.5 tw-transition-all disabled:tw-opacity-40 disabled:hover:tw-transform-none disabled:hover:tw-shadow-none">
                            <i class="fas fa-sync-alt tw-text-sm"></i> Apply Change
                        </button>
                    </div>
                    <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                        <button type="submit" name="action" value="Delete" id="btnDelete" @(isNewRecord ? "disabled" : null) onclick="return confirm('Are you sure you want to delete this recorded holiday?');"
                                class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-bg-white tw-text-red-500 tw-border tw-border-red-100 tw-shadow-sm tw-rounded-xl tw-font-extrabold tw-text-[11px] tw-tracking-wider tw-uppercase hover:tw-bg-red-50 hover:tw-border-red-200 tw-transition-all disabled:tw-opacity-40 disabled:tw-cursor-not-allowed">
                            <i class="fas fa-trash-alt"></i> Purge Rule
                        </button>
                        <button type="submit" name="action" value="Reset" id="btnReset" formnovalidate
                                class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-bg-white tw-text-slate-600 tw-border tw-border-slate-200 tw-shadow-sm tw-rounded-xl tw-font-extrabold tw-text-[11px] tw-tracking-wider tw-uppercase hover:tw-bg-slate-50 hover:tw-text-slate-900 tw-transition-all">
                            <i class="fas fa-undo-alt tw-opacity-60"></i> Reset Input
                        </button>
                    </div>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/lib/jquery-ui/jquery-ui.min.js"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            if ($.fn.DataTable) {
                var table = $('#dg1').DataTable({
                    "pageLength": 10,
                    "lengthChange": false,
                    "dom": '<"tw-flex tw-flex-col sm:tw-flex-row tw-justify-between tw-items-center tw-mb-2"f>rt<"tw-flex tw-flex-col sm:tw-flex-row tw-justify-between tw-items-center"ip>',
                    "language": { 
                        "search": "", 
                        "searchPlaceholder": "Search Holiday Records...",
                        "paginate": {
                            "previous": "<i class='fas fa-chevron-left tw-text-[10px]'></i>",
                            "next": "<i class='fas fa-chevron-right tw-text-[10px]'></i>"
                        }
                    }
                });

                // Add search icon inside datatable filter
                $('.dataTables_filter label').addClass('tw-relative tw-block tw-w-full');
                $('.dataTables_filter input').addClass('tw-pl-10');
                $('.dataTables_filter label').append('<i class="fas fa-search tw-absolute tw-left-4 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400"></i>');
            }

            function toggleLocation() {
                if ($('#rdbcity').is(':checked')) {
                    $('#loctr').slideDown('fast');
                } else {
                    $('#loctr').slideUp('fast');
                    $('#LocationID').val('');
                    $('#LocationDescription').val('');
                }
            }

            $('input[name="IsAllLocations"]').change(function () {
                toggleLocation();
            });

            toggleLocation();

            $("#LocationDescription").autocomplete({
                source: function (request, response) {
                    $.ajax({
                        url: '@Url.Action("GetLocations", "Admin")',
                        type: "GET",
                        dataType: "json",
                        data: { term: request.term },
                        success: function (data) {
                            response($.map(data, function (item) {
                                return { label: item.label, value: item.label, id: item.value };
                            }))
                        }
                    })
                },
                select: function (event, ui) {
                    $("#LocationDescription").val(ui.item.label);
                    $("#LocationID").val(ui.item.id);
                    return false;
                },
                minLength: 1
            });
            
            $("#LocationDescription").keyup(function() {
                if (!$(this).val()) {
                    $("#LocationID").val('');
                }
            });

            $('.hol-link').click(function (e) {
                e.preventDefault();
                var code = $(this).data('code');
                var from = $(this).data('from');
                var to = $(this).data('to');
                var loc = $(this).data('loc');
                var locdesc = $(this).data('locdesc');
                var isall = $(this).data('all') === true || $(this).data('all') === 'true';
                var reason = $(this).data('reason');
                
                $('#Code').val(code);
                $('#displayCode').val(code);
                $('#FromDate').val(from);
                $('#ToDate').val(to);
                $('#Reason').val(reason);
                
                if(isall) {
                    $('#rdball').prop('checked', true);
                } else {
                    $('#rdbcity').prop('checked', true);
                    $('#LocationID').val(loc);
                    $('#LocationDescription').val(locdesc);
                }

                toggleLocation();

                $('#btnSave').prop('disabled', true);
                $('#btnUpdate').prop('disabled', false);
                $('#btnDelete').prop('disabled', false);

                $('html, body').animate({ scrollTop: 0 }, 'fast');
            });

            var currentCode = $('#Code').val();
            if (currentCode && currentCode !== 'Auto Generated') {
                $('#displayCode').val(currentCode);
                $('#btnSave').prop('disabled', true);
                $('#btnUpdate').prop('disabled', false);
                $('#btnDelete').prop('disabled', false);
            }
        });
    </script>
}
