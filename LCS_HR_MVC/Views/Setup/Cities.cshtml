@model LCS_HR_MVC.Models.CityModel
@{
    ViewData["PageTitle"] = "Cities Setup";
    var citiesList = ViewBag.CitiesList as IEnumerable<LCS_HR_MVC.Models.CityModel> ?? new List<LCS_HR_MVC.Models.CityModel>();
    var countriesList = ViewBag.CountriesList as IEnumerable<SelectListItem> ?? new List<SelectListItem>();
    var zonesList = ViewBag.ZonesList as IEnumerable<SelectListItem> ?? new List<SelectListItem>();
}

@section Styles {
    <style>
        /* Modern Fade Animation */
        @@keyframes slideUp { 
            from { opacity: 0; transform: translateY(15px); } 
            to { opacity: 1; transform: translateY(0); } 
        }
        .animate-main { animation: slideUp 0.4s ease-out; }

        /* DataTable Overrides - Modern & Balanced */
        .dataTables_wrapper .dataTables_filter {
            @@apply tw-relative tw-mb-5;
        }
        .dataTables_wrapper .dataTables_filter label {
            @@apply tw-w-full sm:tw-w-auto;
        }
        .dataTables_wrapper .dataTables_filter input {
            @@apply tw-w-full sm:tw-w-[300px] tw-border-2 tw-border-slate-100 tw-rounded-2xl tw-px-5 tw-py-2.5 tw-text-sm tw-outline-none tw-transition-all tw-bg-slate-50 focus:tw-bg-white tw-text-slate-700 tw-shadow-inner tw-font-medium;
        }
        .dataTables_wrapper .dataTables_filter input:focus { 
            @@apply tw-border-amber-400 tw-ring-4 tw-ring-amber-400/20 tw-shadow-lg; 
        }
        
        table.dataTable {
            @@apply tw-border-collapse;
        }
        table.dataTable thead th {
            @@apply tw-bg-slate-50 tw-text-slate-400 tw-font-black tw-uppercase tw-text-[10px] tw-tracking-[0.15em] tw-py-4 tw-px-5 tw-border-b-2 tw-border-slate-100 !important;
        }
        
        table.dataTable tbody tr {
            @@apply tw-border-b tw-border-slate-50 tw-transition-colors hover:tw-bg-amber-50/30;
        }
        table.dataTable tbody td {
            @@apply tw-py-4 tw-px-5 tw-align-middle;
        }
        
        .dataTables_info {
            @@apply tw-text-xs tw-font-semibold tw-text-slate-500 tw-mt-5;
        }
        
        /* Modern Pagination */
        .dataTables_wrapper .dataTables_paginate {
            @@apply tw-flex tw-items-center tw-gap-1 tw-mt-5;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button {
            @@apply tw-min-w-[32px] tw-h-8 tw-flex tw-items-center tw-justify-center tw-rounded-lg tw-text-xs tw-font-bold tw-text-slate-500 tw-border tw-border-slate-200 tw-bg-white tw-cursor-pointer tw-transition-all !important;
            padding: 0 0.5rem !important;
            margin: 0 !important;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
            @@apply tw-bg-slate-100 tw-text-slate-800 tw-border-slate-300 !important;
            background: none !important;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button.current,
        .dataTables_wrapper .dataTables_paginate .paginate_button.current:hover {
            @@apply tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-text-slate-900 tw-border-transparent tw-shadow-md tw-cursor-default !important;
            background: none !important;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button.disabled {
            @@apply tw-opacity-50 tw-cursor-not-allowed hover:tw-bg-white hover:tw-text-slate-500 hover:tw-border-slate-200 !important;
        }
    </style>
}

<div class="tw-p-4 sm:tw-p-6 tw-bg-transparent tw-min-h-screen animate-main">

    <!-- Messages -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-red-50 tw-border tw-border-red-100 tw-rounded-xl tw-text-red-600 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(239,68,68,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-red-100 tw-text-red-500 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0">
                <i class="fas fa-exclamation-triangle tw-text-[10px]"></i>
            </div>
            <span class="tw-pt-0.5">@TempData["ErrorMessage"]</span>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-emerald-50 tw-border tw-border-emerald-100 tw-rounded-xl tw-text-emerald-700 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(16,185,129,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-emerald-100 tw-text-emerald-600 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0">
                <i class="fas fa-check tw-text-[10px]"></i>
            </div>
            <span class="tw-pt-0.5">@TempData["SuccessMessage"]</span>
        </div>
    }

    <div class="tw-flex tw-flex-col sm:tw-flex-row sm:tw-items-end tw-justify-between tw-gap-4 tw-mb-8">
        <div>
            <nav class="tw-flex tw-items-center tw-gap-2.5 tw-text-[11px] tw-font-bold tw-text-slate-400 tw-mb-2 tw-uppercase tw-tracking-widest">
                <div class="tw-flex tw-items-center tw-gap-1.5 hover:tw-text-[#eab308] tw-transition-colors tw-cursor-pointer">
                    <i class="fas fa-cogs tw-text-[10px] tw-text-slate-300"></i>
                    <span>Setup</span>
                </div>
                <i class="fas fa-chevron-right tw-text-[8px] tw-text-slate-300"></i> 
                <span class="tw-text-slate-600 tw-bg-white tw-px-2 tw-py-0.5 tw-rounded-md tw-border tw-border-slate-200 tw-shadow-sm">Cities</span>
            </nav>
            <div class="tw-flex tw-flex-col">
                <h1 class="tw-text-3xl tw-font-black tw-text-slate-900 tw-leading-tight tw-tracking-tight">Strategic Setup</h1>
                <div class="tw-h-1.5 tw-w-10 tw-bg-gradient-to-r tw-from-[#f5c518] tw-to-transparent tw-rounded-full tw-mt-1"></div>
            </div>
            <p class="tw-text-slate-500 tw-text-sm tw-font-medium tw-mt-3 tw-leading-relaxed">Manage global operational cities and stations for Leopards Courier system</p>
        </div>
    </div>

    <div class="tw-grid lg:tw-grid-cols-12 tw-gap-6 xl:tw-gap-8">
        
        <!-- Left Side: Data Table -->
        <div class="lg:tw-col-span-8">
            <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-relative h-full">
                <!-- Decorative background -->
                <div class="tw-absolute tw-top-0 tw-right-0 tw-w-64 tw-h-64 tw-bg-gradient-to-bl tw-from-amber-50/50 tw-to-transparent tw-rounded-bl-full tw-pointer-events-none z-0"></div>

                <div class="tw-relative tw-z-10 tw-px-6 tw-py-5 tw-border-b tw-border-slate-100 tw-flex tw-items-center tw-gap-4 tw-bg-white/50 tw-backdrop-blur-sm">
                    <div class="tw-w-10 tw-h-10 tw-rounded-xl tw-bg-gradient-to-br tw-from-slate-900 tw-to-slate-800 tw-flex tw-items-center tw-justify-center tw-shadow-[0_4px_10px_rgba(15,23,42,0.2)]">
                        <i class="fas fa-city tw-text-amber-400 tw-text-sm"></i>
                    </div>
                    <div>
                        <h2 class="tw-font-black tw-text-base tw-text-slate-800 tw-tracking-tight">Available Cities</h2>
                        <p class="tw-text-[10px] tw-font-bold tw-text-slate-400 tw-uppercase tw-tracking-widest">Directory Overview</p>
                    </div>
                </div>

                <div class="tw-relative tw-z-10 tw-p-6">
                    <div class="tw-overflow-x-auto">
                        <table id="dg1" class="tw-w-full dataTable tw-text-xs">
                            <thead>
                                <tr>
                                    <th class="tw-w-20 tw-text-center">ID</th>
                                    <th>City/Station</th>
                                    <th>Short</th>
                                    <th>Region (Prov/Zn/Country)</th>
                                    <th class="tw-text-right tw-pr-4">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="tw-divide-y tw-divide-slate-100">
                                @foreach (var city in citiesList)
                                {
                                    <tr class="hover:tw-bg-slate-50 tw-transition-colors group text-sm">
                                        <td class="tw-py-4 tw-text-center">
                                            <span class="tw-px-2.5 tw-py-1 tw-bg-slate-100 group-hover:tw-bg-white tw-border tw-border-slate-200 tw-rounded-lg tw-font-mono tw-font-black tw-text-slate-600 tw-shadow-sm tw-transition-colors">@city.Code</span>
                                        </td>
                                        <td class="tw-py-4">
                                            <div class="tw-font-bold tw-text-slate-800 group-hover:tw-text-amber-500 tw-transition-colors">@city.FullName</div>
                                            <div class="tw-text-[10px] tw-font-bold tw-text-slate-400 tw-mt-0.5">
                                                S ID: <span class="tw-text-amber-500 tw-font-mono">@city.StationId</span> | B: <span class="tw-text-slate-500 tw-font-mono">@city.BranchId</span>
                                            </div>
                                        </td>
                                        <td class="tw-py-4 tw-text-slate-500 tw-font-semibold">
                                            <span class="tw-inline-flex tw-bg-slate-50 tw-px-2 tw-py-0.5 tw-rounded tw-border tw-border-slate-100">@city.ShortName</span>
                                        </td>
                                        <td class="tw-py-4">
                                            <div class="tw-flex tw-items-center tw-gap-1.5 tw-text-slate-600 tw-font-medium tw-text-xs">
                                                <i class="fas fa-map-marker-alt tw-text-[10px] tw-text-slate-300"></i>
                                                @city.ProvinceName, @city.ZoneName
                                            </div>
                                        </td>
                                        <td class="tw-py-4 tw-text-right tw-pr-4">
                                            <button class="city-link tw-inline-flex tw-items-center tw-justify-center tw-w-8 tw-h-8 tw-rounded-lg tw-bg-slate-50 tw-border tw-border-slate-200 tw-text-slate-400 hover:tw-bg-amber-400 hover:tw-border-amber-400 hover:tw-text-slate-900 tw-shadow-sm hover:tw-shadow-md hover:tw--translate-y-0.5 tw-transition-all"
                                                    data-code="@city.Code" 
                                                    data-country="@city.CountryCode"
                                                    data-province="@city.ProvinceCode"
                                                    data-zone="@city.ZoneCode"
                                                    data-fname="@city.FullName" 
                                                    data-sname="@city.ShortName"
                                                    data-station="@city.StationId"
                                                    data-branch="@city.BranchId"
                                                    data-extra="@city.ExtraFixedDays"
                                                    title="Edit Record">
                                                <i class="fas fa-edit tw-text-[11px]"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Side: Form -->
        <div class="lg:tw-col-span-4">
            <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-sticky tw-top-24 tw-relative">
                <div class="tw-absolute tw-top-[-50px] tw-right-[-50px] tw-w-40 tw-h-40 tw-bg-amber-100/40 tw-blur-2xl tw-rounded-full tw-pointer-events-none"></div>

                <div class="tw-p-6 tw-bg-gradient-to-r tw-from-slate-900 tw-to-slate-800 tw-relative tw-z-10">
                    <h3 class="tw-text-amber-400 tw-font-black tw-text-xs tw-uppercase tw-tracking-[0.2em] tw-flex tw-items-center tw-gap-2">
                        <div class="tw-w-6 tw-h-6 tw-bg-white/10 tw-rounded-md tw-flex tw-items-center tw-justify-center">
                            <i class="fas fa-keyboard"></i>
                        </div>
                        Configuration Panel
                    </h3>
                </div>
                
                <form asp-controller="Setup" asp-action="Cities" method="post" id="cityForm" class="tw-p-7 tw-space-y-4 tw-relative tw-z-10">
                    
                    <!-- Read-only Code view -->
                    <div>
                        <label class="tw-block tw-text-[10px] tw-font-black tw-text-slate-400 tw-uppercase tw-tracking-widest tw-mb-1.5">System Identity</label>
                        <div class="tw-flex tw-items-center tw-bg-slate-50 tw-rounded-xl tw-px-4 tw-py-2.5 tw-border tw-border-slate-200 tw-shadow-inner opacity-80">
                            <i class="fas fa-fingerprint tw-text-slate-400 tw-mr-3"></i>
                            <input type="text" id="displayCode" value="@Model.Code" disabled 
                                   class="tw-bg-transparent tw-w-full tw-text-sm tw-font-mono tw-font-bold tw-text-slate-600 tw-outline-none" />
                        </div>
                        <input type="hidden" asp-for="Code" id="Code" />
                    </div>

                    <!-- Location Selects -->
                    <div class="tw-grid tw-grid-cols-2 tw-gap-4">
                        <div>
                            <label asp-for="CountryCode" class="tw-block tw-text-[10px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Country <span class="tw-text-red-500">*</span></label>
                            <div class="tw-relative">
                                <i class="fas fa-globe-americas tw-absolute tw-left-3 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs"></i>
                                <select asp-for="CountryCode" asp-items="countriesList" id="CountryCode" 
                                        class="tw-w-full tw-pl-8 tw-pr-3 tw-py-2.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-xs tw-font-semibold tw-text-slate-800 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm tw-appearance-none"
                                        style="background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%2394a3b8%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right 0.75rem top 50%; background-size: 0.65rem auto;"></select>
                            </div>
                            <span asp-validation-for="CountryCode" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                        </div>

                        <div>
                            <label asp-for="ProvinceCode" class="tw-block tw-text-[10px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Province <span class="tw-text-red-500">*</span></label>
                            <div class="tw-relative">
                                <i class="fas fa-map-marked-alt tw-absolute tw-left-3 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs"></i>
                                <select asp-for="ProvinceCode" id="ProvinceCode" 
                                        class="tw-w-full tw-pl-8 tw-pr-3 tw-py-2.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-xs tw-font-semibold tw-text-slate-800 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm tw-appearance-none"
                                        style="background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%2394a3b8%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right 0.75rem top 50%; background-size: 0.65rem auto;">
                                    <option value="00">Select province</option>
                                </select>
                            </div>
                            <span asp-validation-for="ProvinceCode" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                        </div>
                    </div>

                    <div>
                        <label asp-for="ZoneCode" class="tw-block tw-text-[10px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Zone <span class="tw-text-red-500">*</span></label>
                        <div class="tw-relative">
                            <i class="fas fa-draw-polygon tw-absolute tw-left-3 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs"></i>
                            <select asp-for="ZoneCode" asp-items="zonesList" id="ZoneCode" 
                                    class="tw-w-full tw-pl-8 tw-pr-4 tw-py-2.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-xs tw-font-semibold tw-text-slate-800 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm tw-appearance-none"
                                    style="background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%2394a3b8%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right 1rem top 50%; background-size: 0.65rem auto;"></select>
                        </div>
                        <span asp-validation-for="ZoneCode" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                    </div>

                    <!-- Names -->
                    <div class="tw-grid tw-grid-cols-[2fr_1fr] tw-gap-4">
                        <div>
                            <label asp-for="FullName" class="tw-block tw-text-[10px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Full Name <span class="tw-text-red-500">*</span></label>
                            <div class="tw-relative">
                                <i class="fas fa-building tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-amber-500 tw-text-xs"></i>
                                <input asp-for="FullName" id="FullName" 
                                       class="tw-w-full tw-pl-9 tw-pr-3 tw-py-2.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-xs tw-font-semibold tw-text-slate-800 placeholder-slate-400 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm" placeholder="e.g. Karachi" />
                            </div>
                            <span asp-validation-for="FullName" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                        </div>

                        <div>
                            <label asp-for="ShortName" class="tw-block tw-text-[10px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Short</label>
                            <div class="tw-relative">
                                <i class="fas fa-tag tw-absolute tw-left-3 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-[10px]"></i>
                                <input asp-for="ShortName" id="ShortName" maxlength="2" 
                                       class="tw-w-full tw-pl-8 tw-pr-3 tw-py-2.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-xs tw-font-semibold tw-text-slate-800 placeholder-slate-400 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm uppercase" placeholder="KHI" />
                            </div>
                            <span asp-validation-for="ShortName" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                        </div>
                    </div>

                    <!-- IDs -->
                    <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                        <div>
                            <label asp-for="StationId" class="tw-block tw-text-[10px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Station ID</label>
                            <div class="tw-relative">
                                <i class="fas fa-broadcast-tower tw-absolute tw-left-3 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-[10px]"></i>
                                <input asp-for="StationId" id="StationId" maxlength="5" 
                                       class="tw-w-full tw-pl-8 tw-pr-3 tw-py-2.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-xs tw-font-semibold tw-text-slate-800 placeholder-slate-400 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-font-mono tw-shadow-sm" placeholder="000" />
                            </div>
                            <span asp-validation-for="StationId" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                        </div>
                        <div>
                            <label asp-for="BranchId" class="tw-block tw-text-[10px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Branch ID</label>
                            <div class="tw-relative">
                                <i class="fas fa-code-branch tw-absolute tw-left-3 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-[10px]"></i>
                                <input asp-for="BranchId" id="BranchId" maxlength="5" 
                                       class="tw-w-full tw-pl-8 tw-pr-3 tw-py-2.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-xs tw-font-semibold tw-text-slate-800 placeholder-slate-400 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-font-mono tw-shadow-sm" placeholder="000" />
                            </div>
                            <span asp-validation-for="BranchId" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                        </div>
                    </div>

                    <div class="tw-pt-2 tw-mb-1 tw-border-t tw-border-slate-100"></div>

                    <!-- Action Buttons -->
                    <div class="tw-space-y-3">
                        <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                            <button type="submit" name="action" value="Save" id="btnSave" 
                                    class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-text-slate-900 tw-rounded-xl tw-font-black tw-text-[10px] tw-tracking-widest tw-uppercase tw-shadow-[0_8px_20px_rgba(245,197,24,0.25)] hover:tw-shadow-[0_8px_25px_rgba(245,197,24,0.35)] hover:tw--translate-y-0.5 tw-transition-all disabled:tw-opacity-50 disabled:tw-cursor-not-allowed">
                                <i class="fas fa-check-circle tw-text-sm"></i> Save
                            </button>
                            <button type="submit" name="action" value="Update" id="btnUpdate" disabled="disabled"
                                    class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-bg-slate-900 tw-text-white tw-rounded-xl tw-font-black tw-text-[10px] tw-tracking-widest tw-uppercase hover:tw-bg-slate-800 hover:tw-shadow-[0_8px_20px_rgba(15,23,42,0.2)] hover:tw--translate-y-0.5 tw-transition-all disabled:tw-opacity-40 disabled:hover:tw-transform-none disabled:hover:tw-shadow-none">
                                <i class="fas fa-sync-alt tw-text-sm"></i> Update
                            </button>
                        </div>
                        <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                            <button type="submit" name="action" value="Delete" id="btnDelete" disabled="disabled" onclick="return confirm('Are you sure you want to delete this city?');"
                                    class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-2.5 tw-bg-white tw-text-red-500 tw-border tw-border-red-100 tw-shadow-sm tw-rounded-xl tw-font-extrabold tw-text-[10px] tw-tracking-wider tw-uppercase hover:tw-bg-red-50 hover:tw-border-red-200 tw-transition-all disabled:tw-opacity-40 disabled:tw-cursor-not-allowed">
                                <i class="fas fa-trash-alt"></i> Trash
                            </button>
                            <button type="submit" name="action" value="Reset" id="btnReset" formnovalidate
                                    class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-2.5 tw-bg-white tw-text-slate-600 tw-border tw-border-slate-200 tw-shadow-sm tw-rounded-xl tw-font-extrabold tw-text-[10px] tw-tracking-wider tw-uppercase hover:tw-bg-slate-50 hover:tw-text-slate-900 tw-transition-all">
                                <i class="fas fa-undo-alt"></i> Reset
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script type="text/javascript">
        $(document).ready(function () {
            if ($.fn.DataTable) {
                var table = $('#dg1').DataTable({
                    "pageLength": 10,
                    "lengthChange": false,
                    "dom": '<"tw-flex tw-flex-col sm:tw-flex-row tw-justify-between tw-items-center tw-mb-2"f>rt<"tw-flex tw-flex-col sm:tw-flex-row tw-justify-between tw-items-center"ip>',
                    "language": { 
                        "search": "", 
                        "searchPlaceholder": "Search by city or core...",
                        "paginate": {
                            "previous": "<i class='fas fa-chevron-left tw-text-[10px]'></i>",
                            "next": "<i class='fas fa-chevron-right tw-text-[10px]'></i>"
                        }
                    }
                });

                // Add search icon inside datatable filter
                $('.dataTables_filter label').addClass('tw-relative tw-block tw-w-full');
                $('.dataTables_filter input').addClass('tw-pl-10');
                $('.dataTables_filter label').append('<i class="fas fa-search tw-absolute tw-left-4 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400"></i>');
            }

            function loadProvinces(countryCode, selectedProvince) {
                if (countryCode && countryCode !== "00") {
                    $.ajax({
                        url: '@Url.Action("GetProvinces", "Setup")',
                        type: 'GET',
                        data: { countryCode: countryCode },
                        success: function (data) {
                            var dropdown = $('#ProvinceCode');
                            dropdown.empty();
                            $.each(data, function (index, item) {
                                dropdown.append($('<option/>', {
                                    value: item.value,
                                    text: item.text
                                }));
                            });
                            if (selectedProvince) {
                                dropdown.val(selectedProvince);
                            }
                        }
                    });
                } else {
                    $('#ProvinceCode').empty().append('<option value="00">Select province</option>');
                }
            }

            $('#CountryCode').change(function () {
                loadProvinces($(this).val(), null);
            });

            $('.city-link').click(function (e) {
                e.preventDefault();
                var code = $(this).data('code');
                var country = $(this).data('country');
                var province = $(this).data('province');
                var zone = $(this).data('zone');
                var fname = $(this).data('fname');
                var sname = $(this).data('sname');
                var station = $(this).data('station');
                var branch = $(this).data('branch');

                $('#Code').val(code);
                $('#displayCode').val(code);
                $('#CountryCode').val(country);
                $('#ZoneCode').val(zone);
                $('#FullName').val(fname);
                $('#ShortName').val(sname);
                $('#StationId').val(station);
                $('#BranchId').val(branch);

                loadProvinces(country, province);

                $('#btnSave').prop('disabled', true);
                $('#btnUpdate').prop('disabled', false);
                $('#btnDelete').prop('disabled', false);
                
                // Focus element visually
                $('#FullName').focus();
            });

            var currentCode = $('#Code').val();
            if (currentCode && currentCode !== 'Auto Generated') {
                $('#displayCode').val(currentCode);
                $('#btnSave').prop('disabled', true);
                $('#btnUpdate').prop('disabled', false);
                $('#btnDelete').prop('disabled', false);
                
                var currentCountry = $('#CountryCode').val();
                var currentProvince = '@Model.ProvinceCode';
                if(currentCountry !== '00') {
                    loadProvinces(currentCountry, currentProvince);
                }
            }
            
            $('#btnReset').click(function() {
                $('#btnSave').prop('disabled', false);
                $('#btnUpdate, #btnDelete').prop('disabled', true);
                $('#ProvinceCode').empty().append('<option value="00">Select province</option>');
            });
        });
    </script>
}
