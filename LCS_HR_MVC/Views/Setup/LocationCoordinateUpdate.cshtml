@model LCS_HR_MVC.Models.LocationCoordinateViewModel
@{
    ViewData["PageTitle"] = "Location Coordinate Update";
    var zonesList = ViewBag.ZonesList as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
    var citiesList = ViewBag.CitiesList as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
    var locationsList = ViewBag.LocationsList as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
}

@section Styles {
    <style>
        /* Modern Fade Animation */
        @@keyframes slideUp { 
            from { opacity: 0; transform: translateY(15px); } 
            to { opacity: 1; transform: translateY(0); } 
        }
        .animate-main { animation: slideUp 0.4s ease-out; }

        /* Detail Scrollbar */
        .custom-scrollbar::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: #f1f5f9;
            border-radius: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }

        /* DataTable Overrides - Modern & Balanced */
        .dataTables_wrapper .dataTables_filter {
            @@apply tw-relative tw-mb-5;
        }
        .dataTables_wrapper .dataTables_filter label {
            @@apply tw-w-full sm:tw-w-auto;
        }
        .dataTables_wrapper .dataTables_filter input {
            @@apply tw-w-full sm:tw-w-[300px] tw-border-2 tw-border-slate-100 tw-rounded-2xl tw-px-5 tw-py-2.5 tw-text-sm tw-outline-none tw-bg-slate-50 focus:tw-bg-white tw-text-slate-700 tw-shadow-inner tw-font-medium;
        }
        .dataTables_wrapper .dataTables_filter input:focus { 
            @@apply tw-border-amber-400 tw-ring-4 tw-ring-amber-400/20 tw-shadow-lg; 
        }
        
        table.dataTable {
            @@apply tw-border-collapse;
        }
        table.dataTable thead th {
            @@apply tw-bg-slate-50 tw-text-slate-400 tw-font-black tw-uppercase tw-text-[10px] tw-tracking-[0.15em] tw-py-4 tw-px-5 tw-border-b-2 tw-border-slate-100 !important;
        }
        
        table.dataTable tbody tr {
            @@apply tw-border-b tw-border-slate-50 tw-transition-colors hover:tw-bg-amber-50/30;
        }
        table.dataTable tbody td {
            @@apply tw-py-4 tw-px-5 tw-align-middle;
        }
        
        .dataTables_info {
            @@apply tw-text-xs tw-font-semibold tw-text-slate-500 tw-mt-5;
        }
        
        /* Modern Pagination */
        .dataTables_wrapper .dataTables_paginate {
            @@apply tw-flex tw-items-center tw-gap-1 tw-mt-5;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button {
            @@apply tw-min-w-[32px] tw-h-8 tw-flex tw-items-center tw-justify-center tw-rounded-lg tw-text-xs tw-font-bold tw-text-slate-500 tw-border tw-border-slate-200 tw-bg-white tw-cursor-pointer tw-transition-all !important;
            padding: 0 0.5rem !important;
            margin: 0 !important;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
            @@apply tw-bg-slate-100 tw-text-slate-800 tw-border-slate-300 !important;
            background: none !important;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button.current,
        .dataTables_wrapper .dataTables_paginate .paginate_button.current:hover {
            @@apply tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-text-slate-900 tw-border-transparent tw-shadow-md tw-cursor-default !important;
            background: none !important;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button.disabled {
            @@apply tw-opacity-50 tw-cursor-not-allowed hover:tw-bg-white hover:tw-text-slate-500 hover:tw-border-slate-200 !important;
        }
    </style>
}

<div class="tw-p-4 sm:tw-p-6 tw-bg-transparent tw-min-h-screen animate-main">

    <!-- Messages -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-red-50 tw-border tw-border-red-100 tw-rounded-xl tw-text-red-600 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(239,68,68,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-red-100 tw-text-red-500 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0">
                <i class="fas fa-exclamation-triangle tw-text-[10px]"></i>
            </div>
            <span class="tw-pt-0.5">@TempData["ErrorMessage"]</span>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-emerald-50 tw-border tw-border-emerald-100 tw-rounded-xl tw-text-emerald-700 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(16,185,129,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-emerald-100 tw-text-emerald-600 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0">
                <i class="fas fa-check tw-text-[10px]"></i>
            </div>
            <span class="tw-pt-0.5">@TempData["SuccessMessage"]</span>
        </div>
    }

    <!-- Header Map -->
    <div class="tw-flex tw-flex-col sm:tw-flex-row sm:tw-items-end tw-justify-between tw-gap-4 tw-mb-8">
        <div>
            <nav class="tw-flex tw-items-center tw-gap-2.5 tw-text-[11px] tw-font-bold tw-text-slate-400 tw-mb-2 tw-uppercase tw-tracking-widest">
                <div class="tw-flex tw-items-center tw-gap-1.5 hover:tw-text-[#eab308] tw-transition-colors tw-cursor-pointer">
                    <i class="fas fa-cogs tw-text-[10px] tw-text-slate-300"></i>
                    <span>Setup</span>
                </div>
                <i class="fas fa-chevron-right tw-text-[8px] tw-text-slate-300"></i> 
                <span class="tw-text-slate-600 tw-bg-white tw-px-2 tw-py-0.5 tw-rounded-md tw-border tw-border-slate-200 tw-shadow-sm">Geocoding</span>
            </nav>
            <div class="tw-flex tw-flex-col">
                <h1 class="tw-text-3xl tw-font-black tw-text-slate-900 tw-leading-tight tw-tracking-tight">Coordinates Engine</h1>
                <div class="tw-h-1.5 tw-w-10 tw-bg-gradient-to-r tw-from-[#f5c518] tw-to-transparent tw-rounded-full tw-mt-1"></div>
            </div>
            <p class="tw-text-slate-500 tw-text-sm tw-font-medium tw-mt-3 tw-leading-relaxed">Update geographical mappings for remote locations across network</p>
        </div>
    </div>


    <div class="tw-grid xl:tw-grid-cols-[1fr_0.9fr] tw-gap-6 xl:tw-gap-8 align-top">
        
        <!-- Left Side: Table View -->
        <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-relative tw-h-full">
            <div class="tw-absolute tw-top-0 tw-right-0 tw-w-64 tw-h-64 tw-bg-gradient-to-bl tw-from-amber-50/50 tw-to-transparent tw-rounded-bl-full tw-pointer-events-none z-0"></div>

            <div class="tw-relative tw-z-10 tw-px-6 tw-py-5 tw-border-b tw-border-slate-100 tw-flex tw-items-center tw-gap-4 tw-bg-slate-50/80">
                <div class="tw-w-10 tw-h-10 tw-rounded-xl tw-bg-gradient-to-br tw-from-slate-900 tw-to-slate-800 tw-flex tw-items-center tw-justify-center tw-shadow-[0_4px_10px_rgba(15,23,42,0.3)]">
                    <i class="fas fa-map-pin tw-text-amber-400 tw-text-lg"></i>
                </div>
                <div>
                    <h2 class="tw-font-black tw-text-base tw-text-slate-800 tw-tracking-tight">Geocoding Registry</h2>
                    <p class="tw-text-[10px] tw-font-bold tw-text-slate-400 tw-uppercase tw-tracking-widest">Click a row to edit</p>
                </div>
            </div>

            <div class="tw-relative tw-z-10 tw-p-6">
                <div class="tw-overflow-x-auto custom-scrollbar">
                    <table id="dg1" class="tw-w-full dataTable tw-text-xs">
                        <thead>
                            <tr>
                                <th>Zone Segment</th>
                                <th>City Base</th>
                                <th>Target Location</th>
                                <th class="tw-text-right">Latitude</th>
                                <th class="tw-text-right tw-pr-4">Longitude</th>
                            </tr>
                        </thead>
                        <tbody class="tw-divide-y tw-divide-slate-100">
                            @foreach (var loc in Model.Locations)
                            {
                                <tr class="hover:tw-bg-amber-50/50 tw-transition-colors group tw-text-sm tw-cursor-pointer coord-row"
                                    data-locationid="@loc.LocationId"
                                    data-citycode="@loc.CityCode"
                                    data-zonecode="@loc.ZoneCode"
                                    data-latitude="@loc.Latitude"
                                    data-longitude="@loc.Longitude"
                                    data-locationname="@loc.LocationName"
                                    data-cityname="@loc.CityName"
                                    title="Click to load into editor">
                                    
                                    <td class="tw-py-4">
                                        <span class="tw-inline-flex tw-bg-slate-100 tw-text-slate-600 tw-px-2.5 tw-py-1 tw-rounded-lg tw-font-bold tw-border tw-border-slate-200 group-hover:tw-bg-white group-hover:tw-border-amber-200 transition-colors">@loc.ZoneName</span>
                                    </td>
                                    <td class="tw-py-4 tw-font-bold tw-text-slate-800 group-hover:tw-text-amber-600 transition-colors">
                                        @loc.CityName
                                    </td>
                                    <td class="tw-py-4 tw-text-slate-600 tw-font-medium">
                                        <i class="fas fa-building tw-text-slate-300 tw-mr-1.5 group-hover:tw-text-amber-300"></i> @loc.LocationName
                                    </td>
                                    <td class="tw-py-4 tw-text-right tw-font-mono tw-font-black tw-text-slate-700">
                                        @(string.IsNullOrEmpty(loc.Latitude) ? "N/A" : loc.Latitude)
                                    </td>
                                    <td class="tw-py-4 tw-text-right tw-pr-4 tw-font-mono tw-font-black tw-text-slate-700">
                                        @(string.IsNullOrEmpty(loc.Longitude) ? "N/A" : loc.Longitude)
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Right Side: Config Form -->
        <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-sticky tw-top-24 tw-relative">
            <div class="tw-absolute tw-top-[-50px] tw-right-[-50px] tw-w-40 tw-h-40 tw-bg-amber-100/40 tw-blur-2xl tw-rounded-full tw-pointer-events-none"></div>

            <div class="tw-p-6 tw-bg-gradient-to-r tw-from-slate-900 tw-to-slate-800 tw-relative tw-z-10">
                <h3 class="tw-text-amber-400 tw-font-black tw-text-xs tw-uppercase tw-tracking-[0.2em] tw-flex tw-items-center tw-gap-2">
                    <div class="tw-w-6 tw-h-6 tw-bg-white/10 tw-rounded-md tw-flex tw-items-center tw-justify-center">
                        <i class="fas fa-satellite-dish"></i>
                    </div>
                    Coord Tracker
                </h3>
            </div>

            <form asp-controller="Setup" asp-action="LocationCoordinateUpdate" method="post" id="coordForm" class="tw-p-7 tw-space-y-5 tw-relative tw-z-10">
                
                <div>
                    <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Zone Sector <span class="tw-text-red-500">*</span></label>
                    <div class="tw-relative">
                        <i class="fas fa-map-signs tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-amber-500 tw-text-sm"></i>
                        <select id="ddlZone" 
                                class="tw-w-full tw-pl-10 tw-pr-4 tw-py-3 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-semibold tw-text-slate-800 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm tw-appearance-none tw-cursor-pointer"
                                style="background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%2394a3b8%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right 1rem top 50%; background-size: 0.65rem auto;">
                            @foreach (var z in zonesList)
                            {
                                <option value="@z.Value">@z.Text</option>
                            }
                        </select>
                    </div>
                </div>

                <div>
                    <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">City Base <span class="tw-text-red-500">*</span></label>
                    <div class="tw-relative">
                        <i class="fas fa-city tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-amber-500 tw-text-sm"></i>
                        <select id="ddlCity" name="SelectedCityCode" 
                                class="tw-w-full tw-pl-10 tw-pr-4 tw-py-3 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-semibold tw-text-slate-800 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm tw-appearance-none tw-cursor-pointer"
                                style="background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%2394a3b8%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right 1rem top 50%; background-size: 0.65rem auto;">
                            <option value="00">Select parameter</option>
                        </select>
                    </div>
                    <input type="hidden" asp-for="SelectedCityCode" id="SelectedCityCodeHidden" />
                </div>

                <div>
                    <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Target Location <span class="tw-text-red-500">*</span></label>
                    <div class="tw-relative">
                        <i class="fas fa-building tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-amber-500 tw-text-sm"></i>
                        <select id="ddlLocation" name="SelectedLocationId" 
                                class="tw-w-full tw-pl-10 tw-pr-4 tw-py-3 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-semibold tw-text-slate-800 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm tw-appearance-none tw-cursor-pointer"
                                style="background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%2394a3b8%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right 1rem top 50%; background-size: 0.65rem auto;">
                            <option value="0">Select parameter</option>
                        </select>
                    </div>
                    <input type="hidden" asp-for="SelectedLocationId" id="SelectedLocationIdHidden" />
                </div>

                <div class="tw-grid tw-grid-cols-2 tw-gap-4">
                    <div>
                        <label asp-for="Latitude" class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Latitude</label>
                        <div class="tw-relative">
                            <i class="fas fa-map-marker-alt tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-sm"></i>
                            <input asp-for="Latitude" id="Latitude" maxlength="50" 
                                   class="tw-w-full tw-pl-10 tw-pr-3 tw-py-3 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-semibold tw-text-slate-800 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm tw-font-mono" 
                                   placeholder="0.000000" />
                        </div>
                    </div>
                    <div>
                        <label asp-for="Longitude" class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Longitude</label>
                        <div class="tw-relative">
                            <i class="fas fa-location-arrow tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-sm"></i>
                            <input asp-for="Longitude" id="Longitude" maxlength="50" 
                                   class="tw-w-full tw-pl-10 tw-pr-3 tw-py-3 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-semibold tw-text-slate-800 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm tw-font-mono" 
                                   placeholder="0.000000" />
                        </div>
                    </div>
                </div>

                <div class="tw-pt-3 tw-mb-2 tw-border-t tw-border-slate-100"></div>

                <!-- Action Controls (2x2 Grid) -->
                <div class="tw-space-y-3">
                    <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                        <button type="submit" name="action" value="Save" id="btnSave" disabled
                                class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-text-slate-900 tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase tw-shadow-[0_8px_20px_rgba(245,197,24,0.25)] hover:tw-shadow-[0_8px_25px_rgba(245,197,24,0.35)] hover:tw--translate-y-0.5 tw-transition-all disabled:tw-opacity-50 disabled:tw-cursor-not-allowed">
                            <i class="fas fa-check-circle tw-text-sm"></i> Commit
                        </button>
                        <button type="submit" name="action" value="Update" id="btnUpdate" 
                                class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-slate-900 tw-text-white tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase hover:tw-bg-slate-800 hover:tw-shadow-[0_8px_20px_rgba(15,23,42,0.2)] hover:tw--translate-y-0.5 tw-transition-all">
                            <i class="fas fa-sync-alt tw-text-sm"></i> Push Update
                        </button>
                    </div>
                    <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                        <button type="submit" name="action" value="Delete" id="btnDelete" disabled
                                class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-bg-white tw-text-red-500 tw-border tw-border-red-100 tw-shadow-sm tw-rounded-xl tw-font-extrabold tw-text-[11px] tw-tracking-wider tw-uppercase hover:tw-bg-red-50 hover:tw-border-red-200 tw-transition-all disabled:tw-opacity-40 disabled:tw-cursor-not-allowed">
                            <i class="fas fa-trash-alt"></i> Purge
                        </button>
                        <button type="submit" name="action" value="Reset" id="btnReset" formnovalidate
                                class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-bg-white tw-text-slate-600 tw-border tw-border-slate-200 tw-shadow-sm tw-rounded-xl tw-font-extrabold tw-text-[11px] tw-tracking-wider tw-uppercase hover:tw-bg-slate-50 hover:tw-text-slate-900 tw-transition-all">
                            <i class="fas fa-undo-alt tw-opacity-60"></i> Clear Data
                        </button>
                    </div>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script type="text/javascript">
        $(document).ready(function () {
            if ($.fn.DataTable) {
                $('#dg1').DataTable({
                    "pageLength": 10,
                    "lengthChange": false,
                    "dom": '<"tw-flex tw-flex-col sm:tw-flex-row tw-justify-between tw-items-center tw-mb-2"f>rt<"tw-flex tw-flex-col sm:tw-flex-row tw-justify-between tw-items-center"ip>',
                    "language": { 
                        "search": "", 
                        "searchPlaceholder": "Search regions or coords...",
                        "paginate": {
                            "previous": "<i class='fas fa-chevron-left tw-text-[10px]'></i>",
                            "next": "<i class='fas fa-chevron-right tw-text-[10px]'></i>"
                        }
                    }
                });

                // Add search icon inside datatable filter
                $('.dataTables_filter label').addClass('tw-relative tw-block tw-w-full');
                $('.dataTables_filter input').addClass('tw-pl-10');
                $('.dataTables_filter label').append('<i class="fas fa-search tw-absolute tw-left-4 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400"></i>');
            }

            // Row click — fill form
            $('#dg1 tbody').on('click', '.coord-row', function () {
                var row = $(this);
                var locationId = row.data('locationid');
                var cityCode = row.data('citycode');
                var zoneCode = row.data('zonecode');
                var lat = row.data('latitude');
                var lng = row.data('longitude');

                $('#Latitude').val(lat);
                $('#Longitude').val(lng);
                $('#SelectedLocationIdHidden').val(locationId);
                $('#SelectedCityCodeHidden').val(cityCode);

                // Populate zone dropdown
                $('#ddlZone').val(zoneCode);

                // Load cities for this zone then set city
                loadCities(zoneCode, cityCode, function () {
                    // Load locations for this city then set location
                    loadLocations(cityCode, locationId);
                });
                
                // Emphasize Inputs visually 
                $('#Latitude').focus();
            });

            $('#ddlZone').on('change', function () {
                var zoneCode = $(this).val();
                loadCities(zoneCode, null, null);
            });

            $('#ddlCity').on('change', function () {
                var cityCode = $(this).val();
                $('#SelectedCityCodeHidden').val(cityCode);
                loadLocations(cityCode, null);
            });

            $('#ddlLocation').on('change', function () {
                $('#SelectedLocationIdHidden').val($(this).val());
            });

            function loadCities(zoneCode, selectedCityCode, callback) {
                $.getJSON('@Url.Action("GetCitiesByZone", "Setup")', { zoneCode: zoneCode }, function (data) {
                    var ddl = $('#ddlCity');
                    ddl.empty();
                    $.each(data, function (i, item) {
                        ddl.append($('<option></option>').val(item.value).text(item.text));
                    });
                    if (selectedCityCode) {
                        ddl.val(selectedCityCode);
                        $('#SelectedCityCodeHidden').val(selectedCityCode);
                    }
                    // Reset location list
                    $('#ddlLocation').empty().append('<option value="0">Select parameter</option>');
                    $('#SelectedLocationIdHidden').val('0');
                    if (callback) callback();
                });
            }

            function loadLocations(cityId, selectedLocationId) {
                $.getJSON('@Url.Action("GetLocationsByCity", "Setup")', { cityId: cityId }, function (data) {
                    var ddl = $('#ddlLocation');
                    ddl.empty();
                    $.each(data, function (i, item) {
                        ddl.append($('<option></option>').val(item.value).text(item.text));
                    });
                    if (selectedLocationId) {
                        ddl.val(selectedLocationId);
                        $('#SelectedLocationIdHidden').val(selectedLocationId);
                    }
                });
            }
        });
    </script>
}
