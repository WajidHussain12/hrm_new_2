@model LCS_HR_MVC.Models.GradeAllowanceModel
@{
    ViewData["PageTitle"] = "Grade Allowance & Deduction";
    var dataList = ViewBag.GradeAllowancesList as IEnumerable<LCS_HR_MVC.Models.GradeAllowanceModel> ?? new List<LCS_HR_MVC.Models.GradeAllowanceModel>();
}

@section Styles {
    <link href="~/lib/jquery-ui/jquery-ui.min.css" rel="stylesheet" />
    <style>
        /* Modern Fade Animation */
        @@keyframes slideUp { 
            from { opacity: 0; transform: translateY(15px); } 
            to { opacity: 1; transform: translateY(0); } 
        }
        .animate-main { animation: slideUp 0.4s ease-out; }

        /* DataTable Overrides - Modern & Balanced */
        .dataTables_wrapper .dataTables_filter {
            @@apply tw-relative tw-mb-5;
        }
        .dataTables_wrapper .dataTables_filter label {
            @@apply tw-w-full sm:tw-w-auto;
        }
        .dataTables_wrapper .dataTables_filter input {
            @@apply tw-w-full sm:tw-w-[300px] tw-border-2 tw-border-slate-100 tw-rounded-2xl tw-px-5 tw-py-2.5 tw-text-sm tw-outline-none tw-transition-all tw-bg-slate-50 focus:tw-bg-white tw-text-slate-700 tw-shadow-inner tw-font-medium;
        }
        .dataTables_wrapper .dataTables_filter input:focus { 
            @@apply tw-border-amber-400 tw-ring-4 tw-ring-amber-400/20 tw-shadow-lg; 
        }
        
        table.dataTable {
            @@apply tw-border-collapse;
        }
        table.dataTable thead th {
            @@apply tw-bg-slate-50 tw-text-slate-400 tw-font-black tw-uppercase tw-text-[10px] tw-tracking-[0.15em] tw-py-4 tw-px-5 tw-border-b-2 tw-border-slate-100 !important;
        }
        
        table.dataTable tbody tr {
            @@apply tw-border-b tw-border-slate-50 tw-transition-colors hover:tw-bg-amber-50/30;
        }
        table.dataTable tbody td {
            @@apply tw-py-4 tw-px-5 tw-align-middle;
        }
        
        .dataTables_info {
            @@apply tw-text-xs tw-font-semibold tw-text-slate-500 tw-mt-5;
        }
        
        /* Modern Pagination */
        .dataTables_wrapper .dataTables_paginate {
            @@apply tw-flex tw-items-center tw-gap-1 tw-mt-5;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button {
            @@apply tw-min-w-[32px] tw-h-8 tw-flex tw-items-center tw-justify-center tw-rounded-lg tw-text-xs tw-font-bold tw-text-slate-500 tw-border tw-border-slate-200 tw-bg-white tw-cursor-pointer tw-transition-all !important;
            padding: 0 0.5rem !important;
            margin: 0 !important;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
            @@apply tw-bg-slate-100 tw-text-slate-800 tw-border-slate-300 !important;
            background: none !important;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button.current,
        .dataTables_wrapper .dataTables_paginate .paginate_button.current:hover {
            @@apply tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-text-slate-900 tw-border-transparent tw-shadow-md tw-cursor-default !important;
            background: none !important;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button.disabled {
            @@apply tw-opacity-50 tw-cursor-not-allowed hover:tw-bg-white hover:tw-text-slate-500 hover:tw-border-slate-200 !important;
        }

        /* Modern UI Autocomplete Override */
        .ui-autocomplete {
            @@apply tw-max-h-60 tw-overflow-y-auto tw-rounded-xl tw-border-slate-200 tw-shadow-xl tw-text-sm tw-font-medium tw-font-sans !important;
            z-index: 1000 !important;
        }
        .ui-menu-item-wrapper {
            @@apply tw-py-2 tw-px-3 tw-transition-colors !important;
        }
        .ui-menu-item-wrapper.ui-state-active {
            @@apply tw-bg-amber-500 tw-text-white tw-border-transparent tw-rounded-md !important;
            margin: 0 !important;
        }

        /* Custom Radio Toggle Buttons */
        .toggle-radio input[type="radio"]:checked + div {
            @@apply tw-bg-slate-800 tw-text-white tw-border-slate-800 tw-shadow-md;
        }
        .toggle-radio input[type="radio"]:checked + div i {
            @@apply tw-text-amber-400 tw-opacity-100;
        }
    </style>
}

<div class="tw-p-4 sm:tw-p-6 tw-bg-transparent tw-min-h-screen animate-main">

    <!-- Messages -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-red-50 tw-border tw-border-red-100 tw-rounded-xl tw-text-red-600 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(239,68,68,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-red-100 tw-text-red-500 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0">
                <i class="fas fa-exclamation-triangle tw-text-[10px]"></i>
            </div>
            <span class="tw-pt-0.5">@TempData["ErrorMessage"]</span>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-emerald-50 tw-border tw-border-emerald-100 tw-rounded-xl tw-text-emerald-700 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(16,185,129,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-emerald-100 tw-text-emerald-600 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0">
                <i class="fas fa-check tw-text-[10px]"></i>
            </div>
            <span class="tw-pt-0.5">@TempData["SuccessMessage"]</span>
        </div>
    }

    <div class="tw-flex tw-flex-col sm:tw-flex-row sm:tw-items-end tw-justify-between tw-gap-4 tw-mb-8">
        <div>
            <nav class="tw-flex tw-items-center tw-gap-2.5 tw-text-[11px] tw-font-bold tw-text-slate-400 tw-mb-2 tw-uppercase tw-tracking-widest">
                <div class="tw-flex tw-items-center tw-gap-1.5 hover:tw-text-[#eab308] tw-transition-colors tw-cursor-pointer">
                    <i class="fas fa-cogs tw-text-[10px] tw-text-slate-300"></i>
                    <span>Setup</span>
                </div>
                <i class="fas fa-chevron-right tw-text-[8px] tw-text-slate-300"></i> 
                <span class="tw-text-slate-600 tw-bg-white tw-px-2 tw-py-0.5 tw-rounded-md tw-border tw-border-slate-200 tw-shadow-sm">Payroll Rules</span>
            </nav>
            <div class="tw-flex tw-flex-col">
                <h1 class="tw-text-3xl tw-font-black tw-text-slate-900 tw-leading-tight tw-tracking-tight">Allowances &amp; Deductions</h1>
                <div class="tw-h-1.5 tw-w-10 tw-bg-gradient-to-r tw-from-[#f5c518] tw-to-transparent tw-rounded-full tw-mt-1"></div>
            </div>
            <p class="tw-text-slate-500 tw-text-sm tw-font-medium tw-mt-3 tw-leading-relaxed">Manage financial elements applied to grade levels via global, department, or individual scopes.</p>
        </div>
    </div>

    <div class="tw-grid xl:tw-grid-cols-[1fr_0.9fr] tw-gap-6 xl:tw-gap-8 align-top">
        
        <!-- Left Side: Data Table -->
        <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-relative tw-h-full">
            <div class="tw-absolute tw-top-0 tw-right-0 tw-w-64 tw-h-64 tw-bg-gradient-to-bl tw-from-amber-50/50 tw-to-transparent tw-rounded-bl-full tw-pointer-events-none z-0"></div>

            <div class="tw-relative tw-z-10 tw-px-6 tw-py-5 tw-border-b tw-border-slate-100 tw-flex tw-items-center tw-gap-4 tw-bg-slate-50/80">
                <div class="tw-w-10 tw-h-10 tw-rounded-xl tw-bg-gradient-to-br tw-from-slate-900 tw-to-slate-800 tw-flex tw-items-center tw-justify-center tw-shadow-[0_4px_10px_rgba(15,23,42,0.3)]">
                    <i class="fas fa-balance-scale tw-text-amber-400 tw-text-lg"></i>
                </div>
                <div>
                    <h2 class="tw-font-black tw-text-base tw-text-slate-800 tw-tracking-tight">Current Definitions</h2>
                    <p class="tw-text-[10px] tw-font-bold tw-text-slate-400 tw-uppercase tw-tracking-widest">Financial Rules Grid</p>
                </div>
            </div>

            <div class="tw-relative tw-z-10 tw-p-6">
                <div class="tw-overflow-x-auto custom-scrollbar">
                    <table id="dg1" class="tw-w-full dataTable tw-text-xs">
                        <thead>
                            <tr>
                                <th class="tw-w-16 tw-text-center">ID</th>
                                <th>Definition</th>
                                <th>Category</th>
                                <th>Rates Detail</th>
                                <th class="tw-text-right tw-pr-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="tw-divide-y tw-divide-slate-100">
                            @foreach (var item in dataList)
                            {
                                <tr class="hover:tw-bg-slate-50 tw-transition-colors group tw-text-sm">
                                    <td class="tw-py-4 tw-text-center">
                                        <span class="tw-px-2.5 tw-py-1 tw-bg-slate-100 group-hover:tw-bg-white tw-border tw-border-slate-200 tw-rounded-lg tw-font-mono tw-font-black tw-text-slate-600 tw-shadow-sm tw-transition-colors">@item.Code</span>
                                    </td>
                                    <td class="tw-py-4">
                                        <div class="tw-font-bold tw-text-slate-800 group-hover:tw-text-amber-500 tw-transition-colors">@item.FullName</div>
                                        <div class="tw-text-[10px] tw-font-semibold tw-text-slate-400 tw-uppercase tw-mt-0.5">Abbr: @item.ShortName</div>
                                    </td>
                                    <td class="tw-py-4">
                                        @if(item.Type == "A")
                                        {
                                            <span class="tw-text-[10px] tw-font-black tw-text-emerald-600 tw-bg-emerald-50 border border-emerald-100 tw-px-2 tw-py-0.5 tw-rounded tw-uppercase"><i class="fas fa-plus-circle tw-mr-1"></i>Allowance</span>
                                        }
                                        else 
                                        {
                                            <span class="tw-text-[10px] tw-font-black tw-text-red-600 tw-bg-red-50 border border-red-100 tw-px-2 tw-py-0.5 tw-rounded tw-uppercase"><i class="fas fa-minus-circle tw-mr-1"></i>Deduction</span>
                                        }
                                    </td>
                                    <td class="tw-py-4">
                                        <div class="tw-flex tw-flex-col tw-gap-1">
                                            @if(item.PctAmount > 0)
                                            {
                                                <span class="tw-text-[10px] tw-font-mono tw-font-bold tw-text-indigo-600 tw-bg-indigo-50 tw-px-2 tw-py-0.5 tw-rounded tw-w-fit">@item.PctAmount %</span>
                                            }
                                            @if(item.FixAmount > 0)
                                            {
                                                <span class="tw-text-[10px] tw-font-mono tw-font-bold tw-text-slate-600 tw-bg-slate-100 tw-px-2 tw-py-0.5 tw-rounded tw-w-fit">Fix: @item.FixAmount</span>
                                            }
                                            @if(item.PctAmount == 0 && item.FixAmount == 0)
                                            {
                                                 <span class="tw-text-[10px] tw-font-medium tw-text-slate-400 italic">No Rate Set</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="tw-py-4 tw-text-right tw-pr-4">
                                        <button class="grade-link tw-inline-flex tw-items-center tw-justify-center tw-w-8 tw-h-8 tw-rounded-lg tw-bg-slate-50 tw-border tw-border-slate-200 tw-text-slate-400 hover:tw-bg-amber-400 hover:tw-border-amber-400 hover:tw-text-slate-900 tw-shadow-sm hover:tw-shadow-md hover:tw--translate-y-0.5 tw-transition-all"
                                                data-code="@item.Code"
                                                title="Edit Rule">
                                            <i class="fas fa-edit tw-text-[11px]"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Right Side: Form -->
        <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-sticky tw-top-24 tw-relative">
            <div class="tw-absolute tw-top-[-50px] tw-right-[-50px] tw-w-40 tw-h-40 tw-bg-amber-100/40 tw-blur-2xl tw-rounded-full tw-pointer-events-none"></div>

            <div class="tw-p-6 tw-bg-gradient-to-r tw-from-slate-900 tw-to-slate-800 tw-relative tw-z-10">
                <h3 class="tw-text-amber-400 tw-font-black tw-text-xs tw-uppercase tw-tracking-[0.2em] tw-flex tw-items-center tw-gap-2">
                    <div class="tw-w-6 tw-h-6 tw-bg-white/10 tw-rounded-md tw-flex tw-items-center tw-justify-center">
                        <i class="fas fa-layer-group"></i>
                    </div>
                    Config Builder
                </h3>
            </div>

            <form asp-controller="Setup" asp-action="GradeAllowances" method="post" id="gradeForm" class="tw-p-7 tw-space-y-4 tw-relative tw-z-10">
                
                <div class="tw-flex tw-gap-3 w-full">
                    <div class="tw-w-1/3">
                        <label class="tw-block tw-text-[10px] tw-font-black tw-text-slate-400 tw-uppercase tw-tracking-widest tw-mb-1.5">Rule ID</label>
                        <div class="tw-flex tw-items-center tw-bg-slate-50 tw-rounded-xl tw-px-3 tw-py-2.5 tw-border tw-border-slate-200 tw-shadow-inner opacity-80">
                            <i class="fas fa-fingerprint tw-text-slate-400 tw-mr-2 tw-text-xs"></i>
                            <input type="text" id="displayCode" value="@Model.Code" disabled 
                                   class="tw-bg-transparent tw-w-full tw-text-sm tw-font-mono tw-font-bold tw-text-center tw-text-slate-600 tw-outline-none" />
                        </div>
                        <input type="hidden" asp-for="Code" id="Code" />
                    </div>
                    <div class="tw-w-2/3">
                        <label asp-for="ShortName" class="tw-block tw-text-[10px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Abbreviation / Key <span class="tw-text-red-500">*</span></label>
                        <div class="tw-relative">
                            <i class="fas fa-tag tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-amber-500 tw-text-xs"></i>
                            <input asp-for="ShortName" id="ShortName" maxlength="10" 
                                   class="tw-w-full tw-pl-9 tw-pr-3 tw-py-2.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-indigo-700 placeholder-slate-400 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm tw-uppercase" placeholder="e.g. MED_ALL" />
                        </div>
                        <span asp-validation-for="ShortName" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                    </div>
                </div>

                <div>
                    <label asp-for="FullName" class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Full Definition Title <span class="tw-text-red-500">*</span></label>
                    <div class="tw-relative">
                        <i class="fas fa-pen-nib tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs"></i>
                        <input asp-for="FullName" id="FullName" maxlength="45" 
                               class="tw-w-full tw-pl-9 tw-pr-3 tw-py-2.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-semibold tw-text-slate-800 placeholder-slate-400 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm" placeholder="e.g. Medical Allowance" />
                    </div>
                    <span asp-validation-for="FullName" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                </div>

                <div class="tw-flex tw-gap-3">
                    <div class="tw-w-1/2">
                        <label asp-for="Type" class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Record Type <span class="tw-text-red-500">*</span></label>
                        <div class="tw-relative">
                            <i class="fas fa-filter tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs tw-z-10"></i>
                            <select asp-for="Type" id="Type" 
                                    class="tw-w-full tw-pl-9 tw-pr-3 tw-py-2.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-semibold tw-text-slate-800 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm tw-appearance-none"
                                    style="background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%2394a3b8%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right 0.75rem top 50%; background-size: 0.65rem auto;">
                                <option value="">Please Select</option>
                                <option value="A">Allowance (Add)</option>
                                <option value="D">Deduction (Sub)</option>
                            </select>
                        </div>
                        <span asp-validation-for="Type" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                    </div>
                    <div class="tw-w-1/2">
                        <label asp-for="GlCode" class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Ledger GL#</label>
                        <div class="tw-relative">
                            <i class="fas fa-book tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs"></i>
                            <input asp-for="GlCode" id="GlCode" maxlength="5" 
                                   class="tw-w-full tw-pl-9 tw-pr-3 tw-py-2.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-mono tw-font-bold tw-text-slate-600 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm read-only:tw-bg-slate-100 read-only:focus:tw-ring-0 read-only:focus:tw-border-slate-200" />
                        </div>
                        <span asp-validation-for="GlCode" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                    </div>
                </div>

                <!-- Setup Divider Rates-->
                <div class="tw-relative tw-pt-2 tw-mb-2">
                    <div class="tw-absolute tw-inset-0 tw-flex tw-items-center" aria-hidden="true">
                        <div class="tw-w-full tw-border-t tw-border-slate-200"></div>
                    </div>
                    <div class="tw-relative tw-flex tw-justify-start">
                        <span class="tw-pr-3 tw-bg-white tw-text-[10px] tw-font-black tw-text-slate-400 tw-uppercase tw-tracking-widest">
                            Processing Value Rates
                        </span>
                    </div>
                </div>

                <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                    <div>
                        <label asp-for="PctAmount" class="tw-block tw-text-[10px] tw-font-black tw-text-slate-600 tw-uppercase tw-tracking-wide tw-mb-1.5">Percentage (%)</label>
                        <div class="tw-relative">
                            <input asp-for="PctAmount" type="number" step="0.01" id="PctAmount" 
                                   class="tw-w-full tw-pl-3 tw-pr-8 tw-py-2.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-font-mono tw-text-slate-800 placeholder-slate-400 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all" />
                             <i class="fas fa-percent tw-absolute tw-right-3 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-[10px]"></i>
                        </div>
                    </div>
                    <div>
                        <label asp-for="FixAmount" class="tw-block tw-text-[10px] tw-font-black tw-text-slate-600 tw-uppercase tw-tracking-wide tw-mb-1.5">Fixed Amount</label>
                        <div class="tw-relative">
                            <i class="fas fa-money-bill tw-absolute tw-left-3 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs"></i>
                            <input asp-for="FixAmount" type="number" step="0.01" id="FixAmount" 
                                   class="tw-w-full tw-pl-9 tw-pr-3 tw-py-2.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-font-mono tw-text-slate-800 placeholder-slate-400 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all" />
                        </div>
                    </div>
                </div>

                 <!-- Setup Divider Rules -->
                <div class="tw-relative tw-pt-2 tw-mb-2">
                    <div class="tw-absolute tw-inset-0 tw-flex tw-items-center" aria-hidden="true">
                        <div class="tw-w-full tw-border-t tw-border-slate-200"></div>
                    </div>
                    <div class="tw-relative tw-flex tw-justify-start">
                        <span class="tw-pr-3 tw-bg-white tw-text-[10px] tw-font-black tw-text-slate-400 tw-uppercase tw-tracking-widest">
                            Condition Rules
                        </span>
                    </div>
                </div>

                <!-- Exclude Absents -->
                <div>
                    <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-2">Exclude Scope On Absent</label>
                    <div class="tw-flex tw-bg-slate-100 tw-p-1 tw-rounded-xl">
                        <label class="toggle-radio tw-flex-1 tw-relative tw-cursor-pointer">
                            <input type="radio" asp-for="ExcludeAbsent" value="Q" class="tw-sr-only" />
                            <div class="tw-flex tw-items-center tw-justify-center tw-gap-1.5 tw-py-1.5 tw-rounded-lg tw-text-xs tw-font-bold tw-text-slate-500 tw-transition-all">
                                <i class="fas fa-circle tw-text-[6px] tw-opacity-0 tw-transition-opacity"></i> Quarterly
                            </div>
                        </label>
                        <label class="toggle-radio tw-flex-1 tw-relative tw-cursor-pointer">
                            <input type="radio" asp-for="ExcludeAbsent" value="M" class="tw-sr-only" />
                            <div class="tw-flex tw-items-center tw-justify-center tw-gap-1.5 tw-py-1.5 tw-rounded-lg tw-text-xs tw-font-bold tw-text-slate-500 tw-transition-all">
                                <i class="fas fa-circle tw-text-[6px] tw-opacity-0 tw-transition-opacity"></i> Monthly
                            </div>
                        </label>
                        <label class="toggle-radio tw-flex-1 tw-relative tw-cursor-pointer">
                            <input type="radio" asp-for="ExcludeAbsent" value="N" class="tw-sr-only" />
                            <div class="tw-flex tw-items-center tw-justify-center tw-gap-1.5 tw-py-1.5 tw-rounded-lg tw-text-xs tw-font-bold tw-text-slate-500 tw-transition-all">
                                <i class="fas fa-circle tw-text-[6px] tw-opacity-0 tw-transition-opacity"></i> None
                            </div>
                        </label>
                    </div>
                </div>
                
                <!-- Apply To Segment -->
                <div class="tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-p-4 tw-mt-2">
                    <label class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-2">Target Audience Applied To</label>
                    <div class="tw-grid tw-grid-cols-3 tw-gap-2">
                         <label class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-2 tw-bg-white tw-border tw-border-slate-200 tw-rounded-lg tw-cursor-pointer hover:tw-bg-amber-50 tw-transition-colors">
                            <input type="radio" asp-for="ApplyTo" value="All" id="applyAll" class="tw-w-3.5 tw-h-3.5 tw-accent-amber-500" />
                            <span class="tw-text-xs tw-font-bold tw-text-slate-700">All</span>
                        </label>
                        <label class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-2 tw-bg-white tw-border tw-border-slate-200 tw-rounded-lg tw-cursor-pointer hover:tw-bg-amber-50 tw-transition-colors">
                            <input type="radio" asp-for="ApplyTo" value="Department" id="applyDept" class="tw-w-3.5 tw-h-3.5 tw-accent-amber-500" />
                            <span class="tw-text-xs tw-font-bold tw-text-slate-700">Department</span>
                        </label>
                        <label class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-2 tw-bg-white tw-border tw-border-slate-200 tw-rounded-lg tw-cursor-pointer hover:tw-bg-amber-50 tw-transition-colors">
                            <input type="radio" asp-for="ApplyTo" value="NIL" id="applyInd" class="tw-w-3.5 tw-h-3.5 tw-accent-amber-500" />
                            <span class="tw-text-[10px] tw-font-bold tw-text-slate-700">Individual (NIL)</span>
                        </label>
                    </div>
                    
                    <div id="deptTr" style="display:none;" class="tw-mt-4">
                        <label asp-for="DepartmentDescription" class="tw-block tw-text-[10px] tw-font-black tw-text-slate-600 tw-uppercase tw-tracking-wide tw-mb-1.5">Select Department</label>
                        <div class="tw-flex tw-gap-2">
                            <div class="tw-flex-1 tw-relative">
                                <i class="fas fa-search tw-absolute tw-left-3 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs"></i>
                                <input asp-for="DepartmentDescription" id="DepartmentDescription" 
                                       class="tw-w-full tw-pl-9 tw-pr-3 tw-py-2.5 tw-bg-white tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-semibold tw-text-slate-800 placeholder-slate-400 focus:tw-bg-slate-50 focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm" placeholder="Search Dept %" />
                            </div>
                            <input asp-for="DepartmentCode" id="DepartmentCode" readonly="readonly" 
                                   class="tw-w-20 tw-text-center tw-bg-slate-100 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-mono tw-font-bold tw-text-slate-500 tw-outline-none" placeholder="ID" />
                        </div>
                        <span asp-validation-for="DepartmentDescription" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                    </div>
                </div>


                <!-- Comments -->
                <div>
                    <label asp-for="Comments" class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-1.5">Remarks / Comments</label>
                    <div class="tw-relative">
                        <i class="fas fa-comment-dots tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-xs"></i>
                        <input asp-for="Comments" id="Comments" maxlength="45" 
                               class="tw-w-full tw-pl-9 tw-pr-3 tw-py-2.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-medium tw-text-slate-800 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm" placeholder="Add remarks..." />
                    </div>
                    <span asp-validation-for="Comments" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                </div>

                <div class="tw-pt-2 tw-pb-1 tw-border-t tw-border-slate-100"></div>

                <!-- Buttons block -->
                <div class="tw-space-y-3">
                    <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                        <button type="submit" name="action" value="Save" id="btnSave" 
                                class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-text-slate-900 tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase tw-shadow-[0_8px_20px_rgba(245,197,24,0.25)] hover:tw-shadow-[0_8px_25px_rgba(245,197,24,0.35)] hover:tw--translate-y-0.5 tw-transition-all disabled:tw-opacity-50 disabled:tw-cursor-not-allowed">
                            <i class="fas fa-check-circle tw-text-sm"></i> Save
                        </button>
                        <button type="submit" name="action" value="Update" id="btnUpdate" disabled="disabled"
                                class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-slate-900 tw-text-white tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase hover:tw-bg-slate-800 hover:tw-shadow-[0_8px_20px_rgba(15,23,42,0.2)] hover:tw--translate-y-0.5 tw-transition-all disabled:tw-opacity-40 disabled:hover:tw-transform-none disabled:hover:tw-shadow-none">
                            <i class="fas fa-sync-alt tw-text-sm"></i> Update
                        </button>
                    </div>
                    <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                        <button type="submit" name="action" value="Delete" id="btnDelete" disabled="disabled" onclick="return confirm('Are you sure you want to delete this grade allowance definition?');"
                                class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-bg-white tw-text-red-500 tw-border tw-border-red-100 tw-shadow-sm tw-rounded-xl tw-font-extrabold tw-text-[11px] tw-tracking-wider tw-uppercase hover:tw-bg-red-50 hover:tw-border-red-200 tw-transition-all disabled:tw-opacity-40 disabled:tw-cursor-not-allowed">
                            <i class="fas fa-trash-alt"></i> Delete
                        </button>
                        <button type="submit" name="action" value="Reset" id="btnReset" formnovalidate
                                class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-bg-white tw-text-slate-600 tw-border tw-border-slate-200 tw-shadow-sm tw-rounded-xl tw-font-extrabold tw-text-[11px] tw-tracking-wider tw-uppercase hover:tw-bg-slate-50 hover:tw-text-slate-900 tw-transition-all">
                            <i class="fas fa-undo-alt"></i> Reset
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/lib/jquery-ui/jquery-ui.min.js"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            if ($.fn.DataTable) {
                var table = $('#dg1').DataTable({
                    "pageLength": 10,
                    "lengthChange": false,
                    "dom": '<"tw-flex tw-flex-col sm:tw-flex-row tw-justify-between tw-items-center tw-mb-2"f>rt<"tw-flex tw-flex-col sm:tw-flex-row tw-justify-between tw-items-center"ip>',
                    "language": { 
                        "search": "", 
                        "searchPlaceholder": "Search Config Rules...",
                        "paginate": {
                            "previous": "<i class='fas fa-chevron-left tw-text-[10px]'></i>",
                            "next": "<i class='fas fa-chevron-right tw-text-[10px]'></i>"
                        }
                    }
                });

                // Add search icon inside datatable filter
                $('.dataTables_filter label').addClass('tw-relative tw-block tw-w-full');
                $('.dataTables_filter input').addClass('tw-pl-10');
                $('.dataTables_filter label').append('<i class="fas fa-search tw-absolute tw-left-4 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400"></i>');
            }

            function toggleDept() {
                if ($('#applyDept').is(':checked')) {
                    $('#deptTr').slideDown('fast');
                } else {
                    $('#deptTr').slideUp('fast');
                    $('#DepartmentCode').val('');
                    $('#DepartmentDescription').val('');
                }
            }

            $('input[name="ApplyTo"]').change(function () {
                toggleDept();
            });

            toggleDept(); // Initial check

            // Department Autocomplete Styling hook mapped in css
            $("#DepartmentDescription").autocomplete({
                source: function (request, response) {
                    $.ajax({
                        url: '@Url.Action("SearchDepartments", "Setup")',
                        type: "GET",
                        dataType: "json",
                        data: { term: request.term },
                        success: function (data) {
                            response($.map(data, function (item) {
                                return { label: item.label, value: item.label, id: item.value };
                            }))
                        }
                    })
                },
                select: function (event, ui) {
                    $("#DepartmentDescription").val(ui.item.label);
                    $("#DepartmentCode").val(ui.item.id);
                    return false;
                },
                minLength: 1
            });
            
            $("#DepartmentDescription").keyup(function() {
                if (!$(this).val()) {
                    $("#DepartmentCode").val('');
                }
            });

            // GLCode auto-fetch on ShortName blur
            $('#ShortName').blur(function() {
                var sname = $(this).val();
                if(sname) {
                    $.ajax({
                        url: '@Url.Action("GetGlCodeByShortName", "Setup")',
                        type: 'GET',
                        data: { shortName: sname },
                        success: function (data) {
                            if(data && data.glCode) {
                                $('#GlCode').val(data.glCode);
                                $('#GlCode').prop('readonly', true);
                            } else {
                                $('#GlCode').val('');
                                $('#GlCode').prop('readonly', false);
                            }
                        }
                    });
                }
            });

            $('.grade-link').click(function (e) {
                e.preventDefault();
                var code = $(this).data('code');

                $.ajax({
                    url: '@Url.Action("GetGradeAllowanceData", "Setup")',
                    type: 'GET',
                    data: { code: code },
                    success: function (data) {
                        if(data) {
                            $('#Code').val(data.code);
                            $('#displayCode').val(data.code);
                            $('#FullName').val(data.fullName);
                            $('#ShortName').val(data.shortName);
                            $('#Type').val(data.type);
                            $('#GlCode').val(data.glCode);
                            $('#PctAmount').val(data.pctAmount);
                            $('#FixAmount').val(data.fixAmount);
                            
                            $('input[name="ExcludeAbsent"][value="' + data.excludeAbsent + '"]').prop('checked', true);
                            $('input[name="ApplyTo"][value="' + data.applyTo + '"]').prop('checked', true);

                            toggleDept();

                            if(data.applyTo === "Department") {
                                $('#DepartmentCode').val(data.departmentCode);
                                $('#DepartmentDescription').val(data.departmentDescription);
                            }

                            $('#Comments').val(data.comments);

                            $('#btnSave').prop('disabled', true);
                            $('#btnUpdate').prop('disabled', false);
                            $('#btnDelete').prop('disabled', false);

                            $('html, body').animate({ scrollTop: 0 }, 'fast');
                        }
                    }
                });
            });

            var currentCode = $('#Code').val();
            if (currentCode && currentCode !== 'Auto Generated') {
                $('#displayCode').val(currentCode);
                $('#btnSave').prop('disabled', true);
                $('#btnUpdate').prop('disabled', false);
                $('#btnDelete').prop('disabled', false);
            }
        });
    </script>
}