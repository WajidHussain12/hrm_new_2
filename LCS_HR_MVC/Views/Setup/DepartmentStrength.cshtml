@model LCS_HR_MVC.Models.DepartmentStrengthViewModel
@{
    ViewData["PageTitle"] = "Department Strength";
    var citiesList = ViewBag.CitiesList as IEnumerable<SelectListItem> ?? new List<SelectListItem>();
    var hasStrengths = Model.Strengths != null && Model.Strengths.Count > 0;
}

@section Styles {
    <style>
        /* Modern Fade Animation */
        @@keyframes slideUp { 
            from { opacity: 0; transform: translateY(15px); } 
            to { opacity: 1; transform: translateY(0); } 
        }
        .animate-main { animation: slideUp 0.4s ease-out; }

        /* Detail Scrollbar */
        .custom-scrollbar::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: #f1f5f9;
            border-radius: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }

        /* Custom Table Styling */
        .strength-table thead th {
            @@apply tw-bg-slate-50 tw-text-slate-400 tw-font-black tw-uppercase tw-text-[10px] tw-tracking-[0.15em] tw-py-4 tw-px-5 tw-border-b-2 tw-border-slate-100 !important;
        }
        .strength-table tbody tr {
            @@apply tw-border-b tw-border-slate-50 tw-transition-colors hover:tw-bg-amber-50/30;
        }
        .strength-table tbody td {
            @@apply tw-py-4 tw-px-5 tw-align-middle;
        }
    </style>
}

<div class="tw-p-4 sm:tw-p-6 tw-bg-transparent tw-min-h-screen animate-main">

    <!-- Messages -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-red-50 tw-border tw-border-red-100 tw-rounded-xl tw-text-red-600 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(239,68,68,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-red-100 tw-text-red-500 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0">
                <i class="fas fa-exclamation-triangle tw-text-[10px]"></i>
            </div>
            <span class="tw-pt-0.5">@TempData["ErrorMessage"]</span>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="tw-mb-4 tw-flex tw-items-start tw-gap-3 tw-p-4 tw-bg-emerald-50 tw-border tw-border-emerald-100 tw-rounded-xl tw-text-emerald-700 tw-text-sm tw-font-bold tw-shadow-[0_2px_10px_rgba(16,185,129,0.1)]">
            <div class="tw-w-6 tw-h-6 tw-bg-emerald-100 tw-text-emerald-600 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-shrink-0">
                <i class="fas fa-check tw-text-[10px]"></i>
            </div>
            <span class="tw-pt-0.5">@TempData["SuccessMessage"]</span>
        </div>
    }

    <!-- Header Map -->
    <div class="tw-flex tw-flex-col sm:tw-flex-row sm:tw-items-end tw-justify-between tw-gap-4 tw-mb-8">
        <div>
            <nav class="tw-flex tw-items-center tw-gap-2.5 tw-text-[11px] tw-font-bold tw-text-slate-400 tw-mb-2 tw-uppercase tw-tracking-widest">
                <div class="tw-flex tw-items-center tw-gap-1.5 hover:tw-text-[#eab308] tw-transition-colors tw-cursor-pointer">
                    <i class="fas fa-cogs tw-text-[10px] tw-text-slate-300"></i>
                    <span>Setup</span>
                </div>
                <i class="fas fa-chevron-right tw-text-[8px] tw-text-slate-300"></i> 
                <span class="tw-text-slate-600 tw-bg-white tw-px-2 tw-py-0.5 tw-rounded-md tw-border tw-border-slate-200 tw-shadow-sm">Department Strength</span>
            </nav>
            <div class="tw-flex tw-flex-col">
                <h1 class="tw-text-3xl tw-font-black tw-text-slate-900 tw-leading-tight tw-tracking-tight">Capacity Matrix</h1>
                <div class="tw-h-1.5 tw-w-10 tw-bg-gradient-to-r tw-from-[#f5c518] tw-to-transparent tw-rounded-full tw-mt-1"></div>
            </div>
            <p class="tw-text-slate-500 tw-text-sm tw-font-medium tw-mt-3 tw-leading-relaxed">Manage operational employee limits per city specific sub-departments.</p>
        </div>
    </div>


    <div class="tw-grid xl:tw-grid-cols-[0.7fr_1fr] tw-gap-6 xl:tw-gap-8 align-top">
        
        <!-- Left Side: Selection & Context -->
        <div class="tw-space-y-6">
            <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-relative">
                <div class="tw-absolute tw-top-0 tw-right-0 tw-w-64 tw-h-64 tw-bg-gradient-to-bl tw-from-amber-50/50 tw-to-transparent tw-rounded-bl-full tw-pointer-events-none z-0"></div>

                <div class="tw-relative tw-z-10 tw-px-6 tw-py-5 tw-border-b tw-border-slate-100 tw-flex tw-items-center tw-gap-4 tw-bg-slate-50/80">
                    <div class="tw-w-10 tw-h-10 tw-rounded-xl tw-bg-gradient-to-br tw-from-slate-900 tw-to-slate-800 tw-flex tw-items-center tw-justify-center tw-shadow-[0_4px_10px_rgba(15,23,42,0.3)]">
                        <i class="fas fa-map-marked-alt tw-text-amber-400 tw-text-lg"></i>
                    </div>
                    <div>
                        <h2 class="tw-font-black tw-text-base tw-text-slate-800 tw-tracking-tight">Origin Scope</h2>
                        <p class="tw-text-[10px] tw-font-bold tw-text-slate-400 tw-uppercase tw-tracking-widest">Geographical Target</p>
                    </div>
                </div>

                <div class="tw-relative tw-z-10 tw-p-7">
                    <form asp-controller="Setup" asp-action="DepartmentStrength" method="post" id="loadForm">
                        <label asp-for="CityCode" class="tw-block tw-text-[11px] tw-font-black tw-text-slate-700 tw-uppercase tw-tracking-wide tw-mb-2">Select Origin City <span class="tw-text-red-500">*</span></label>
                        <div class="tw-relative">
                            <i class="fas fa-city tw-absolute tw-left-3.5 tw-top-1/2 tw--translate-y-1/2 tw-text-amber-500 tw-text-sm"></i>
                            <select asp-for="CityCode" asp-items="citiesList" id="CityCode" onchange="this.form.action.value='Load'; this.form.submit();"
                                    class="tw-w-full tw-pl-10 tw-pr-10 tw-py-3.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-700 focus:tw-bg-white focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm tw-appearance-none"
                                    style="background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%2394a3b8%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right 1rem top 50%; background-size: 0.65rem auto;">
                            </select>
                        </div>
                        <input type="hidden" name="action" value="Load" />
                        <span asp-validation-for="CityCode" class="tw-text-[9px] tw-font-bold tw-text-red-500 tw-mt-1 tw-block"></span>
                    </form>

                    @if (hasStrengths)
                    {
                        <div class="tw-mt-8 tw-bg-emerald-50/50 tw-border tw-border-emerald-100 tw-rounded-2xl tw-p-5">
                            <div class="tw-flex tw-items-center tw-gap-3 tw-mb-3">
                                <div class="tw-w-8 tw-h-8 tw-rounded-lg tw-bg-emerald-100 tw-flex tw-items-center tw-justify-center">
                                    <i class="fas fa-info-circle tw-text-emerald-600 tw-text-xs"></i>
                                </div>
                                <h4 class="tw-font-black tw-text-xs tw-text-emerald-800 tw-uppercase tw-tracking-wider">Active Load Stats</h4>
                            </div>
                            <div class="tw-grid tw-grid-cols-2 tw-gap-4">
                                <div class="tw-bg-white/60 tw-p-3 tw-rounded-xl tw-border tw-border-emerald-100">
                                    <p class="tw-text-[9px] tw-font-bold tw-text-emerald-600 tw-uppercase tw-tracking-widest tw-mb-1">Nodes</p>
                                    <p class="tw-text-xl tw-font-black tw-text-slate-800">@Model.Strengths.Count</p>
                                </div>
                                <div class="tw-bg-white/60 tw-p-3 tw-rounded-xl tw-border tw-border-emerald-100">
                                    <p class="tw-text-[9px] tw-font-bold tw-text-emerald-600 tw-uppercase tw-tracking-widest tw-mb-1">Total Cap</p>
                                    <p class="tw-text-xl tw-font-black tw-text-slate-800">@Model.Strengths.Sum(s => s.Strength)</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Action Controls Card -->
            <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden">
                <div class="tw-p-6 tw-bg-gradient-to-r tw-from-slate-900 tw-to-slate-800 tw-relative tw-z-10">
                    <h3 class="tw-text-amber-400 tw-font-black tw-text-xs tw-uppercase tw-tracking-[0.2em] tw-flex tw-items-center tw-gap-2">
                        <div class="tw-w-6 tw-h-6 tw-bg-white/10 tw-rounded-md tw-flex tw-items-center tw-justify-center">
                            <i class="fas fa-save"></i>
                        </div>
                        Control Interface
                    </h3>
                </div>
                <div class="tw-p-7 tw-space-y-3">
                    <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                        <button type="submit" form="strengthForm" name="action" value="Save" id="btnSave" @(!hasStrengths ? "disabled" : null)
                                class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-gradient-to-r tw-from-amber-400 tw-to-orange-500 tw-text-slate-900 tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase tw-shadow-[0_8px_20px_rgba(245,197,24,0.25)] hover:tw-shadow-[0_8px_25px_rgba(245,197,24,0.35)] hover:tw--translate-y-0.5 tw-transition-all disabled:tw-opacity-50 disabled:tw-cursor-not-allowed">
                            <i class="fas fa-check-circle tw-text-sm"></i> File Intent
                        </button>
                        <button type="submit" form="strengthForm" name="action" value="Update" id="btnUpdate" @(!hasStrengths ? "disabled" : null)
                                class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3.5 tw-bg-slate-900 tw-text-white tw-rounded-xl tw-font-black tw-text-[11px] tw-tracking-widest tw-uppercase hover:tw-bg-slate-800 hover:tw-shadow-[0_8px_20px_rgba(15,23,42,0.2)] hover:tw--translate-y-0.5 tw-transition-all disabled:tw-opacity-40 disabled:hover:tw-transform-none">
                            <i class="fas fa-sync-alt tw-text-sm"></i> Edit Target
                        </button>
                    </div>
                    <div class="tw-grid tw-grid-cols-2 tw-gap-3">
                        <button type="button" id="btnDeleteMock" disabled
                                class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-bg-white tw-text-red-500 tw-border tw-border-red-100 tw-shadow-sm tw-rounded-xl tw-font-extrabold tw-text-[11px] tw-tracking-wider tw-uppercase hover:tw-bg-red-50 hover:tw-border-red-200 tw-transition-all disabled:tw-opacity-40 disabled:tw-cursor-not-allowed">
                            <i class="fas fa-trash-alt"></i> Revoke
                        </button>
                        <button type="submit" form="loadForm" name="action" value="Reset" id="btnReset"
                                class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-bg-white tw-text-slate-600 tw-border tw-border-slate-200 tw-shadow-sm tw-rounded-xl tw-font-extrabold tw-text-[11px] tw-tracking-wider tw-uppercase hover:tw-bg-slate-50 hover:tw-text-slate-900 tw-transition-all">
                            <i class="fas fa-undo-alt tw-opacity-60"></i> Deselect
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Side: Editable Grid -->
        <div class="tw-bg-white tw-rounded-3xl tw-shadow-[0_8px_30px_rgb(0,0,0,0.04)] tw-border tw-border-slate-200/80 tw-overflow-hidden tw-relative tw-h-full">
            <div class="tw-absolute tw-bottom-0 tw-left-0 tw-w-64 tw-h-64 tw-bg-gradient-to-tr tw-from-slate-50/50 tw-to-transparent tw-rounded-tr-full tw-pointer-events-none z-0"></div>

            <div class="tw-relative tw-z-10 tw-px-6 tw-py-5 tw-border-b tw-border-slate-100 tw-flex tw-items-center tw-gap-4 tw-bg-white/50 tw-backdrop-blur-sm">
                <div class="tw-w-10 tw-h-10 tw-rounded-xl tw-bg-gradient-to-br tw-from-slate-900 tw-to-slate-800 tw-flex tw-items-center tw-justify-center tw-shadow-[0_4px_10_rgba(15,23,42,0.2)]">
                    <i class="fas fa-users-cog tw-text-amber-400 tw-text-sm"></i>
                </div>
                <div>
                    <h2 class="tw-font-black tw-text-base tw-text-slate-800 tw-tracking-tight">Capacity Blueprint</h2>
                    <p class="tw-text-[10px] tw-font-bold tw-text-slate-400 tw-uppercase tw-tracking-widest">Global Variable Grid</p>
                </div>
            </div>

            <div class="tw-relative tw-z-10 tw-p-6">
                @if (hasStrengths)
                {
                    <form asp-controller="Setup" asp-action="DepartmentStrength" method="post" id="strengthForm">
                        <input type="hidden" asp-for="CityCode" />
                        <div class="tw-overflow-x-auto custom-scrollbar tw-max-h-[600px] tw-overflow-y-auto tw-rounded-2xl tw-border tw-border-slate-100">
                            <table class="tw-w-full strength-table tw-text-xs">
                                <thead class="tw-sticky tw-top-0 tw-z-20">
                                    <tr>
                                        <th>Hierarchy Segment</th>
                                        <th class="tw-text-center tw-w-32">Authorized Cap</th>
                                    </tr>
                                </thead>
                                <tbody class="tw-divide-y tw-divide-slate-100">
                                    @for (int i = 0; i < Model.Strengths.Count; i++)
                                    {
                                        <tr class="hover:tw-bg-slate-50 tw-transition-colors group">
                                            <td class="tw-py-4">
                                                <div class="tw-flex tw-items-center tw-gap-4">
                                                    <div class="tw-flex-1">
                                                        <div class="tw-text-[9px] tw-font-bold tw-text-slate-400 tw-uppercase tw-mb-0.5">Parent Root</div>
                                                        <div class="tw-font-bold tw-text-slate-700 tw-text-sm">@Model.Strengths[i].PDeptName</div>
                                                    </div>
                                                    <i class="fas fa-arrow-right tw-text-slate-200 tw-text-[10px]"></i>
                                                    <div class="tw-flex-1">
                                                        <div class="tw-text-[9px] tw-font-bold tw-text-slate-400 tw-uppercase tw-mb-0.5">Sub Branch</div>
                                                        <div class="tw-font-bold tw-text-slate-800 tw-text-sm group-hover:tw-text-amber-600 tw-transition-colors">@Model.Strengths[i].SubDeptName</div>
                                                    </div>
                                                </div>

                                                <input type="hidden" asp-for="Strengths[i].CityID" />
                                                <input type="hidden" asp-for="Strengths[i].PDID" />
                                                <input type="hidden" asp-for="Strengths[i].PDeptName" />
                                                <input type="hidden" asp-for="Strengths[i].SDID" />
                                                <input type="hidden" asp-for="Strengths[i].SubDeptName" />
                                            </td>
                                            <td class="tw-py-4 tw-text-center">
                                                <div class="tw-relative tw-inline-block">
                                                    <i class="fas fa-user-plus tw-absolute tw-left-3 tw-top-1/2 tw--translate-y-1/2 tw-text-slate-400 tw-text-[10px]"></i>
                                                    <input asp-for="Strengths[i].Strength" type="number" min="0"
                                                           class="tw-w-24 tw-pl-8 tw-pr-3 tw-py-2 tw-bg-white tw-border tw-border-slate-200 tw-rounded-lg tw-text-center tw-font-bold tw-font-mono tw-text-slate-800 focus:tw-border-amber-400 focus:tw-ring-4 focus:tw-ring-amber-400/10 tw-outline-none tw-transition-all tw-shadow-sm" />
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </form>
                }
                else
                {
                    <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-py-20 tw-text-center">
                        <div class="tw-w-20 tw-h-20 tw-bg-slate-50 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-mb-5 tw-border tw-border-slate-100 tw-shadow-inner">
                            <i class="fas fa-city tw-text-slate-200 tw-text-3xl"></i>
                        </div>
                        <h4 class="tw-text-slate-800 tw-font-black tw-text-base tw-tracking-tight">No Scope Selected</h4>
                        <p class="tw-text-slate-400 tw-text-xs tw-mt-2 tw-max-w-xs tw-mx-auto tw-leading-relaxed">Please choose a target origin city from the selection panel to load the operational capacity blueprint.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
